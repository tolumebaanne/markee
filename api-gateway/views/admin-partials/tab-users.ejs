<!-- ══════════════════════ TAB: USERS ══════════════════════ -->
<div class="tab-panel" id="tab-users">
  <div class="page-header">
    <div>
      <h1><i class="fas fa-users" style="color:var(--accent);margin-right:0.4rem;font-size:1.1rem"></i> Users</h1>
      <p>Platform user accounts — suspend, ban, role changes, deletion</p>
    </div>
    <button class="btn btn-ghost btn-sm" onclick="loadUsers()"><i class="fas fa-rotate-right"></i> Refresh</button>
  </div>

  <div class="filter-bar">
    <select id="u-role-filter" onchange="loadUsers()">
      <option value="">All Roles</option>
      <option value="buyer">Buyers</option>
      <option value="seller">Sellers</option>
      <option value="admin">Admins</option>
    </select>
    <select id="u-status-filter" onchange="loadUsers()">
      <option value="">All Statuses</option>
      <option value="active">Active</option>
      <option value="suspended">Suspended</option>
      <option value="banned">Banned</option>
    </select>
    <input id="u-search" type="text" placeholder="Search by email or ID..." style="min-width:220px" oninput="debounce(loadUsers,400)()">
  </div>

  <div id="u-error" class="error-banner" style="display:none"><i class="fas fa-triangle-exclamation"></i><span></span></div>
  <div id="u-table"><div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading users...</div></div>
  <div class="pagination" id="u-pagination"></div>

  <!-- ── Deleted Accounts Section (Superuser only — hidden until _isSuperuser flag set) ── -->
  <div id="deleted-accounts-section" style="margin-top:2rem;border:1px solid var(--border);border-radius:8px;overflow:hidden;display:none">
    <div
      style="display:flex;align-items:center;justify-content:space-between;padding:.75rem 1.25rem;background:var(--surface2);cursor:pointer;user-select:none"
      onclick="toggleDeletedUsers()"
    >
      <div style="display:flex;align-items:center;gap:.6rem">
        <i class="fas fa-user-slash" style="color:var(--danger)"></i>
        <span style="font-weight:600;color:var(--danger)">Deleted Accounts</span>
        <span id="deleted-users-header" style="color:var(--muted);font-size:.8rem"></span>
      </div>
      <i id="deleted-toggle-icon" class="fas fa-chevron-down" style="color:var(--muted)"></i>
    </div>
    <div id="deleted-users-panel" style="display:none;padding:1rem">
      <p style="color:var(--muted);font-size:.8rem;margin:0 0 .75rem">
        These users self-deleted their accounts. Their original email is preserved here for investigation.
        Use <b>Hard Delete</b> to permanently erase all their data — blocked if active escrows or open orders exist.
      </p>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Original Email</th>
              <th>Display Name</th>
              <th>User ID</th>
              <th>Store ID</th>
              <th>Deleted At</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody id="deleted-users-body">
            <tr><td colspan="6" class="loading"><i class="fas fa-spinner fa-spin"></i> Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
  <script>
    // Reveal deleted-accounts section once superuser status is confirmed (window._isSuperuser set by admin.ejs)
    (function revealIfSuper() {
      if (window._isSuperuser) {
        const s = document.getElementById('deleted-accounts-section');
        if (s) s.style.display = 'block';
      } else {
        setTimeout(revealIfSuper, 150);
      }
    })();
  </script>
</div>

<script>
let _uPage = 1;

async function loadUsers(page) {
  if (page != null) _uPage = page; else _uPage = 1;
  hideErr('u-error');
  const el = document.getElementById('u-table');
  el.innerHTML = `<div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading...</div>`;

  const role   = document.getElementById('u-role-filter').value;
  const status = document.getElementById('u-status-filter').value;
  const search = document.getElementById('u-search').value.trim();
  const qs = new URLSearchParams({ page: _uPage, limit: 25 });
  if (role)   qs.set('role', role);
  if (status) qs.set('status', status);
  if (search) qs.set('search', search); // proxied to user-service — searches email + displayName

  try {
    const data  = await adminApi('GET', `/proxy/users?${qs}`);
    const users = data.users || data || [];
    const total = data.total || users.length;
    if (!users.length) {
      el.innerHTML = `<div class="empty-state"><i class="fas fa-user-slash"></i>No users match your filters</div>`;
      document.getElementById('u-pagination').innerHTML = '';
      return;
    }

    el.innerHTML = `<div class="table-wrap"><table>
      <thead><tr><th>User</th><th>Role</th><th>Status</th><th>Joined</th><th>Actions</th></tr></thead>
      <tbody>${users.map(u => {
        // Auth-service fields: _id, email, displayName, role, moderationStatus, status, createdAt
        const uid  = u._id || '';
        const name = u.displayName || '';
        const modStatus = u.moderationStatus || 'active'; // suspended / banned / active
        const authStatus = u.status || 'active';           // active / pending_deletion
        // Show moderation badge if suspended/banned, else auth status
        const displayStatus = (modStatus !== 'active') ? modStatus : authStatus;
        const userCell = name
          ? `<span style="font-weight:600">${name}</span><br>
             <span style="font-size:.75rem;color:var(--muted)">${u.email || '—'}</span><br>
             <span style="font-family:monospace;font-size:.65rem;color:var(--muted)">${trunc(uid, 14)}</span>`
          : `<span style="font-weight:600">${u.email || '—'}</span><br>
             <span style="font-family:monospace;font-size:.65rem;color:var(--muted)">${trunc(uid, 14)}</span>`;
        return `<tr>
        <td>${userCell}</td>
        <td>${badge(u.role||'user')}</td>
        <td>${badge(displayStatus)}</td>
        <td style="color:var(--muted);font-size:0.7rem">${fmtDate(u.createdAt)}</td>
        <td>
          <div class="btn-gap">
            <button class="btn btn-info btn-xs" onclick="viewUserDetail('${uid}')"><i class="fas fa-eye"></i></button>
            ${modStatus !== 'suspended' && modStatus !== 'banned'
              ? `<button class="btn btn-warn btn-xs" onclick="suspendUser('${uid}')"><i class="fas fa-pause"></i> Suspend</button>`
              : `<button class="btn btn-success btn-xs" onclick="unbanUser('${uid}')"><i class="fas fa-rotate-right"></i> Restore</button>`}
            ${modStatus !== 'banned'
              ? `<button class="btn btn-danger btn-xs" onclick="banUser('${uid}')"><i class="fas fa-ban"></i> Ban</button>`
              : ''}
            <button class="btn btn-ghost btn-xs" onclick="changeUserRole('${uid}','${u.role||'user'}')"><i class="fas fa-user-gear"></i> Role</button>
            ${window._isSuperuser ? `<button class="btn btn-danger btn-xs" onclick="deleteUser('${uid}','${u.email||''}')"><i class="fas fa-trash"></i></button>` : ''}
          </div>
        </td>
      </tr>`;
      }).join('')}
      </tbody>
    </table></div>`;

    const pages = Math.ceil(total / 25);
    document.getElementById('u-pagination').innerHTML =
      `<span style="margin-right:auto">Showing ${users.length} of ${total}</span>` +
      (_uPage > 1 ? `<button class="btn btn-ghost btn-xs" onclick="loadUsers(${_uPage-1})">← Prev</button>` : '') +
      `<span style="color:var(--text);font-weight:600">Page ${_uPage} / ${pages}</span>` +
      (_uPage < pages ? `<button class="btn btn-ghost btn-xs" onclick="loadUsers(${_uPage+1})">Next →</button>` : '');
  } catch (err) {
    showErr('u-error', err.message);
    el.innerHTML = '';
  }
}

async function viewUserDetail(id) {
  const modal = document.getElementById('userDetailModal');
  const body  = document.getElementById('userDetailBody');
  if (!modal || !body) return;
  body.innerHTML = `<div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading profile…</div>`;
  openModal('userDetailModal');
  try {
    const profile = await adminApi('GET', `/proxy/users/${id}/profile`);
    const p = profile.profile || profile.user || profile;
    const addresses = p.addresses || [];
    const addrCount = addresses.length;
    const defaultAddr = addresses.find(a => a.isDefault) || addresses[0];
    body.innerHTML = `<div class="grid-2">
      <div>${[
        ['Display Name', p.displayName || '—'],
        ['Email',        p.email       || '—'],
        ['User ID',      `<span class="mono" style="font-size:.75rem">${trunc(id, 22)}</span>`],
        ['Role',         badge(p.role || 'user')],
        ['Status',       badge(p.moderationStatus || p.status || 'active')],
        ['Joined',       fmtDate(p.createdAt)],
      ].map(([l,v]) => `<div class="order-detail-row"><div class="order-detail-label" style="min-width:110px">${l}</div><div style="font-size:.83rem">${v}</div></div>`).join('')}
      </div>
      <div>
        <div style="font-weight:600;margin-bottom:.5rem">Saved Addresses <span style="font-weight:400;color:var(--muted)">(${addrCount})</span></div>
        ${addrCount
          ? addresses.map(a => `<div style="font-size:.8rem;margin-bottom:.4rem;padding:.4rem .6rem;border:1px solid var(--border);border-radius:6px;background:var(--bg2)">
              ${a.isDefault ? '<span style="color:var(--success);font-weight:700;font-size:.68rem;margin-right:.3rem">DEFAULT</span>' : ''}
              ${[a.label,a.street,a.city,a.province,a.postalCode,a.country].filter(Boolean).join(', ')}
            </div>`).join('')
          : '<p style="color:var(--muted);font-size:.8rem">No saved addresses.</p>'}
      </div>
    </div>`;
  } catch(err) {
    body.innerHTML = `<div class="error-banner"><i class="fas fa-triangle-exclamation"></i> ${err.message}</div>`;
  }
}

async function suspendUser(id) {
  const r = await showConfirm({ title: 'Suspend User', body: 'Suspend this account? Existing tokens remain valid until expiry. New logins blocked.', withReason: true, danger: true });
  if (!r.confirmed) return;
  try {
    await adminApi('PATCH', `/proxy/users/${id}/suspend`, { reason: r.reason });
    toast('User suspended.', 'warn');
    loadUsers(_uPage);
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function banUser(id) {
  const r = await showConfirm({ title: 'Ban User', body: 'Hard ban this account? All refresh tokens revoked immediately. Login permanently blocked.', withReason: true, danger: true });
  if (!r.confirmed) return;
  try {
    await adminApi('PATCH', `/proxy/users/${id}/ban`, { reason: r.reason });
    toast('User banned and tokens revoked.', 'warn');
    loadUsers(_uPage);
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function unbanUser(id) {
  const r = await showConfirm({ title: 'Restore User', body: 'Lift suspension or ban and restore login access for this account?' });
  if (!r.confirmed) return;
  try {
    await adminApi('PATCH', `/proxy/users/${id}/unban`, {});
    toast('User restored.', 'success');
    loadUsers(_uPage);
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function changeUserRole(id, currentRole) {
  const roles = ['buyer','seller'].filter(r => r !== currentRole);
  const r = await showConfirm({
    title: 'Change User Role',
    body: `Current role: ${currentRole}. Select new role. Scopes update on user's next token refresh.`,
    withSelect: roles.map(r => ({ value: r, label: r.charAt(0).toUpperCase()+r.slice(1) })),
    selectLabel: 'New Role'
  });
  if (!r.confirmed) return;
  try {
    await adminApi('PATCH', `/proxy/users/${id}/role`, { role: r.selected });
    toast(`Role changed to ${r.selected}.`, 'success');
    loadUsers(_uPage);
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function deleteUser(id, email) {
  const r = await showConfirm({
    title: 'Hard Delete User Account',
    body: `Permanently delete ${email || id}? This is irreversible.\n\n` +
          `Blocked if user has active escrows or open seller orders.\n\n` +
          `All data across every service will be anonymised or removed.`,
    withReason: true,
    danger: true
  });
  if (!r.confirmed) return;
  try {
    await adminApi('DELETE', `/proxy/users/${id}`, { reason: r.reason });
    toast('User hard-deleted. Full cascade cleanup emitted.', 'warn');
    loadUsers(_uPage);
    loadDeletedUsers();
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

// ── Deleted Accounts (Superuser only) ────────────────────────────────────────

let _delUsersLoaded = false;

function toggleDeletedUsers() {
  const panel = document.getElementById('deleted-users-panel');
  const icon  = document.getElementById('deleted-toggle-icon');
  const open  = panel.style.display === 'none' || !panel.style.display;
  panel.style.display = open ? 'block' : 'none';
  icon.className = open ? 'fas fa-chevron-up' : 'fas fa-chevron-down';
  if (open && !_delUsersLoaded) loadDeletedUsers();
}

async function loadDeletedUsers() {
  if (!window._isSuperuser) return;
  _delUsersLoaded = true;
  const el = document.getElementById('deleted-users-body');
  const hd = document.getElementById('deleted-users-header');
  el.innerHTML = '<tr><td colspan="6" class="loading"><i class="fas fa-spinner fa-spin"></i> Loading…</td></tr>';
  try {
    const data = await adminApi('GET', '/proxy/users/deleted');
    const users = data.users || data || [];
    hd.textContent = `${users.length} deleted account${users.length === 1 ? '' : 's'}`;
    if (!users.length) {
      el.innerHTML = '<tr><td colspan="6" class="empty-state">No deleted accounts on record.</td></tr>';
      return;
    }
    el.innerHTML = users.map(u => `
      <tr>
        <td style="font-weight:600">${u.originalEmail || '—'}</td>
        <td>${u.displayName || '—'}</td>
        <td class="mono" style="font-size:.72rem">${trunc(u.userId, 16)}</td>
        <td class="mono" style="font-size:.72rem">${trunc(u.storeId, 16)}</td>
        <td style="color:var(--muted);font-size:.7rem">${fmtDate(u.deletedAt)}</td>
        <td>
          <button class="btn btn-xs btn-danger" onclick="hardDeleteDeletedUser('${u.userId}','${u.originalEmail||''}')">
            <i class="fas fa-skull"></i> Hard Delete
          </button>
        </td>
      </tr>`).join('');
  } catch (err) {
    el.innerHTML = `<tr><td colspan="6"><div class="error-banner" style="display:flex"><i class="fas fa-triangle-exclamation"></i><span>${err.message}</span></div></td></tr>`;
  }
}

async function hardDeleteDeletedUser(id, email) {
  const r = await showConfirm({
    title: 'Hard Delete Deleted Account',
    body: `Permanently erase all traces of ${email || id}?\n\nBlocked if active escrows or open seller orders exist.`,
    danger: true
  });
  if (!r.confirmed) return;
  try {
    await adminApi('DELETE', `/proxy/users/${id}`, {});
    toast('Account permanently erased. Full mop complete.', 'warn');
    loadDeletedUsers();
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}
</script>

<!-- ── User Detail Modal ── -->
<div class="modal-overlay" id="userDetailModal">
  <div class="modal modal-xl">
    <div class="modal-header">
      <h3>User Profile</h3>
      <button class="modal-close" onclick="closeModal('userDetailModal')"><i class="fas fa-times"></i></button>
    </div>
    <div id="userDetailBody"></div>
    <div class="modal-footer"><button class="btn btn-ghost" onclick="closeModal('userDetailModal')">Close</button></div>
  </div>
</div>

