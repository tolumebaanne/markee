<!-- ══════════════════════ TAB: LISTING REVIEW ══════════════════════ -->
<div class="tab-panel" id="tab-listing-review">
  <div class="page-header">
    <div>
      <h1><i class="fas fa-clipboard-check" style="color:var(--accent);margin-right:0.4rem;font-size:1.1rem"></i> Listing Review</h1>
      <p>Content quality gate — approve, send back for changes, or reject seller listings</p>
    </div>
    <button class="btn btn-ghost btn-sm" onclick="loadListingReview()"><i class="fas fa-rotate-right"></i> Refresh</button>
  </div>

  <div class="sub-tabs">
    <button class="sub-tab active" onclick="switchSubTab('lr','queue',this)">
      <i class="fas fa-inbox"></i> My Queue
      <span id="lr-queue-count" style="background:var(--accent);color:#fff;font-size:0.6rem;padding:0.08rem 0.35rem;border-radius:10px;margin-left:0.25rem;display:none"></span>
    </button>
    <button class="sub-tab" onclick="switchSubTab('lr','unassigned',this);if(!this.dataset.loaded){this.dataset.loaded=1;loadLrUnassigned();}">
      <i class="fas fa-layer-group"></i> Unassigned
      <span id="lr-unassigned-count" style="background:var(--warn);color:#fff;font-size:0.6rem;padding:0.08rem 0.35rem;border-radius:10px;margin-left:0.25rem;display:none"></span>
    </button>
    <button class="sub-tab" onclick="switchSubTab('lr','history',this);if(!this.dataset.loaded){this.dataset.loaded=1;loadLrHistory(1);}">
      <i class="fas fa-clock-rotate-left"></i> History
    </button>
    <button class="sub-tab" id="lr-templates-tab" style="display:none" onclick="switchSubTab('lr','templates',this);if(!this.dataset.loaded){this.dataset.loaded=1;loadLrTemplatesCrud();}">
      <i class="fas fa-comment-medical"></i> Templates
    </button>
  </div>

  <!-- My Queue -->
  <div id="lr-queue" class="sub-panel" style="display:block">
    <div id="lr-queue-error" class="error-banner" style="display:none"><i class="fas fa-triangle-exclamation"></i><span></span></div>
    <div id="lr-queue-table"><div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading your review queue...</div></div>
  </div>

  <!-- Unassigned Pool -->
  <div id="lr-unassigned" class="sub-panel" style="display:none">
    <!-- Assign bar (Super only) -->
    <div id="lr-assign-bar" style="display:none;align-items:center;gap:0.75rem;padding:0.6rem 0.75rem;background:var(--bg2);border-radius:6px;margin-bottom:0.75rem;flex-wrap:wrap;">
      <span id="lr-selected-count" style="font-size:0.8rem;color:var(--muted);font-weight:600">0 selected</span>
      <select id="lr-assign-reviewer" style="min-width:200px;flex:1">
        <option value="">— Assign to reviewer —</option>
      </select>
      <button class="btn btn-primary btn-sm" onclick="lrAssignSelected()"><i class="fas fa-user-check"></i> Assign</button>
      <button class="btn btn-ghost btn-sm" onclick="lrClearSelection()"><i class="fas fa-times"></i> Clear</button>
    </div>
    <div id="lr-unassigned-error" class="error-banner" style="display:none"><i class="fas fa-triangle-exclamation"></i><span></span></div>
    <div id="lr-unassigned-table"><div class="loading"><i class="fas fa-spinner fa-spin"></i></div></div>
  </div>

  <!-- History -->
  <div id="lr-history" class="sub-panel" style="display:none">
    <div id="lr-history-error" class="error-banner" style="display:none"><i class="fas fa-triangle-exclamation"></i><span></span></div>
    <div id="lr-history-table"><div class="loading"><i class="fas fa-spinner fa-spin"></i></div></div>
    <div class="pagination" id="lr-history-pagination"></div>
  </div>

  <!-- Templates (Super only) -->
  <div id="lr-templates" class="sub-panel" style="display:none">
    <div id="lr-templates-error" class="error-banner" style="display:none"><i class="fas fa-triangle-exclamation"></i><span></span></div>
    <!-- Create form -->
    <div style="background:var(--bg2);border-radius:8px;padding:1rem;margin-bottom:1rem">
      <div style="font-size:0.8rem;font-weight:700;color:var(--muted2);margin-bottom:0.75rem"><i class="fas fa-plus"></i> New Template</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-bottom:0.5rem">
        <input id="lr-tpl-title" type="text" placeholder="Title (required)" style="min-width:0">
        <input id="lr-tpl-category" type="text" placeholder="Category (optional, e.g. Images)">
      </div>
      <textarea id="lr-tpl-body" rows="3" style="width:100%;resize:vertical;margin-bottom:0.5rem" placeholder="Template body — min 10 characters (required)"></textarea>
      <button class="btn btn-primary btn-sm" onclick="lrCreateTemplate()"><i class="fas fa-plus"></i> Create Template</button>
    </div>
    <div id="lr-templates-table"><div class="loading"><i class="fas fa-spinner fa-spin"></i></div></div>
  </div>
</div>

<!-- Disapprove Modal -->
<div id="lr-disapprove-modal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeLrModal()">
  <div class="modal-box" style="max-width:520px" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3><i class="fas fa-comment-dots"></i> Send Back for Changes</h3>
      <button class="modal-close" onclick="closeLrModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body">
      <div style="margin-bottom:0.75rem">
        <label style="font-size:0.8rem;font-weight:600;color:var(--muted2);display:block;margin-bottom:0.35rem">Use a Template</label>
        <select id="lr-template-select" style="width:100%" onchange="applyLrTemplate(this.value)">
          <option value="">— Write custom comment —</option>
        </select>
      </div>
      <div>
        <label style="font-size:0.8rem;font-weight:600;color:var(--muted2);display:block;margin-bottom:0.35rem">Reviewer Comment <span style="color:var(--danger)">*</span></label>
        <textarea id="lr-disapprove-comment" rows="5" style="width:100%;resize:vertical" placeholder="Explain what needs to change before this listing can be approved…"></textarea>
        <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem">This comment is shown to the seller.</div>
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn btn-ghost btn-sm" onclick="closeLrModal()">Cancel</button>
      <button class="btn btn-warn btn-sm" onclick="submitLrDisapprove()"><i class="fas fa-paper-plane"></i> Send Back</button>
    </div>
  </div>
</div>

<!-- Detail Modal -->
<div id="lr-detail-modal" class="modal-overlay" style="display:none" onclick="if(event.target===this)closeLrDetailModal()">
  <div class="modal-box" style="max-width:780px;max-height:90vh;overflow-y:auto" onclick="event.stopPropagation()">
    <div class="modal-header">
      <h3><i class="fas fa-magnifying-glass"></i> Listing Details</h3>
      <button class="modal-close" onclick="closeLrDetailModal()"><i class="fas fa-times"></i></button>
    </div>
    <div class="modal-body" id="lr-detail-body">
      <div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading…</div>
    </div>
    <div class="modal-footer" id="lr-detail-footer" style="display:none">
      <button class="btn btn-ghost btn-sm" onclick="closeLrDetailModal()">Close</button>
      <button class="btn btn-warn btn-sm" id="lr-detail-changes-btn" onclick=""><i class="fas fa-comment-dots"></i> Request Changes</button>
      <button class="btn btn-danger btn-sm" id="lr-detail-reject-btn" onclick=""><i class="fas fa-times"></i> Reject</button>
      <button class="btn btn-success btn-sm" id="lr-detail-approve-btn" style="display:none" onclick=""><i class="fas fa-check"></i> Approve</button>
    </div>
  </div>
</div>

<script>
// ── State ─────────────────────────────────────────────────────────────────────
let _lrPendingProductId = null;
let _lrTemplates        = [];
let _lrReviewers        = [];   // admin accounts with canReview permission

// ── Entry point ───────────────────────────────────────────────────────────────
function loadListingReview() {
  loadLrQueue();
  loadLrTemplates();
  if (window._isSuperuser) {
    // Show Super-only UI elements
    const tplTab  = document.getElementById('lr-templates-tab');
    const assignBar = document.getElementById('lr-assign-bar');
    if (tplTab)    tplTab.style.display    = 'inline-flex';
    if (assignBar) assignBar.style.display = 'flex';
    loadLrReviewers();
  }
}

// ── Load reviewer accounts (Super only — for assign selector) ─────────────────
async function loadLrReviewers() {
  try {
    const data = await adminApi('GET', '/accounts?status=active&limit=100');
    _lrReviewers = (data.accounts || []).filter(a => a.isSuperuser || a.permissions?.listingReview?.canReview);
    const sel = document.getElementById('lr-assign-reviewer');
    if (!sel) return;
    sel.innerHTML = '<option value="">— Assign to reviewer —</option>' +
      _lrReviewers.map(a => `<option value="${a._id}">${a.email}</option>`).join('');
  } catch { /* non-fatal */ }
}

// ── Queue (assigned to this reviewer; super admins also see all unassigned) ───
async function loadLrQueue() {
  hideErr('lr-queue-error');
  const el = document.getElementById('lr-queue-table');
  el.innerHTML = `<div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading...</div>`;
  try {
    const adminId = parseJwt(localStorage.getItem('admin_access_token'))?.sub || '';
    let products;

    if (window._isSuperuser) {
      // Super admins see their assigned items PLUS every unassigned item
      const [assignedData, unassignedData] = await Promise.all([
        adminApi('GET', `/proxy/catalog/products/review/assigned/${adminId}`),
        adminApi('GET', '/proxy/catalog/products/review/unassigned')
      ]);
      const assigned   = Array.isArray(assignedData)   ? assignedData   : (assignedData.products   || []);
      const unassigned = Array.isArray(unassignedData) ? unassignedData : (unassignedData.products || []);
      const seen = new Set(assigned.map(p => p._id));
      products = [...assigned, ...unassigned.filter(p => !seen.has(p._id))];
    } else {
      const data = await adminApi('GET', `/proxy/catalog/products/review/assigned/${adminId}`);
      products = Array.isArray(data) ? data : (data.products || []);
    }

    const countEl = document.getElementById('lr-queue-count');
    if (countEl) {
      if (products.length > 0) { countEl.textContent = products.length; countEl.style.display = 'inline-flex'; }
      else { countEl.style.display = 'none'; }
    }
    // sidebar badge
    const sb = document.getElementById('badge-listing-review');
    if (sb && products.length > 0) { sb.textContent = products.length; sb.style.display = 'inline-flex'; }

    if (!products.length) {
      el.innerHTML = `<div class="empty-state"><i class="fas fa-check-double"></i>Your queue is empty<p>Pick up listings from the Unassigned pool.</p></div>`;
      return;
    }
    el.innerHTML = lrRenderTable(products, 'queue');
  } catch (err) { showErr('lr-queue-error', err.message); el.innerHTML = ''; }
}

// ── Unassigned pool ───────────────────────────────────────────────────────────
async function loadLrUnassigned() {
  hideErr('lr-unassigned-error');
  const el = document.getElementById('lr-unassigned-table');
  el.innerHTML = `<div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading...</div>`;
  try {
    const data     = await adminApi('GET', '/proxy/catalog/products/review/unassigned');
    const products = Array.isArray(data) ? data : (data.products || []);

    const countEl = document.getElementById('lr-unassigned-count');
    if (countEl) {
      if (products.length > 0) { countEl.textContent = products.length; countEl.style.display = 'inline-flex'; }
      else { countEl.style.display = 'none'; }
    }

    if (!products.length) {
      el.innerHTML = `<div class="empty-state"><i class="fas fa-inbox"></i>No unassigned listings<p>All submissions are currently assigned or processed.</p></div>`;
      return;
    }
    el.innerHTML = lrRenderTable(products, 'unassigned');
  } catch (err) { showErr('lr-unassigned-error', err.message); el.innerHTML = ''; }
}

// ── History ───────────────────────────────────────────────────────────────────
async function loadLrHistory(page = 1) {
  hideErr('lr-history-error');
  const el = document.getElementById('lr-history-table');
  el.innerHTML = `<div class="loading"><i class="fas fa-spinner fa-spin"></i></div>`;
  try {
    const data     = await adminApi('GET', `/proxy/catalog/products/review/history?page=${page}&limit=20`);
    const products = Array.isArray(data) ? data : (data.products || []);
    const total    = data.total || products.length;

    if (!products.length) {
      el.innerHTML = `<div class="empty-state"><i class="fas fa-clock-rotate-left"></i>No review history yet</div>`;
      document.getElementById('lr-history-pagination').innerHTML = '';
      return;
    }
    el.innerHTML = `<div class="table-wrap"><table>
      <thead><tr><th>Product</th><th>Seller</th><th>Category</th><th>Review Status</th><th>Reviewer</th><th>Last Action</th></tr></thead>
      <tbody>${products.map(p => {
        const last = (p.reviewHistory || []).slice(-1)[0] || {};
        return `<tr>
          <td><div style="font-weight:600">${trunc(p.title, 28)}</div><div class="mono" style="font-size:0.67rem;margin-top:0.1rem">${trunc(p._id, 18)}</div></td>
          <td style="font-size:0.78rem">${p.sellerName ? escHtml(p.sellerName) : `<span class="mono" style="font-size:0.68rem" title="${p.sellerId || p.storeId || ''}">${trunc(String(p.sellerId || p.storeId || ''), 14)}</span>`}</td>
          <td style="color:var(--muted2);font-size:0.78rem">${p.category || '—'}</td>
          <td>${lrReviewBadge(p.reviewStatus)}</td>
          <td style="font-size:0.78rem">${last.reviewerEmail ? escHtml(last.reviewerEmail.split('@')[0]) : (last.reviewerId ? `<span class="mono" style="font-size:0.68rem" title="${last.reviewerId}">${trunc(String(last.reviewerId), 14)}</span>` : '—')}</td>
          <td style="color:var(--muted);font-size:0.72rem">${last.timestamp ? fmtDate(last.timestamp) : '—'}</td>
        </tr>`;
      }).join('')}
      </tbody></table></div>`;

    const pages = Math.ceil(total / 20);
    document.getElementById('lr-history-pagination').innerHTML =
      `<span style="margin-right:auto">Showing ${products.length} of ${total}</span>` +
      (page > 1 ? `<button class="btn btn-ghost btn-xs" onclick="loadLrHistory(${page-1})">← Prev</button>` : '') +
      `<span style="color:var(--text);font-weight:600">Page ${page}/${pages}</span>` +
      (page < pages ? `<button class="btn btn-ghost btn-xs" onclick="loadLrHistory(${page+1})">Next →</button>` : '');
  } catch (err) { showErr('lr-history-error', err.message); el.innerHTML = ''; }
}

// ── Comment templates ─────────────────────────────────────────────────────────
async function loadLrTemplates() {
  try {
    const data = await adminApi('GET', '/listing-review/comment-templates');
    _lrTemplates = Array.isArray(data) ? data : [];
    const sel = document.getElementById('lr-template-select');
    if (!sel) return;
    sel.innerHTML = '<option value="">— Write custom comment —</option>' +
      _lrTemplates.map(t =>
        `<option value="${t._id}">[${t.category || 'General'}] ${trunc(t.title, 40)}</option>`
      ).join('');
  } catch { /* non-fatal — templates enhance but don't block */ }
}

function applyLrTemplate(templateId) {
  if (!templateId) return;
  const t = _lrTemplates.find(x => x._id === templateId);
  if (!t) return;
  document.getElementById('lr-disapprove-comment').value = t.body;
  // Track usage — fire-and-forget, no await
  adminApi('POST', `/listing-review/comment-templates/${templateId}/use`, {}).catch(() => {});
}

// ── Shared table renderer ─────────────────────────────────────────────────────
// mode: 'queue' | 'unassigned'
function lrRenderTable(products, mode) {
  const showApprove  = mode === 'queue' || window._isSuperuser;
  const showCheckbox = mode === 'unassigned' && window._isSuperuser;
  const showPullback = mode === 'queue'      && window._isSuperuser;

  const selectAllTh = showCheckbox
    ? `<th style="width:32px"><input type="checkbox" id="lr-select-all" onclick="lrToggleSelectAll(this)"></th>`
    : '';

  return `<div class="table-wrap"><table>
    <thead><tr>${selectAllTh}<th>Product</th><th>Category</th><th>Price</th><th>Seller</th><th>Submitted</th><th>Rejections</th><th>Actions</th></tr></thead>
    <tbody>${products.map(p => {
      const cbTd = showCheckbox
        ? `<td><input type="checkbox" class="lr-unassigned-cb" value="${p._id}" onchange="lrUpdateSelectBar()"></td>`
        : '';
      return `<tr id="lr-row-${p._id}" style="cursor:pointer" onclick="openLrDetailModal('${p._id}')">
        ${cbTd}
        <td>
          <div style="font-weight:600">${trunc(p.title, 30)}</div>
          <div class="mono" style="font-size:0.67rem;margin-top:0.1rem">${trunc(p._id, 18)}</div>
        </td>
        <td><span style="background:var(--bg2);color:var(--muted2);padding:0.1rem 0.45rem;border-radius:5px;font-size:0.7rem">${p.category || '—'}</span></td>
        <td style="font-weight:700;color:var(--success)">${fmt$(p.price)}</td>
        <td style="font-size:0.75rem">${p.sellerName ? escHtml(p.sellerName) : `<span class="mono" style="font-size:0.68rem">${trunc(p.sellerId || p.storeId, 14)}</span>`}</td>
        <td style="color:var(--muted);font-size:0.72rem">${fmtDate(p.reviewSubmittedAt || p.createdAt)}</td>
        <td style="text-align:center;color:${(p.rejectionCount||0)>0?'var(--warn)':'var(--muted)'};font-weight:${(p.rejectionCount||0)>0?700:400}">${p.rejectionCount||0}</td>
        <td onclick="event.stopPropagation()"><div class="btn-gap">
          ${showApprove    ? `<button class="btn btn-success btn-xs" onclick="lrApprove('${p._id}')"><i class="fas fa-check"></i> Approve</button>` : ''}
          <button class="btn btn-warn btn-xs" onclick="openLrDisapproveModal('${p._id}')"><i class="fas fa-comment-dots"></i> Changes</button>
          <button class="btn btn-danger btn-xs" onclick="lrReject('${p._id}')"><i class="fas fa-times"></i> Reject</button>
          ${showPullback   ? `<button class="btn btn-ghost btn-xs" onclick="lrPullBack('${p._id}')"><i class="fas fa-inbox-in"></i> Pull Back</button>` : ''}
        </div></td>
      </tr>`;
    }).join('')}
    </tbody></table></div>`;
}

function lrReviewBadge(rs) {
  const map = {
    pending_review: `<span style="font-size:0.7rem;background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe;border-radius:4px;padding:0.1rem 0.4rem">⏳ In Queue</span>`,
    in_review:      `<span style="font-size:0.7rem;background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;border-radius:4px;padding:0.1rem 0.4rem">🔍 In Review</span>`,
    needs_changes:  `<span style="font-size:0.7rem;background:#fefce8;color:#a16207;border:1px solid #fde047;border-radius:4px;padding:0.1rem 0.4rem">⚠ Needs Changes</span>`,
    approved:       `<span style="font-size:0.7rem;background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;border-radius:4px;padding:0.1rem 0.4rem">✓ Approved</span>`,
    rejected:       `<span style="font-size:0.7rem;background:#fef2f2;color:#991b1b;border:1px solid #fecaca;border-radius:4px;padding:0.1rem 0.4rem">✕ Rejected</span>`,
    published:      `<span style="font-size:0.7rem;background:#f0fdf4;color:#15803d;border:1px solid #bbf7d0;border-radius:4px;padding:0.1rem 0.4rem">✓ Published</span>`,
    offline:        `<span style="font-size:0.7rem;background:#f3f4f6;color:#6b7280;border:1px solid #e5e7eb;border-radius:4px;padding:0.1rem 0.4rem">◌ Offline</span>`,
  };
  return map[rs] || `<span style="font-size:0.7rem;color:var(--muted)">${rs || '—'}</span>`;
}

// ── Review actions ────────────────────────────────────────────────────────────
async function lrApprove(id) {
  const r = await showConfirm({ title: 'Approve Listing', body: 'This listing will go live on the marketplace immediately.' });
  if (!r.confirmed) return;
  try {
    await adminApi('POST', `/proxy/catalog/products/${id}/approve`, {});
    toast('Listing approved and live.', 'success');
    _removeRowAndRefreshCounts(id);
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

function openLrDisapproveModal(id) {
  _lrPendingProductId = id;
  document.getElementById('lr-disapprove-comment').value = '';
  document.getElementById('lr-template-select').value = '';
  document.getElementById('lr-disapprove-modal').style.display = 'flex';
}

function closeLrModal() {
  document.getElementById('lr-disapprove-modal').style.display = 'none';
  _lrPendingProductId = null;
}

// ── Detail Modal ──────────────────────────────────────────────────────────────
async function openLrDetailModal(id) {
  const modal  = document.getElementById('lr-detail-modal');
  const body   = document.getElementById('lr-detail-body');
  const footer = document.getElementById('lr-detail-footer');
  footer.style.display = 'none';
  body.innerHTML = `<div class="loading"><i class="fas fa-spinner fa-spin"></i> Loading…</div>`;
  modal.style.display = 'flex';
  try {
    const p = await adminApi('GET', `/proxy/catalog/products/${id}`);

    // Images carousel
    const imgs = (p.images || []).slice(0, 6);
    const imgsHtml = imgs.length
      ? `<div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem">
           ${imgs.map(img => `<img src="${escHtml(img)}" style="width:120px;height:120px;object-fit:cover;border-radius:6px;border:1px solid var(--border)">`).join('')}
         </div>`
      : `<div style="color:var(--muted);font-size:0.8rem;margin-bottom:0.75rem"><i class="fas fa-image"></i> No images</div>`;

    // Review history
    const hist = (p.reviewHistory || []);
    const histHtml = hist.length
      ? `<div style="margin-top:1rem">
           <div style="font-size:0.8rem;font-weight:700;color:var(--muted2);margin-bottom:0.5rem">Review History (${hist.length})</div>
           ${hist.map(h => `<div style="background:var(--bg2);border-radius:6px;padding:0.6rem 0.75rem;margin-bottom:0.4rem;font-size:0.76rem">
             <div style="display:flex;justify-content:space-between;margin-bottom:0.3rem">
               <span style="font-weight:600;color:var(--text)">${h.toStatus || '—'}</span>
               <span style="color:var(--muted)">${h.timestamp ? fmtDate(h.timestamp) : '—'}</span>
             </div>
             ${h.comment ? `<div style="color:var(--muted2);white-space:pre-wrap">${escHtml(h.comment)}</div>` : ''}
           </div>`).join('')}
         </div>`
      : `<div style="color:var(--muted);font-size:0.78rem;margin-top:0.75rem">No review history yet.</div>`;

    const rejCount = p.rejectionCount || 0;

    body.innerHTML = `
      <div style="display:grid;grid-template-columns:1fr auto;gap:0.5rem;align-items:start;margin-bottom:0.75rem">
        <div>
          <div style="font-size:1.05rem;font-weight:700;color:var(--text);margin-bottom:0.15rem">${escHtml(p.title || '(no title)')}</div>
          <div style="font-size:0.72rem;color:var(--muted);font-family:monospace">${escHtml(String(p._id))}</div>
        </div>
        <div style="text-align:right">
          ${lrReviewBadge(p.reviewStatus)}
          ${rejCount > 0 ? `<div style="font-size:0.72rem;color:var(--warn);margin-top:0.25rem;font-weight:700">${rejCount} rejection${rejCount!==1?'s':''}</div>` : ''}
        </div>
      </div>
      ${imgsHtml}
      <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0.6rem;margin-bottom:0.75rem">
        <div style="background:var(--bg2);border-radius:6px;padding:0.5rem 0.75rem">
          <div style="font-size:0.67rem;font-weight:700;color:var(--muted2);text-transform:uppercase;letter-spacing:.05em">Category</div>
          <div style="font-size:0.85rem;margin-top:0.2rem">${escHtml(p.category || '—')}${p.subcategory ? ` / ${escHtml(p.subcategory)}` : ''}</div>
        </div>
        <div style="background:var(--bg2);border-radius:6px;padding:0.5rem 0.75rem">
          <div style="font-size:0.67rem;font-weight:700;color:var(--muted2);text-transform:uppercase;letter-spacing:.05em">Price</div>
          <div style="font-size:0.85rem;font-weight:700;color:var(--success);margin-top:0.2rem">${fmt$(p.price)}</div>
        </div>
        <div style="background:var(--bg2);border-radius:6px;padding:0.5rem 0.75rem">
          <div style="font-size:0.67rem;font-weight:700;color:var(--muted2);text-transform:uppercase;letter-spacing:.05em">Seller</div>
          <div style="font-size:0.82rem;margin-top:0.2rem">${p.sellerName ? escHtml(p.sellerName) : `<span style="font-family:monospace;font-size:0.7rem">${escHtml(String(p.sellerId||'—'))}</span>`}</div>
        </div>
      </div>
      ${p.description ? `<div style="margin-bottom:0.75rem">
        <div style="font-size:0.72rem;font-weight:700;color:var(--muted2);margin-bottom:0.35rem">Description</div>
        <div style="font-size:0.83rem;white-space:pre-wrap;color:var(--text2);background:var(--bg2);border-radius:6px;padding:0.6rem 0.75rem;max-height:180px;overflow-y:auto">${escHtml(p.description)}</div>
      </div>` : ''}
      ${histHtml}`;

    // Wire footer action buttons to this product id
    const showApprove = window._isSuperuser ||
      (p.reviewStatus === 'pending_review' || p.reviewStatus === 'in_review');
    const approveBtn = document.getElementById('lr-detail-approve-btn');
    const changesBtn = document.getElementById('lr-detail-changes-btn');
    const rejectBtn  = document.getElementById('lr-detail-reject-btn');
    approveBtn.style.display = (showApprove || window._isSuperuser) ? 'inline-flex' : 'none';
    approveBtn.onclick = () => { closeLrDetailModal(); lrApprove(id); };
    changesBtn.onclick = () => { closeLrDetailModal(); openLrDisapproveModal(id); };
    rejectBtn.onclick  = () => { closeLrDetailModal(); lrReject(id); };
    footer.style.display = 'flex';
  } catch (err) {
    body.innerHTML = `<div class="error-banner"><i class="fas fa-triangle-exclamation"></i> ${escHtml(err.message)}</div>`;
  }
}

function closeLrDetailModal() {
  document.getElementById('lr-detail-modal').style.display = 'none';
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

async function submitLrDisapprove() {
  const comment = document.getElementById('lr-disapprove-comment').value.trim();
  if (!comment) { toast('A comment is required when sending back for changes.', 'warn'); return; }
  if (!_lrPendingProductId) return;
  try {
    await adminApi('POST', `/proxy/catalog/products/${_lrPendingProductId}/disapprove`, { comment });
    closeLrModal();
    toast('Listing sent back — seller notified.', 'warn');
    _removeRowAndRefreshCounts(_lrPendingProductId);
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function lrReject(id) {
  const r = await showConfirm({
    title: 'Reject Listing',
    body: 'This listing will be permanently rejected. The seller will be notified and the rejection count will increment.',
    withReason: true,
    danger: true
  });
  if (!r.confirmed) return;
  try {
    await adminApi('POST', `/proxy/catalog/products/${id}/reject`, { reason: r.reason || 'Does not meet listing standards' });
    toast('Listing rejected.', 'warn');
    _removeRowAndRefreshCounts(id);
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

// ── Assignment (Super only) ───────────────────────────────────────────────────
function lrToggleSelectAll(masterCb) {
  document.querySelectorAll('.lr-unassigned-cb').forEach(cb => { cb.checked = masterCb.checked; });
  lrUpdateSelectBar();
}

function lrUpdateSelectBar() {
  const checked = [...document.querySelectorAll('.lr-unassigned-cb:checked')];
  const countEl = document.getElementById('lr-selected-count');
  if (countEl) countEl.textContent = `${checked.length} selected`;
}

function lrClearSelection() {
  document.querySelectorAll('.lr-unassigned-cb').forEach(cb => { cb.checked = false; });
  const all = document.getElementById('lr-select-all');
  if (all) all.checked = false;
  lrUpdateSelectBar();
}

async function lrAssignSelected() {
  const reviewerId = document.getElementById('lr-assign-reviewer').value;
  if (!reviewerId) { toast('Select a reviewer first.', 'warn'); return; }

  const listings = [...document.querySelectorAll('.lr-unassigned-cb:checked')].map(cb => cb.value);
  if (!listings.length) { toast('No listings selected.', 'warn'); return; }

  const reviewer = _lrReviewers.find(a => a._id === reviewerId);
  const r = await showConfirm({
    title: 'Assign Listings',
    body:  `Assign ${listings.length} listing(s) to ${reviewer?.email || reviewerId}?`
  });
  if (!r.confirmed) return;

  try {
    await adminApi('POST', '/proxy/catalog/products/review/assign', { listingIds: listings, assignedTo: reviewerId });
    // Log to assignment log
    await adminApi('POST', '/listing-review/assignment-log', {
      type: 'assign', assignedTo: reviewerId, listings, note: r.reason || ''
    }).catch(() => {});
    toast(`${listings.length} listing(s) assigned.`, 'success');
    lrClearSelection();
    loadLrUnassigned();
  } catch (err) { toast('Assign failed: ' + err.message, 'error'); }
}

async function lrPullBack(id) {
  const r = await showConfirm({ title: 'Pull Back to Pool', body: 'Return this listing to the unassigned pool.' });
  if (!r.confirmed) return;
  try {
    await adminApi('POST', '/proxy/catalog/products/review/pullback', { listingIds: [id] });
    await adminApi('POST', '/listing-review/assignment-log', {
      type: 'pullback', listings: [id], note: r.reason || ''
    }).catch(() => {});
    toast('Listing returned to pool.', 'success');
    _removeRowAndRefreshCounts(id);
  } catch (err) { toast('Pull back failed: ' + err.message, 'error'); }
}

// ── Template CRUD (Super only) ────────────────────────────────────────────────
async function loadLrTemplatesCrud() {
  hideErr('lr-templates-error');
  const el = document.getElementById('lr-templates-table');
  el.innerHTML = `<div class="loading"><i class="fas fa-spinner fa-spin"></i></div>`;
  try {
    const data  = await adminApi('GET', '/listing-review/comment-templates');
    const tmpls = Array.isArray(data) ? data : [];

    if (!tmpls.length) {
      el.innerHTML = `<div class="empty-state"><i class="fas fa-comment-slash"></i>No templates yet<p>Create one above.</p></div>`;
      return;
    }

    el.innerHTML = `<div class="table-wrap"><table>
      <thead><tr><th>Title</th><th>Category</th><th>Body</th><th>Uses</th><th>Active</th><th>Actions</th></tr></thead>
      <tbody>${tmpls.map(t => `<tr id="lr-tpl-row-${t._id}">
        <td style="font-weight:600">${trunc(t.title, 30)}</td>
        <td style="font-size:0.75rem;color:var(--muted)">${t.category || '—'}</td>
        <td style="font-size:0.73rem;color:var(--muted2);max-width:280px;white-space:pre-wrap">${trunc(t.body, 80)}</td>
        <td style="text-align:center;font-size:0.75rem">${t.usageCount || 0}</td>
        <td style="text-align:center">
          <input type="checkbox" ${t.isActive ? 'checked' : ''} onchange="lrToggleTemplate('${t._id}', this.checked)">
        </td>
        <td><div class="btn-gap">
          <button class="btn btn-ghost btn-xs" onclick="lrEditTemplate('${t._id}')"><i class="fas fa-pen"></i></button>
          <button class="btn btn-danger btn-xs" onclick="lrDeleteTemplate('${t._id}')"><i class="fas fa-trash"></i></button>
        </div></td>
      </tr>`).join('')}
      </tbody></table></div>`;
  } catch (err) { showErr('lr-templates-error', err.message); el.innerHTML = ''; }
}

async function lrCreateTemplate() {
  const title    = document.getElementById('lr-tpl-title').value.trim();
  const body     = document.getElementById('lr-tpl-body').value.trim();
  const category = document.getElementById('lr-tpl-category').value.trim();
  if (!title)         { toast('Title is required.', 'warn'); return; }
  if (body.length < 10) { toast('Body must be at least 10 characters.', 'warn'); return; }
  try {
    await adminApi('POST', '/listing-review/comment-templates', { title, body, category });
    toast('Template created.', 'success');
    document.getElementById('lr-tpl-title').value    = '';
    document.getElementById('lr-tpl-body').value     = '';
    document.getElementById('lr-tpl-category').value = '';
    loadLrTemplatesCrud();
    loadLrTemplates(); // refresh the disapprove modal selector
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function lrToggleTemplate(id, isActive) {
  try {
    await adminApi('PUT', `/listing-review/comment-templates/${id}`, { isActive });
    toast(isActive ? 'Template activated.' : 'Template deactivated.', 'success');
    loadLrTemplates();
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function lrEditTemplate(id) {
  try {
    const t = await adminApi('GET', `/listing-review/comment-templates/${id}`);
    const r = await showConfirm({
      title:       'Edit Template',
      body:        `Editing: ${t.title}`,
      withInput:   true,
      inputLabel:  'Body',
      inputDefault: t.body,
      danger: false
    });
    if (!r.confirmed || !r.input?.trim()) return;
    await adminApi('PUT', `/listing-review/comment-templates/${id}`, { body: r.input.trim() });
    toast('Template updated.', 'success');
    loadLrTemplatesCrud();
    loadLrTemplates();
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

async function lrDeleteTemplate(id) {
  const r = await showConfirm({ title: 'Delete Template', body: 'Permanently delete this template?', danger: true });
  if (!r.confirmed) return;
  try {
    await adminApi('DELETE', `/listing-review/comment-templates/${id}`, {});
    toast('Template deleted.', 'success');
    document.getElementById(`lr-tpl-row-${id}`)?.remove();
    loadLrTemplates();
  } catch (err) { toast('Error: ' + err.message, 'error'); }
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function _removeRowAndRefreshCounts(id) {
  const row = document.getElementById(`lr-row-${id}`);
  if (row) row.remove();

  // Update queue count badge
  const queueTable = document.getElementById('lr-queue-table');
  if (queueTable) {
    const remaining = queueTable.querySelectorAll('tbody tr').length;
    const countEl   = document.getElementById('lr-queue-count');
    if (countEl) {
      if (remaining > 0) { countEl.textContent = remaining; }
      else { countEl.style.display = 'none'; }
    }
    const sb = document.getElementById('badge-listing-review');
    if (sb) { if (remaining > 0) { sb.textContent = remaining; } else { sb.style.display = 'none'; } }
    if (remaining === 0) {
      queueTable.innerHTML = `<div class="empty-state"><i class="fas fa-check-double"></i>Your queue is empty<p>Pick up listings from the Unassigned pool.</p></div>`;
    }
  }
}
</script>
