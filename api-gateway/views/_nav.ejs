<%# Unified nav partial — included by all pages %>
    <div class="nav-links">
        <a href="/cart" class="nav-cart-btn" id="nav-cart-link" title="View Cart">
            <i class="fa fa-shopping-cart"></i>
            <span class="cart-count-badge" id="cart-count-badge">0</span>
        </a>

        <%# Guest state %>
        <div id="auth-links" style="display:flex; gap:0.5rem; align-items:center;">
            <button type="button" class="nav-pill nav-pill-outline" onclick="openSignInModal()">Sign In</button>
            <button type="button" class="nav-pill nav-pill-red" onclick="navigateSell()">
                <i class="fa fa-tag" style="margin-right:0.4rem;"></i> Sell
            </button>
        </div>

        <%# Logged-in state %>
        <div id="user-links" style="display:none; align-items:center; gap:0.35rem;">

            <%# Messages %>
            <button type="button" class="nav-icon-btn" id="nav-msg-btn" title="Messages" onclick="window.location='/messages'">
                <i class="fa fa-comments"></i>
                <span class="nav-icon-badge" id="msg-nav-badge" style="display:none;"></span>
            </button>

            <%# Bell %>
            <div style="position:relative;">
                <button type="button" class="nav-icon-btn" id="nav-bell-btn" title="Notifications" onclick="toggleBellDropdown()">
                    <i class="fa fa-bell"></i>
                    <span class="nav-icon-badge" id="bell-badge" style="display:none;"></span>
                </button>
                <div id="bell-dropdown" class="notif-dropdown" style="display:none;">
                    <div class="notif-panel-header">
                        <span style="font-weight:600; font-size:0.875rem;">Notifications</span>
                        <div style="display:flex; gap:0.75rem; align-items:center;">
                            <button type="button" onclick="markAllRead()" style="background:none; border:none; color:var(--accent-red); font-size:0.75rem; cursor:pointer; font-weight:600;">Mark all read</button>
                            <button type="button" onclick="clearAllNotifications(event)" style="background:none; border:none; color:var(--text-muted); font-size:0.75rem; cursor:pointer; font-weight:600;">Clear all</button>
                        </div>
                    </div>
                    <div id="bell-list" style="max-height:320px; overflow-y:auto;"></div>
                    <div style="padding:0.5rem 1rem; border-top:1px solid var(--border-light); text-align:center;">
                        <a href="/notifications" style="font-size:0.75rem; color:var(--accent-red); text-decoration:none; font-weight:600;">See all notifications</a>
                    </div>
                </div>
            </div>

            <%# Sell %>
            <button type="button" class="nav-pill nav-pill-red" style="margin-left:0.15rem;" onclick="navigateSell()">
                <i class="fa fa-tag" style="margin-right:0.4rem;"></i> Sell
            </button>

            <%# Avatar dropdown %>
            <div style="position:relative; margin-left:0.15rem;">
                <button type="button" class="nav-avatar-btn" id="nav-avatar-btn" onclick="toggleUserDropdown()" aria-label="Account menu" aria-expanded="false">
                    <i class="fa fa-user-circle"></i>
                </button>
                <div class="nav-dropdown" id="user-dropdown" style="display:none;">
                    <div class="nav-dropdown-header">
                        <div class="nav-dropdown-name" id="nav-display-name">—</div>
                        <div class="nav-dropdown-role" id="nav-display-role"></div>
                    </div>
                    <a href="/profile" class="nav-dropdown-item">
                        <i class="fa fa-user"></i> Profile &amp; Settings
                    </a>
                    <a href="/dashboard" class="nav-dropdown-item">
                        <i class="fa fa-th-large"></i> Dashboard
                    </a>
                    <a href="/orders" class="nav-dropdown-item">
                        <i class="fa fa-shopping-bag"></i> My Orders
                    </a>
                    <button type="button" class="nav-dropdown-item logout" onclick="handleLogout()">
                        <i class="fa fa-sign-out-alt"></i> Log Out
                    </button>
                </div>
            </div>

        </div>
    </div>
<script>
(function initNav() {
    const t = localStorage.getItem('access_token');
    if (!t) return;
    try {
        const u = JSON.parse(atob(t.split('.')[1]));
        // If token is expired, clear it and stop — don't make API calls with a dead token
        if (u.exp && u.exp * 1000 < Date.now()) {
            localStorage.removeItem('access_token');
            localStorage.removeItem('refresh_token');
            return;
        }
        document.getElementById('auth-links').style.display = 'none';
        document.getElementById('user-links').style.display = 'flex';

        const name = u.displayName || u.email?.split('@')[0] || 'Account';
        const dn = document.getElementById('nav-display-name');
        if (dn) dn.textContent = name;
        const dr = document.getElementById('nav-display-role');
        if (dr) dr.textContent = u.role || 'buyer';
    } catch {}

    // Bell badge — refreshed every 30s (matches message badge pattern)
    function refreshBellBadge() {
        fetch('/api/notifications/unread-count', {
            headers: { Authorization: 'Bearer ' + t }
        }).then(r => r.ok ? r.json() : null).then(data => {
            const b = document.getElementById('bell-badge');
            if (!b) return;
            if (data && data.count > 0) {
                b.textContent = data.count > 9 ? '9+' : data.count;
                b.style.display = 'block';
            } else {
                b.style.display = 'none';
            }
        }).catch(() => {});
    }
    refreshBellBadge();
    setInterval(refreshBellBadge, 30000);

    // Messages badge — non-blocking, refreshed every 30s
    function refreshMsgBadge() {
        fetch('/api/messages/unread-count', {
            headers: { Authorization: 'Bearer ' + t }
        }).then(r => r.ok ? r.json() : null).then(data => {
            const b = document.getElementById('msg-nav-badge');
            if (!b) return;
            if (data?.total > 0) {
                b.textContent = data.total > 9 ? '9+' : data.total;
                b.style.display = 'block';
            } else {
                b.style.display = 'none';
            }
        }).catch(() => {});
    }
    refreshMsgBadge();
    setInterval(refreshMsgBadge, 30000);
})();

function toggleUserDropdown() {
    const dd  = document.getElementById('user-dropdown');
    const btn = document.getElementById('nav-avatar-btn');
    if (!dd) return;
    const open = dd.style.display === 'none';
    dd.style.display = open ? 'block' : 'none';
    if (btn) btn.setAttribute('aria-expanded', String(open));
}

document.addEventListener('click', function(e) {
    if (!e.target.closest('#user-links')) {
        const dd = document.getElementById('user-dropdown');
        if (dd) dd.style.display = 'none';
        const btn = document.getElementById('nav-avatar-btn');
        if (btn) btn.setAttribute('aria-expanded', 'false');
    }
    // Close bell dropdown when clicking outside
    if (!e.target.closest('#nav-bell-btn') && !e.target.closest('#bell-dropdown')) {
        const bd = document.getElementById('bell-dropdown');
        if (bd) bd.style.display = 'none';
    }
});

let _bellLoaded = false;
function toggleBellDropdown() {
    const bd = document.getElementById('bell-dropdown');
    if (!bd) return;
    const open = bd.style.display === 'none';
    bd.style.display = open ? 'block' : 'none';
    if (open && !_bellLoaded) {
        _bellLoaded = true;
        loadBellNotifications();
    }
}

function loadBellNotifications() {
    const t = localStorage.getItem('access_token');
    const list = document.getElementById('bell-list');
    if (!t || !list) return;
    list.innerHTML = '<div style="padding:1rem; text-align:center; color:var(--text-muted); font-size:0.8rem;">Loading...</div>';
    fetch('/api/notifications/my', { headers: { Authorization: 'Bearer ' + t } })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            const notifs = Array.isArray(data) ? data : (data?.notifications || []);
            if (!notifs.length) {
                list.innerHTML = '<div style="padding:1.5rem; text-align:center; color:var(--text-muted); font-size:0.8rem;">No notifications yet.</div>';
                return;
            }
            list.innerHTML = notifs.slice(0, 8).map(n => {
                    const iconColor = n.priority === 'high' ? 'var(--accent-red)' : 'var(--text-muted)';
                    const timeStr = n.sentAt ? new Date(n.sentAt).toLocaleDateString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) :
                                    (n.createdAt ? new Date(n.createdAt).toLocaleDateString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}) : '');
                    return `
                <div class="notif-item${n.read ? '' : ' unread'}" data-notif-id="${n._id}">
                    <div class="notif-icon"><i class="fa ${n.icon || 'fa-bell'}" style="color:${iconColor};"></i></div>
                    <div class="notif-body"${n.link ? ` onclick="window.location='${n.link}'; dismissNotification('${n._id}', null);"` : ''} style="${n.link ? 'cursor:pointer;' : ''}">
                        <div class="notif-subject">${n.subject || n.body || '—'}</div>
                        ${n.body && n.subject ? `<div class="notif-preview">${n.body}</div>` : ''}
                        <div class="notif-time">${timeStr}</div>
                    </div>
                    <button type="button" onclick="dismissNotification('${n._id}', this)" title="Dismiss" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:0.8rem;padding:0.25rem;flex-shrink:0;line-height:1;opacity:0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">&times;</button>
                </div>`;
                }).join('');
        }).catch(() => {
            list.innerHTML = '<div style="padding:1rem; text-align:center; color:var(--text-muted); font-size:0.8rem;">Failed to load.</div>';
        });
}

function markAllRead() {
    const t = localStorage.getItem('access_token');
    if (!t) return;
    fetch('/api/notifications/read-all', { method: 'PATCH', headers: { Authorization: 'Bearer ' + t } })
        .then(r => r.ok ? r.json() : null)
        .then(() => {
            const b = document.getElementById('bell-badge');
            if (b) { b.textContent = ''; b.style.display = 'none'; }
            _bellLoaded = false;
            loadBellNotifications();
        }).catch(() => {});
}

function clearAllNotifications(evt) {
    const t = localStorage.getItem('access_token');
    if (!t) return;
    fetch('/api/notifications/my', { method: 'DELETE', headers: { Authorization: 'Bearer ' + t } })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            if (!data?.ok) return;
            const b = document.getElementById('bell-badge');
            if (b) { b.textContent = ''; b.style.display = 'none'; }
            const list = document.getElementById('bell-list');
            if (list) list.innerHTML = '<div style="padding:1.5rem; text-align:center; color:var(--text-muted); font-size:0.8rem;">No notifications yet.</div>';
            _bellLoaded = true;
            if (typeof showToast === 'function') showToast('All notifications cleared', 'success', 3500, evt);
        }).catch(() => {});
}

function dismissNotification(id, btn) {
    const t = localStorage.getItem('access_token');
    if (!t || !id) return;
    fetch('/api/notifications/' + id, { method: 'DELETE', headers: { Authorization: 'Bearer ' + t } })
        .then(r => r.ok ? r.json() : null)
        .then(data => {
            if (!data?.ok) return;
            const row = document.querySelector('[data-notif-id="' + id + '"]');
            if (row) row.remove();
            // Refresh badge count
            const list = document.getElementById('bell-list');
            if (list && !list.querySelector('[data-notif-id]')) {
                list.innerHTML = '<div style="padding:1.5rem; text-align:center; color:var(--text-muted); font-size:0.8rem;">No notifications yet.</div>';
            }
        }).catch(() => {});
}

function navigateSell() {
    const t = localStorage.getItem('access_token');
    if (!t) { openSignInModal(function(){ window.location.href = '/dashboard?sell=1'; }, 'Sign in to start selling'); return; }
    window.location.href = '/dashboard?sell=1';
}

function handleLogout() {
    localStorage.removeItem('access_token');
    localStorage.removeItem('refresh_token');
    window.location.href = '/login';
}

// ── Inline error helpers (shared across all pages via _nav.ejs) ──────────────
window.showInlineError = function(containerId, message) {
    var el = document.getElementById(containerId);
    if (!el) return;
    var err = el.querySelector('.inline-error-msg');
    if (!err) {
        err = document.createElement('div');
        err.className = 'inline-error-msg';
        el.appendChild(err);
    }
    err.textContent = message;
    err.style.display = 'block';
};
window.clearInlineError = function(containerId) {
    var el = document.getElementById(containerId);
    if (!el) return;
    var err = el.querySelector('.inline-error-msg');
    if (err) err.style.display = 'none';
};

// Shared monetary formatting (used across all pages)
window.formatCurrency = function(amountCents, currency) {
    currency = currency || 'CAD';
    return (amountCents / 100).toLocaleString('en-CA', { style: 'currency', currency: currency });
};

// ===== Sign In Modal (shared across all pages) =====
var _pendingAction = null;

function openSignInModal(pendingAction, subtitle) {
    _pendingAction = pendingAction || null;
    var sub = document.getElementById('signin-modal-subtitle');
    if (sub) sub.textContent = subtitle || 'Sign in to continue';
    var modal = document.getElementById('signin-modal');
    if (modal) modal.classList.add('modal-open');
    setTimeout(function(){ var el = document.getElementById('modal-email'); if (el) el.focus(); }, 200);
}

function closeSignInModal() {
    var modal = document.getElementById('signin-modal');
    if (modal) modal.classList.remove('modal-open');
    var form = document.getElementById('signin-form');
    if (form) form.reset();
    var btn = document.getElementById('modal-submit-btn');
    if (btn) { btn.disabled = false; btn.textContent = 'Sign In'; }
    var sub = document.getElementById('signin-modal-subtitle');
    if (sub) sub.textContent = 'Sign in to continue';
    _pendingAction = null;
}

function _handleSignInModalOutsideClick(e) {
    if (e.target === document.getElementById('signin-modal')) {
        closeSignInModal();
    }
}

async function submitSignIn(e) {
    e.preventDefault();
    clearInlineError('signin-error-container');
    var btn = document.getElementById('modal-submit-btn');
    var email = document.getElementById('modal-email').value;
    var password = document.getElementById('modal-password').value;

    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i>Signing in...';

    try {
        var res = await fetch('/oauth/quick-login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email: email, password: password })
        });
        var data = await res.json();
        if (!res.ok) {
            showInlineError('signin-error-container', data.error || 'Invalid credentials');
            btn.disabled = false;
            btn.textContent = 'Sign In';
            return;
        }
        localStorage.setItem('access_token', data.access_token);
        localStorage.setItem('refresh_token', data.refresh_token);
        if (window.MarkeeCart) MarkeeCart.migrateGuestCart();
        var pendingAction = _pendingAction;
        closeSignInModal();
        // Re-init nav state
        try {
            document.getElementById('auth-links').style.display = 'none';
            document.getElementById('user-links').style.display = 'flex';
            var u = JSON.parse(atob(data.access_token.split('.')[1]));
            var dn = document.getElementById('nav-display-name');
            if (dn) dn.textContent = u.displayName || u.email?.split('@')[0] || 'Account';
            var dr = document.getElementById('nav-display-role');
            if (dr) dr.textContent = u.role || 'buyer';
        } catch (_) {}
        if (typeof showToast === 'function') showToast('Welcome back!', 'success');
        if (pendingAction) pendingAction();
    } catch (err) {
        showInlineError('signin-error-container', 'Connection error. Please try again.');
        btn.disabled = false;
        btn.textContent = 'Sign In';
    }
}
</script>

<%# ── Sign-in modal (rendered on every page via _nav.ejs) ── %>
<div class="modal-overlay" id="signin-modal" onclick="_handleSignInModalOutsideClick(event)">
    <div class="modal-box">
        <button class="modal-close-btn" onclick="closeSignInModal()" title="Close">&times;</button>
        <div style="text-align:center; margin-bottom:1.5rem;">
            <span class="brand" style="font-size:1.5rem;">Markee</span>
            <p id="signin-modal-subtitle" style="color:var(--text-muted); margin-top:0.5rem; font-size:0.9rem;">Sign in to continue</p>
        </div>
        <form id="signin-form" onsubmit="submitSignIn(event)">
            <div class="form-group mb-3">
                <label>Email address</label>
                <input type="email" id="modal-email" placeholder="you@example.com" required autocomplete="email" oninput="clearInlineError('signin-error-container')">
            </div>
            <div class="form-group mb-4">
                <label>Password</label>
                <input type="password" id="modal-password" placeholder="••••••••" required autocomplete="current-password" oninput="clearInlineError('signin-error-container')">
            </div>
            <div id="signin-error-container"></div>
            <button type="submit" id="modal-submit-btn" class="btn w-100" style="background:var(--accent-red); margin-top:0.75rem;">
                Sign In
            </button>
        </form>
        <p class="text-muted small text-center" style="margin-top:1rem;">
            Don't have an account? <a href="/register" style="color:var(--accent-red);font-weight:600;">Register</a>
        </p>
    </div>
</div>
