<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Messages | Markee Marketplace</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        .messages-layout {
            display: grid;
            grid-template-columns: 300px 1fr;
            gap: 0;
            height: calc(100vh - 80px - 2rem);
            background: var(--bg-primary);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            overflow: hidden;
        }
        @media (max-width: 720px) {
            .messages-layout { grid-template-columns: 1fr; }
            .threads-panel { display: none; }
            .threads-panel.mobile-show { display: flex; }
        }

        /* ── Threads panel ──────────────────────────────────────────────────── */
        .threads-panel { border-right: 1px solid var(--border-light); display: flex; flex-direction: column; overflow: hidden; }
        .threads-header {
            padding: 0.85rem 1.1rem;
            border-bottom: 1px solid var(--border-light);
            background: var(--bg-secondary);
            display: flex; justify-content: space-between; align-items: center;
            flex-shrink: 0; gap: 0.5rem;
        }
        .threads-header h4 { margin: 0; font-size: 0.88rem; }
        .tabs-row { display: flex; border-bottom: 1px solid var(--border-light); flex-shrink: 0; }
        .tab-btn {
            flex: 1; padding: 0.5rem; font-size: 0.78rem; font-weight: 600;
            background: none; border: none; cursor: pointer; color: var(--text-muted);
            border-bottom: 2px solid transparent; transition: all 0.15s;
        }
        .tab-btn.active { color: var(--accent-red); border-bottom-color: var(--accent-red); }
        .thread-list { overflow-y: auto; flex-grow: 1; }

        .thread-item {
            padding: 0.75rem 1rem; border-bottom: 1px solid var(--border-light);
            cursor: pointer; transition: background 0.15s;
            display: flex; align-items: flex-start; gap: 0.65rem;
            position: relative;
        }
        .thread-item:hover { background: var(--bg-secondary); }
        .thread-item.active { background: #eff6ff; border-left: 3px solid var(--accent-red); }
        .thread-item.urgent { border-left: 3px solid #d97706; }
        .thread-item.pinned .thread-name::before {
            content: '\U0001F4CC '; font-size: 0.7rem;
        }

        .thread-avatar {
            width: 36px; height: 36px; border-radius: 50%;
            background: var(--bg-secondary); border: 1px solid var(--border-light);
            display: flex; align-items: center; justify-content: center;
            font-size: 0.8rem; font-weight: 700; color: var(--text-muted); flex-shrink: 0;
            position: relative;
        }
        .online-dot {
            position: absolute; bottom: 1px; right: 1px;
            width: 9px; height: 9px; border-radius: 50%;
            background: #22c55e; border: 1.5px solid white;
        }
        .thread-meta { flex-grow: 1; min-width: 0; }
        .thread-name { font-weight: 600; font-size: 0.82rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .thread-subtitle { font-size: 0.7rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 0.05rem; }
        .thread-preview { font-size: 0.73rem; color: var(--text-muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; margin-top: 0.15rem; }
        .thread-preview.system-preview { font-style: italic; }
        .context-badge {
            display: inline-block; font-size: 0.6rem; font-weight: 700; padding: 0.1rem 0.35rem;
            border-radius: 4px; margin-bottom: 0.2rem; text-transform: uppercase; letter-spacing: 0.03em;
        }
        .badge-product { background: #dbeafe; color: #1d4ed8; }
        .badge-order   { background: #dcfce7; color: #15803d; }
        .badge-general { background: #f3f4f6; color: #6b7280; }

        .unread-badge {
            background: var(--accent-red); color: white; font-size: 0.62rem;
            font-weight: 700; border-radius: 10px; padding: 0.1rem 0.4rem;
            flex-shrink: 0; align-self: flex-start; margin-top: 0.1rem; min-width: 18px; text-align: center;
        }
        .thread-actions {
            display: none; position: absolute; right: 0.5rem; top: 50%; transform: translateY(-50%);
            gap: 0.3rem;
        }
        .thread-item:hover .thread-actions { display: flex; }
        .thread-action-btn {
            background: var(--bg-primary); border: 1px solid var(--border-light); border-radius: 6px;
            padding: 0.2rem 0.4rem; font-size: 0.65rem; cursor: pointer; color: var(--text-muted);
            transition: all 0.15s;
        }
        .thread-action-btn:hover { background: var(--accent-red); color: white; border-color: var(--accent-red); }

        /* ── Chat panel ─────────────────────────────────────────────────────── */
        .chat-panel { display: flex; flex-direction: column; overflow: hidden; }
        .chat-header {
            padding: 0.85rem 1.1rem; border-bottom: 1px solid var(--border-light);
            background: var(--bg-secondary); display: flex; align-items: center;
            gap: 0.75rem; flex-shrink: 0; min-height: 56px;
        }
        .chat-header h4 { margin: 0; font-size: 0.88rem; flex-grow: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .header-actions { display: flex; gap: 0.4rem; flex-shrink: 0; }
        .header-btn {
            background: none; border: 1px solid var(--border-light); border-radius: 6px;
            padding: 0.25rem 0.55rem; font-size: 0.72rem; cursor: pointer;
            color: var(--text-muted); transition: all 0.15s;
        }
        .header-btn:hover { background: var(--bg-primary); }
        .context-card {
            background: var(--bg-primary); border: 1px solid var(--border-light);
            border-radius: 8px; padding: 0.5rem 0.75rem; display: flex;
            align-items: center; gap: 0.5rem; font-size: 0.75rem; cursor: pointer;
            text-decoration: none; color: var(--text-main); max-width: 240px;
        }
        .context-card img { width: 32px; height: 32px; object-fit: cover; border-radius: 4px; flex-shrink: 0; }
        .context-card-title { font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        /* Search bar */
        .search-bar {
            padding: 0.5rem 1rem; border-bottom: 1px solid var(--border-light);
            background: var(--bg-secondary); display: none; gap: 0.5rem; align-items: center;
        }
        .search-bar.visible { display: flex; }
        .search-bar input { flex-grow: 1; padding: 0.4rem 0.75rem; border: 1px solid var(--border-light); border-radius: 8px; font-size: 0.8rem; outline: none; }
        .search-results { padding: 0.5rem 1rem; background: #fffbeb; border-bottom: 1px solid var(--border-light); font-size: 0.78rem; display: none; }
        .search-results.visible { display: block; }

        .chat-body {
            flex-grow: 1; overflow-y: auto; padding: 1rem 1.25rem;
            background: var(--bg-secondary); display: flex; flex-direction: column; gap: 0.6rem;
        }

        /* ── Bubbles ─────────────────────────────────────────────────────────── */
        .bubble-row { display: flex; align-items: flex-end; gap: 0.5rem; }
        .bubble-row.sent { justify-content: flex-end; }
        .bubble-row.received { justify-content: flex-start; }

        .bubble {
            max-width: 70%; padding: 0.6rem 0.85rem; border-radius: 14px;
            font-size: 0.875rem; line-height: 1.5; word-break: break-word; position: relative;
        }
        .bubble.sent {
            background: var(--accent-red); color: white;
            border-radius: 14px 14px 3px 14px;
        }
        .bubble.received {
            background: var(--bg-primary); border: 1px solid var(--border-light);
            color: var(--text-main); border-radius: 14px 14px 14px 3px;
        }
        .bubble.deleted { font-style: italic; color: var(--text-muted); background: #f9fafb; border-color: #e5e7eb; }

        /* System messages */
        .system-msg {
            text-align: center; padding: 0.3rem 1rem;
            font-size: 0.72rem; color: var(--text-muted); font-style: italic;
        }
        .system-msg span {
            background: var(--bg-primary); border: 1px solid var(--border-light);
            border-radius: 20px; padding: 0.2rem 0.75rem; display: inline-block;
        }

        /* Load more */
        .load-more-btn {
            text-align: center; padding: 0.5rem;
            font-size: 0.75rem; color: var(--accent-red); cursor: pointer; background: none;
            border: none; width: 100%; border-bottom: 1px solid var(--border-light);
        }

        /* Status indicators */
        .msg-status { font-size: 0.65rem; margin-left: 4px; }
        .msg-edited { font-size: 0.65rem; color: var(--text-muted); margin-left: 4px; font-style: italic; }
        .bubble-time { font-size: 0.65rem; color: var(--text-muted); flex-shrink: 0; padding-bottom: 2px; }

        /* Reactions */
        .msg-reactions { display: flex; flex-wrap: wrap; gap: 0.2rem; margin-top: 0.3rem; }
        .reaction-chip {
            background: var(--bg-primary); border: 1px solid var(--border-light);
            border-radius: 12px; padding: 0.1rem 0.4rem; font-size: 0.75rem; cursor: pointer;
            display: flex; align-items: center; gap: 0.2rem; transition: all 0.15s;
        }
        .reaction-chip:hover { border-color: var(--accent-red); }
        .reaction-chip.own { background: #fef2f2; border-color: #fecaca; }

        /* Hover actions on bubble */
        .bubble-group { display: flex; flex-direction: column; max-width: 72%; }
        .bubble-group.sent { align-items: flex-end; }
        .bubble-group.received { align-items: flex-start; }
        .bubble-actions {
            display: none; gap: 0.25rem; margin-top: 0.2rem;
        }
        .bubble-group:hover .bubble-actions { display: flex; }
        .bubble-act-btn {
            background: var(--bg-primary); border: 1px solid var(--border-light);
            border-radius: 6px; padding: 0.15rem 0.4rem; font-size: 0.65rem;
            cursor: pointer; color: var(--text-muted); transition: all 0.15s;
        }
        .bubble-act-btn:hover { background: var(--accent-red); color: white; border-color: var(--accent-red); }

        /* Inline images */
        .msg-image { max-width: 240px; border-radius: 8px; cursor: pointer; display: block; margin-top: 0.35rem; }

        /* Typing indicator */
        .typing-indicator {
            display: none; font-size: 0.73rem; color: var(--text-muted);
            font-style: italic; padding: 0.2rem 0;
        }
        .typing-indicator.visible { display: flex; align-items: center; gap: 0.4rem; }
        .typing-dots span {
            display: inline-block; width: 5px; height: 5px; border-radius: 50%;
            background: var(--text-muted); animation: bounce 1.2s infinite;
        }
        .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
        .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes bounce { 0%, 80%, 100% { transform: translateY(0); } 40% { transform: translateY(-5px); } }

        /* ── Composer area ───────────────────────────────────────────────────── */
        .starter-suggestions {
            padding: 0.5rem 1rem; border-top: 1px solid var(--border-light);
            display: flex; flex-wrap: wrap; gap: 0.4rem; background: var(--bg-secondary);
        }
        .starter-chip {
            background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 16px;
            padding: 0.3rem 0.75rem; font-size: 0.72rem; cursor: pointer; color: #1d4ed8;
            transition: all 0.15s;
        }
        .starter-chip:hover { background: #dbeafe; }

        .upload-preview-bar {
            padding: 0.5rem 1rem; border-top: 1px solid var(--border-light);
            background: var(--bg-secondary); display: none; align-items: center; gap: 0.75rem;
        }
        .upload-preview-bar.visible { display: flex; }
        .upload-preview-bar img { width: 48px; height: 48px; object-fit: cover; border-radius: 6px; }
        .upload-status { font-size: 0.75rem; color: var(--text-muted); flex-grow: 1; }
        .remove-upload-btn { background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 0.9rem; }

        .templates-dropdown {
            position: absolute; bottom: calc(100% + 4px); right: 0;
            background: var(--bg-primary); border: 1px solid var(--border-light);
            border-radius: 10px; box-shadow: var(--shadow-md); min-width: 220px;
            z-index: 100; display: none; max-height: 200px; overflow-y: auto;
        }
        .templates-dropdown.open { display: block; }
        .template-item {
            padding: 0.55rem 0.9rem; cursor: pointer; font-size: 0.78rem;
            border-bottom: 1px solid var(--border-light); transition: background 0.15s;
        }
        .template-item:last-child { border-bottom: none; }
        .template-item:hover { background: var(--bg-secondary); }
        .template-item .t-label { font-weight: 600; color: var(--text-main); }
        .template-item .t-body  { color: var(--text-muted); font-size: 0.72rem; margin-top: 0.1rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

        .char-counter { font-size: 0.68rem; color: var(--text-muted); align-self: flex-end; margin-bottom: 0.2rem; flex-shrink: 0; }
        .char-counter.warn { color: #d97706; }
        .char-counter.over { color: #dc2626; }

        .chat-input-bar {
            padding: 0.75rem 1rem; border-top: 1px solid var(--border-light);
            background: var(--bg-primary); display: flex; gap: 0.6rem; align-items: center;
            flex-shrink: 0;
        }
        .chat-input-bar input {
            flex-grow: 1; padding: 0.6rem 1rem; border: 1.5px solid var(--border-light);
            border-radius: 20px; font-size: 0.875rem; outline: none; transition: border-color 0.2s;
        }
        .chat-input-bar input:focus { border-color: var(--accent-red); }
        .icon-btn {
            width: 36px; height: 36px; border-radius: 50%; background: var(--bg-secondary);
            border: 1px solid var(--border-light); cursor: pointer; display: flex;
            align-items: center; justify-content: center; color: var(--text-muted);
            font-size: 0.85rem; flex-shrink: 0; transition: all 0.15s; position: relative;
        }
        .icon-btn:hover { background: var(--accent-red); color: white; border-color: var(--accent-red); }
        .send-btn {
            width: 38px; height: 38px; border-radius: 50%; background: var(--accent-red);
            border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
            color: white; font-size: 0.88rem; flex-shrink: 0; transition: background 0.2s;
        }
        .send-btn:hover { background: var(--accent-red-hover, #990000); }
        .send-btn:disabled { background: #d1d5db; cursor: not-allowed; }

        /* ── Empty / status ─────────────────────────────────────────────────── */
        .chat-empty {
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            flex-grow: 1; color: var(--text-muted); padding: 2rem; text-align: center;
        }
        .chat-empty i { font-size: 2.5rem; margin-bottom: 0.75rem; color: #d1d5db; }
        .skeleton {
            background: linear-gradient(90deg, var(--bg-secondary) 25%, #e9eaec 50%, var(--bg-secondary) 75%);
            background-size: 200% 100%; animation: shimmer 1.4s infinite; border-radius: 8px;
        }
        @keyframes shimmer { to { background-position: -200% 0; } }
        .conn-status { font-size: 0.68rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 10px; }
        .conn-online  { background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; }
        .conn-offline { background:#fef2f2; color:#b91c1c; border:1px solid #fecaca; }
    </style>
</head>
<body class="bg-light">

<nav class="navbar">
    <div class="brand-combo">
        <a href="/"><span class="brand">Markee</span></a>
    </div>
    <%- include('_nav') %>
</nav>

<div style="padding: 1rem 5%;">
<div class="messages-layout">

    <!-- ── Threads panel ─────────────────────────────────────────────────────── -->
    <div class="threads-panel">
        <div class="threads-header">
            <h4><i class="fa fa-comments" style="margin-right:0.4rem; color:var(--accent-red);"></i> Messages</h4>
            <span class="conn-status conn-offline" id="conn-badge">Connecting...</span>
        </div>
        <div class="tabs-row">
            <button class="tab-btn active" id="tab-active" data-tab="active">Inbox</button>
            <button class="tab-btn"        id="tab-archived" data-tab="archived">Archived</button>
        </div>
        <div class="thread-list" id="thread-list">
            <div id="thread-skeleton">
                <% for(let i=0;i<5;i++) { %>
                <div style="padding:0.75rem 1rem; border-bottom:1px solid var(--border-light); display:flex; gap:0.65rem; align-items:center;">
                    <div class="skeleton" style="width:36px; height:36px; border-radius:50%; flex-shrink:0;"></div>
                    <div style="flex-grow:1;">
                        <div class="skeleton" style="height:11px; width:90px; margin-bottom:0.3rem;"></div>
                        <div class="skeleton" style="height:9px; width:140px;"></div>
                    </div>
                </div>
                <% } %>
            </div>
            <div id="thread-content" style="display:none;"></div>
        </div>
    </div>

    <!-- ── Chat panel ────────────────────────────────────────────────────────── -->
    <div class="chat-panel" id="chat-panel">

        <div class="chat-header" id="chat-header">
            <div class="thread-avatar" id="chat-avatar" style="background:var(--bg-secondary);">
                <i class="fa fa-user"></i>
            </div>
            <h4 id="chat-title">Select a conversation</h4>
            <div class="header-actions" id="header-actions" style="display:none;">
                <button class="header-btn" id="search-toggle-btn" title="Search messages"><i class="fa fa-search"></i></button>
                <button class="header-btn" id="export-btn" title="Export conversation"><i class="fa fa-download"></i></button>
                <button class="header-btn" id="archive-btn" title="Archive thread"><i class="fa fa-archive"></i></button>
                <button class="header-btn" id="pin-btn" title="Pin thread"><i class="fa fa-thumbtack"></i></button>
            </div>
        </div>

        <!-- Context card (product/order reference) -->
        <div id="context-card-container" style="padding: 0.5rem 1rem; border-bottom: 1px solid var(--border-light); background: var(--bg-secondary); display: none;"></div>

        <!-- In-thread search bar -->
        <div class="search-bar" id="search-bar">
            <i class="fa fa-search" style="color:var(--text-muted); font-size:0.8rem;"></i>
            <input type="text" id="search-input" placeholder="Search messages...">
            <button class="header-btn" id="search-close-btn"><i class="fa fa-times"></i></button>
        </div>
        <div class="search-results" id="search-results"></div>

        <!-- Load earlier messages -->
        <button class="load-more-btn" id="load-more-btn" style="display:none;">
            <i class="fa fa-chevron-up" style="margin-right:0.3rem;"></i> Load earlier messages
        </button>

        <div class="chat-body" id="chat-body">
            <div class="chat-empty" id="chat-empty">
                <i class="fa fa-comment-dots"></i>
                <div style="font-weight:600; margin-bottom:0.35rem;">No conversation open</div>
                <div class="small">Select a thread or start one from a product page.</div>
            </div>
        </div>

        <!-- Typing indicator -->
        <div class="typing-indicator" id="typing-indicator">
            <div class="typing-dots"><span></span><span></span><span></span></div>
            <span id="typing-label">typing...</span>
        </div>

        <!-- Starter suggestions (shown when thread has 0 messages) -->
        <div class="starter-suggestions" id="starter-suggestions" style="display:none;"></div>

        <!-- Image upload preview -->
        <div class="upload-preview-bar" id="upload-preview-bar">
            <img id="upload-preview-img" src="" alt="Preview">
            <div class="upload-status" id="upload-status">Ready to send</div>
            <button class="remove-upload-btn" id="remove-upload-btn" title="Remove image"><i class="fa fa-times"></i></button>
        </div>

        <!-- Quick-reply templates (sellers only) -->
        <div style="position:relative; display:none;" id="templates-wrapper">
            <div class="templates-dropdown" id="templates-dropdown"></div>
        </div>

        <div class="chat-input-bar">
            <div id="char-counter" class="char-counter" style="display:none;"></div>

            <!-- Attachment button -->
            <button class="icon-btn" id="attach-btn" title="Attach image" disabled>
                <i class="fa fa-paperclip"></i>
            </button>
            <input type="file" id="file-input" accept="image/*" style="display:none;">

            <!-- Templates button (sellers only) -->
            <button class="icon-btn" id="templates-btn" style="display:none;" title="Quick replies">
                <i class="fa fa-bolt"></i>
            </button>

            <input type="text" id="msg-input" placeholder="Type a message..." maxlength="1001" disabled>

            <button class="send-btn" id="send-btn" disabled title="Send">
                <i class="fa fa-paper-plane"></i>
            </button>
        </div>
    </div>

</div>
</div>

<script>
(function() {
'use strict';

// ═══════════════════════════════════════════════════════════════════════════════
// SECTION A: State Variables + Initialization
// ═══════════════════════════════════════════════════════════════════════════════

let token = localStorage.getItem('access_token');
if (!token) {
    window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search));
}

function parseJwt(t) {
    try {
        var p = JSON.parse(atob(t.split('.')[1]));
        if (p.exp && p.exp * 1000 < Date.now()) {
            localStorage.removeItem('access_token');
            localStorage.removeItem('refresh_token');
            return null;
        }
        return p;
    } catch (err) {
        console.error('[MSG] Failed to parse JWT:', err.message);
        return null;
    }
}

var user = parseJwt(token);
if (!user) {
    window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search));
}

// Core state
var socket              = null;
var currentThreadId     = null;
var currentThread       = null;
var isConnected         = false;
var activeTab           = 'active';
var pendingUploadUrl    = null;
var uploadInProgress    = false;
var typingTimer         = null;
var typingActive        = false;
var typingHideTimer     = null;
var reconnectTs         = null;
var oldestMsgTs         = null;
var templates           = [];
var searchDebounce      = null;

// FIX #1: AbortController for in-flight requests
var currentAbortController = null;

// FIX #3: Message deduplication
var renderedMessageIds = new Set();

// FIX #5: Interval management
var activeIntervals = [];

function startInterval(fn, ms) {
    var id = setInterval(fn, ms);
    activeIntervals.push(id);
    return id;
}

function clearAllIntervals() {
    activeIntervals.forEach(clearInterval);
    activeIntervals.length = 0;
}

// Starter suggestions
var STARTER_SUGGESTIONS = {
    product: ["Is this available in a different size?", "What is the shipping time?", "Do you offer bulk pricing?"],
    order:   ["I have a question about my order.", "Can I modify my order?", "I'd like to request a return."],
    general: []
};

// Emoji reactions
var EMOJIS = ['\uD83D\uDC4D', '\u2764\uFE0F', '\uD83D\uDE2E'];


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION B: Socket.io Connection + All Event Handlers
// ═══════════════════════════════════════════════════════════════════════════════

function connectSocket() {
    if (typeof io === 'undefined') {
        updateConnBadge(false, 'Socket unavailable');
        return;
    }

    socket = io({
        auth: function(cb) { cb({ token: localStorage.getItem('access_token') || token }); },
        transports: ['polling', 'websocket']
    });

    // --- connect ---
    socket.on('connect', function() {
        isConnected = true;
        updateConnBadge(true, 'Online');
        enableInput(true);
        loadThreads();
        if (currentThreadId && reconnectTs) {
            fetchMissedMessages();
        }
    });

    // --- disconnect ---
    socket.on('disconnect', function() {
        isConnected = false;
        reconnectTs = new Date().toISOString();
        updateConnBadge(false, 'Offline');
        enableInput(false);
    });

    // --- connect_error ---
    socket.on('connect_error', function() {
        updateConnBadge(false, 'Offline');
    });

    // --- message_sent ---
    socket.on('message_sent', function(msg) {
        appendBubble(msg, true);
        scrollToBottomIfNeeded();
    });

    // --- new_message ---
    socket.on('new_message', function(msg) {
        if (msg.threadId === currentThreadId) {
            appendBubble(msg, false);
            scrollToBottomIfNeeded();
            markRead(currentThreadId);
        } else {
            showToast('New message received!', 'info');
            loadThreads();
        }
        refreshUnreadBadge();
    });

    // --- messages_read ---
    socket.on('messages_read', function(data) {
        if (data.threadId !== currentThreadId) return;
        var chatBody = document.getElementById('chat-body');
        if (!chatBody) return;
        // Remove existing read receipts, pin one after last sent bubble
        chatBody.querySelectorAll('.read-receipt').forEach(function(el) { el.remove(); });
        var sentRows = Array.from(chatBody.querySelectorAll('.bubble-row.sent'));
        if (sentRows.length) {
            var receipt = document.createElement('div');
            receipt.className = 'read-receipt';
            receipt.style.cssText = 'text-align:right; font-size:0.65rem; color:var(--text-muted); margin-top:-0.25rem; margin-bottom:0.35rem; padding-right:0.25rem;';
            receipt.textContent = 'Read';
            sentRows[sentRows.length - 1].insertAdjacentElement('afterend', receipt);
        }
    });

    // --- message_delivered ---
    socket.on('message_delivered', function() {
        /* Future: delivery checkmarks */
    });

    // --- message_edited ---
    socket.on('message_edited', function(msg) {
        if (msg.threadId === currentThreadId) {
            updateBubbleEdited(msg);
        }
    });

    // --- message_deleted ---
    socket.on('message_deleted', function(data) {
        updateBubbleDeleted(data.messageId);
    });

    // --- reaction_added ---
    socket.on('reaction_added', function(data) {
        updateBubbleReactions(data.messageId, data.reactions);
    });

    // --- system_message ---
    socket.on('system_message', function(msg) {
        if (msg.threadId === currentThreadId) {
            appendSystemMsg(msg.body);
            scrollToBottomIfNeeded();
        }
        loadThreads();
    });

    // --- typing_start ---
    socket.on('typing_start', function(data) {
        if (data.threadId === currentThreadId) {
            showTypingIndicator(true);
        }
    });

    // --- typing_stop ---
    socket.on('typing_stop', function(data) {
        if (data.threadId === currentThreadId) {
            showTypingIndicator(false);
        }
    });

    // --- unread_count_update ---
    socket.on('unread_count_update', function(data) {
        updateMsgNavBadge(data.total);
    });

    // --- rate_limited ---
    socket.on('rate_limited', function() {
        showToast('Sending too fast — slow down.', 'error');
    });

    // --- message_error ---
    socket.on('message_error', function(err) {
        showToast('Message failed: ' + (err.error || 'Unknown error'), 'error');
    });
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION C: API Functions (apiFetch wrapper with AbortController + timeout)
// ═══════════════════════════════════════════════════════════════════════════════

// FIX #6: apiFetch with timeout (10s default)
function apiFetch(url, opts) {
    opts = opts || {};
    var timeout = opts.timeout || 10000;
    var controller = opts.signal ? undefined : new AbortController();
    var signal = opts.signal || (controller ? controller.signal : undefined);
    var timer = controller ? setTimeout(function() { controller.abort(); }, timeout) : null;

    var headers = { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' };
    if (opts.headers) {
        var k;
        for (k in opts.headers) {
            if (opts.headers.hasOwnProperty(k)) headers[k] = opts.headers[k];
        }
    }

    var fetchOpts = {};
    var key;
    for (key in opts) {
        if (opts.hasOwnProperty(key) && key !== 'timeout' && key !== 'headers') {
            fetchOpts[key] = opts[key];
        }
    }
    fetchOpts.headers = headers;
    fetchOpts.signal = signal;

    return fetch(url, fetchOpts).finally(function() {
        if (timer) clearTimeout(timer);
    });
}

// Upload fetch (FormData, no JSON content-type)
function apiUploadFetch(url, formData) {
    var controller = new AbortController();
    var timer = setTimeout(function() { controller.abort(); }, 30000);
    return fetch(url, {
        method: 'POST',
        headers: { 'Authorization': 'Bearer ' + token },
        body: formData,
        signal: controller.signal
    }).finally(function() { clearTimeout(timer); });
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION D: Thread Management
// ═══════════════════════════════════════════════════════════════════════════════

async function loadThreads() {
    try {
        var isArchived = activeTab === 'archived';
        var res = await apiFetch('/api/messages/threads?archived=' + isArchived);
        if (res.status === 401) { window.location.replace('/login'); return; }
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        var threads = data.threads || data;

        document.getElementById('thread-skeleton').style.display = 'none';
        var content = document.getElementById('thread-content');
        content.style.display = 'block';

        if (!threads.length) {
            content.innerHTML =
                '<div style="padding:2rem; text-align:center; color:var(--text-muted);">' +
                    '<i class="fa fa-comment-slash" style="font-size:1.5rem; margin-bottom:0.5rem; display:block;"></i>' +
                    '<div class="small">' + (isArchived ? 'No archived conversations.' : 'No conversations yet.') + '</div>' +
                    (!isArchived ? '<div class="small">Start one from a product page.</div>' : '') +
                '</div>';
            return;
        }

        content.innerHTML = threads.map(function(t) { return renderThreadItem(t); }).join('');
    } catch (err) {
        console.error('[MSG] loadThreads failed:', err.message);
        document.getElementById('thread-skeleton').style.display = 'none';
        document.getElementById('thread-content').innerHTML =
            '<div class="text-center p-4 text-muted small">Failed to load threads.</div>';
    }
}

function renderThreadItem(t) {
    var ctx = t.context || {};
    var contextType = ctx.type || 'general';
    var badgeClass  = 'badge-' + contextType;
    var badgeLabel  = contextType;

    // Participant display name: the "other" participant
    var otherMeta = (t.participantMeta || []).find(function(m) {
        return m.userId && m.userId.toString() !== user.sub;
    });
    var displayName = (otherMeta && otherMeta.displayName) ? otherMeta.displayName : ('\u2026' + (t.threadId || '').slice(-6));

    var isActive  = t.threadId === currentThreadId;
    var isUrgent  = t.priority === 'urgent';
    var isPinned  = t.pinned;
    var unread    = t.unreadCount || 0;
    var preview   = t.lastMessage || '\u2014';
    var isSystem  = t.lastMessageType === 'system';
    var subtitle  = ctx.refTitle || '';

    var cls = 'thread-item' + (isActive ? ' active' : '') + (isUrgent ? ' urgent' : '') + (isPinned ? ' pinned' : '');

    return '<div class="' + cls + '" id="thread-item-' + escapeHtml(t.threadId) + '"' +
         ' data-thread-id="' + escapeHtml(t.threadId) + '">' +
        '<div class="thread-avatar" style="background:' + stringToColor(t.threadId) + '; color:white;">' +
            escapeHtml(displayName.slice(0,2).toUpperCase()) +
        '</div>' +
        '<div class="thread-meta">' +
            '<div style="display:flex; align-items:center; gap:0.3rem;">' +
                '<span class="context-badge ' + badgeClass + '">' + badgeLabel + '</span>' +
            '</div>' +
            '<div class="thread-name">' + escapeHtml(displayName) + '</div>' +
            (subtitle ? '<div class="thread-subtitle">' + escapeHtml(subtitle) + '</div>' : '') +
            '<div class="thread-preview' + (isSystem ? ' system-preview' : '') + '">' + escapeHtml(preview) + '</div>' +
        '</div>' +
        (unread > 0 ? '<div class="unread-badge">' + (unread > 99 ? '99+' : unread) + '</div>' : '') +
        '<div class="thread-actions">' +
            '<button class="thread-action-btn" data-archive-thread="' + escapeHtml(t.threadId) + '" title="Archive">' +
                '<i class="fa fa-archive"></i>' +
            '</button>' +
            '<button class="thread-action-btn" data-pin-thread="' + escapeHtml(t.threadId) + '" title="Pin">' +
                '<i class="fa fa-thumbtack"></i>' +
            '</button>' +
        '</div>' +
    '</div>';
}

// FIX #1 + #2: AbortController on openThread, timer cleanup on thread switch
async function openThread(threadId) {
    // Cancel any in-flight request from a previous openThread
    if (currentAbortController) {
        currentAbortController.abort();
    }
    currentAbortController = new AbortController();
    var signal = currentAbortController.signal;

    // FIX #2: Clear stale timers on thread switch
    clearTimeout(typingTimer);
    clearTimeout(typingHideTimer);
    typingActive = false;

    // FIX #3: Clear deduplication set
    clearRenderedMessages();

    // Update UI selection
    document.querySelectorAll('.thread-item').forEach(function(el) { el.classList.remove('active'); });
    var ti = document.getElementById('thread-item-' + threadId);
    if (ti) ti.classList.add('active');

    currentThreadId = threadId;
    var headerActions = document.getElementById('header-actions');
    if (headerActions) headerActions.style.display = 'flex';
    var chatEmpty = document.getElementById('chat-empty');
    if (chatEmpty) chatEmpty.style.display = 'none';
    enableInput(isConnected);

    // Join thread room for reactions/edits
    if (socket) socket.emit('join_thread', threadId);

    // Reset state
    pendingUploadUrl = null;
    oldestMsgTs      = null;
    var msgInput = document.getElementById('msg-input');
    if (msgInput) msgInput.value = '';
    hideUploadPreview();
    document.getElementById('starter-suggestions').style.display = 'none';
    document.getElementById('search-bar').classList.remove('visible');
    document.getElementById('search-results').classList.remove('visible');
    hideTypingIndicator();

    document.getElementById('chat-body').innerHTML =
        '<div class="chat-empty" id="chat-empty">' +
            '<i class="fa fa-spinner fa-spin"></i>' +
            '<div class="small" style="margin-top:0.5rem;">Loading messages...</div>' +
        '</div>';

    try {
        var res = await apiFetch('/api/messages/thread/' + threadId, { signal: signal });

        // FIX #1: Check if aborted after await
        if (signal.aborted) return;

        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();

        // FIX #1: Check abort again after JSON parse
        if (signal.aborted) return;

        var thread = data.thread;
        var messages = data.messages;
        var hasMore = data.hasMore;

        currentThread = thread;
        enableInput(isConnected);
        renderThreadHeader(thread);
        renderContextCard(thread);

        // Load templates for sellers
        if (user.storeId) loadTemplates();

        var chatBody = document.getElementById('chat-body');
        chatBody.innerHTML = '';

        if (hasMore) {
            document.getElementById('load-more-btn').style.display = 'block';
        } else {
            document.getElementById('load-more-btn').style.display = 'none';
        }

        if (!messages.length) {
            var sug = (thread.context && thread.context.type && STARTER_SUGGESTIONS[thread.context.type]) || [];
            if (sug.length) renderStarterSuggestions(sug);
        } else {
            messages.forEach(function(m) {
                if (m.type === 'system') {
                    appendSystemMsg(m.body);
                } else {
                    appendBubble(m, m.senderId && m.senderId.toString() === user.sub);
                }
            });
            if (messages.length) oldestMsgTs = messages[0].createdAt;
        }

        scrollToBottom();
        markRead(threadId);
        refreshUnreadBadge();
        loadPresence(thread);

    } catch (err) {
        if (err.name === 'AbortError') return; // Thread switch cancelled this request
        console.error('[MSG] openThread failed:', err.message);
        document.getElementById('chat-body').innerHTML =
            '<div class="chat-empty" id="chat-empty">' +
                '<i class="fa fa-exclamation-triangle" style="color:var(--accent-red);"></i>' +
                '<div class="small">Failed to load messages.</div>' +
            '</div>';
    }
}

async function loadMoreMessages() {
    if (!currentThreadId || !oldestMsgTs) return;
    var btn = document.getElementById('load-more-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>';
    try {
        var res = await apiFetch('/api/messages/thread/' + currentThreadId + '?before=' + encodeURIComponent(oldestMsgTs));
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        var messages = data.messages;
        var hasMore = data.hasMore;
        var chatBody = document.getElementById('chat-body');
        var prevScrollH = chatBody.scrollHeight;
        messages.reverse().forEach(function(m) {
            var el = m.type === 'system' ? makeSystemEl(m.body) : makeBubbleEl(m, m.senderId && m.senderId.toString() === user.sub);
            chatBody.insertBefore(el, chatBody.firstChild);
        });
        if (messages.length) oldestMsgTs = messages[0].createdAt;
        chatBody.scrollTop = chatBody.scrollHeight - prevScrollH;
        btn.disabled = false;
        btn.innerHTML = '<i class="fa fa-chevron-up" style="margin-right:0.3rem;"></i> Load earlier messages';
        if (!hasMore) btn.style.display = 'none';
    } catch (err) {
        console.error('[MSG] loadMoreMessages failed:', err.message);
        btn.disabled = false;
        btn.innerHTML = '<i class="fa fa-chevron-up" style="margin-right:0.3rem;"></i> Load earlier messages';
    }
}

function renderThreadHeader(thread) {
    var otherMeta = (thread.participantMeta || []).find(function(m) {
        return m.userId && m.userId.toString() !== user.sub;
    });
    var displayName = (otherMeta && otherMeta.displayName) ? otherMeta.displayName : ('\u2026' + (thread._id || '').slice(-6));
    var avatar = document.getElementById('chat-avatar');
    avatar.style.background = stringToColor(thread._id);
    avatar.style.color      = 'white';
    avatar.textContent      = displayName.slice(0, 2).toUpperCase();
    document.getElementById('chat-title').textContent = displayName;

    // Pin/archive button state
    var isPinned   = (thread.pinnedBy   || []).some(function(p) { return p.toString() === user.sub; });
    var isArchived = (thread.archivedBy || []).some(function(p) { return p.toString() === user.sub; });
    document.getElementById('pin-btn').title     = isPinned   ? 'Unpin thread'  : 'Pin thread';
    document.getElementById('archive-btn').title = isArchived ? 'Unarchive'     : 'Archive thread';
}

function renderContextCard(thread) {
    var container = document.getElementById('context-card-container');
    var ctx = thread.context;
    if (!ctx || ctx.type === 'general') { container.style.display = 'none'; return; }

    var link  = ctx.type === 'order' ? '/orders/' + ctx.refId : '/product/' + ctx.refId;
    var label = ctx.refTitle || (ctx.type === 'order' ? 'Order' : 'Product');
    var imgHtml = ctx.refImage
        ? '<img src="' + escapeHtml(ctx.refImage) + '" alt="" onerror="this.style.display=\'none\'">'
        : '<i class="fa fa-' + (ctx.type === 'order' ? 'shopping-bag' : 'box') + '" style="color:var(--accent-red);"></i>';

    container.innerHTML =
        '<a href="' + escapeHtml(link) + '" class="context-card" target="_blank">' +
            imgHtml +
            '<div>' +
                '<div style="font-size:0.65rem; color:var(--text-muted); text-transform:uppercase;">' + ctx.type + '</div>' +
                '<div class="context-card-title">' + escapeHtml(label) + '</div>' +
            '</div>' +
            '<i class="fa fa-external-link-alt" style="font-size:0.65rem; color:var(--text-muted); margin-left:auto;"></i>' +
        '</a>';
    container.style.display = 'block';
}

async function loadPresence(thread) {
    var otherMeta = (thread.participantMeta || []).find(function(m) {
        return m.userId && m.userId.toString() !== user.sub;
    });
    if (!otherMeta) return;
    try {
        var res = await apiFetch('/api/messages/presence/' + otherMeta.userId);
        if (!res.ok) return;
        var data = await res.json();
        var avatar = document.getElementById('chat-avatar');
        var dot = avatar.querySelector('.online-dot');
        if (data.online && !dot) {
            var d = document.createElement('div');
            d.className = 'online-dot';
            avatar.appendChild(d);
        } else if (!data.online && dot) {
            dot.remove();
        }
    } catch (err) {
        console.error('[MSG] loadPresence failed:', err.message);
    }
}

function switchTab(tab) {
    activeTab = tab;
    document.getElementById('tab-active').classList.toggle('active', tab === 'active');
    document.getElementById('tab-archived').classList.toggle('active', tab === 'archived');
    loadThreads();
}

function renderStarterSuggestions(suggestions) {
    var container = document.getElementById('starter-suggestions');
    container.innerHTML = suggestions.map(function(s) {
        return '<button class="starter-chip" data-suggestion="' + escapeHtml(s) + '">' + escapeHtml(s) + '</button>';
    }).join('');
    container.style.display = 'flex';
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION E: Message Management
// ═══════════════════════════════════════════════════════════════════════════════

function sendMessage() {
    if (!socket || !isConnected) { showToast('Not connected.', 'error'); return; }
    if (!currentThread) { showToast('Open a conversation first.', 'error'); return; }
    if (uploadInProgress) { showToast('Wait for upload to finish.', 'error'); return; }

    var input = document.getElementById('msg-input');
    var body  = input.value.trim();
    if (!body && !pendingUploadUrl) return;
    if (body.length > 1000) { showToast('Message too long (max 1000 characters).', 'error'); return; }

    var otherMeta = (currentThread.participantMeta || []).find(function(m) {
        return m.userId && m.userId.toString() !== user.sub;
    });
    var recipientId = otherMeta ? otherMeta.userId : null;
    if (!recipientId) { showToast('Cannot determine recipient.', 'error'); return; }

    var ctx = currentThread.context;
    socket.emit('send_message', {
        recipientId: recipientId,
        body: body,
        contextType:    (ctx && ctx.type)     || 'general',
        refId:          (ctx && ctx.refId)    || '',
        refTitle:       (ctx && ctx.refTitle) || '',
        attachmentUrl:  pendingUploadUrl || '',
        attachmentType: pendingUploadUrl ? 'image' : ''
    });

    input.value = '';
    onInputChange();
    removeUpload();
    stopTypingEmit();
    document.getElementById('starter-suggestions').style.display = 'none';
}

// FIX #3: Message deduplication
function appendBubble(msg, isSent) {
    if (renderedMessageIds.has(msg._id)) return;
    renderedMessageIds.add(msg._id);

    var chatBody = document.getElementById('chat-body');
    var empty = chatBody.querySelector('.chat-empty');
    if (empty) empty.remove();
    chatBody.appendChild(makeBubbleEl(msg, isSent));
}

function makeBubbleEl(msg, isSent) {
    var row = document.createElement('div');
    row.className = 'bubble-row ' + (isSent ? 'sent' : 'received');
    row.setAttribute('data-msg-id', msg._id);

    var group = document.createElement('div');
    group.className = 'bubble-group ' + (isSent ? 'sent' : 'received');
    group.setAttribute('data-msg-id', msg._id);

    var bubble = document.createElement('div');
    var isDeleted = msg.deleted;

    if (isDeleted) {
        bubble.className = 'bubble deleted';
        bubble.innerHTML = '<i class="fa fa-ban" style="margin-right:0.3rem;font-size:0.75rem;"></i>This message was removed.';
    } else {
        bubble.className = 'bubble ' + (isSent ? 'sent' : 'received');
        var innerHtml = '';
        if (msg.attachmentUrl && msg.attachmentType === 'image') {
            innerHtml += '<img src="' + escapeHtml(msg.attachmentUrl) + '" class="msg-image" data-img-url="' + escapeHtml(msg.attachmentUrl) + '" alt="Image">';
        } else if (msg.attachmentUrl) {
            innerHtml += '<a href="' + escapeHtml(msg.attachmentUrl) + '" target="_blank" style="color:inherit;">Attachment</a>';
        }
        if (msg.body) innerHtml += escapeHtml(msg.body);
        if (msg.edited) innerHtml += '<span class="msg-edited"> (edited)</span>';
        bubble.innerHTML = innerHtml;
    }

    group.appendChild(bubble);

    // Reactions container
    var reactionDiv = document.createElement('div');
    reactionDiv.className = 'msg-reactions';
    reactionDiv.setAttribute('data-msg-id', msg._id);
    if (msg.reactions && msg.reactions.length) {
        renderReactionsInto(reactionDiv, msg._id, msg.reactions);
    }
    group.appendChild(reactionDiv);

    // FIX #9: Hover actions use data attributes (event delegation), not inline onclick
    if (!isDeleted) {
        var actions = document.createElement('div');
        actions.className = 'bubble-actions';
        var actionsHtml = EMOJIS.map(function(e) {
            return '<button class="bubble-act-btn" data-react-msg="' + msg._id + '" data-emoji="' + e + '">' + e + '</button>';
        }).join('');
        if (isSent) {
            actionsHtml += '<button class="bubble-act-btn" data-edit-msg="' + msg._id + '"><i class="fa fa-pen"></i></button>';
            actionsHtml += '<button class="bubble-act-btn" data-delete-msg="' + msg._id + '" style="color:#dc2626;"><i class="fa fa-trash"></i></button>';
        }
        actions.innerHTML = actionsHtml;
        group.appendChild(actions);
    }

    var time = document.createElement('span');
    time.className = 'bubble-time';
    time.textContent = formatTime(msg.createdAt);

    if (isSent) {
        row.appendChild(time);
        row.appendChild(group);
    } else {
        row.appendChild(group);
        row.appendChild(time);
    }

    return row;
}

function appendSystemMsg(body) {
    var chatBody = document.getElementById('chat-body');
    var empty = chatBody.querySelector('.chat-empty');
    if (empty) empty.remove();
    chatBody.appendChild(makeSystemEl(body));
}

function makeSystemEl(body) {
    var el = document.createElement('div');
    el.className = 'system-msg';
    el.innerHTML = '<span>' + escapeHtml(body) + '</span>';
    return el;
}

function clearRenderedMessages() {
    renderedMessageIds.clear();
}

// ── Reaction UI ──────────────────────────────────────────────────────────────
function renderReactionsInto(container, msgId, reactions) {
    var groups = {};
    reactions.forEach(function(r) {
        if (!groups[r.emoji]) groups[r.emoji] = { count: 0, mine: false };
        groups[r.emoji].count++;
        if (r.userId && r.userId.toString() === user.sub) groups[r.emoji].mine = true;
    });
    container.innerHTML = Object.entries(groups).map(function(entry) {
        var emoji = entry[0];
        var info = entry[1];
        return '<span class="reaction-chip' + (info.mine ? ' own' : '') + '" data-react-msg="' + msgId + '" data-emoji="' + emoji + '">' +
            emoji + (info.count > 1 ? ' ' + info.count : '') +
        '</span>';
    }).join('');
}

function updateBubbleReactions(msgId, reactions) {
    var containers = document.querySelectorAll('.msg-reactions[data-msg-id="' + msgId + '"]');
    containers.forEach(function(c) { renderReactionsInto(c, msgId, reactions); });
}

async function reactToMessage(msgId, emoji) {
    try {
        var res = await apiFetch('/api/messages/' + msgId + '/react', {
            method: 'POST',
            body: JSON.stringify({ emoji: emoji })
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        updateBubbleReactions(msgId, data.reactions || data);
    } catch (err) {
        console.error('[MSG] reactToMessage failed:', err.message);
        showToast('Failed to react.', 'error');
    }
}

// ── Edit / Delete ────────────────────────────────────────────────────────────
async function editMessage(msgId) {
    var newBody = prompt('Edit message (within 5 minutes of sending):');
    if (!newBody) return;
    try {
        var res = await apiFetch('/api/messages/' + msgId, {
            method: 'PUT',
            body: JSON.stringify({ body: newBody })
        });
        if (!res.ok) {
            var errData = await res.json().catch(function() { return {}; });
            throw new Error(errData.error || 'Failed');
        }
    } catch (err) {
        console.error('[MSG] editMessage failed:', err.message);
        showToast(err.message || 'Edit failed.', 'error');
    }
}

async function deleteMessage(msgId) {
    if (!confirm('Remove this message?')) return;
    try {
        var res = await apiFetch('/api/messages/' + msgId, { method: 'DELETE' });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        updateBubbleDeleted(msgId);
    } catch (err) {
        console.error('[MSG] deleteMessage failed:', err.message);
        showToast('Delete failed.', 'error');
    }
}

function updateBubbleEdited(msg) {
    var groups = document.querySelectorAll('.bubble-group[data-msg-id="' + msg._id + '"]');
    groups.forEach(function(g) {
        var bubble = g.querySelector('.bubble');
        if (!bubble) return;
        bubble.innerHTML = escapeHtml(msg.body) + '<span class="msg-edited"> (edited)</span>';
    });
}

function updateBubbleDeleted(msgId) {
    var groups = document.querySelectorAll('.bubble-group[data-msg-id="' + msgId + '"]');
    groups.forEach(function(g) {
        var bubble = g.querySelector('.bubble');
        if (!bubble) return;
        bubble.className = 'bubble deleted';
        bubble.innerHTML = '<i class="fa fa-ban" style="margin-right:0.3rem;font-size:0.75rem;"></i>This message was removed.';
        var actions = g.querySelector('.bubble-actions');
        if (actions) actions.remove();
    });
}

async function fetchMissedMessages() {
    if (!currentThreadId || !reconnectTs) return;
    try {
        var res = await apiFetch('/api/messages/thread/' + currentThreadId + '/since?timestamp=' + encodeURIComponent(reconnectTs));
        if (!res.ok) return;
        var msgs = await res.json();
        msgs.forEach(function(m) {
            appendBubble(m, m.senderId && m.senderId.toString() === user.sub);
        });
        if (msgs.length) scrollToBottomIfNeeded();
    } catch (err) {
        console.error('[MSG] fetchMissedMessages failed:', err.message);
    }
    reconnectTs = null;
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION F: UI Helpers
// ═══════════════════════════════════════════════════════════════════════════════

// FIX #4: Smart auto-scroll — only scroll if user is within 100px of bottom
function shouldAutoScroll() {
    var b = document.getElementById('chat-body');
    return b.scrollHeight - b.scrollTop - b.clientHeight < 100;
}

function scrollToBottom() {
    var b = document.getElementById('chat-body');
    b.scrollTop = b.scrollHeight;
}

function scrollToBottomIfNeeded() {
    if (shouldAutoScroll()) {
        scrollToBottom();
    }
}

function showToast(msg, type) {
    if (typeof window.showToast === 'function') {
        window.showToast(msg, type);
    } else {
        console.log('[MSG Toast]', type, msg);
    }
}

// FIX #8: String-based escapeHtml (not DOM-based)
function escapeHtml(str) {
    return (str || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
}

function formatTime(ts) {
    if (!ts) return '';
    return new Date(ts).toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' });
}

function stringToColor(str) {
    var hash = 0;
    var s = str || '';
    for (var i = 0; i < s.length; i++) {
        hash = s.charCodeAt(i) + ((hash << 5) - hash);
    }
    var colors = ['#cc0000','#1d4ed8','#15803d','#6d28d9','#0e7490','#b45309'];
    return colors[Math.abs(hash) % colors.length];
}

function updateConnBadge(online, label) {
    var b = document.getElementById('conn-badge');
    if (!b) return;
    b.textContent = label;
    b.className   = 'conn-status ' + (online ? 'conn-online' : 'conn-offline');
}

function enableInput(on) {
    var noThread = !currentThread;
    document.getElementById('msg-input').disabled  = noThread;
    document.getElementById('send-btn').disabled   = noThread || !on;
    document.getElementById('attach-btn').disabled = noThread;
}

// Nav badge
function updateMsgNavBadge(count) {
    var badge = document.getElementById('msg-nav-badge');
    if (!badge) return;
    if (count > 0) {
        badge.textContent = count > 99 ? '99+' : count;
        badge.style.display = 'flex';
    } else {
        badge.style.display = 'none';
    }
}

async function refreshUnreadBadge() {
    try {
        var res = await apiFetch('/api/messages/unread-count');
        if (!res.ok) return;
        var data = await res.json();
        updateMsgNavBadge(data.total);
    } catch (err) {
        console.error('[MSG] refreshUnreadBadge failed:', err.message);
    }
}

async function markRead(threadId) {
    try {
        await apiFetch('/api/messages/thread/' + threadId + '/read', { method: 'POST' });
    } catch (err) {
        console.error('[MSG] markRead failed:', err.message);
    }
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION G: Upload Handling
// ═══════════════════════════════════════════════════════════════════════════════

function handleFileSelect(event) {
    var file = event.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(e) {
        document.getElementById('upload-preview-img').src = e.target.result;
        document.getElementById('upload-preview-bar').classList.add('visible');
        document.getElementById('upload-status').textContent = 'Uploading...';
        document.getElementById('send-btn').disabled = true;
    };
    reader.readAsDataURL(file);
    uploadImage(file);
}

async function uploadImage(file) {
    uploadInProgress = true;
    try {
        var formData = new FormData();
        formData.append('image', file);
        var res = await apiUploadFetch('/api/messages/upload', formData);
        if (!res.ok) {
            var errData = await res.json().catch(function() { return {}; });
            throw new Error(errData.error || 'HTTP ' + res.status);
        }
        var data = await res.json();
        pendingUploadUrl = data.url;
        document.getElementById('upload-status').textContent = 'Ready (' + data.sizeKb + 'KB)';
        document.getElementById('send-btn').disabled = !isConnected;
    } catch (err) {
        console.error('[MSG] uploadImage failed:', err.message);
        showToast('Upload failed: ' + err.message, 'error');
        removeUpload();
    } finally {
        uploadInProgress = false;
        document.getElementById('file-input').value = '';
    }
}

function removeUpload() {
    pendingUploadUrl = null;
    document.getElementById('upload-preview-bar').classList.remove('visible');
    document.getElementById('upload-preview-img').src = '';
    document.getElementById('file-input').value = '';
}

function hideUploadPreview() { removeUpload(); }


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION H: Search + Export
// ═══════════════════════════════════════════════════════════════════════════════

function toggleSearch() {
    var bar = document.getElementById('search-bar');
    var results = document.getElementById('search-results');
    var visible = bar.classList.contains('visible');
    bar.classList.toggle('visible', !visible);
    if (visible) {
        results.classList.remove('visible');
    } else {
        document.getElementById('search-input').focus();
    }
}

function debounceSearch() {
    clearTimeout(searchDebounce);
    searchDebounce = setTimeout(runSearch, 300);
}

async function runSearch() {
    var q = document.getElementById('search-input').value.trim();
    var results = document.getElementById('search-results');
    if (!q || !currentThreadId) { results.classList.remove('visible'); return; }
    try {
        var res = await apiFetch('/api/messages/thread/' + currentThreadId + '/search?q=' + encodeURIComponent(q));
        if (!res.ok) return;
        var data = await res.json();
        var items = data.results || data;
        if (!items.length) {
            results.innerHTML = '<span style="color:var(--text-muted);">No results.</span>';
        } else {
            results.innerHTML = items.map(function(item) {
                var match = item.match || item;
                return '<div style="margin-bottom:0.25rem;">' +
                    '<span style="color:var(--text-muted); font-size:0.68rem;">' + formatTime(match.createdAt) + '</span>' +
                    '<span style="margin-left:0.5rem;">' + escapeHtml((match.body || '').slice(0, 100)) + '</span>' +
                '</div>';
            }).join('');
        }
        results.classList.add('visible');
    } catch (err) {
        console.error('[MSG] runSearch failed:', err.message);
    }
}

// Archive / Pin
async function archiveThread() {
    if (currentThreadId) await archiveThreadId(currentThreadId);
}

async function archiveThreadId(threadId) {
    try {
        var res = await apiFetch('/api/messages/thread/' + threadId + '/archive', { method: 'POST' });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        showToast(data.archived ? 'Thread archived.' : 'Thread unarchived.', 'success');
        loadThreads();
    } catch (err) {
        console.error('[MSG] archiveThreadId failed:', err.message);
        showToast('Failed to update archive state.', 'error');
    }
}

async function pinThread() {
    if (currentThreadId) await pinThreadId(currentThreadId);
}

async function pinThreadId(threadId) {
    try {
        var res = await apiFetch('/api/messages/thread/' + threadId + '/pin', { method: 'POST' });
        if (!res.ok) {
            var errData = await res.json().catch(function() { return {}; });
            throw new Error(errData.error || 'Failed');
        }
        var data = await res.json();
        showToast(data.pinned ? 'Thread pinned.' : 'Thread unpinned.', 'success');
        loadThreads();
    } catch (err) {
        console.error('[MSG] pinThreadId failed:', err.message);
        showToast(err.message || 'Failed to pin thread.', 'error');
    }
}

async function exportThread() {
    if (!currentThreadId) return;
    try {
        var res = await apiFetch('/api/messages/thread/' + currentThreadId + '/export');
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        var blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'thread-export-' + currentThreadId.slice(-8) + '.json';
        a.click();
        URL.revokeObjectURL(a.href);
    } catch (err) {
        console.error('[MSG] exportThread failed:', err.message);
        showToast('Export failed.', 'error');
    }
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION I: Typing Indicator
// ═══════════════════════════════════════════════════════════════════════════════

function onInputChange() {
    var body    = document.getElementById('msg-input').value;
    var len     = body.length;
    var counter = document.getElementById('char-counter');

    if (len >= 800) {
        counter.style.display = 'block';
        counter.textContent   = len + '/1000';
        counter.className     = 'char-counter ' + (len > 1000 ? 'over' : 'warn');
    } else {
        counter.style.display = 'none';
    }

    if (!socket || !currentThread) return;
    var otherMeta = (currentThread.participantMeta || []).find(function(m) {
        return m.userId && m.userId.toString() !== user.sub;
    });
    if (!otherMeta) return;

    if (!typingActive) {
        typingActive = true;
        socket.emit('typing_start', { recipientId: otherMeta.userId, threadId: currentThreadId });
    }
    clearTimeout(typingTimer);
    typingTimer = setTimeout(function() { stopTypingEmit(); }, 3000);
}

function stopTypingEmit() {
    if (!typingActive) return;
    typingActive = false;
    if (!socket || !currentThread) return;
    var otherMeta = (currentThread.participantMeta || []).find(function(m) {
        return m.userId && m.userId.toString() !== user.sub;
    });
    if (otherMeta) {
        socket.emit('typing_stop', { recipientId: otherMeta.userId, threadId: currentThreadId });
    }
    clearTimeout(typingTimer);
}

function showTypingIndicator(visible) {
    var el = document.getElementById('typing-indicator');
    if (!el) return;
    el.classList.toggle('visible', visible);
    if (visible) {
        clearTimeout(typingHideTimer);
        typingHideTimer = setTimeout(function() { showTypingIndicator(false); }, 4000);
    }
}

function hideTypingIndicator() {
    showTypingIndicator(false);
    clearTimeout(typingHideTimer);
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION J: Templates
// ═══════════════════════════════════════════════════════════════════════════════

async function loadTemplates() {
    try {
        var res = await apiFetch('/api/messages/templates');
        if (!res.ok) return;
        var data = await res.json();
        templates = data.templates || [];
        if (templates.length) {
            document.getElementById('templates-wrapper').style.display = 'block';
            document.getElementById('templates-btn').style.display = 'flex';
        }
    } catch (err) {
        console.error('[MSG] loadTemplates failed:', err.message);
    }
}

function toggleTemplates() {
    var dd = document.getElementById('templates-dropdown');
    if (dd.classList.contains('open')) {
        dd.classList.remove('open');
        return;
    }
    dd.innerHTML = templates.map(function(t) {
        return '<div class="template-item" data-template-body="' + escapeHtml(t.body) + '">' +
            '<div class="t-label">' + escapeHtml(t.label) + '</div>' +
            '<div class="t-body">' + escapeHtml(t.body) + '</div>' +
        '</div>';
    }).join('') || '<div class="template-item" style="color:var(--text-muted);">No templates yet.</div>';
    dd.classList.add('open');
}

function pasteToComposer(text) {
    var input = document.getElementById('msg-input');
    input.value = text;
    input.focus();
    onInputChange();
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION K: Entry Point Parsing
// ═══════════════════════════════════════════════════════════════════════════════

function parseUrlParams() {
    var params  = new URLSearchParams(window.location.search);
    var threadP = params.get('thread');
    var withId  = params.get('with');
    var target  = params.get('target');
    var reId    = params.get('re');
    var reType  = params.get('type');
    var ctxStr  = params.get('ctx');

    if (threadP) {
        openThread(threadP);
    } else if (withId) {
        _openOrStartThread(withId, reId, reType);
    } else if (target) {
        openThreadWithUser(target);
    }

    if (ctxStr) {
        try {
            var ctx = JSON.parse(decodeURIComponent(ctxStr));
            openThreadWithContext(ctx);
        } catch (err) {
            console.error('[MSG] Failed to parse ctx param:', err.message);
        }
    }
}

// Open thread with target userId (backward compat, no context)
async function openThreadWithUser(targetId) {
    try {
        var res = await apiFetch('/api/messages/thread', {
            method: 'POST',
            body: JSON.stringify({ recipientId: targetId })
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        await openThread(data.threadId || (data.thread && data.thread._id));
    } catch (err) {
        console.error('[MSG] openThreadWithUser failed:', err.message);
        showToast('Failed to open conversation.', 'error');
    }
}

// Open thread with full context (from product/order pages)
async function openThreadWithContext(ctx) {
    try {
        var res = await apiFetch('/api/messages/thread', {
            method: 'POST',
            body: JSON.stringify({
                recipientId: ctx.recipientId,
                contextType: ctx.contextType,
                refId:       ctx.refId,
                refTitle:    ctx.refTitle,
                refImage:    ctx.refImage
            })
        });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        var data = await res.json();
        await openThread(data.threadId || (data.thread && data.thread._id));
    } catch (err) {
        console.error('[MSG] openThreadWithContext failed:', err.message);
        showToast('Failed to open conversation.', 'error');
    }
}

// Open or start thread with known user (from ?with= param)
async function _openOrStartThread(recipientId, contextId, contextType) {
    try {
        var r = await apiFetch('/api/messages/threads');
        if (r.ok) {
            var data = await r.json();
            var threadList = Array.isArray(data) ? data : (data.threads || []);
            var existing = threadList.find(function(t) {
                return (t.participantMeta || []).some(function(p) {
                    return p.userId && p.userId.toString() === recipientId.toString();
                });
            });
            if (existing) {
                openThread(existing.threadId || existing._id);
                return;
            }
        }
    } catch (err) {
        console.error('[MSG] _openOrStartThread thread lookup failed:', err.message);
    }
    // No existing thread found -- create with context
    openThreadWithContext({
        recipientId: recipientId,
        contextType: contextType || 'product',
        refId: contextId || '',
        refTitle: '',
        refImage: ''
    });
}


// ═══════════════════════════════════════════════════════════════════════════════
// SECTION L: Lifecycle (init, token refresh, intervals, cleanup)
// ═══════════════════════════════════════════════════════════════════════════════

// FIX #9: Event delegation — wire all interactive elements via delegation
function setupEventDelegation() {
    // ── Chat body: reactions, edit, delete, image open ──
    document.getElementById('chat-body').addEventListener('click', function(e) {
        // Reaction button (bubble actions or reaction chips)
        var reactBtn = e.target.closest('[data-react-msg]');
        if (reactBtn) {
            e.preventDefault();
            reactToMessage(reactBtn.dataset.reactMsg, reactBtn.dataset.emoji);
            return;
        }
        // Edit button
        var editBtn = e.target.closest('[data-edit-msg]');
        if (editBtn) {
            e.preventDefault();
            editMessage(editBtn.dataset.editMsg);
            return;
        }
        // Delete button
        var deleteBtn = e.target.closest('[data-delete-msg]');
        if (deleteBtn) {
            e.preventDefault();
            deleteMessage(deleteBtn.dataset.deleteMsg);
            return;
        }
        // Image click to open in new tab
        var img = e.target.closest('.msg-image');
        if (img) {
            window.open(img.dataset.imgUrl || img.src, '_blank');
            return;
        }
    });

    // ── Thread list: open thread, archive, pin ──
    document.getElementById('thread-list').addEventListener('click', function(e) {
        // Archive action button
        var archiveBtn = e.target.closest('[data-archive-thread]');
        if (archiveBtn) {
            e.stopPropagation();
            archiveThreadId(archiveBtn.dataset.archiveThread);
            return;
        }
        // Pin action button
        var pinBtn = e.target.closest('[data-pin-thread]');
        if (pinBtn) {
            e.stopPropagation();
            pinThreadId(pinBtn.dataset.pinThread);
            return;
        }
        // Thread item click
        var threadItem = e.target.closest('[data-thread-id]');
        if (threadItem) {
            openThread(threadItem.dataset.threadId);
            return;
        }
    });

    // ── Tab buttons ──
    document.querySelector('.tabs-row').addEventListener('click', function(e) {
        var btn = e.target.closest('.tab-btn');
        if (btn && btn.dataset.tab) {
            switchTab(btn.dataset.tab);
        }
    });

    // ── Header action buttons ──
    document.getElementById('search-toggle-btn').addEventListener('click', toggleSearch);
    document.getElementById('export-btn').addEventListener('click', exportThread);
    document.getElementById('archive-btn').addEventListener('click', archiveThread);
    document.getElementById('pin-btn').addEventListener('click', pinThread);

    // ── Search bar ──
    document.getElementById('search-input').addEventListener('input', debounceSearch);
    document.getElementById('search-input').addEventListener('keydown', function(e) {
        if (e.key === 'Escape') toggleSearch();
    });
    document.getElementById('search-close-btn').addEventListener('click', toggleSearch);

    // ── Load more button ──
    document.getElementById('load-more-btn').addEventListener('click', loadMoreMessages);

    // ── Composer input ──
    document.getElementById('msg-input').addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });
    document.getElementById('msg-input').addEventListener('input', onInputChange);

    // ── Send button ──
    document.getElementById('send-btn').addEventListener('click', sendMessage);

    // ── Attachment ──
    document.getElementById('attach-btn').addEventListener('click', function() {
        document.getElementById('file-input').click();
    });
    document.getElementById('file-input').addEventListener('change', handleFileSelect);

    // ── Remove upload ──
    document.getElementById('remove-upload-btn').addEventListener('click', removeUpload);

    // ── Templates ──
    document.getElementById('templates-btn').addEventListener('click', toggleTemplates);
    document.getElementById('templates-dropdown').addEventListener('click', function(e) {
        var item = e.target.closest('[data-template-body]');
        if (item) {
            pasteToComposer(item.dataset.templateBody);
            toggleTemplates();
        }
    });

    // ── Starter suggestions ──
    document.getElementById('starter-suggestions').addEventListener('click', function(e) {
        var chip = e.target.closest('[data-suggestion]');
        if (chip) {
            pasteToComposer(chip.dataset.suggestion);
        }
    });
}

// FIX #10: Token refresh without dropping messages
function setupTokenRefresh() {
    startInterval(async function() {
        var rt = localStorage.getItem('refresh_token');
        if (!rt) return;
        try {
            var r = await fetch('/oauth/refresh', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ grant_type: 'refresh_token', refresh_token: rt, client_id: 'markee-gateway' })
            });
            if (!r.ok) return;
            var data = await r.json();
            if (!data.access_token) return;
            localStorage.setItem('access_token', data.access_token);
            token = data.access_token;
            // Update socket auth without full disconnect/reconnect if possible
            if (socket && socket.connected) {
                socket.auth = function(cb) { cb({ token: token }); };
                // The new token will be used on next reconnect automatically
            } else if (socket) {
                socket.disconnect();
                connectSocket();
            }
        } catch (err) {
            console.error('[MSG] Token refresh failed:', err.message);
        }
    }, 50 * 60 * 1000);
}

// FIX #5: Unread badge polling with managed interval
function setupUnreadPolling() {
    startInterval(refreshUnreadBadge, 30000);
}

// Cleanup on page unload
function setupCleanup() {
    window.addEventListener('beforeunload', function() {
        clearAllIntervals();
        clearTimeout(typingTimer);
        clearTimeout(typingHideTimer);
        clearTimeout(searchDebounce);
        if (currentAbortController) currentAbortController.abort();
        if (socket) socket.disconnect();
    });
}

// ── Init ─────────────────────────────────────────────────────────────────────
function init() {
    setupEventDelegation();
    setupCleanup();
    connectSocket();
    setupTokenRefresh();
    setupUnreadPolling();

    loadThreads().then(function() {
        parseUrlParams();
    });

    if (typeof MarkeeCart !== 'undefined' && MarkeeCart.updateAllCartBadges) {
        MarkeeCart.updateAllCartBadges();
    }
    refreshUnreadBadge();
}

// Boot
init();

})();
</script>
