<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Orders | Markee Marketplace</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <script src="/js/confirm.js"></script>
    <script src="/js/cart.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        .orders-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
        }

        .tab-bar {
            display: flex;
            gap: 0.5rem;
            background: var(--bg-primary);
            border: 1px solid var(--border-light);
            border-radius: 10px;
            padding: 0.35rem;
            margin-bottom: 2rem;
            width: fit-content;
        }

        .tab-btn {
            padding: 0.5rem 1.25rem;
            border-radius: 7px;
            font-size: 0.875rem;
            font-weight: 600;
            border: none;
            cursor: pointer;
            background: transparent;
            color: var(--text-muted);
            transition: all 0.2s;
        }

        .tab-btn.active {
            background: var(--accent-red);
            color: white;
        }

        .tab-btn:hover:not(.active) {
            background: var(--bg-secondary);
            color: var(--text-main);
        }

        .order-card {
            background: var(--bg-primary);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
            transition: box-shadow 0.2s, transform 0.2s, border-left 0.2s, padding-left 0.2s;
            cursor: pointer;
        }

        .order-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-2px);
            border-left: 3px solid var(--accent-red);
            padding-left: calc(1.5rem - 3px);
        }

        .order-icon {
            width: 48px;
            height: 48px;
            border-radius: 10px;
            background: var(--bg-secondary);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            font-size: 1.25rem;
            color: var(--text-muted);
        }

        .order-meta {
            flex-grow: 1;
            min-width: 0;
        }

        .order-id {
            font-size: 0.8rem;
            color: var(--text-muted);
            font-weight: 500;
            font-family: monospace;
            letter-spacing: 0.05em;
        }

        .order-title {
            font-weight: 600;
            font-size: 0.95rem;
            margin: 0.15rem 0;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .order-date {
            font-size: 0.8rem;
            color: var(--text-muted);
        }

        .order-right { display: flex; align-items: center; gap: 1rem; flex-shrink: 0; min-width: 260px; justify-content: flex-end; }

        .order-total {
            font-weight: 700;
            font-size: 1.05rem;
            color: var(--text-main);
            text-align: right;
        }

        .order-total-label {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-weight: 500;
        }

        .order-total { font-weight: 700; font-size: 1rem; white-space: nowrap; }
        .status-badge { white-space: nowrap; }
        .order-actions { display: flex; gap: 0.5rem; align-items: center; }

        /* Status badges */
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.3rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            white-space: nowrap;
        }

        .status-badge::before {
            content: '';
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background: currentColor;
            display: inline-block;
        }

        .status-pending  { background: #fefce8; color: #a16207; border: 1px solid #fde68a; }
        .status-paid     { background: #eff6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
        .status-processing { background: #f5f3ff; color: #6d28d9; border: 1px solid #ddd6fe; }
        .status-shipped  { background: #ecfeff; color: #0e7490; border: 1px solid #a5f3fc; }
        .status-delivered { background: #f0fdf4; color: #15803d; border: 1px solid #bbf7d0; }
        .status-cancelled { background: #fef2f2; color: #b91c1c; border: 1px solid #fecaca; }
        .status-ready_for_pickup { background: #dbeafe; color: #1e40af; }
        .status-picked_up        { background: #d1fae5; color: #065f46; }
        .status-self_fulfilled   { background: #ede9fe; color: #5b21b6; }

        .view-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.4rem;
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.82rem;
            font-weight: 600;
            border: 1.5px solid var(--border-light);
            background: transparent;
            color: var(--text-main);
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            white-space: nowrap;
        }

        .view-btn:hover {
            background: var(--text-main);
            color: white;
            border-color: var(--text-main);
        }

        /* Seller order card extras */
        .order-items-preview {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 0.35rem;
        }

        .item-chip {
            background: var(--bg-secondary);
            border: 1px solid var(--border-light);
            border-radius: 5px;
            padding: 0.15rem 0.5rem;
            font-size: 0.75rem;
            color: var(--text-muted);
        }

        /* ── Inline action buttons ──────────────────────────────────────────── */
        .order-actions { display: flex; align-items: center; gap: 0.4rem; flex-shrink: 0; }

        .act-btn {
            padding: 0.3rem 0.65rem;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid var(--border-light);
            cursor: pointer;
            background: var(--bg-main);
            color: var(--text-muted);
            transition: all 0.15s;
            white-space: nowrap;
        }
        .act-btn:hover { background: var(--bg-secondary); color: var(--text-main); }
        .act-btn.success:hover { background: #f0fdf4; color: #15803d; border-color: #bbf7d0; }
        .act-btn.danger:hover  { background: #fef2f2; color: #b91c1c; border-color: #fecaca; }

        /* Empty state */
        .empty-state {
            text-align: center;
            padding: 5rem 2rem;
        }

        .empty-icon {
            width: 72px;
            height: 72px;
            background: var(--bg-secondary);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.25rem;
            font-size: 1.75rem;
            color: var(--text-muted);
        }

        /* Loading skeleton */
        .skeleton {
            background: linear-gradient(90deg, var(--bg-secondary) 25%, #e9eaec 50%, var(--bg-secondary) 75%);
            background-size: 200% 100%;
            animation: shimmer 1.4s infinite;
            border-radius: 8px;
        }

        @keyframes shimmer { to { background-position: -200% 0; } }

        .skeleton-card {
            background: var(--bg-primary);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 1.5rem;
        }

        @media (max-width: 640px) {
            .order-card { flex-wrap: wrap; }
            .order-right { width: 100%; justify-content: space-between; }
            .order-items-preview { display: none; }
        }

        @keyframes newOrderFlash {
            0%   { background: #fef3c7; }
            100% { background: var(--bg-primary); }
        }
        .new-order-flash { animation: newOrderFlash 2s ease-out; }
    </style>
</head>
<body class="bg-light">

<!-- ============ NAVBAR ============ -->
<nav class="navbar">
    <div class="brand-combo">
        <a href="/"><span class="brand">Markee</span></a>
    </div>
    <%- include('_nav') %>
</nav>

<!-- ============ MAIN ============ -->
<div class="container py-4 animate-fade">

    <div class="orders-header">
        <div>
            <h2 style="margin-bottom:0.25rem;">Orders</h2>
            <p class="text-muted" id="orders-subtitle">Your purchase history</p>
        </div>
        <a href="/" class="nav-pill nav-pill-outline" style="width:auto;">
            <i class="fa fa-plus" style="margin-right:0.4rem;"></i> Browse Listings
        </a>
    </div>

    <!-- Tab bar — only shown for sellers -->
    <div class="tab-bar" id="tab-bar" style="display:none;">
        <button class="tab-btn active" id="tab-purchases" onclick="switchTab('purchases')">
            <i class="fa fa-shopping-bag" style="margin-right:0.4rem;"></i> My Purchases
        </button>
        <button class="tab-btn" id="tab-sales" onclick="switchTab('sales')">
            <i class="fa fa-store" style="margin-right:0.4rem;"></i> Sales Received
        </button>
    </div>

    <!-- Order list containers -->
    <div id="purchases-list">
        <!-- Skeleton loading -->
        <div id="purchases-skeleton">
            <% for(let i=0; i<4; i++) { %>
            <div class="skeleton-card">
                <div class="skeleton" style="width:48px; height:48px; border-radius:10px; flex-shrink:0;"></div>
                <div style="flex-grow:1; display:flex; flex-direction:column; gap:0.5rem;">
                    <div class="skeleton" style="height:12px; width:120px;"></div>
                    <div class="skeleton" style="height:16px; width:220px;"></div>
                    <div class="skeleton" style="height:12px; width:90px;"></div>
                </div>
                <div style="display:flex; gap:1rem; align-items:center;">
                    <div class="skeleton" style="height:28px; width:80px; border-radius:20px;"></div>
                    <div class="skeleton" style="height:36px; width:90px; border-radius:8px;"></div>
                </div>
            </div>
            <% } %>
        </div>
        <div id="purchases-content" style="display:none;"></div>
    </div>

    <div id="sales-list" style="display:none;">
        <div id="sales-skeleton">
            <% for(let i=0; i<3; i++) { %>
            <div class="skeleton-card">
                <div class="skeleton" style="width:48px; height:48px; border-radius:10px; flex-shrink:0;"></div>
                <div style="flex-grow:1; display:flex; flex-direction:column; gap:0.5rem;">
                    <div class="skeleton" style="height:12px; width:120px;"></div>
                    <div class="skeleton" style="height:16px; width:220px;"></div>
                    <div class="skeleton" style="height:12px; width:90px;"></div>
                </div>
                <div style="display:flex; gap:1rem; align-items:center;">
                    <div class="skeleton" style="height:28px; width:80px; border-radius:20px;"></div>
                    <div class="skeleton" style="height:36px; width:90px; border-radius:8px;"></div>
                </div>
            </div>
            <% } %>
        </div>
        <div id="sales-content" style="display:none;"></div>
    </div>

</div>

<script>
    // ── Auth guard ────────────────────────────────────────────────────────────
    const token = localStorage.getItem('access_token');
    if (!token) { window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search)); }

    function parseJwt(t) {
        try {
            const p = JSON.parse(atob(t.split('.')[1]));
            if (p.exp && p.exp * 1000 < Date.now()) {
                localStorage.removeItem('access_token');
                localStorage.removeItem('refresh_token');
                return null;
            }
            return p;
        } catch { return null; }
    }

    const user = parseJwt(token);
    if (!user) { window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search)); }

    // ── Navbar role awareness ────────────────────────────────────────────────
    const isSeller = user.storeActive === true;
    const isAdmin  = user.role === 'admin';

    const _ndEl = document.getElementById('nav-dashboard');
    if ((isSeller || isAdmin) && _ndEl) _ndEl.style.display = 'inline-flex';
    const _naEl = document.getElementById('nav-admin');
    if (isAdmin && _naEl) _naEl.style.display = 'inline-flex';
    if (isSeller || isAdmin) {
        document.getElementById('tab-bar').style.display = 'flex';
        document.getElementById('orders-subtitle').textContent = 'Your purchases and storefront sales';
    }

    // ── Orders cache (fixes browser-back skeleton flash) ─────────────────────────
    const ORDERS_CACHE_KEY = `markee_orders_${user.sub}_${user.role}_${user.storeId || 'none'}`;
    const ORDERS_CACHE_TTL = 2 * 60 * 1000; // 2 minutes

    function saveOrdersCache(purchases, sales) {
        try {
            sessionStorage.setItem(ORDERS_CACHE_KEY, JSON.stringify({
                purchases, sales, savedAt: Date.now()
            }));
        } catch {}
    }

    function loadOrdersCache() {
        try {
            const raw  = sessionStorage.getItem(ORDERS_CACHE_KEY);
            if (!raw) return null;
            const data = JSON.parse(raw);
            if (Date.now() - data.savedAt > ORDERS_CACHE_TTL) return null;
            return data;
        } catch { return null; }
    }

    function handleLogout() {
        localStorage.removeItem('access_token');
        localStorage.removeItem('refresh_token');
        window.location.replace('/');
    }

    // ── Status badge ─────────────────────────────────────────────────────────
    const STATUS_ICONS = {
        pending:          'fa-clock',
        paid:             'fa-credit-card',
        processing:       'fa-cog',
        shipped:          'fa-truck',
        delivered:        'fa-check-circle',
        cancelled:        'fa-times-circle',
        ready_for_pickup: 'fa-map-marker-alt',
        picked_up:        'fa-person-walking',
        self_fulfilled:   'fa-box-open'
    };

    function statusBadge(status) {
        const cls = `status-${status}` in { 'status-pending':1,'status-paid':1,'status-processing':1,'status-shipped':1,'status-delivered':1,'status-cancelled':1 }
            ? `status-${status}` : 'status-pending';
        return `<span class="status-badge ${cls}">${status}</span>`;
    }

    // ── Format helpers ────────────────────────────────────────────────────────
    function formatDate(iso) {
        const d = new Date(iso);
        return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    }

    function formatPrice(cents) {
        return `$${(cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
    }

    function shortId(id) {
        return id ? '…' + id.slice(-8) : '—';
    }

    // ── Render purchase card ─────────────────────────────────────────────────
    function renderPurchaseCard(order) {
        const itemCount = (order.items || []).reduce((s, i) => s + (i.qty || 1), 0);
        const icon = STATUS_ICONS[order.status] || 'fa-box';
        const VALID_STATUSES = ['pending','paid','processing','shipped','delivered','cancelled','ready_for_pickup','picked_up','self_fulfilled'];
        const statusCls = VALID_STATUSES.includes(order.status) ? `status-${order.status}` : 'status-pending';

        const buyerCanCancel = order.status === 'pending';

        return `
        <div class="order-card" onclick="window.location='/orders/${order._id}'" id="purchase-card-${order._id}">
            <div class="order-icon">
                <i class="fa ${icon}"></i>
            </div>
            <div class="order-meta">
                <div class="order-id">#${shortId(order._id)}</div>
                <div class="order-title">${itemCount} item${itemCount !== 1 ? 's' : ''}</div>
                <div class="order-date">${formatDate(order.createdAt)}</div>
            </div>
            <div class="order-right">
                <div>
                    <div class="order-total-label">Total</div>
                    <div class="order-total">${formatPrice(order.totalAmount || order.totalCents || 0)}</div>
                </div>
                <span class="status-badge ${statusCls}">${order.status}</span>
                <div class="order-actions" onclick="event.stopPropagation()">
                    ${buyerCanCancel ? `<button class="act-btn danger" onclick="buyerCancelOrder('${order._id}')" title="Cancel order"><i class="fa fa-times"></i> Cancel</button>` : ''}
                    <a href="/orders/${order._id}" class="view-btn">Details <i class="fa fa-chevron-right"></i></a>
                </div>
            </div>
        </div>
        `;
    }

    // ── Render seller-received order card ────────────────────────────────────
    function renderSaleCard(order) {
        const myItems = (order.items || []).filter(i =>
            i.sellerId?.toString() === user.storeId?.toString()
        );
        const itemCount = myItems.reduce((s, i) => s + (i.qty || 1), 0);
        const myRevenue = myItems.reduce((s, i) => s + ((i.price || 0) * (i.qty || 1)), 0);
        const VALID_STATUSES_SALE = ['pending','paid','processing','shipped','delivered','cancelled','ready_for_pickup','picked_up','self_fulfilled'];
        const statusCls = VALID_STATUSES_SALE.includes(order.status) ? `status-${order.status}` : 'status-pending';

        const itemChips = myItems.slice(0, 3).map(i =>
            `<span class="item-chip">${i.title || 'Item'}</span>`
        ).join('');
        const moreChip = myItems.length > 3
            ? `<span class="item-chip">+${myItems.length - 3} more</span>` : '';

        const canAccept = ['pending', 'paid'].includes(order.status);
        const canCancel = ['pending', 'paid', 'processing'].includes(order.status);

        return `
        <div class="order-card" onclick="window.location='/orders/${order._id}'" id="sale-card-${order._id}">
            <div class="order-icon" style="background:#f0fdf4; color:#15803d;">
                <i class="fa fa-store"></i>
            </div>
            <div class="order-meta">
                <div class="order-id">Order #${shortId(order._id)}</div>
                <div class="order-title">${itemCount} item${itemCount !== 1 ? 's' : ''} from your store</div>
                <div class="order-items-preview">${itemChips}${moreChip}</div>
                <div class="order-date">${formatDate(order.createdAt)}</div>
            </div>
            <div class="order-right">
                <div>
                    <div class="order-total-label">Your earnings</div>
                    <div class="order-total">${formatPrice(myRevenue)}</div>
                </div>
                <span class="status-badge ${statusCls}">${order.status}</span>
                <div class="order-actions" onclick="event.stopPropagation()">
                    ${canAccept ? `<button class="act-btn success" onclick="acceptOrder('${order._id}', event)"><i class="fa fa-check"></i> Accept</button>` : ''}
                    ${canCancel ? `<button class="act-btn danger" onclick="cancelOrder('${order._id}')" title="Cancel"><i class="fa fa-times"></i></button>` : ''}
                    <a href="/orders/${order._id}" class="view-btn">Details <i class="fa fa-chevron-right"></i></a>
                </div>
            </div>
        </div>
        `;
    }

    // ── Empty state ──────────────────────────────────────────────────────────
    function renderEmpty(message, ctaLabel, ctaHref) {
        return `
        <div class="empty-state">
            <div class="empty-icon"><i class="fa fa-box-open"></i></div>
            <h3 style="margin-bottom:0.5rem;">${message}</h3>
            <p class="text-muted" style="margin-bottom:1.5rem;">Your orders will appear here once you place them.</p>
            <a href="${ctaHref}" class="btn btn-red" style="width:auto; display:inline-flex;">
                <i class="fa fa-search" style="margin-right:0.5rem;"></i> ${ctaLabel}
            </a>
        </div>
        `;
    }

    // ── Order action helpers ──────────────────────────────────────────────────
    async function acceptOrder(orderId, evt) {
        showConfirm('Accept this order? You are committing to fulfil it.', async () => {
            try {
                const res = await fetch(`/api/orders/${orderId}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({ status: 'processing' })
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
                showToast('Order accepted — now processing!', 'success', 3500, evt);
                loadSales();
            } catch (err) { showToast('Error: ' + err.message, 'error'); }
        }, null, { confirmText: 'Accept Order' });
    }

    async function cancelOrder(orderId) {
        const reason = prompt('Reason for cancellation (optional):');
        if (reason === null) return;
        try {
            const res = await fetch(`/api/orders/${orderId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ status: 'cancelled', cancellationReason: reason })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
            showToast('Order cancelled.', 'info');
            loadSales();
        } catch (err) { showToast('Error: ' + err.message, 'error'); }
    }

    async function buyerCancelOrder(orderId) {
        showConfirm('Cancel this order? This cannot be undone.', async () => {
            try {
                const res = await fetch(`/api/orders/${orderId}/status`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({ status: 'cancelled' })
                });
                const data = await res.json();
                if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
                showToast('Order cancelled.', 'info');
                loadPurchases();
            } catch (err) { showToast('Error: ' + err.message, 'error'); }
        }, null, { confirmText: 'Cancel Order', type: 'danger' });
    }

    // ── Load purchases (buyer view) ───────────────────────────────────────────
    async function loadPurchases() {
        // Check cache first — render immediately, then background-refresh
        const cached = loadOrdersCache();
        if (cached && cached.purchases) {
            document.getElementById('purchases-skeleton').style.display = 'none';
            const contentEl = document.getElementById('purchases-content');
            contentEl.style.display = 'block';
            contentEl.innerHTML = cached.purchases.length
                ? cached.purchases.map(renderPurchaseCard).join('')
                : renderEmpty('No purchases yet', 'Start Shopping', '/');
        }

        try {
            const res = await fetch('/api/orders/my-orders', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (res.status === 401) { window.location.replace('/login'); return; }
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const orders = await res.json();

            document.getElementById('purchases-skeleton').style.display = 'none';
            const content = document.getElementById('purchases-content');
            content.style.display = 'block';

            if (!orders.length) {
                content.innerHTML = renderEmpty('No purchases yet', 'Start Shopping', '/');
            } else {
                content.innerHTML = orders.map(renderPurchaseCard).join('');
            }

            // Update cache with fresh purchases (keep sales from previous cache if available)
            const prevCache = loadOrdersCache();
            saveOrdersCache(orders, prevCache ? prevCache.sales : []);
        } catch (err) {
            if (!loadOrdersCache()) {
                // Only show error if there was no cache to fall back on
                document.getElementById('purchases-skeleton').style.display = 'none';
                const content = document.getElementById('purchases-content');
                content.style.display = 'block';
                content.innerHTML = `<div class="alert alert-error"><i class="fa fa-exclamation-circle mr-2"></i> Failed to load orders. <a href="#" onclick="loadPurchases(); return false;">Retry</a></div>`;
                showToast('Failed to load orders', 'error');
            }
        }
    }

    // ── Sales polling (real-time seller orders) ───────────────────────────────
    let _salesPollingInterval = null;
    let _knownSaleIds = new Set();

    function startSalesPolling() {
        if (_salesPollingInterval) return;
        _salesPollingInterval = setInterval(async () => {
            try {
                const r = await fetch('/api/orders/my-sales', {
                    headers: { Authorization: `Bearer ${token}` }
                });
                if (!r.ok) return;
                const orders = await r.json();
                const container = document.getElementById('sales-content');
                if (!container) return;
                let hasNew = false;
                (orders || []).forEach(order => {
                    if (!_knownSaleIds.has(order._id.toString())) {
                        _knownSaleIds.add(order._id.toString());
                        if (container.children.length > 0) {
                            // New order arrived after initial load
                            const wrapper = document.createElement('div');
                            wrapper.innerHTML = renderSaleCard(order);
                            const card = wrapper.firstElementChild;
                            if (card) { card.classList.add('new-order-flash'); container.prepend(card); }
                            hasNew = true;
                        }
                    }
                });
                if (hasNew && typeof showToast === 'function') showToast('New order received!', 'success');
            } catch {}
        }, 30000);
    }

    function stopSalesPolling() {
        if (_salesPollingInterval) { clearInterval(_salesPollingInterval); _salesPollingInterval = null; }
    }

    // ── Load sales (seller view) ──────────────────────────────────────────────
    async function loadSales() {
        // Check cache first
        const cached = loadOrdersCache();
        if (cached && cached.sales) {
            document.getElementById('sales-skeleton').style.display = 'none';
            const contentEl = document.getElementById('sales-content');
            contentEl.style.display = 'block';
            contentEl.innerHTML = cached.sales.length
                ? cached.sales.map(renderSaleCard).join('')
                : renderEmpty('No sales yet', 'Manage Listings', '/dashboard');
        }

        try {
            const res = await fetch('/api/orders/seller-orders', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const orders = await res.json();

            document.getElementById('sales-skeleton').style.display = 'none';
            const content = document.getElementById('sales-content');
            content.style.display = 'block';

            if (!orders.length) {
                content.innerHTML = renderEmpty('No sales yet', 'Manage Listings', '/dashboard');
            } else {
                content.innerHTML = orders.map(renderSaleCard).join('');
            }

            // Seed _knownSaleIds with all currently loaded order IDs
            _knownSaleIds = new Set((orders || []).map(o => o._id.toString()));

            // Update cache with fresh sales
            const prevCache = loadOrdersCache();
            saveOrdersCache(prevCache ? prevCache.purchases : [], orders);
        } catch (err) {
            if (!loadOrdersCache()) {
                document.getElementById('sales-skeleton').style.display = 'none';
                const content = document.getElementById('sales-content');
                content.style.display = 'block';
                content.innerHTML = `<div class="alert alert-error"><i class="fa fa-exclamation-circle mr-2"></i> Failed to load sales. <a href="#" onclick="loadSales(); return false;">Retry</a></div>`;
            }
        }
    }

    // ── Tab switching ─────────────────────────────────────────────────────────
    function switchTab(tab) {
        const isPurchases = tab === 'purchases';
        document.getElementById('tab-purchases').classList.toggle('active', isPurchases);
        document.getElementById('tab-sales').classList.toggle('active', !isPurchases);
        document.getElementById('purchases-list').style.display = isPurchases ? 'block' : 'none';
        document.getElementById('sales-list').style.display = isPurchases ? 'none' : 'block';

        if (!isPurchases) {
            startSalesPolling();
        } else {
            stopSalesPolling();
        }
    }

    // ── Socket.io for real-time seller order notifications ────────────────────
    if (isSeller) {
        try {
            const socket = io({ auth: { token }, transports: ['websocket', 'polling'] });
            socket.on('order.new', () => {
                // Pre-empt the 30s polling cycle
                stopSalesPolling();
                // Re-fetch immediately
                setTimeout(() => startSalesPolling(), 100);
            });
            socket.on('order.status', ({ orderId, status }) => {
                const card = document.getElementById(`purchase-card-${orderId}`);
                if (!card) return;
                const badge = card.querySelector('.status-badge');
                if (badge) {
                    badge.className = `status-badge status-${status}`;
                    badge.textContent = status.replace(/_/g, ' ');
                }
                if (typeof showToast === 'function') showToast(`Order status: ${status.replace(/_/g, ' ')}`);
            });
        } catch {}
    }

    // ── Boot ─────────────────────────────────────────────────────────────────
    loadPurchases();
    // Pre-load sales in background so switching tabs feels instant
    if (isSeller || isAdmin) loadSales();
</script>
</body>
</html>
