<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Storefront — Markee</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <script src="/js/cart.js"></script>
    <style>
        /* ── Storefront-specific overrides ───────────────────────────────── */
        .sf-banner {
            width: 100%;
            max-height: 280px;
            object-fit: cover;
            display: block;
            border-radius: 0 0 12px 12px;
        }
        .sf-sale-banner {
            position: relative;
            background: var(--accent-red);
            color: #fff;
            padding: 1.25rem 1.5rem;
            border-radius: 12px;
            margin-bottom: 1.5rem;
            overflow: hidden;
        }
        .sf-sale-banner-bg {
            position: absolute; inset: 0;
            background-size: cover;
            background-position: center;
            opacity: 0.25;
        }
        .sf-sale-banner-body { position: relative; z-index: 1; }
        .sf-store-header {
            display: flex;
            align-items: flex-start;
            gap: 1.25rem;
            padding: 1.5rem 0;
            flex-wrap: wrap;
        }
        .sf-store-avatar {
            width: 72px; height: 72px;
            border-radius: 50%;
            background: var(--accent-red);
            color: #fff;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.75rem;
            font-weight: 800;
            flex-shrink: 0;
            box-shadow: var(--shadow-md);
        }
        .sf-store-meta { flex: 1; min-width: 0; }
        .sf-store-name {
            font-size: 1.45rem;
            font-weight: 800;
            margin: 0 0 0.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
        .sf-open-pill {
            font-size: 0.65rem;
            font-weight: 700;
            padding: 0.15rem 0.55rem;
            border-radius: 20px;
            letter-spacing: 0.04em;
        }
        .sf-open-pill.open  { background: var(--toast-success-bg); color: var(--toast-success-fg); border: 1px solid var(--toast-success-border); }
        .sf-open-pill.closed{ background: var(--toast-error-bg); color: var(--color-error); border: 1px solid var(--toast-error-border); }

        /* ── Canonical store badge (open/closed/vacation) ────────────────────── */
        .store-badge { display:inline-flex; align-items:center; gap:0.4rem; padding:0.25rem 0.75rem; border-radius:20px; font-size:0.8rem; font-weight:600; }
        .store-badge.open     { background:#d1fae5; color:#065f46; }
        .store-badge.closed   { background:#fee2e2; color:var(--toast-error-fg); }
        .store-badge.vacation { background:#fef3c7; color:#92400e; }
        .sf-online-dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--color-green);
            box-shadow: 0 0 6px var(--color-green);
            display: inline-block;
        }
        .sf-stat-row {
            display: flex;
            gap: 1.5rem;
            margin-top: 0.5rem;
            flex-wrap: wrap;
        }
        .sf-stat { font-size: 0.78rem; color: var(--text-muted); }
        .sf-stat strong { color: var(--text-main); }
        .sf-actions { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
        .sf-grid {
            display: grid;
            grid-template-columns: 280px 1fr;
            gap: 1.5rem;
            align-items: start;
        }
        .sf-sidebar { position: sticky; top: 80px; }
        .sf-info-card {
            background: var(--card-bg);
            border: 1px solid var(--border-light);
            border-radius: 12px;
            padding: 1.25rem;
            margin-bottom: 1rem;
            box-shadow: var(--shadow-sm);
        }
        .sf-info-card h5 {
            font-size: 0.8rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            margin: 0 0 0.75rem;
        }
        .sf-policy-toggle {
            background: none; border: none; cursor: pointer;
            color: var(--text-main); font-size: 0.85rem;
            display: flex; justify-content: space-between; align-items: center;
            width: 100%; padding: 0.35rem 0;
            font-weight: 600;
        }
        .sf-policy-body {
            font-size: 0.8rem;
            color: var(--text-muted);
            line-height: 1.55;
            padding-top: 0.5rem;
            display: none;
        }
        .sf-products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
        }
        .sf-countdown {
            font-size: 0.72rem;
            font-weight: 700;
            padding: 0.2rem 0.5rem;
            background: rgba(255,255,255,0.2);
            border-radius: 4px;
            display: inline-block;
            margin-top: 0.35rem;
        }
        @media (max-width: 768px) {
            .sf-grid { grid-template-columns: 1fr; }
            .sf-sidebar { position: static; }
        }

        /* ── Seller reviews section ──────────────────────────────────────── */
        .seller-reviews-section {
            margin-top: 2.5rem;
            padding-top: 2rem;
            border-top: 1px solid var(--border-light);
        }
        .seller-review-card {
            background: var(--bg-primary);
            border: 1px solid var(--border-light);
            border-radius: 10px;
            padding: 1rem 1.25rem;
            margin-bottom: 0.85rem;
        }
        .sr-tag {
            display: inline-block;
            font-size: 0.65rem;
            font-weight: 700;
            padding: 0.12rem 0.4rem;
            border-radius: 4px;
            background: var(--bg-secondary);
            color: var(--text-muted);
            border: 1px solid var(--border-light);
            margin-right: 0.25rem;
            margin-top: 0.35rem;
            text-transform: capitalize;
        }
    </style>
</head>
<body>

<!-- ── Navbar ─────────────────────────────────────────────────────────────── -->
<nav class="navbar">
    <div class="brand-combo">
        <a href="/"><span class="brand">Markee</span></a>
    </div>
    <%- include('_nav') %>
</nav>

<!-- ── Banner image (shows if store has one) ─────────────────────────────── -->
<div id="banner-wrap" style="display:none;">
    <img id="sf-main-banner" class="sf-banner" src="" alt="">
</div>

<div class="container" style="padding-top:1.5rem; padding-bottom:3rem;">

    <!-- Sales banner (if active) -->
    <div id="sf-sale-banner" style="display:none;" class="sf-sale-banner">
        <div id="sf-sale-banner-bg" class="sf-sale-banner-bg"></div>
        <div class="sf-sale-banner-body">
            <div style="font-size:0.65rem; font-weight:800; letter-spacing:0.1em; opacity:0.85; margin-bottom:0.25rem;">LIMITED TIME SALE</div>
            <div id="sf-sale-headline" style="font-size:1.2rem; font-weight:800; margin-bottom:0.2rem;"></div>
            <div id="sf-sale-subtext" style="font-size:0.85rem; opacity:0.9;"></div>
            <div id="sf-sale-countdown" class="sf-countdown"></div>
            <a id="sf-sale-cta" href="#products" style="display:inline-block; margin-top:0.75rem; background:rgba(255,255,255,0.2); color:#fff; font-weight:700; font-size:0.8rem; padding:0.35rem 0.85rem; border-radius:6px; text-decoration:none; border:1px solid rgba(255,255,255,0.4);">
                Shop Now →
            </a>
        </div>
    </div>

    <!-- Store header -->
    <div class="sf-store-header">
        <div class="sf-store-avatar" id="sf-avatar">?</div>
        <div class="sf-store-meta">
            <div class="sf-store-name">
                <span id="sf-store-name">Loading...</span>
                <span id="store-open-badge" class="sf-open-pill closed" style="display:none;"></span>
                <span id="sf-online-dot" class="sf-online-dot" style="display:none;" title="Online recently"></span>
            </div>
            <div id="sf-store-desc" style="font-size:0.85rem; color:var(--text-muted); margin-bottom:0.5rem;"></div>
            <div class="sf-stat-row">
                <div class="sf-stat"><strong id="sf-total-sales">—</strong> total sales</div>
                <div class="sf-stat"><strong id="sf-total-orders">—</strong> orders</div>
                <div class="sf-stat" id="sf-avg-rating-wrap" style="display:none;">
                    <strong><i class="fa fa-star" style="color:var(--color-amber);"></i> <span id="sf-avg-rating">—</span></strong>
                </div>
                <div class="sf-stat" id="sf-hours-meta" style="color:var(--text-muted); font-size:0.75rem;"></div>
            </div>
        </div>
        <div class="sf-actions">
            <button id="sf-msg-btn" class="btn btn-outline" style="width:auto;" onclick="messageStore()">
                <i class="fa fa-comment" style="margin-right:0.4rem;"></i> Message
            </button>
            <button id="sf-cta-btn" class="btn" style="width:auto; background:var(--accent-red); display:none;" onclick="window.location='/dashboard'">
                <i class="fa fa-sliders-h" style="margin-right:0.4rem;"></i> Manage Store
            </button>
        </div>
    </div>

    <!-- Grid: sidebar + products -->
    <div class="sf-grid">

        <!-- Sidebar -->
        <aside class="sf-sidebar">

            <!-- Store info card -->
            <div class="sf-info-card">
                <h5><i class="fa fa-info-circle" style="margin-right:0.4rem; color:var(--accent-red);"></i>Store Info</h5>
                <div style="font-size:0.83rem; display:grid; gap:0.5rem;">
                    <div id="sf-response-time" style="display:none;">
                        <i class="fa fa-clock" style="width:16px; color:var(--text-muted);"></i>
                        <span></span>
                    </div>
                    <div id="sf-phone" style="display:none;">
                        <i class="fa fa-phone" style="width:16px; color:var(--text-muted);"></i>
                        <span></span>
                    </div>
                    <div id="sf-schedule-today" style="display:none;">
                        <i class="fa fa-calendar-day" style="width:16px; color:var(--text-muted);"></i>
                        <span></span>
                    </div>
                    <div id="sf-member-since" style="display:none;">
                        <i class="fa fa-calendar" style="width:16px; color:var(--text-muted);"></i>
                        <span></span>
                    </div>
                </div>
            </div>

            <!-- Discount badge (if store-wide discount active) -->
            <div id="sf-discount-card" class="sf-info-card" style="display:none; border-left:3px solid var(--accent-red);">
                <h5><i class="fa fa-percent" style="margin-right:0.4rem; color:var(--accent-red);"></i>Store Discount</h5>
                <div id="sf-discount-body" style="font-size:0.85rem; font-weight:700; color:var(--accent-red);"></div>
            </div>

            <!-- Seller ratings card (populated from review-service) -->
            <div id="sf-ratings-card" class="sf-info-card" style="display:none;">
                <h5><i class="fa fa-star" style="margin-right:0.4rem; color:var(--color-amber);"></i>Product Ratings</h5>
                <div id="sf-ratings-body" style="font-size:0.83rem; display:grid; gap:0.4rem;"></div>
            </div>

            <!-- Store Aggregate Rating (Segment 3) -->
            <div id="sf-store-rating-card" class="sf-info-card" style="display:none;">
                <h5><i class="fa fa-store" style="margin-right:0.4rem; color:var(--accent-red);"></i>Store Rating</h5>
                <div id="sf-store-rating-body" style="font-size:0.83rem; display:grid; gap:0.4rem;"></div>
            </div>

            <!-- Policies accordion -->
            <div id="sf-policies-card" class="sf-info-card" style="display:none;">
                <h5><i class="fa fa-file-alt" style="margin-right:0.4rem; color:var(--accent-red);"></i>Policies</h5>
                <div id="sf-return-wrap" style="border-bottom:1px solid var(--border-light); padding-bottom:0.5rem; margin-bottom:0.5rem;">
                    <button class="sf-policy-toggle" onclick="togglePolicy('return')">
                        <span>Return Policy</span>
                        <i class="fa fa-chevron-down" id="icon-return" style="font-size:0.7rem; transition:transform 0.2s;"></i>
                    </button>
                    <div class="sf-policy-body" id="body-return"></div>
                </div>
                <div id="sf-shipping-wrap">
                    <button class="sf-policy-toggle" onclick="togglePolicy('shipping')">
                        <span>Shipping Policy</span>
                        <i class="fa fa-chevron-down" id="icon-shipping" style="font-size:0.7rem; transition:transform 0.2s;"></i>
                    </button>
                    <div class="sf-policy-body" id="body-shipping"></div>
                </div>
            </div>

        </aside>

        <!-- Products section -->
        <main id="products">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; flex-wrap:wrap; gap:0.5rem;">
                <h3 style="margin:0; font-size:1rem;" id="sf-products-heading">Products</h3>
                <div style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
                    <select id="sf-cat-filter" class="ops-input" style="width:auto; font-size:0.8rem;" onchange="filterStorefront()">
                        <option value="">All Categories</option>
                    </select>
                    <span id="sf-product-count" style="font-size:0.78rem; color:var(--text-muted);"></span>
                </div>
            </div>

            <div id="sf-products-grid" class="sf-products-grid">
                <div style="grid-column:1/-1; text-align:center; padding:3rem;">
                    <div class="load-more-spinner" style="margin:0 auto;"></div>
                </div>
            </div>

            <div id="sf-empty" style="display:none; text-align:center; padding:3rem; color:var(--text-muted);">
                <i class="fa fa-box-open" style="font-size:2.5rem; margin-bottom:1rem; opacity:0.4;"></i>
                <p>This store has no active listings right now.</p>
            </div>
        </main>

    </div>

    <!-- Seller reviews section -->
    <div class="seller-reviews-section" id="seller-reviews-section" style="display:none;">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem; flex-wrap:wrap; gap:0.5rem;">
            <h3 style="margin:0; font-size:1rem;">Customer Reviews of This Seller</h3>
            <span id="sr-count-label" style="font-size:0.8rem; color:var(--text-muted);"></span>
        </div>
        <div id="sr-cta-container" style="margin-bottom:1.5rem; display:none;">
            <button class="btn btn-sm" style="border:1px solid var(--toast-success-border); color:var(--toast-success-fg); background:var(--toast-success-bg);" onclick="openSellerReviewModal()">
                <i class="fa fa-star"></i> Leave a Seller Review
            </button>
        </div>
        <div id="sr-avg-row" style="display:none; align-items:center; gap:0.65rem; margin-bottom:1rem; flex-wrap:wrap;">
            <span style="font-size:1.8rem; font-weight:800;" id="sr-avg-num"></span>
            <div>
                <div id="sr-avg-stars" style="font-size:0.95rem;"></div>
                <div id="sr-breakdown" style="margin-top:0.4rem;"></div>
            </div>
        </div>
        <div id="sr-list"></div>
        <div id="sr-load-more-wrap" style="display:none; text-align:center; margin-top:1rem;">
            <button class="btn btn-outline" style="width:auto; font-size:0.82rem;" onclick="loadMoreSellerReviews()">Load More Reviews</button>
        </div>
        <div id="sr-empty" style="display:none; text-align:center; padding:2rem; color:var(--text-muted);">
            <i class="fa fa-star" style="font-size:1.75rem; margin-bottom:0.75rem; display:block; color:var(--border-light);"></i>
            <div style="font-weight:600; margin-bottom:0.25rem;">No seller reviews yet</div>
            <div class="small">Be the first to review this seller after completing an order.</div>
        </div>
    </div>
</div>

<!-- Seller Review Modal -->
<div class="review-modal-overlay" id="seller-review-modal" onclick="if(event.target===this) this.classList.remove('open')">
    <div class="review-modal">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
            <h4 style="margin:0;">Rate this Seller</h4>
            <button onclick="document.getElementById('seller-review-modal').classList.remove('open')" style="background:none; border:none; cursor:pointer; font-size:1.25rem; color:var(--text-muted);">&times;</button>
        </div>
        <div style="margin-bottom:1rem;">
            <label style="font-size:0.85rem; font-weight:600; display:block; margin-bottom:0.5rem;">Rating</label>
            <div class="star-group" id="seller-star-group">
                <span class="star" data-val="1" onclick="setSellerRating(1)">&#9733;</span>
                <span class="star" data-val="2" onclick="setSellerRating(2)">&#9733;</span>
                <span class="star" data-val="3" onclick="setSellerRating(3)">&#9733;</span>
                <span class="star" data-val="4" onclick="setSellerRating(4)">&#9733;</span>
                <span class="star" data-val="5" onclick="setSellerRating(5)">&#9733;</span>
            </div>
        </div>
        <div class="form-group mb-4">
            <label>Experience Tags</label>
            <div style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:0.5rem;">
                <label style="font-weight:400; font-size:0.85rem; cursor:pointer;"><input type="checkbox" name="seller-tag" value="fast_shipping"> Fast Shipping</label>
                <label style="font-weight:400; font-size:0.85rem; cursor:pointer;"><input type="checkbox" name="seller-tag" value="good_communication"> Good Communication</label>
                <label style="font-weight:400; font-size:0.85rem; cursor:pointer;"><input type="checkbox" name="seller-tag" value="accurate_description"> Accurate Description</label>
                <label style="font-weight:400; font-size:0.85rem; cursor:pointer;"><input type="checkbox" name="seller-tag" value="well_packaged"> Well Packaged</label>
            </div>
        </div>
        <div class="form-group mb-4">
            <label>Comments (optional)</label>
            <textarea id="seller-review-body" placeholder="Any additional comments on the seller..." rows="3"></textarea>
        </div>
        <button id="seller-review-submit-btn" class="btn btn-red" onclick="submitSellerReview()">Submit Rating</button>
    </div>
</div>

<script>
    // Stale store ID from server-side template
    const STORE_ID = '<%= storeId %>';

    let _allProducts = [];
    let _storeData   = null;

    // ── Auth ──────────────────────────────────────────────────────────────────
    const token = localStorage.getItem('access_token');
    let currentUser = null;
    if (token) {
        try {
            currentUser = JSON.parse(atob(token.split('.')[1]));
        } catch {}
    }

    if (currentUser && currentUser.storeId === STORE_ID) {
        document.getElementById('sf-cta-btn').style.display = 'inline-flex';
        document.getElementById('sf-msg-btn').style.display = 'none';
    }

    // ── Countdown helper ──────────────────────────────────────────────────────
    function formatCountdown(endsAt) {
        const diff = new Date(endsAt) - Date.now();
        if (diff <= 0) return 'Sale ended';
        const d = Math.floor(diff / 86400000);
        const h = Math.floor((diff % 86400000) / 3600000);
        const m = Math.floor((diff % 3600000) / 60000);
        if (d > 0) return `Ends in ${d}d ${h}h`;
        if (h > 0) return `Ends in ${h}h ${m}m`;
        return `Ends in ${m}m`;
    }

    // ── Policy accordion ──────────────────────────────────────────────────────
    function togglePolicy(which) {
        const body = document.getElementById(`body-${which}`);
        const icon = document.getElementById(`icon-${which}`);
        const open = body.style.display === 'block';
        body.style.display = open ? 'none' : 'block';
        icon.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
    }

    // ── Load store info ───────────────────────────────────────────────────────
    async function loadStore() {
        try {
            const res = await fetch(`/api/public-seller/${STORE_ID}`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const store = await res.json();
            _storeData = store;

            const initial = (store.name || '?').charAt(0).toUpperCase();
            document.getElementById('sf-avatar').textContent = initial;
            document.getElementById('sf-store-name').textContent = store.name || 'Unknown Store';
            document.title = `${store.name || 'Store'} — Markee`;

            if (store.description) {
                document.getElementById('sf-store-desc').textContent = store.description;
            }

            const pill = document.getElementById('store-open-badge');
            pill.style.display = 'inline-block';
            if (store.isOpen) {
                pill.textContent = '● OPEN';
                pill.className = 'sf-open-pill open';
                const hoursEl = document.getElementById('sf-hours-meta');
                if (store.closesAt) hoursEl.textContent = `Closes at ${store.closesAt}`;
            } else {
                pill.textContent = '● CLOSED';
                pill.className = 'sf-open-pill closed';
                const hoursEl = document.getElementById('sf-hours-meta');
                if (store.nextOpen) hoursEl.textContent = `Opens ${store.nextOpen}`;
            }

            _currentIsOpen = store.isOpen;
            updateOpenBadge(store.isOpen, store.nextOpen, store.closesAt, store.vacationMode);

            if (store.lastActive) {
                const hoursSince = (Date.now() - new Date(store.lastActive)) / 3600000;
                if (hoursSince < 24) {
                    document.getElementById('sf-online-dot').style.display = 'inline-block';
                }
            }

            document.getElementById('sf-total-sales').textContent  = `$${((store.totalSales || 0) / 100).toLocaleString()}`;
            document.getElementById('sf-total-orders').textContent = store.totalOrders || 0;

            if (store.banner?.imageUrl) {
                document.getElementById('sf-main-banner').src = store.banner.imageUrl;
                document.getElementById('sf-main-banner').alt = store.banner.altText || store.name;
                document.getElementById('banner-wrap').style.display = 'block';
            }

            if (store.salesBanner) {
                const sb = store.salesBanner;
                document.getElementById('sf-sale-banner').style.display = 'block';
                document.getElementById('sf-sale-headline').textContent = sb.headline || 'Sale On Now';
                document.getElementById('sf-sale-subtext').textContent  = sb.subtext  || '';
                if (sb.imageUrl) {
                    document.getElementById('sf-sale-banner-bg').style.backgroundImage = `url('${sb.imageUrl}')`;
                }
                if (sb.ctaLabel) {
                    document.getElementById('sf-sale-cta').textContent = sb.ctaLabel + ' →';
                }
                if (sb.endsAt) {
                    const cd = document.getElementById('sf-sale-countdown');
                    cd.textContent = formatCountdown(sb.endsAt);
                    setInterval(() => { cd.textContent = formatCountdown(sb.endsAt); }, 60000);
                }
                if (sb.discountPercent) {
                    document.getElementById('sf-sale-headline').textContent =
                        sb.headline || `Up to ${sb.discountPercent}% Off`;
                }
            }

            if (store.responseTime) {
                const el = document.getElementById('sf-response-time');
                el.style.display = 'flex';
                el.querySelector('span').textContent = store.responseTime;
            }
            if (store.phone) {
                const el = document.getElementById('sf-phone');
                el.style.display = 'flex';
                el.querySelector('span').textContent = store.phone;
            }
            if (store.createdAt) {
                const el = document.getElementById('sf-member-since');
                el.style.display = 'flex';
                el.querySelector('span').textContent = `Member since ${new Date(store.createdAt).toLocaleDateString('en-CA', { year:'numeric', month:'short' })}`;
            }

            const days   = ['sun','mon','tue','wed','thu','fri','sat'];
            const dayKey = days[new Date().getDay()];
            const todaySch = store.schedule?.[dayKey];
            if (todaySch) {
                const el = document.getElementById('sf-schedule-today');
                el.style.display = 'flex';
                el.querySelector('span').textContent = todaySch.open
                    ? `Today ${todaySch.openTime || '09:00'} – ${todaySch.closeTime || '18:00'}`
                    : 'Closed today';
            }

            if (store.discount?.storeWide?.enabled && store.discount.storeWide.percent > 0) {
                document.getElementById('sf-discount-card').style.display = 'block';
                let txt = `${store.discount.storeWide.percent}% off all products`;
                if (store.discount.storeWide.endsAt) {
                    txt += ` · ${formatCountdown(store.discount.storeWide.endsAt)}`;
                }
                document.getElementById('sf-discount-body').textContent = txt;
            }

            const hasReturn   = !!store.returnPolicy;
            const hasShipping = !!store.shippingPolicy;
            if (hasReturn || hasShipping) {
                document.getElementById('sf-policies-card').style.display = 'block';
                if (hasReturn)   document.getElementById('body-return').textContent   = store.returnPolicy;
                if (hasShipping) document.getElementById('body-shipping').textContent = store.shippingPolicy;
                if (!hasReturn)  document.getElementById('sf-return-wrap').style.display   = 'none';
                if (!hasShipping)document.getElementById('sf-shipping-wrap').style.display = 'none';
            }

        loadSellerRatingSidebar(STORE_ID);

        } catch (err) {
            document.getElementById('sf-store-name').textContent = 'Store unavailable';
            console.error('[Storefront] loadStore error:', err.message);
        }
    }

    async function loadSellerRatingSidebar(storeId) {
        try {
            const res = await fetch(`/api/reviews/seller/${storeId}/stats`);
            if (!res.ok) return;
            const stats = await res.json();
            if (!stats.totalCount) return;
            const replyPct = stats.replyRate != null ? Math.round(stats.replyRate * 100) : null;
            document.getElementById('sf-ratings-body').innerHTML = `
                <div style="display:flex; align-items:center; gap:0.5rem;">
                    <span style="font-size:1.2rem; font-weight:800;">${(stats.avgRating||0).toFixed(1)}</span>
                    <span style="color:#f59e0b;">${renderStarsHtml(stats.avgRating||0)}</span>
                </div>
                <div style="color:var(--text-muted);">${stats.totalCount} review${stats.totalCount!==1?'s':''}</div>
                ${replyPct != null ? `<div style="color:var(--text-muted);">Responds to <strong style="color:var(--text-main);">${replyPct}%</strong> of reviews</div>` : ''}`;
            document.getElementById('sf-ratings-card').style.display = 'block';

            if (stats.storeRating) {
                const sr = stats.storeRating;
                const srBody = document.getElementById('sf-store-rating-body');
                if (sr.totalCount > 0) {
                    const tagHtml = Object.entries(sr.tagBreakdown || {})
                        .slice(0, 3)
                        .map(([t]) => `<span style="background:var(--bg-secondary); color:var(--text-muted); font-size:0.7rem; padding:0.1rem 0.4rem; border-radius:4px; border:1px solid var(--border-light); display:inline-block; margin-top:0.2rem; text-transform:capitalize;">${t.replace(/_/g,' ')}</span>`)
                        .join(' ');
                        
                    srBody.innerHTML = `
                        <div style="display:flex; align-items:center; gap:0.5rem;">
                            <span style="font-size:1.2rem; font-weight:800;">${(sr.avgRating||0).toFixed(1)}</span>
                            <span style="color:#f59e0b;">${renderStarsHtml(sr.avgRating||0)}</span>
                        </div>
                        <div style="color:var(--text-muted);">${sr.totalCount} seller review${sr.totalCount!==1?'s':''}</div>
                        ${tagHtml ? `<div style="display:flex; flex-wrap:wrap; gap:0.3rem;">${tagHtml}</div>` : ''}`;
                } else {
                    srBody.innerHTML = `
                        <div style="color:var(--text-muted); font-style:italic;">No store reviews yet.</div>
                        <div style="margin-top:0.4rem; font-size:0.75rem;"><a href="#seller-reviews-section" style="color:var(--accent-red); text-decoration:none;">Be the first to review →</a></div>`;
                }
                document.getElementById('sf-store-rating-card').style.display = 'block';
            }
        } catch {}
    }

    // ── Load products ─────────────────────────────────────────────────────────
    async function loadProducts() {
        try {
            const res = await fetch(`/api/catalog/by-seller/${STORE_ID}`);
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            _allProducts = await res.json();

            const cats = [...new Set(_allProducts.map(p => p.category).filter(Boolean))].sort();
            const sel = document.getElementById('sf-cat-filter');
            cats.forEach(c => {
                const opt = document.createElement('option');
                opt.value = c; opt.textContent = c;
                sel.appendChild(opt);
            });

            renderProducts(_allProducts);
        } catch (err) {
            document.getElementById('sf-products-grid').innerHTML = `
                <div style="grid-column:1/-1; text-align:center; padding:2rem; color:var(--text-muted);">
                    <i class="fa fa-exclamation-circle" style="margin-right:0.5rem;"></i>
                    Could not load products.
                </div>`;
        }
    }

    function filterStorefront() {
        const cat = document.getElementById('sf-cat-filter').value;
        const filtered = cat ? _allProducts.filter(p => p.category === cat) : _allProducts;
        renderProducts(filtered);
    }

    function renderProducts(products) {
        const grid = document.getElementById('sf-products-grid');
        const heading = document.getElementById('sf-products-heading');
        const count   = document.getElementById('sf-product-count');

        if (!products.length) {
            grid.innerHTML = '';
            document.getElementById('sf-empty').style.display = 'block';
            count.textContent = '';
            return;
        }
        document.getElementById('sf-empty').style.display = 'none';
        count.textContent = `${products.length} listing${products.length !== 1 ? 's' : ''}`;
        if (_storeData?.name) heading.textContent = `${_storeData.name}'s Listings`;

        grid.innerHTML = products.map(p => renderProductCard(p)).join('');
    }

    function renderProductCard(p) {
        const di = p.discountInfo;
        const rawPrice  = (p.price || 0) / 100;
        const img       = (p.images && p.images[0]) ? p.images[0] : 'https://via.placeholder.com/300?text=No+Image';
        const safeTitle = (p.title || '').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        const productData = JSON.stringify({
            _id: p._id, title: p.title, price: p.price, images: p.images || [],
            sellerId: STORE_ID, fastDeliveryFee: p.fastDeliveryFee || 0,
            fulfillmentOptions: p.fulfillmentOptions || [],
            enabledCarriers:    p.enabledCarriers   || [],
            pickupLocationId:   p.pickupLocationId  || null
        }).replace(/"/g, '&quot;');

        const priceHtml = di
            ? `<span class="price-pill" style="text-decoration:line-through; opacity:0.55; font-size:0.75rem;">$${rawPrice.toLocaleString()}</span>
               <span class="price-pill" style="color:#b91c1c;">$${(di.discountedPrice / 100).toLocaleString()}</span>
               <span style="font-size:0.6rem; background:#fef2f2; color:#b91c1c; border:1px solid #fecaca; border-radius:4px; padding:0.1rem 0.3rem; font-weight:700;">-${di.percent}%</span>`
            : `<span class="price-pill">$${rawPrice.toLocaleString()}</span>`;

        const countdownHtml = di?.endsAt
            ? `<div style="font-size:0.62rem; color:#b91c1c; margin-top:0.2rem;">${formatCountdown(di.endsAt)}</div>`
            : '';

        return `
            <div class="product-card" onclick="window.location='/product/${p._id}'">
                <div class="product-img-wrapper">
                    <img src="${img}" alt="${safeTitle}" loading="lazy" onerror="this.onerror=null; this.style.visibility='hidden'">
                </div>
                <div class="product-info">
                    <div style="display:flex; gap:0.3rem; flex-wrap:wrap; align-items:center;">${priceHtml}</div>
                    ${countdownHtml}
                    ${p.reviewCount >= 5 ? `<div style="font-size:0.72rem; color:#f59e0b; margin-top:0.15rem; margin-bottom:0.1rem;"><i class="fa fa-star"></i> ${(p.rating||0).toFixed(1)} <span style="color:var(--text-muted);">(${p.reviewCount})</span></div>` : ''}
                    <h4>${p.title || 'Product'}</h4>
                    <p class="text-muted small">${p.category || 'Uncategorized'}</p>
                </div>
                <div class="card-cta-row">
                    <button class="cta-btn cta-btn-cart" onclick='addToCartFromCard(${productData}, event)' title="Add to Cart">
                        <i class="fa fa-cart-plus"></i> Cart
                    </button>
                    <button class="cta-btn cta-btn-view" onclick="event.stopPropagation(); window.location='/product/${p._id}'" title="View">
                        <i class="fa fa-eye"></i> View
                    </button>
                </div>
            </div>`;
    }

    function addToCartFromCard(product, event) {
        if (event) event.stopPropagation();
        if (window.MarkeeCart) {
            MarkeeCart.addItem(product);
            if (window.showToast) showToast(`Added "${(product.title || '').slice(0,30)}..." to cart`, 'success');
        }
    }

    function messageStore() {
        if (!currentUser) { window.location.href = `/login?next=/messages`; return; }
        window.location.href = `/messages`;
    }

    // ── Helpers ───────────────────────────────────────────────────────────────
    function renderStarsHtml(rating) {
        const full = Math.floor(rating);
        const half = rating - full >= 0.5;
        const empty = 5 - full - (half ? 1 : 0);
        return [
            ...Array(full).fill('<i class="fa fa-star" style="color:#f59e0b;"></i>'),
            ...(half ? ['<i class="fa fa-star-half-alt" style="color:#f59e0b;"></i>'] : []),
            ...Array(empty).fill('<i class="fa fa-star" style="color:#d1d5db;"></i>')
        ].join('');
    }

    function escHtml(str) {
        const d = document.createElement('div');
        d.appendChild(document.createTextNode(str || ''));
        return d.innerHTML;
    }

    function fmtDate(iso) {
        return new Date(iso).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' });
    }

    // ── Seller reviews ────────────────────────────────────────────────────────
    let _srAllReviews  = [];
    let _srPageSize    = 5;
    let _srShown       = 0;
    let _eligibleOrderId = null;

    async function loadSellerReviews() {
        try {
            const res = await fetch(`/api/reviews/seller-reviews/${STORE_ID}`);
            if (!res.ok) return;
            const data = await res.json();
            const reviews   = data.reviews   || [];
            const avg       = data.avgRating  || 0;
            const total     = data.totalCount || reviews.length;
            const breakdown = data.breakdown  || null;

            document.getElementById('seller-reviews-section').style.display = 'block';

            if (!total) {
                document.getElementById('sr-empty').style.display = 'block';
            } else {
                document.getElementById('sr-count-label').textContent = `${total} review${total!==1?'s':''}`;
            }

            if (token) {
                try {
                    const cRes = await fetch(`/api/reviews/check/seller/${STORE_ID}`, { headers: { Authorization: `Bearer ${token}` } });
                    if (cRes.ok) {
                        const eligibility = await cRes.json();
                        if (eligibility.canReview && !eligibility.alreadyReviewed) {
                            _eligibleOrderId = eligibility.orderId;
                            document.getElementById('sr-cta-container').style.display = 'block';
                        }
                    }
                } catch {}
            }

            if (!total) return;

            if (avg > 0) {
                const row = document.getElementById('sr-avg-row');
                row.style.display = 'flex';
                document.getElementById('sr-avg-num').textContent = avg.toFixed(1);
                document.getElementById('sr-avg-stars').innerHTML = renderStarsHtml(avg);
                if (breakdown) {
                    const barsHtml = [5,4,3,2,1].map(n => {
                        const count = breakdown[n] || 0;
                        const pct = total ? Math.round((count/total)*100) : 0;
                        return `<div style="display:flex; align-items:center; gap:0.5rem; font-size:0.72rem; margin-bottom:0.15rem;">
                            <span style="width:10px; text-align:right; color:var(--text-muted);">${n}</span>
                            <i class="fa fa-star" style="color:#f59e0b; font-size:0.6rem;"></i>
                            <div style="flex:1; height:5px; background:var(--bg-secondary); border-radius:3px; overflow:hidden;">
                                <div style="height:100%; width:${pct}%; background:#f59e0b; border-radius:3px;"></div>
                            </div>
                            <span style="width:26px; color:var(--text-muted);">${pct}%</span>
                        </div>`;
                    }).join('');
                    document.getElementById('sr-breakdown').innerHTML = barsHtml;
                }
            }

            _srAllReviews = reviews;
            _srShown = 0;
            appendSellerReviews();

        } catch (err) {
            console.error('[Storefront] loadSellerReviews error:', err.message);
        }
    }

    function appendSellerReviews() {
        const batch = _srAllReviews.slice(_srShown, _srShown + _srPageSize);
        const list  = document.getElementById('sr-list');
        batch.forEach(r => {
            const el = document.createElement('div');
            el.innerHTML = renderSellerReviewCard(r);
            list.appendChild(el.firstElementChild);
        });
        _srShown += batch.length;
        const moreWrap = document.getElementById('sr-load-more-wrap');
        moreWrap.style.display = _srShown < _srAllReviews.length ? 'block' : 'none';
    }

    function loadMoreSellerReviews() {
        appendSellerReviews();
    }

    function renderSellerReviewCard(r) {
        const buyerLabel = 'Buyer #' + (r.buyerId||'').toString().slice(-4).toUpperCase();
        const tagsHtml = (r.tags || []).map(t =>
            `<span class="sr-tag">${escHtml(t.replace(/_/g,' '))}</span>`
        ).join('');
        const replyHtml = r.sellerReply?.body
            ? `<div style="margin-top:0.65rem; background:var(--bg-secondary); border-left:3px solid var(--accent-red); border-radius:0 8px 8px 0; padding:0.55rem 0.85rem;">
                   <div style="font-size:0.7rem; font-weight:700; color:var(--accent-red); margin-bottom:0.2rem;">
                       <i class="fa fa-store" style="margin-right:0.3rem;"></i> Seller Response
                   </div>
                   <div style="font-size:0.8rem; color:var(--text-main); line-height:1.5;">${escHtml(r.sellerReply.body)}</div>
               </div>` : '';
        return `
        <div class="seller-review-card">
            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:0.4rem; flex-wrap:wrap; gap:0.3rem;">
                <div>
                    <span style="font-weight:600; font-size:0.875rem;">${buyerLabel}</span>
                    <span style="margin-left:0.4rem; font-size:0.65rem; background:#f0fdf4; color:#15803d; border:1px solid #bbf7d0; border-radius:4px; padding:0.05rem 0.35rem; font-weight:700;">Verified</span>
                    <div style="font-size:0.85rem; color:#f59e0b; margin-top:0.15rem;">${renderStarsHtml(r.rating)}</div>
                </div>
                <span style="font-size:0.72rem; color:var(--text-muted);">${fmtDate(r.createdAt)}</span>
            </div>
            <div style="font-size:0.875rem; color:var(--text-main); line-height:1.55;">${escHtml(r.body||'')}</div>
            ${tagsHtml ? `<div style="margin-top:0.35rem;">${tagsHtml}</div>` : ''}
            ${replyHtml}
        </div>`;
    }

    // ── Open/closed badge polling ─────────────────────────────────────────────
    let _currentIsOpen = null;

    function updateOpenBadge(isOpen, nextOpen, closesAt, vacationMode) {
        const badge = document.getElementById('store-open-badge');
        if (!badge) return;

        if (vacationMode && vacationMode.active) {
            badge.className = 'store-badge vacation';
            badge.innerHTML = `<i class="fa fa-umbrella-beach"></i> On Vacation`;
            badge.title = vacationMode.message || '';
            return;
        }
        if (isOpen) {
            badge.className = 'store-badge open';
            badge.innerHTML = `<i class="fa fa-circle" style="color:#10b981; font-size:0.6rem;"></i> Open`;
            if (closesAt) badge.title = `Closes at ${closesAt}`;
        } else {
            badge.className = 'store-badge closed';
            badge.innerHTML = `<i class="fa fa-circle" style="color:#ef4444; font-size:0.6rem;"></i> Closed`;
            if (nextOpen) badge.title = `Opens ${nextOpen}`;
        }
    }

    async function checkStoreOpen() {
        try {
            const storeIdVal = typeof STORE_ID !== 'undefined' ? STORE_ID : '';
            if (!storeIdVal) return;
            const r = await fetch(`/api/public-seller/${storeIdVal}`);
            if (!r.ok) return;
            const data = await r.json();
            if (data.isOpen !== _currentIsOpen) {
                _currentIsOpen = data.isOpen;
                updateOpenBadge(data.isOpen, data.nextOpen, data.closesAt, data.vacationMode);
            }
        } catch {}
    }

    setInterval(checkStoreOpen, 5 * 60 * 1000);

    // ── Init ──────────────────────────────────────────────────────────────────
    Promise.all([loadStore(), loadProducts(), loadSellerReviews()]);

    // ── Seller Rating JS ───────────────────────────────────────────────────────
    let currentSellerRating = 0;

    function setSellerRating(val) {
        currentSellerRating = val;
        const group = document.getElementById('seller-star-group');
        const stars = group.querySelectorAll('.star');
        stars.forEach((s, idx) => {
            if (idx < val) s.classList.add('filled');
            else s.classList.remove('filled');
        });
    }

    function openSellerReviewModal() {
        setSellerRating(0);
        document.getElementById('seller-review-body').value = '';
        document.querySelectorAll('input[name="seller-tag"]').forEach(cb => cb.checked = false);
        document.getElementById('seller-review-modal').classList.add('open');
    }

    async function submitSellerReview() {
        if (!currentSellerRating) { showToast('Please select a rating', 'error'); return; }
        const btn = document.getElementById('seller-review-submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Submitting...';

        const tags = Array.from(document.querySelectorAll('input[name="seller-tag"]:checked')).map(cb => cb.value);
        const body = document.getElementById('seller-review-body').value.trim();

        try {
            const res = await fetch('/api/reviews/seller', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ sellerId: STORE_ID, orderId: _eligibleOrderId, rating: currentSellerRating, tags, body })
            });

            const data = await res.json();
            if (!res.ok) throw new Error(data.error || 'Failed to submit rating');
            
            showToast('Seller rated successfully', 'success', 3500);
            document.getElementById('seller-review-modal').classList.remove('open');
            setTimeout(() => window.location.reload(), 1000);
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
            btn.disabled = false;
            btn.innerHTML = 'Submit Rating';
        }
    }
</script>
</body>
</html>
