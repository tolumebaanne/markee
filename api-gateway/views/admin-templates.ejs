<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Permission Templates | Markee Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <style>
        body { background:#0f172a;color:#f1f5f9; }
        .admin-shell { display:grid;grid-template-columns:220px 1fr;min-height:100vh; }
        .admin-sidebar { background:#1e293b;border-right:1px solid #334155;padding:1.5rem 1rem;position:sticky;top:0;height:100vh;overflow-y:auto; }
        .sidebar-logo { display:flex;align-items:center;gap:0.6rem;margin-bottom:1.75rem; }
        .sidebar-logo .mark { width:32px;height:32px;background:linear-gradient(135deg,#ef4444,#b91c1c);border-radius:8px;display:flex;align-items:center;justify-content:center; }
        .sidebar-logo .mark i { color:white;font-size:0.85rem; }
        .sidebar-logo span { font-weight:700;font-size:0.95rem; }
        .sidebar-section { font-size:0.68rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.08em;padding:0.5rem 0.5rem 0.25rem; }
        .sidebar-link { display:flex;align-items:center;gap:0.6rem;padding:0.6rem 0.75rem;border-radius:8px;color:#94a3b8;font-size:0.82rem;font-weight:500;text-decoration:none;cursor:pointer;transition:all 0.15s;border:none;background:none;width:100%; }
        .sidebar-link:hover { background:#334155;color:#f1f5f9; }
        .sidebar-link.active { background:#450a0a;color:#fca5a5; }
        .sidebar-link i { width:16px;text-align:center; }
        .admin-main { padding:2rem 2.5rem; }
        .page-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem; }
        .page-header h1 { font-size:1.4rem;font-weight:700;margin:0; }
        .templates-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.1rem; }
        .template-card { background:#1e293b;border:1px solid #334155;border-radius:12px;padding:1.25rem;position:relative; }
        .template-card.built-in { border-color:#1e3a5f; }
        .template-name { font-size:0.95rem;font-weight:700;margin-bottom:0.25rem; }
        .template-desc { font-size:0.75rem;color:#64748b;margin-bottom:0.9rem;line-height:1.4; }
        .template-perms { display:flex;flex-wrap:wrap;gap:0.3rem;margin-bottom:0.9rem; }
        .perm-chip { background:#0f172a;border:1px solid #334155;border-radius:5px;font-size:0.65rem;padding:0.15rem 0.4rem;color:#94a3b8; }
        .perm-chip.enabled { border-color:#1e3a5f;background:#0d1b2a;color:#93c5fd; }
        .template-footer { display:flex;align-items:center;justify-content:space-between; }
        .built-in-badge { font-size:0.65rem;font-weight:700;background:#1e3a5f;color:#93c5fd;padding:0.15rem 0.45rem;border-radius:5px;text-transform:uppercase; }
        .btn { padding:0.4rem 0.8rem;border-radius:7px;font-size:0.75rem;font-weight:600;cursor:pointer;border:none;transition:all 0.15s; }
        .btn-outline { background:transparent;color:#94a3b8;border:1px solid #334155; }
        .btn-outline:hover { background:#334155;color:#f1f5f9; }
        .btn-primary { background:#ef4444;color:white; }
        .btn-primary:hover { background:#dc2626; }
        .btn-danger-sm { background:#450a0a;color:#f87171;border:none; }
        .btn-danger-sm:hover { background:#7f1d1d; }
        .modal-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;align-items:center;justify-content:center; }
        .modal-overlay.open { display:flex; }
        .modal { background:#1e293b;border:1px solid #334155;border-radius:14px;padding:2rem;width:90%;max-width:640px;max-height:90vh;overflow-y:auto; }
        .modal h3 { margin:0 0 1.25rem;font-size:1rem;font-weight:700; }
        .form-group { margin-bottom:1rem; }
        .form-group label { display:block;font-size:0.75rem;font-weight:600;color:#94a3b8;margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.05em; }
        .form-group input, .form-group textarea {
            width:100%;padding:0.6rem 0.8rem;background:#0f172a;border:1px solid #334155;
            border-radius:7px;color:#f1f5f9;font-size:0.85rem;box-sizing:border-box;
        }
        .form-group textarea { min-height:60px;resize:vertical; }
        .perm-grid { display:grid;gap:0.6rem;margin-top:0.75rem; }
        .perm-domain { background:#0f172a;border:1px solid #334155;border-radius:8px;padding:0.7rem 0.9rem; }
        .perm-domain-title { font-size:0.7rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#64748b;margin-bottom:0.45rem; }
        .perm-toggles { display:flex;flex-wrap:wrap;gap:0.4rem; }
        .perm-toggle label { display:flex;align-items:center;gap:0.3rem;font-size:0.73rem;color:#94a3b8;cursor:pointer; }
        .perm-toggle input[type=checkbox] { width:13px;height:13px;accent-color:#ef4444; }
    </style>
</head>
<body>
<div class="admin-shell">
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <div class="mark"><i class="fa fa-shield-alt"></i></div>
            <span>Markee Admin</span>
        </div>
        <div class="sidebar-section">Navigation</div>
        <a class="sidebar-link" href="/admin"><i class="fa fa-th-large"></i> Overview</a>
        <a class="sidebar-link" href="/admin/accounts"><i class="fa fa-users-cog"></i> Admin Accounts</a>
        <a class="sidebar-link active" href="/admin/templates"><i class="fa fa-layer-group"></i> Templates</a>
        <a class="sidebar-link" href="/admin/intelligence"><i class="fa fa-brain"></i> Intelligence</a>
        <a class="sidebar-link" href="/admin/system"><i class="fa fa-cog"></i> System</a>
        <div style="margin-top:auto;padding-top:2rem;">
            <button class="sidebar-link" onclick="adminLogout()" style="color:#ef4444;">
                <i class="fa fa-sign-out-alt"></i> Logout
            </button>
        </div>
    </aside>

    <main class="admin-main">
        <div class="page-header">
            <div>
                <h1><i class="fa fa-layer-group" style="color:#ef4444;margin-right:0.5rem;"></i> Permission Templates</h1>
                <p style="color:#64748b;margin:0.25rem 0 0;font-size:0.82rem;">9 built-in presets + your custom templates</p>
            </div>
            <button class="btn btn-primary" onclick="openCreateModal()">
                <i class="fa fa-plus" style="margin-right:0.4rem;"></i> New Template
            </button>
        </div>

        <div id="templates-grid" class="templates-grid">
            <div style="color:#475569;padding:2rem;grid-column:1/-1;text-align:center;">
                <i class="fa fa-spinner fa-spin"></i> Loading templates...
            </div>
        </div>
    </main>
</div>

<!-- Create Template Modal -->
<div class="modal-overlay" id="create-modal">
    <div class="modal">
        <h3><i class="fa fa-layer-group" style="color:#ef4444;margin-right:0.5rem;"></i> Create Template</h3>
        <div class="form-group">
            <label>Template Name</label>
            <input type="text" id="new-name" placeholder="e.g. Regional Manager" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <textarea id="new-desc" placeholder="What is this template for?"></textarea>
        </div>
        <div class="form-group">
            <label>Permissions</label>
            <div id="create-perm-grid" class="perm-grid"></div>
        </div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1.25rem;">
            <button class="btn btn-outline" onclick="closeCreateModal()">Cancel</button>
            <button class="btn btn-primary" onclick="createTemplate()">
                <i class="fa fa-save" style="margin-right:0.3rem;"></i> Create Template
            </button>
        </div>
    </div>
</div>

<script>
const ADMIN_API = '/api/admin';
const token = () => localStorage.getItem('admin_access_token');
(function guard() {
    const t = token();
    if (!t) { window.location.replace('/admin-login'); return; }
    try {
        const payload = JSON.parse(atob(t.split('.')[1]));
        if (payload.exp && payload.exp * 1000 < Date.now()) {
            localStorage.removeItem('admin_access_token');
            localStorage.removeItem('admin_refresh_token');
            window.location.replace('/admin-login');
        }
    } catch { window.location.replace('/admin-login'); }
})();

async function api(method, path, body) {
    const res = await fetch(ADMIN_API + path, {
        method,
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token() },
        body: body ? JSON.stringify(body) : undefined
    });
    if (res.status === 401) {
        localStorage.removeItem('admin_access_token');
        localStorage.removeItem('admin_refresh_token');
        window.location.replace('/admin-login');
        return;
    }
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.message || 'Request failed');
    return data;
}
function adminLogout() {
    api('POST', '/auth/logout').catch(() => {});
    localStorage.removeItem('admin_access_token');
    localStorage.removeItem('admin_refresh_token');
    window.location.replace('/admin-login');
}

const PERM_DOMAINS = {
    auth:          ['read','write','ban','impersonate'],
    catalog:       ['read','write','approve','reject','feature','categoryMgmt','bulk'],
    orders:        ['read','forceStatus','cancel','bulk'],
    payments:      ['read','refund','release','partialRefund','freeze','splitRefund','resolveDisputes','payoutHold'],
    sellers:       ['read','write','verify','suspend','ban','regApproval','tier'],
    reviews:       ['read','moderate','delete','bulk'],
    messages:      ['read','moderate','inject','ban'],
    notifications: ['read','send','broadcast','editTemplates','prefOverride','config'],
    analytics:     ['read','readAll','export'],
    search:        ['read','feature','reindex','hide','autocomplete'],
    inventory:     ['read','adjust','freeze'],
    shipping:      ['read','forceStatus'],
    intelligence:  ['sellerScores','buyerScores','buyerOverride','fraudSignals','anomalies','leakage','balance','funnel'],
    config:        ['read','write'],
    audit:         ['readOwn','readAll','export']
};

function buildPermGrid(containerId, existing = {}) {
    const container = document.getElementById(containerId);
    container.innerHTML = Object.entries(PERM_DOMAINS).map(([domain, actions]) => `
        <div class="perm-domain">
            <div class="perm-domain-title">${domain}</div>
            <div class="perm-toggles">
                ${actions.map(action => `
                    <label class="perm-toggle">
                        <input type="checkbox" id="${containerId}-${domain}-${action}"
                            ${existing?.[domain]?.[action] ? 'checked' : ''} />
                        <span>${action}</span>
                    </label>
                `).join('')}
            </div>
        </div>
    `).join('');
}

function readPermGrid(containerId) {
    const perms = {};
    for (const [domain, actions] of Object.entries(PERM_DOMAINS)) {
        perms[domain] = {};
        for (const action of actions) {
            const el = document.getElementById(`${containerId}-${domain}-${action}`);
            perms[domain][action] = el?.checked || false;
        }
    }
    return perms;
}

function countEnabled(perms) {
    let n = 0;
    for (const domain of Object.values(perms || {}))
        for (const val of Object.values(domain)) if (val) n++;
    return n;
}

async function loadTemplates() {
    try {
        const templates = await api('GET', '/templates');
        const grid = document.getElementById('templates-grid');
        if (!templates?.length) {
            grid.innerHTML = '<div style="color:#475569;padding:2rem;grid-column:1/-1;text-align:center;">No templates found</div>';
            return;
        }
        grid.innerHTML = templates.map(t => {
            const enabled = countEnabled(t.permissions);
            const total   = Object.values(PERM_DOMAINS).reduce((s, a) => s + a.length, 0);
            return `
                <div class="template-card ${t.isBuiltIn ? 'built-in' : ''}">
                    <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:0.5rem;margin-bottom:0.4rem;">
                        <div class="template-name">${t.name}</div>
                        ${t.isBuiltIn ? '<span class="built-in-badge">Built-in</span>' : ''}
                    </div>
                    <div class="template-desc">${t.description || 'No description'}</div>
                    <div style="font-size:0.72rem;color:#64748b;margin-bottom:0.75rem;">
                        <i class="fa fa-check-circle" style="color:#4ade80;"></i> ${enabled} / ${total} permissions enabled
                    </div>
                    <div class="template-footer">
                        <div style="display:flex;gap:0.4rem;">
                            <button class="btn btn-outline" onclick="viewTemplate('${t._id}','${t.name}',${JSON.stringify(t.permissions).replace(/'/g,'\\\'')})">
                                <i class="fa fa-eye"></i> View
                            </button>
                        </div>
                        ${!t.isBuiltIn ? `<button class="btn btn-danger-sm" onclick="deleteTemplate('${t._id}','${t.name}')"><i class="fa fa-trash"></i></button>` : ''}
                    </div>
                </div>
            `;
        }).join('');
    } catch (err) {
        document.getElementById('templates-grid').innerHTML = `<div style="color:#f87171;padding:2rem;grid-column:1/-1;text-align:center;">${err.message}</div>`;
    }
}

function openCreateModal() {
    buildPermGrid('create-perm-grid');
    document.getElementById('create-modal').classList.add('open');
}
function closeCreateModal() { document.getElementById('create-modal').classList.remove('open'); }

async function createTemplate() {
    const name = document.getElementById('new-name').value.trim();
    const desc = document.getElementById('new-desc').value.trim();
    if (!name) { showToast('Name is required', 'error'); return; }
    const permissions = readPermGrid('create-perm-grid');
    try {
        await api('POST', '/templates', { name, description: desc, permissions });
        showToast('Template created', 'success');
        closeCreateModal();
        loadTemplates();
    } catch (err) { showToast(err.message, 'error'); }
}

function viewTemplate(id, name, perms) {
    // Build a read-only modal inline
    const modal = document.createElement('div');
    modal.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:2000;display:flex;align-items:center;justify-content:center;';
    modal.innerHTML = `
        <div style="background:#1e293b;border:1px solid #334155;border-radius:14px;padding:2rem;width:90%;max-width:640px;max-height:90vh;overflow-y:auto;">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.25rem;">
                <h3 style="margin:0;font-size:1rem;">${name}</h3>
                <button style="background:none;border:none;color:#94a3b8;font-size:1.2rem;cursor:pointer;" onclick="this.closest('[style]').remove()">×</button>
            </div>
            <div id="view-perm-grid" style="display:grid;gap:0.5rem;"></div>
        </div>
    `;
    document.body.appendChild(modal);
    const grid = modal.querySelector('#view-perm-grid');
    grid.innerHTML = Object.entries(PERM_DOMAINS).map(([domain, actions]) => `
        <div style="background:#0f172a;border:1px solid #334155;border-radius:8px;padding:0.65rem 0.85rem;">
            <div style="font-size:0.7rem;font-weight:700;text-transform:uppercase;color:#64748b;margin-bottom:0.4rem;">${domain}</div>
            <div style="display:flex;flex-wrap:wrap;gap:0.3rem;">
                ${actions.map(action => `
                    <span style="font-size:0.68rem;padding:0.12rem 0.4rem;border-radius:4px;
                        ${perms?.[domain]?.[action] ? 'background:#052e16;color:#4ade80;border:1px solid #166534;' : 'background:#0f172a;color:#475569;border:1px solid #334155;'}">
                        ${action}
                    </span>
                `).join('')}
            </div>
        </div>
    `).join('');
}

async function deleteTemplate(id, name) {
    if (!confirm(`Delete template "${name}"?`)) return;
    try {
        await api('DELETE', `/templates/${id}`);
        showToast('Template deleted', 'success');
        loadTemplates();
    } catch (err) { showToast(err.message, 'error'); }
}

loadTemplates();
</script>
</body>
</html>
