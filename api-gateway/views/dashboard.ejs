                        </div>
                        <div id="active-orders-list" class="list-group">
                            <p class="text-muted p-4">Loading your orders...</p>
                        </div>
                    </div>

                    <!-- Order History card -->
                    <div class="card purchases-col">
                        <div class="card-header" style="flex-direction:column; align-items:flex-start; gap:0.5rem;">
                            <div style="display:flex; justify-content:space-between; align-items:center; width:100%;">
                                <h4 style="margin:0"><i class="fa fa-history" style="margin-right:0.5rem; color:var(--text-muted);"></i>Order History</h4>
                                <a href="/purchases/history" style="font-size:0.78rem; color:var(--accent-red); text-decoration:none; white-space:nowrap;">View Full History →</a>
                            </div>
                            <div class="filter-chip-row">
                                <button class="filter-chip active" data-range="all" onclick="filterOrderHistory(this)">All</button>
                                <button class="filter-chip" data-range="7d" onclick="filterOrderHistory(this)">1 week</button>
                                <button class="filter-chip" data-range="1m" onclick="filterOrderHistory(this)">1 month</button>
                                <button class="filter-chip" data-range="3m" onclick="filterOrderHistory(this)">3 months</button>
                                <button class="filter-chip" data-range="range" onclick="filterOrderHistory(this)">Range</button>
                            </div>
                        </div>
                        <div id="history-date-range" style="display:none; padding:0.6rem 1rem; border-bottom:1px solid var(--border-light); gap:0.5rem; align-items:center; flex-wrap:wrap;">
                            <input type="date" id="history-range-start" style="font-size:0.8rem; height:30px;">
                            <span style="color:var(--text-muted); font-size:0.8rem;">to</span>
                            <input type="date" id="history-range-end" style="font-size:0.8rem; height:30px;">
                            <button class="btn" style="width:auto; padding:0.3rem 0.8rem; font-size:0.78rem;" onclick="applyHistoryDateRange()">Apply</button>
                        </div>
                        <div id="history-orders-list" class="list-group">
                            <p class="text-muted p-4">Loading history...</p>
                        </div>
                    </div>
                </div>

                <!-- Bottom row: Suggestions full width (no card feel — floating) -->
                <div style="margin-top:1.25rem; padding:0 0.25rem;">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem; padding:0 0.25rem;">
                        <span style="font-size:0.82rem; color:var(--text-muted); font-weight:600;"><i class="fa fa-lightbulb-o" style="margin-right:0.4rem;"></i>Based on your purchases</span>
                    </div>
                    <div id="suggestions-strip" class="suggestions-strip">
                        <p class="text-muted suggestions-empty" style="font-size:0.82rem;">Loading suggestions...</p>
                    </div>
                </div>
            </div>

            <!-- Listings panel -->
            <div id="panel-listings" style="display:none;">
                <div class="card">
                    <div class="card-header flex-between">
                        <h4 style="margin:0" id="listings-heading">My Listings</h4>
                        <div style="display:flex; gap:0.6rem; align-items:center;">
                            <button type="button" class="btn btn-red" style="padding:0.3rem 0.75rem; font-size:0.8rem; width:auto;" onclick="openNewListingModal()">
                                <i class="fa fa-plus" style="margin-right:0.3rem;"></i> New Listing
                            </button>
                            <a href="/inventory" style="font-size:0.8rem; color:var(--accent-red);">Full Inventory →</a>
                        </div>
                    </div>
                    <!-- Search + filter bar -->
                    <div style="padding:0.75rem 1rem; border-bottom:1px solid var(--border-light); display:flex; gap:0.6rem; align-items:center;">
                        <div style="position:relative; flex:1;">
                            <i class="fa fa-search" style="position:absolute; left:0.65rem; top:50%; transform:translateY(-50%); color:var(--text-muted); font-size:0.78rem;"></i>
                            <input type="text" id="listing-search" placeholder="Search your listings..."
                                   style="padding-left:2rem; font-size:0.82rem; height:34px;"
                                   oninput="filterListings()">
                        </div>
                        <select id="listing-status-filter" style="font-size:0.82rem; height:34px; width:auto; padding:0 0.6rem;" onchange="filterListings()">
                            <option value="">All</option>
                            <option value="active">Active</option>
                            <option value="paused">Paused</option>
                        </select>
                    </div>
                    <div id="seller-products-list" class="list-group">
                        <p class="text-muted p-4">Loading your listings...</p>
                    </div>
                </div>
            </div>

            <!-- Seller Orders panel -->
            <div id="panel-orders" style="display:none;">
                <!-- Status summary chips -->
                <div id="orders-status-summary" style="display:flex; gap:0.5rem; flex-wrap:wrap; margin-bottom:0.75rem;"></div>
                <!-- Two-column layout: Orders Received (left) + Needs Action (right) -->
                <div class="orders-panel-row">
                    <!-- Left: Orders Received list -->
                    <div class="orders-received-panel">
                        <div class="card">
                            <div class="card-header flex-between">
                                <h4 style="margin:0"><i class="fa fa-inbox" style="margin-right:0.5rem; color:var(--accent-red);"></i>Orders Received</h4>
                                <div style="display:flex; gap:0.5rem; align-items:center;">
                                    <select id="orders-status-filter" style="font-size:0.78rem; height:30px; width:auto; padding:0 0.5rem; border-radius:6px;" onchange="filterSellerOrders()">
                                        <option value="">All statuses</option>
                                        <option value="pending">Pending</option>
                                        <option value="paid">Paid</option>
                                        <option value="processing">Processing</option>
                                        <option value="shipped">Shipped</option>
                                        <option value="delivered">Delivered</option>
                                        <option value="cancelled">Cancelled</option>
                                    </select>
                                </div>
                            </div>
                            <div id="seller-orders-list" class="list-group">
                                <p class="text-muted p-4">Loading orders...</p>
                            </div>
                        </div>
                    </div>
                    <!-- Right: Needs Action card -->
                    <div class="needs-action-card">
                        <div class="card-header" style="padding:0.85rem 1rem; border-bottom:1px solid var(--border-light); display:flex; align-items:center; gap:0.5rem;">
                            <h4 style="margin:0; font-size:0.95rem;"><i class="fa fa-exclamation-circle" style="color:var(--accent-red); margin-right:0.4rem;"></i>Needs Action</h4>
                            <span class="action-badge" id="needs-action-count">0</span>
                        </div>
                        <div id="needs-action-list" style="padding:0.5rem 0;"></div>
                        <div class="needs-action-empty" id="needs-action-empty" style="display:none;">
                            <i class="fa fa-check-circle" style="color:#15803d; font-size:1.4rem; margin-bottom:0.4rem;"></i>
                            <div>You're all caught up</div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Watchlist panel -->
            <div id="panel-watchlist" style="display:none;">
                <div class="card">
                    <div class="card-header flex-between">
                        <h4 style="margin:0">My Watchlist</h4>
                        <button class="btn btn-outline" style="width:auto; font-size:0.78rem; padding:0.3rem 0.7rem;" onclick="clearWatchlist()">Clear All</button>
                    </div>
                    <div id="watchlist-list" class="list-group">
                        <p class="text-muted p-4">Nothing saved yet. Click the ♡ on any product to save it.</p>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- ======= LISTING MODAL (new + edit) ======= -->
<div id="modal-backdrop" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:999; align-items:center; justify-content:center; padding:1rem;" onclick="handleBackdropClick(event)">
    <div class="card" style="max-width:520px; width:100%; max-height:92vh; overflow-y:auto;" onclick="event.stopPropagation()">
        <div class="card-header flex-between">
            <h4 style="margin:0" id="modal-title">New Listing</h4>
            <button class="btn btn-outline" style="padding:0.25rem 0.6rem; width:auto; font-size:1.1rem;" onclick="closeModal()">&times;</button>
        </div>
        <form id="listing-form" class="p-4" onsubmit="submitListing(event)">
            <input type="hidden" id="edit-id" value="">

            <div class="form-group mb-3">
                <label for="f-title">Title <span style="color:var(--accent-red)">*</span></label>
                <input type="text" id="f-title" placeholder="e.g. iPhone 15 Pro Max" required>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.75rem;" class="mb-3">
                <div class="form-group" style="margin:0;">
                    <label for="f-category">Category <span style="color:var(--accent-red)">*</span></label>
                    <select id="f-category" required>
                        <option value="Electronics">Electronics</option>
                        <option value="Vehicles">Vehicles</option>
                        <option value="Phones & Tablets">Phones &amp; Tablets</option>
                        <option value="Fashion">Fashion</option>
                        <option value="Home & Garden">Home &amp; Garden</option>
                        <option value="Gaming & Consoles">Gaming &amp; Consoles</option>
                        <option value="Toys & Games">Toys &amp; Games</option>
                        <option value="Health & Wellness">Health &amp; Wellness</option>
                        <option value="Property">Property</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group" style="margin:0;">
                    <label for="f-price">Price (USD) <span style="color:var(--accent-red)">*</span></label>
                    <input type="number" id="f-price" placeholder="49.99" step="0.01" min="0.01" required>
                </div>
            </div>

            <div class="form-group mb-3">
                <label for="f-images">Photos <span style="font-weight:400; color:var(--text-muted);">(up to 4)</span></label>
                <div class="upload-drop-zone" id="drop-zone" onclick="document.getElementById('f-images').click()"
                     ondragover="event.preventDefault(); this.classList.add('drag-over')"
                     ondragleave="this.classList.remove('drag-over')"
                     ondrop="handleDrop(event)">
                    <i class="fa fa-camera" style="font-size:1.4rem; margin-bottom:0.4rem; display:block;"></i>
                    Click to upload or drag &amp; drop photos
                </div>
                <input type="file" id="f-images" accept="image/*" multiple style="display:none" onchange="handleFileSelect(this.files)">
                <p class="compress-note"><i class="fa fa-compress-alt" style="margin-right:0.3rem;"></i>Images are automatically compressed to ~50 KB before upload.</p>
                <div class="img-preview-row" id="img-preview-row"></div>
            </div>

            <div class="form-group mb-4">
                <label for="f-description">Description</label>
                <textarea id="f-description" placeholder="Briefly describe what you're selling..." rows="3"></textarea>
            </div>

            <button type="submit" id="submit-btn" class="btn w-100" style="background:var(--accent-red);">Post Listing</button>
        </form>
    </div>
</div>

<script>
    // ── Auth guard ────────────────────────────────────────────────────────────
    const token = localStorage.getItem('access_token');
    if (!token) { window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search)); }

    function parseJwt(t) {
        try {
            const p = JSON.parse(atob(t.split('.')[1]));
            if (p.exp && p.exp * 1000 < Date.now()) {
                localStorage.removeItem('access_token');
                localStorage.removeItem('refresh_token');
                return null;
            }
            return p;
        } catch { return null; }
    }

    const userData = parseJwt(token);
    if (!userData) { window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search)); }

    // ── Navbar + role-based UI ────────────────────────────────────────────────
    const isSeller = userData.storeActive === true;
    const isAdmin  = userData.role === 'admin';

    if (userData.email) {
        const name = userData.displayName || userData.email.split('@')[0];
        document.getElementById('welcome-msg').textContent = `Welcome, ${name}`;
        document.getElementById('user-role-display').textContent =
            isSeller ? 'Buyer & Seller · Manage your store and purchases below.'
                     : 'Browse, buy, and manage your orders below.';
        // Populate nav avatar dropdown header
        const ddn = document.getElementById('dash-display-name');
        if (ddn) ddn.textContent = name;
        const ddr = document.getElementById('dash-display-role');
        if (ddr) ddr.textContent = isAdmin ? 'admin' : isSeller ? 'seller' : 'buyer';
    }

    if (isAdmin) {
        document.getElementById('nav-admin').style.display = 'inline';
        document.getElementById('admin-panel-btn').style.display = 'inline-flex';
        document.getElementById('tool-admin').style.display = 'flex';
    }

    // ── Store-tools visibility toggle (seller preference, stored in localStorage) ──
    function applyStoreToolsVisibility(show) {
        const btn  = document.getElementById('store-tools-toggle');
        const knob = document.getElementById('store-tools-knob');
        if (btn)  { btn.style.background  = show ? '#15803d' : '#d1d5db'; }
        if (knob) { knob.style.left       = show ? '16px'   : '2px'; }

        const sellerEl = [
            ['seller-stats-strip',    show ? 'grid'         : 'none'],
            ['buyer-stats-strip',     show ? 'none'         : 'grid'],
            ['tab-listings',          show ? 'inline-flex'  : 'none'],
            ['tab-analytics',         show ? 'inline-flex'  : 'none'],
            ['tab-insights',          show ? 'inline-flex'  : 'none'],
            ['seller-nav-section',    show ? 'block'        : 'none'],
            ['seller-mission-control',show ? ''             : 'none'],
            ['seller-quick-actions',  show ? 'block'        : 'none'],
        ];
        sellerEl.forEach(([id, val]) => {
            const el = document.getElementById(id);
            if (el) el.style.display = val;
        });

        // If store tools just turned off and a seller-only tab is active, fall back to overview
        if (!show) {
            const sellerOnlyTabs = ['listings', 'analytics', 'insights', 'operations'];
            const active = document.querySelector('.dash-tab.active');
            if (active && sellerOnlyTabs.includes(active.dataset.tab)) switchTab('overview');
        }
    }

    function toggleStoreTools() {
        const current = localStorage.getItem('dash_show_store') !== 'false';
        const next    = !current;
        localStorage.setItem('dash_show_store', next ? 'true' : 'false');
        applyStoreToolsVisibility(next);
    }

    // Show/hide seller tools sidebar and tabs based on storeActive flag
    if (isSeller || isAdmin) {
        // Orders tab is always visible for sellers regardless of store-tools toggle
        document.getElementById('tab-orders').style.display = 'inline-flex';
        const showStore = localStorage.getItem('dash_show_store') !== 'false';
        applyStoreToolsVisibility(showStore);
    } else {
        document.getElementById('start-selling-card').style.display = 'block';
        // Check if this user has existing products — if so they're a returning seller
        // whose store needs to be reactivated, not a brand-new seller.
        if (userData.storeId) {
            fetch('/api/catalog/my-products', { headers: { Authorization: `Bearer ${token}` } })
                .then(r => r.json())
                .then(products => {
                    if (Array.isArray(products) && products.length > 0) {
                        // Returning seller — update the card copy
                        const card = document.querySelector('#start-selling-card .card');
                        if (card) {
                            card.querySelector('div:first-child').textContent = '🔄';
                            card.querySelectorAll('div')[1].textContent = 'Reactivate Your Storefront';
                            card.querySelectorAll('div')[2].textContent =
                                `Your ${products.length} product listing(s) are ready — just reactivate your storefront to make them visible to buyers.`;
                            const nameInput = document.getElementById('new-store-name');
                            if (nameInput) nameInput.placeholder = 'Re-enter your store name to continue';
                            const btn = document.getElementById('start-selling-btn');
                            if (btn) btn.innerHTML = '<i class="fa fa-check-circle" style="margin-right:0.4rem;"></i> Reactivate Storefront';
                        }
                    }
                })
                .catch(() => {}); // best-effort
        }
    }

    // ── Profile completion nudge banner ──────────────────────────────────────
    function checkProfileNudge() {
        if (localStorage.getItem('markee_profile_nudge_dismissed')) return;
        const hasName = (userData && userData.displayName) || false;
        if (hasName) return;

        const mainContent = document.querySelector('.dash-viewport') || document.querySelector('.main-content') || document.querySelector('.content-area') || document.body;
        const banner = document.createElement('div');
        banner.id = 'profile-nudge-banner';
        banner.style.cssText = 'background:#fef3c7;border:1px solid #fbbf24;border-radius:10px;padding:0.75rem 1.25rem;margin-bottom:1rem;display:flex;align-items:center;gap:0.75rem;font-size:0.875rem;';
        banner.innerHTML = `
            <i class="fa fa-user-circle" style="color:#d97706;font-size:1.2rem;flex-shrink:0;"></i>
            <span style="flex:1;">Your profile is incomplete. <a href="/profile" style="color:var(--accent-red);font-weight:600;">Add a display name</a> so sellers know who you are.</span>
            <button onclick="dismissProfileNudge()" style="background:none;border:none;cursor:pointer;color:#92400e;font-size:1rem;" aria-label="Dismiss">&times;</button>
        `;
        mainContent.prepend(banner);
    }

    function dismissProfileNudge() {
        localStorage.setItem('markee_profile_nudge_dismissed', 'true');
        const banner = document.getElementById('profile-nudge-banner');
        if (banner) banner.remove();
    }

    // Call nudge after user data is available
    checkProfileNudge();

    function navSell() {
        if (userData && userData.storeActive) {
            switchTab('listings');
            openNewListingModal();
        } else {
            switchTab('overview');
            setTimeout(() => {
                const card = document.getElementById('start-selling-card');
                if (card) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }, 100);
        }
    }

    function toggleDashUserDropdown() {
        const dd  = document.getElementById('dash-user-dropdown');
        const btn = document.getElementById('dash-avatar-btn');
        if (!dd) return;
        const open = dd.style.display === 'none';
        dd.style.display = open ? 'block' : 'none';
        if (btn) btn.setAttribute('aria-expanded', String(open));
    }
    document.addEventListener('click', function(e) {
        if (!e.target.closest('#dash-avatar-btn') && !e.target.closest('#dash-user-dropdown')) {
            const dd = document.getElementById('dash-user-dropdown');
            if (dd) dd.style.display = 'none';
            const btn = document.getElementById('dash-avatar-btn');
            if (btn) btn.setAttribute('aria-expanded', 'false');
        }
    });

    function handleLogout() {
        localStorage.removeItem('access_token');
        localStorage.removeItem('refresh_token');
        window.location.replace('/');
    }

    // ── Tab switching ─────────────────────────────────────────────────────────
    let ordersLoaded = false, purchasesLoaded = false, analyticsLoaded = false;

    function switchTab(tab) {
        const allTabs = ['overview','listings','orders','purchases','watchlist','insights','analytics','operations'];
        allTabs.forEach(t => {
            const navEl   = document.getElementById(`nav-${t}`);
            const panelEl = document.getElementById(`panel-${t}`);
            // Legacy tab-btn IDs still work for backward compatibility with any inline onclick
            const tabEl   = document.getElementById(`tab-${t}`);
            if (navEl)   navEl.classList.toggle('active', t === tab);
            if (tabEl)   tabEl.classList.toggle('active', t === tab);
            if (panelEl) panelEl.style.display = t === tab ? 'block' : 'none';
        });
        if (tab === 'orders'    && !ordersLoaded)    { ordersLoaded    = true; loadSellerOrders(); }
        if (tab === 'purchases' && !purchasesLoaded) { purchasesLoaded = true; loadBuyerOrders(); }
        if (tab === 'analytics' && !analyticsLoaded) { analyticsLoaded = true; loadStoreAnalytics(); }
        if (tab === 'operations') { if (isSeller || isAdmin) loadOpsPanel(); }
        if (tab === 'watchlist') renderWatchlist();
        if (tab === 'overview' && typeof renderOverviewPanel === 'function') renderOverviewPanel();
    }

    function showWatchlist() { switchTab('watchlist'); }

    // ── Overview Intelligence ──────────────────────────────────────────────────
    async function renderOverviewPanel() {
        // Race condition guard: if seller products haven't loaded yet, wait
        if ((isSeller || isAdmin) && !window._storeHealthMetrics) {
            await loadSellerProducts();
        }

        if (isSeller || isAdmin) {
            const mc = document.getElementById('seller-mission-control');
            if (mc) mc.style.display = 'grid';
            const oa = document.getElementById('mc-orders-action');
            if (oa) oa.style.display = 'block';

            await Promise.allSettled([
                renderOverviewChart(),
                renderOverviewGauge(),
                renderOverviewFeed()
            ]);
            renderOverviewOrders();
        } else {
            // Buyer overview — watchlist preview + recent orders summary
            renderBuyerOverview();
        }
    }

    // Dual-axis engagement chart: revenue bars + cart-add bars per day (14 days)
    async function renderOverviewChart() {
        try {
            const [revRes, engRes] = await Promise.all([
                fetch('/api/analytics/revenue-trend?days=14', { headers: { Authorization: `Bearer ${token}` } }),
                fetch('/api/analytics/engagement-trend?days=14', { headers: { Authorization: `Bearer ${token}` } })
            ]);
            if (!revRes.ok || !engRes.ok) return;
            const revData = await revRes.json();
            const engData = await engRes.json();

            const maxRev  = Math.max(...revData.map(d => d.revenueCents || 0), 1);
            const maxCart = Math.max(...engData.map(d => d.cartAdds || 0), 1);
            const chartEl = document.getElementById('overview-engagement-chart');
            if (!chartEl) return;

            if (!revData.length) {
                chartEl.innerHTML = '<p class="text-muted small">No activity data yet.</p>';
                return;
            }

            chartEl.innerHTML = revData.map((d, i) => {
                const revPct  = Math.max(2, Math.round(((d.revenueCents || 0) / maxRev) * 76));
                const cartPct = Math.max(2, Math.round(((engData[i]?.cartAdds || 0) / maxCart) * 76));
                const label   = new Date(d.date + 'T00:00:00').toLocaleDateString('en-US', { month:'short', day:'numeric' });
                return `
                    <div style="display:flex; flex-direction:column; align-items:center; flex:1;"
                         title="${label}&#10;Revenue: $${((d.revenueCents||0)/100).toFixed(2)}&#10;Cart adds: ${engData[i]?.cartAdds || 0}">
                        <div style="display:flex; align-items:flex-end; gap:1px; height:76px;">
                            <div style="width:6px; height:${revPct}px; background:var(--accent-red); border-radius:2px 2px 0 0; opacity:0.85;"></div>
                            <div style="width:6px; height:${cartPct}px; background:#0e7490; border-radius:2px 2px 0 0; opacity:0.7;"></div>
                        </div>
                    </div>`;
            }).join('');
        } catch (e) {
            console.warn('renderOverviewChart:', e);
        }
    }

    async function renderOverviewGauge() {
        const el = document.getElementById('overview-gauge');
        if (!el) return;
        const m = window._storeHealthMetrics || {};
        const score = Math.min(100, Math.max(0, Math.round(
            ((m.avgQuality || 0) * 0.2) +
            ((m.topVelocity || 0) * 0.4) +
            ((m.conversionRate || 0) * 100 * 0.4)
        )));

        const color = score >= 70 ? '#15803d' : score >= 40 ? '#b45309' : '#b91c1c';
        const label = score >= 70 ? 'Strong' : score >= 40 ? 'Building' : 'Needs Work';

        el.innerHTML = `
            <div style="text-align:center; margin-bottom:0.75rem;">
                <div style="font-size:2.2rem; font-weight:800; color:${color}; line-height:1;">${score}</div>
                <div style="font-size:0.7rem; color:var(--text-muted); letter-spacing:0.08em; text-transform:uppercase;">Store Score</div>
                <div style="display:inline-block; font-size:0.72rem; font-weight:700; color:${color}; background:${color}18; border-radius:6px; padding:0.1rem 0.5rem; margin-top:0.2rem;">${label}</div>
            </div>
            <div style="height:8px; background:var(--border-light); border-radius:4px; overflow:hidden; margin-bottom:0.75rem;">
                <div style="height:100%; width:${score}%; background:${color}; border-radius:4px; transition:width 0.6s ease;"></div>
            </div>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:0.4rem; font-size:0.72rem;">
                <div style="padding:0.4rem 0.5rem; background:var(--bg-secondary); border-radius:6px;">
