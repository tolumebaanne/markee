    // Live activity feed: real orders (last 7 days) + missed-sales events
    async function renderOverviewFeed() {
        const feed = document.getElementById('mc-activity-feed');
        if (!feed) return;
        try {
            const cutoff = Date.now() - 7 * 24 * 60 * 60 * 1000;
            const entries = [];

            // Pull from already-loaded _sellerOrders
            (_sellerOrders || []).forEach(o => {
                if (new Date(o.createdAt).getTime() < cutoff) return;
                const amt   = (o.items || [])
                    .filter(i => i.sellerId?.toString() === userData.storeId?.toString())
                    .reduce((s, i) => s + (i.price || 0) * (i.qty || 1), 0);
                const shortId = '…' + o._id.slice(-6);
                const color   = o.status === 'cancelled' ? '#b91c1c' : '#22c55e';
                const label   = o.status === 'cancelled'
                    ? `Order ${shortId} was cancelled`
                    : `New order ${shortId} · $${(amt/100).toFixed(2)}`;
                entries.push({ color, label, ts: new Date(o.createdAt) });
            });

            // Fetch missed sales for additional signals
            const msRes = await fetch('/api/analytics/missed-sales', { headers: { Authorization: `Bearer ${token}` } }).catch(() => null);
            if (msRes?.ok) {
                const missed = await msRes.json();
                (missed || []).slice(0, 3).forEach(m => {
                    entries.push({
                        color: '#f59e0b',
                        label: `Missed sale: ${m.title || 'Product'} (${m.qtyWanted} wanted, ${m.available} in stock)`,
                        ts: new Date(m.timestamp)
                    });
                });
            }

            // Sort by most recent and cap at 8
            entries.sort((a, b) => b.ts - a.ts);
            const recent = entries.slice(0, 8);

            if (!recent.length) {
                feed.innerHTML = '<div class="activity-item" style="color:var(--text-muted); font-size:0.82rem; padding:0.75rem 1.25rem;">No activity in the last 7 days.</div>';
                return;
            }

            feed.innerHTML = recent.map(e => `
                <div class="activity-item">
                    <div class="activity-dot" style="background:${e.color};"></div>
                    <span>${e.label}</span>
                </div>`).join('');
        } catch (e) {
            console.warn('renderOverviewFeed:', e);
            if (feed) feed.innerHTML = '<div class="activity-item" style="color:var(--text-muted); font-size:0.82rem; padding:0.75rem 1.25rem;">Unable to load signals.</div>';
        }
    }

