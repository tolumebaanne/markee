    // Populate buyer-facing stat strip from order data
    function updateBuyerStats(orders) {
        const total   = orders.length;
        const spent   = orders.reduce((s, o) => s + (o.totalAmount || o.totalCents || 0), 0);
        const pending = orders.filter(o => ['pending','paid','processing'].includes(o.status)).length;

        const elOrders  = document.getElementById('buyer-stat-orders');
        const elSpent   = document.getElementById('buyer-stat-spent');
        const elPending = document.getElementById('buyer-stat-pending');
        const elSub     = document.getElementById('buyer-stat-orders-sub');

        if (elOrders)  elOrders.textContent  = total;
        if (elSpent)   elSpent.textContent   = `$${(spent / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
        if (elPending) elPending.textContent = pending;
        if (elSub) {
            const delivered = orders.filter(o => o.status === 'delivered').length;
            elSub.textContent = delivered ? `${delivered} delivered` : 'all time';
        }
    }


    // ── Load seller product listings ──────────────────────────────────────────
    const _productsMap = {}; // keyed by product _id — safe lookup for edit modal

    async function loadSellerProducts() {
        const list = document.getElementById('seller-products-list');
        try {
            const res = await fetch('/api/catalog/my-products', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const products = await res.json();

            // Update stat cards from smart metrics
            const totalCartCount = products.reduce((s, p) => s + (p.smartMetrics?.activeCartCount || 0), 0);
            const avgQuality     = products.length
                ? (products.reduce((s, p) => s + (p.smartMetrics?.qualityScore || 0), 0) / products.length).toFixed(1)
                : 0;
            const topVelocity    = products.reduce((max, p) => Math.max(max, p.smartMetrics?.velocityScore || 0), 0);

            const statWatching = document.getElementById('stat-watching');
            if (statWatching) statWatching.textContent = totalCartCount;

            // Store in map so openEditModal can look up by ID (avoids serialization issues)
            const funnelSelect = document.getElementById('funnel-product-select');
            funnelSelect.innerHTML = '<option value="">-- Choose a Product to Analyze --</option>';
            products.forEach(p => {
                _productsMap[p._id] = p;
                funnelSelect.innerHTML += `<option value="${p._id}">${p.title}</option>`;
            });

            // Expose health metrics for analytics panel
            window._storeHealthMetrics = { totalCartCount, avgQuality, topVelocity, products };

            if (!products.length) {
                list.innerHTML = '<p class="text-muted p-4">No active listings. <a href="#" onclick="openNewListingModal(); return false;" style="color:var(--accent-red);">Post your first listing →</a></p>';
                return;
            }

            list.innerHTML = products.map(p => {
                const sm         = p.smartMetrics || {};
                const isLowStock = p.stock !== undefined && p.stock < 5;
                const isPaused   = p.status === 'paused';
                const img        = (p.images || [])[0] || '';
                const velocity   = sm.velocityScore || 0;
                const cartCount  = sm.activeCartCount || 0;
                const velocityBadge = velocity > 60
                    ? '<span style="font-size:0.65rem; background:#fef3c7; color:#b45309; border:1px solid #fde68a; border-radius:4px; padding:0.1rem 0.35rem; margin-left:0.3rem; font-weight:700;">🔥 Hot</span>'
                    : velocity > 20
                    ? '<span style="font-size:0.65rem; background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; border-radius:4px; padding:0.1rem 0.35rem; margin-left:0.3rem; font-weight:700;">⚡ Rising</span>'
                    : '';
                const cartBubble = cartCount > 0
                    ? `<span style="font-size:0.65rem; color:#6b7280; margin-left:0.4rem;"><i class="fa fa-shopping-cart" style="margin-right:0.2rem;"></i>${cartCount} in carts</span>`
                    : '';
                return `
                <div class="list-item flex-between animate-fade" id="prod-row-${p._id}" style="cursor:pointer;" onclick="window.location='/product/${p._id}'">
                    <div class="flex-center gap-2" style="min-width:0;">
                        <img src="${img}"
                             style="width:44px; height:44px; border-radius:6px; object-fit:cover; background:var(--bg-secondary); flex-shrink:0;"
                             onerror="this.onerror=null; this.src=''; this.style.background='var(--bg-secondary)'">
                        <div style="min-width:0;">
                            <div style="font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:240px;">
                                ${p.title}${velocityBadge}
                                ${isLowStock ? '<span class="stock-low-chip">Low Stock</span>' : ''}
                            </div>
                            <div class="text-muted small">$${((p.price || 0) / 100).toFixed(2)} &middot;
                                <span id="status-label-${p._id}" style="color:${isPaused ? '#a16207' : '#15803d'};">${p.status}</span>${cartBubble}
                            </div>
                        </div>
                    </div>
                    <div class="listing-actions" onclick="event.stopPropagation()">
                        <button class="act-btn" title="Edit" onclick="openEditModal('${p._id}')">
                            <i class="fa fa-pen"></i> Edit
                        </button>
                        <button class="act-btn ${isPaused ? 'activate' : ''}" id="toggle-btn-${p._id}" title="${isPaused ? 'Activate' : 'Pause'}"
                                onclick="toggleStatus('${p._id}', '${p.status}')">
                            <i class="fa fa-${isPaused ? 'play' : 'pause'}"></i> ${isPaused ? 'Activate' : 'Pause'}
                        </button>
                        <button class="act-btn danger" title="Delete" onclick="deleteProduct('${p._id}')">
                            <i class="fa fa-trash"></i>
                        </button>
                    </div>
                </div>`;
            }).join('');
        } catch {
            list.innerHTML = '<p class="text-red p-4">Error loading listings.</p>';
        }
    }

    // ── Filter listings (client-side, operates on _productsMap) ──────────────
    function filterListings() {
        const q      = (document.getElementById('listing-search').value || '').toLowerCase().trim();
        const status = document.getElementById('listing-status-filter').value;
        const list   = document.getElementById('seller-products-list');

        const allProducts = Object.values(_productsMap);
        const filtered = allProducts.filter(p => {
            const matchStatus = !status || p.status === status;
            const matchQ      = !q || p.title.toLowerCase().includes(q)
                                   || (p.description || '').toLowerCase().includes(q)
                                   || (p.category || '').toLowerCase().includes(q);
            return matchStatus && matchQ;
        });

        const heading = document.getElementById('listings-heading');
        heading.textContent = filtered.length === allProducts.length
            ? 'My Listings'
            : `My Listings (${filtered.length} of ${allProducts.length})`;

        if (!filtered.length) {
            list.innerHTML = '<p class="text-muted p-4">No listings match your search.</p>';
            return;
        }

        list.innerHTML = filtered.map(p => {
            const sm         = p.smartMetrics || {};
            const isLowStock = p.stock !== undefined && p.stock < 5;
            const isPaused   = p.status === 'paused';
            const img        = (p.images || [])[0] || '';
            const velocity   = sm.velocityScore || 0;
            const cartCount  = sm.activeCartCount || 0;
            const velocityBadge = velocity > 60
                ? '<span style="font-size:0.65rem; background:#fef3c7; color:#b45309; border:1px solid #fde68a; border-radius:4px; padding:0.1rem 0.35rem; margin-left:0.3rem; font-weight:700;">🔥 Hot</span>'
                : velocity > 20
                ? '<span style="font-size:0.65rem; background:#eff6ff; color:#1d4ed8; border:1px solid #bfdbfe; border-radius:4px; padding:0.1rem 0.35rem; margin-left:0.3rem; font-weight:700;">⚡ Rising</span>'
                : '';
            const cartBubble = cartCount > 0
                ? `<span style="font-size:0.65rem; color:#6b7280; margin-left:0.4rem;"><i class="fa fa-shopping-cart" style="margin-right:0.2rem;"></i>${cartCount} in carts</span>`
                : '';
            return `
            <div class="list-item flex-between animate-fade" id="prod-row-${p._id}" style="cursor:pointer;" onclick="window.location='/product/${p._id}'">
                <div class="flex-center gap-2" style="min-width:0;">
                    <img src="${img}"
                         style="width:44px; height:44px; border-radius:6px; object-fit:cover; background:var(--bg-secondary); flex-shrink:0;"
                         onerror="this.onerror=null; this.src=''; this.style.background='var(--bg-secondary)'">
                    <div style="min-width:0;">
                        <div style="font-weight:600; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; max-width:240px;">
                            ${p.title}${velocityBadge}
                            ${isLowStock ? '<span class="stock-low-chip">Low Stock</span>' : ''}
                        </div>
                        <div class="text-muted small">$${((p.price || 0) / 100).toFixed(2)} &middot;
                            <span id="status-label-${p._id}" style="color:${isPaused ? '#a16207' : '#15803d'};">${p.status}</span>${cartBubble}
                        </div>
                    </div>
                </div>
                <div class="listing-actions" onclick="event.stopPropagation()">
                    <button class="act-btn" title="Edit" onclick="openEditModal('${p._id}')">
                        <i class="fa fa-pen"></i> Edit
                    </button>
                    <button class="act-btn ${isPaused ? 'activate' : ''}" id="toggle-btn-${p._id}" title="${isPaused ? 'Activate' : 'Pause'}"
                            onclick="toggleStatus('${p._id}', '${p.status}')">
                        <i class="fa fa-${isPaused ? 'play' : 'pause'}"></i> ${isPaused ? 'Activate' : 'Pause'}
                    </button>
                    <button class="act-btn danger" title="Delete" onclick="deleteProduct('${p._id}')">
                        <i class="fa fa-trash"></i>
                    </button>
                </div>
            </div>`;
        }).join('');
    }

    // ── Load seller orders ────────────────────────────────────────────────────
    let _sellerOrders = []; // full list, kept for client-side filter

    async function loadSellerOrders() {
        const list = document.getElementById('seller-orders-list');
        try {
            const res = await fetch('/api/orders/seller-orders', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            _sellerOrders = await res.json();

            // Update badge on tab
            const pendingCount = _sellerOrders.filter(o => ['pending','paid','processing'].includes(o.status)).length;
            const badge = document.getElementById('tab-orders-badge');
            if (badge && pendingCount > 0) {
                badge.textContent = pendingCount;
                badge.style.display = 'inline';
            }

            // Status summary chips
            const statusCounts = {};
            _sellerOrders.forEach(o => { statusCounts[o.status] = (statusCounts[o.status] || 0) + 1; });
            const chipColors = { pending:'#fefce8,#a16207', paid:'#eff6ff,#1d4ed8', processing:'#f5f3ff,#6d28d9', shipped:'#ecfeff,#0e7490', delivered:'#f0fdf4,#15803d', cancelled:'#fef2f2,#b91c1c' };
            const summaryEl = document.getElementById('orders-status-summary');
            if (summaryEl) {
                summaryEl.innerHTML = Object.entries(statusCounts).map(([st, cnt]) => {
                    const [bg, color] = (chipColors[st] || '#f3f4f6,#374151').split(',');
                    return `<span onclick="document.getElementById('orders-status-filter').value='${st}'; filterSellerOrders();"
                                  style="cursor:pointer; font-size:0.72rem; font-weight:700; padding:0.25rem 0.65rem; border-radius:20px; background:${bg}; color:${color}; border:1px solid ${color}22;">
                                ${cnt} ${st}
                            </span>`;
                }).join('');
            }

            renderSellerOrders(_sellerOrders);
            renderNeedsAction(_sellerOrders);
            updateFloatTray();
        } catch (err) {
            list.innerHTML = `<p class="text-red p-4">Error loading orders: ${err.message}</p>`;
        }
    }

    function updateFloatTray() {
        const pending = _sellerOrders.filter(o => ['pending','paid'].includes(o.status));
        const tray = document.getElementById('float-action-tray');
        if (!tray) return;
        if (pending.length > 0 && (isSeller || isAdmin)) {
            tray.classList.add('visible');
            tray.innerHTML = `
                <button class="float-tray-pill" onclick="switchTab('orders')">
                    <i class="fa fa-inbox"></i> ${pending.length} order${pending.length !== 1 ? 's' : ''} need action
                </button>`;
        } else {
            tray.classList.remove('visible');
        }
    }

    function filterSellerOrders() {
        const status = document.getElementById('orders-status-filter')?.value || '';
        const filtered = status ? _sellerOrders.filter(o => o.status === status) : _sellerOrders;
        renderSellerOrders(filtered);
    }

    function renderSellerOrders(orders) {
        const list = document.getElementById('seller-orders-list');
        if (!orders.length) {
            list.innerHTML = '<p class="text-muted p-4">No orders match this filter.</p>';
            return;
        }

        list.innerHTML = orders.map(o => {
            const myItems   = (o.items || []).filter(i => i.sellerId?.toString() === userData.storeId?.toString());
            const canShip   = ['paid','processing'].includes(o.status);
            const statusCls = ['pending','paid','processing','shipped','delivered','cancelled'].includes(o.status)
                ? `status-${o.status}` : 'status-pending';
            const shortId   = '…' + o._id.slice(-8);
            const date      = new Date(o.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
            const itemCount = myItems.reduce((s, i) => s + (i.qty || 1), 0);
            const myRevCents = myItems.reduce((s, i) => s + (i.price || 0) * (i.qty || 1), 0);

            // Thumbnail strip (up to 3 item images)
            const thumbs = myItems.slice(0, 3).map(i => i.image
                ? `<img src="${i.image}" style="width:32px;height:32px;border-radius:4px;object-fit:cover;border:1px solid var(--border-light);" onerror="this.style.display='none'">`
                : `<div style="width:32px;height:32px;border-radius:4px;background:var(--bg-secondary);border:1px solid var(--border-light);display:flex;align-items:center;justify-content:center;"><i class="fa fa-box" style="font-size:0.7rem;color:var(--text-muted);"></i></div>`
            ).join('');

            const canAccept = o.status === 'pending';
            const canCancel = ['pending','paid','processing'].includes(o.status);

            return `
            <div class="list-item" style="flex-direction:column; align-items:stretch; gap:0.5rem;" id="order-item-${o._id}">
                <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
                    <div style="display:flex; align-items:center; gap:0.75rem;">
                        <div style="display:flex; gap:3px;">${thumbs}</div>
                        <div>
                            <div style="font-weight:600; font-size:0.875rem;">Order ${shortId}
                                <span style="font-size:0.75rem; color:#15803d; margin-left:0.4rem;">$${(myRevCents/100).toFixed(2)}</span>
                            </div>
                            <div class="text-muted small">${date} · ${itemCount} item${itemCount !== 1 ? 's' : ''}</div>
                        </div>
                    </div>
                    <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                        <span class="status-badge ${statusCls}">${o.status}</span>
                        ${canAccept ? `
                        <button class="act-btn activate" onclick="quickAcceptOrder('${o._id}')" title="Accept this order">
                            <i class="fa fa-check"></i> Accept
                        </button>` : ''}
                        ${canShip ? `
                        <button class="act-btn" onclick="toggleShipForm('${o._id}')" title="Create shipment">
                            <i class="fa fa-truck"></i> Ship
                        </button>` : ''}
                        ${canCancel ? `
                        <button class="act-btn danger" onclick="quickCancelOrder('${o._id}')" title="Cancel order">
                            <i class="fa fa-times"></i>
                        </button>` : ''}
                        <a href="/orders/${o._id}" style="font-size:0.78rem; color:var(--accent-red); white-space:nowrap;">Details →</a>
                    </div>
                </div>
                ${canShip ? `
                <div class="ship-form-inline" id="ship-form-${o._id}">
                    <div class="ship-form-row">
                        <div class="form-group" style="margin:0;">
                            <label for="carrier-${o._id}" style="font-size:0.78rem;">Carrier</label>
                            <select id="carrier-${o._id}">
                                <option value="UPS">UPS</option>
                                <option value="FedEx">FedEx</option>
                                <option value="USPS">USPS</option>
                                <option value="DHL">DHL</option>
                                <option value="Other">Other</option>
                            </select>
                        </div>
                        <div class="form-group" style="margin:0;">
                            <label for="tracking-${o._id}" style="font-size:0.78rem;">Tracking #</label>
                            <input type="text" id="tracking-${o._id}" placeholder="Tracking number">
                        </div>
                    </div>
                    <div class="form-group" style="margin-bottom:0.75rem;">
                        <label for="delivery-${o._id}" style="font-size:0.78rem;">Est. Delivery</label>
                        <input type="date" id="delivery-${o._id}" min="${new Date().toISOString().split('T')[0]}">
                    </div>
                    <button class="btn" style="background:var(--accent-red); width:auto; padding:0.5rem 1.1rem; font-size:0.8rem;"
                            onclick="submitShipment('${o._id}')">
                        <i class="fa fa-paper-plane" style="margin-right:0.4rem;"></i> Mark Shipped
                    </button>
                </div>` : ''}
            </div>`;
        }).join('');
    }

    function renderNeedsAction(orders) {
        const actionList  = document.getElementById('needs-action-list');
        const emptyEl     = document.getElementById('needs-action-empty');
        const countBadge  = document.getElementById('needs-action-count');
        if (!actionList) return;
        const actionable = orders.filter(o => ['pending','paid','processing','payment_dispute'].includes(o.status));
        const STATUS_LABEL = { pending: 'Awaiting acceptance', paid: 'Ready to process', processing: 'Ready to ship', payment_dispute: 'Dispute filed' };
        if (countBadge) countBadge.textContent = actionable.length;
        if (!actionable.length) {
            actionList.innerHTML = '';
            if (emptyEl) emptyEl.style.display = 'flex';
            return;
        }
        if (emptyEl) emptyEl.style.display = 'none';
        actionList.innerHTML = actionable.slice(0, 8).map(o => {
            const shortId  = '…' + o._id.slice(-8);
            const statusCls = `status-${o.status}`;
            const label    = STATUS_LABEL[o.status] || o.status;
            return `
            <div class="action-row">
                <div style="flex:1; min-width:0;">
                    <div style="font-weight:600; font-size:0.82rem;">Order ${shortId}</div>
                    <div style="font-size:0.75rem; color:var(--text-muted);">${label}</div>
                </div>
                <span class="status-badge ${statusCls}" style="font-size:0.65rem;">${o.status}</span>
                <a href="/orders/${o._id}" class="act-btn" style="font-size:0.72rem; text-decoration:none; white-space:nowrap;">View</a>
            </div>`;
        }).join('');
    }

    // ── Store Analytics panel ────────────────────────────────────────────────
    async function loadStoreAnalytics() {
        try {
            const [trendRes, topRes, missedRes] = await Promise.all([
                fetch('/api/analytics/revenue-trend?days=14', { headers: { Authorization: `Bearer ${token}` } }),
                fetch('/api/analytics/top-products',          { headers: { Authorization: `Bearer ${token}` } }),
                fetch('/api/analytics/missed-sales',          { headers: { Authorization: `Bearer ${token}` } })
            ]);

            // Revenue sparkline
            if (trendRes.ok) {
                const trend = await trendRes.json();
                const maxRev = Math.max(...trend.map(d => d.revenueCents), 1);
                const totalRev = trend.reduce((s, d) => s + d.revenueCents, 0);
                document.getElementById('trend-total-label').textContent =
                    `$${(totalRev/100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })} in 14 days`;

                const sparkEl = document.getElementById('revenue-sparkline');
                sparkEl.innerHTML = trend.map((d, i) => {
                    const pct    = maxRev > 0 ? Math.max(4, Math.round((d.revenueCents / maxRev) * 64)) : 4;
                    const hasRev = d.revenueCents > 0;
                    const label  = new Date(d.date + 'T00:00:00').toLocaleDateString('en-US', { month:'short', day:'numeric' });
                    return `<div title="${label}: $${(d.revenueCents/100).toFixed(2)} (${d.orders} orders)"
                                 style="flex:1; height:${pct}px; background:${hasRev ? 'var(--accent-red)' : 'var(--border-light)'}; border-radius:3px 3px 0 0; cursor:default; transition:opacity 0.15s;"
                                 onmouseover="this.style.opacity='0.75'" onmouseout="this.style.opacity='1'"></div>`;
                }).join('');

                const lbl = document.getElementById('spark-label-start');
                const lbl2 = document.getElementById('spark-label-end');
                if (trend.length && lbl && lbl2) {
                    const fmt = d => new Date(d + 'T00:00:00').toLocaleDateString('en-US', { month:'short', day:'numeric' });
                    lbl.textContent  = fmt(trend[0].date);
                    lbl2.textContent = fmt(trend[trend.length-1].date);
                }
            }

            // Top products table
            if (topRes.ok) {
                const top = await topRes.json();
                const el  = document.getElementById('top-products-list');
                if (!top.length) {
                    el.innerHTML = '<p class="text-muted small" style="padding:1rem;">No sales data yet.</p>';
                } else {
                    el.innerHTML = top.slice(0,5).map((p, i) => {
                        const sm = (_productsMap[p.productId]?.smartMetrics) || {};
                        const velocity = sm.velocityScore || 0;
                        const badge = velocity > 60 ? '🔥' : velocity > 20 ? '⚡' : '';
                        return `
                        <div style="display:flex; align-items:center; justify-content:space-between; padding:0.7rem 1.25rem; border-bottom:1px solid var(--border-light);">
                            <div style="display:flex; align-items:center; gap:0.65rem;">
                                <span style="font-size:0.75rem; font-weight:800; color:var(--text-muted); width:14px;">${i+1}</span>
                                <div>
                                    <div style="font-weight:600; font-size:0.82rem;">${badge} ${p.title || 'Product'}</div>
                                    <div style="font-size:0.72rem; color:var(--text-muted);">${p.count} order${p.count!==1?'s':''}</div>
                                </div>
                            </div>
                            <div style="font-weight:700; font-size:0.82rem; color:#15803d;">$${(p.revenueCents/100).toFixed(2)}</div>
                        </div>`;
                    }).join('');
                }
                
                // Category revenue from top-products × _productsMap
                const catRevenue = {};
                (top || []).forEach(p => {
                    const cat = _productsMap[p.productId]?.category || 'Other';
                    catRevenue[cat] = (catRevenue[cat] || 0) + p.revenueCents;
                });
                const maxCatRev = Math.max(...Object.values(catRevenue), 1);
                const catEl = document.getElementById('category-revenue-bars');
                if (catEl) {
                    const sorted = Object.entries(catRevenue).sort((a,b) => b[1] - a[1]).slice(0, 6);
                    catEl.innerHTML = sorted.length
                        ? sorted.map(([cat, rev]) => `
                            <div class="cat-bar-row">
                                <div class="cat-bar-label" title="${cat}">${cat}</div>
                                <div class="cat-bar-track">
                                    <div class="cat-bar-fill" style="width:${Math.round((rev/maxCatRev)*100)}%"></div>
                                </div>
                                <div class="cat-bar-value">$${(rev/100).toFixed(0)}</div>
                            </div>`).join('')
                        : '<p class="text-muted small" style="padding:0.5rem;">No sales data yet.</p>';
                }
            }

            // Missed sales
            if (missedRes.ok) {
                const missed = await missedRes.json();
                const el = document.getElementById('missed-sales-list');
                if (!missed.length) {
                    el.innerHTML = '<p class="text-muted small" style="padding:1rem;">No missed sales recorded.</p>';
                } else {
                    el.innerHTML = missed.slice(0,10).map(m => {
                        const date = new Date(m.timestamp).toLocaleDateString('en-US', { month:'short', day:'numeric' });
                        return `
                        <div style="padding:0.65rem 1.25rem; border-bottom:1px solid var(--border-light);">
                            <div style="font-weight:600; font-size:0.8rem; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">${m.title || 'Product'}</div>
                            <div style="font-size:0.72rem; color:#b91c1c; margin-top:0.15rem;">
                                ${m.qtyWanted} wanted · ${m.available} in stock · ${date}
                            </div>
                        </div>`;
                    }).join('');
                }
            }

            // Store health from smart metrics (already loaded via loadSellerProducts)
            const health = window._storeHealthMetrics || {};
            const hCart = document.getElementById('health-cart-count');
            const hQual = document.getElementById('health-avg-quality');
            const hVel  = document.getElementById('health-top-velocity');
            if (hCart) hCart.textContent = health.totalCartCount ?? '—';
            if (hQual) hQual.textContent = health.avgQuality    ? `${health.avgQuality}/100` : '—';
            if (hVel)  hVel.textContent  = health.topVelocity   ? health.topVelocity.toFixed(1) : '—';

            // Review summary
            loadReviewSummary();

        } catch (err) {
            showToast('Analytics load error: ' + err.message, 'error');
        }
    }

    async function loadReviewSummary() {
        try {
            const res = await fetch('/api/analytics/review-summary', {
                headers: { Authorization: `Bearer ${token}` }
            });
            if (!res.ok) return;
            const d = await res.json();
            const card = document.getElementById('review-summary-card');
            if (!d.totalCount) return;
            document.getElementById('rs-avg-rating').textContent  = (d.avgRating   || 0).toFixed(1);
            document.getElementById('rs-total').textContent       = d.totalCount || 0;
            document.getElementById('rs-reply-rate').textContent  = d.replyRate  != null ? Math.round(d.replyRate  * 100) + '%' : '—';
            document.getElementById('rs-flag-rate').textContent   = d.flagRate   != null ? Math.round(d.flagRate   * 100) + '%' : '—';
            card.style.display = 'block';

            // Mini breakdown bars
            if (d.breakdown) {
                const total = d.totalCount || 1;
                document.getElementById('rs-breakdown-bars').innerHTML = [5,4,3,2,1].map(n => {
                    const count = d.breakdown[n] || 0;
                    const pct = Math.round((count / total) * 100);
                    return `<div style="display:flex; align-items:center; gap:0.5rem; font-size:0.72rem; margin-bottom:0.2rem;">
                        <span style="width:10px; text-align:right; color:var(--text-muted);">${n}</span>
                        <i class="fa fa-star" style="color:#f59e0b; font-size:0.6rem;"></i>
                        <div style="flex:1; height:5px; background:var(--bg-secondary); border-radius:3px; overflow:hidden;">
                            <div style="height:100%; width:${pct}%; background:#f59e0b; border-radius:3px;"></div>
                        </div>
                        <span style="width:36px; color:var(--text-muted);">${count} (${pct}%)</span>
                    </div>`;
                }).join('');
            }
        } catch {}
    }

    function toggleShipForm(orderId) {
        const form = document.getElementById(`ship-form-${orderId}`);
        if (form) form.classList.toggle('open');
    }

    // ── Quick order actions from dashboard list ────────────────────────────────
    async function quickAcceptOrder(orderId) {
        if (!confirm('Confirm this order? You are committing to fulfil it.')) return;
        try {
            const res = await fetch(`/api/orders/${orderId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ status: 'processing' })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
            showToast('Order accepted — now processing!', 'success');
            // Reload orders list
            ordersLoaded = false;
            loadSellerOrders();
            ordersLoaded = true;
        } catch (err) { showToast('Error: ' + err.message, 'error'); }
    }

    async function buyerCancelOrder(orderId) {
        if (!confirm('Cancel this order? This action cannot be undone.')) return;
        try {
            const res = await fetch(`/api/orders/${orderId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ status: 'cancelled' })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
            showToast('Order cancelled.', 'info');
            purchasesLoaded = false;
            loadBuyerOrders();
            purchasesLoaded = true;
        } catch (err) { showToast('Error: ' + err.message, 'error'); }
    }

    async function quickCancelOrder(orderId) {
        const reason = prompt('Reason for cancellation (optional):');
        if (reason === null) return; // User pressed Cancel on prompt
        try {
            const res = await fetch(`/api/orders/${orderId}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ status: 'cancelled', cancellationReason: reason || '' })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
            showToast('Order cancelled.', 'info');
            ordersLoaded = false;
            loadSellerOrders();
            ordersLoaded = true;
        } catch (err) { showToast('Error: ' + err.message, 'error'); }
    }

    async function submitShipment(orderId) {
        const carrier  = document.getElementById(`carrier-${orderId}`).value;
        const tracking = document.getElementById(`tracking-${orderId}`).value.trim();
        const delivery = document.getElementById(`delivery-${orderId}`).value;

        if (!tracking) { showToast('Enter a tracking number.', 'error'); return; }
        if (!delivery) { showToast('Enter estimated delivery date.', 'error'); return; }

        try {
            const res = await fetch('/api/shipping', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({ orderId, carrier, trackingNumber: tracking, estimatedDelivery: delivery, sellerId: userData.storeId })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
            showToast('Shipment created — order marked as shipped!', 'success');
            // Re-render orders list
            ordersLoaded = false;
            loadSellerOrders();
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
        }
    }

    // ── Image compression ─────────────────────────────────────────────────────
    // Compresses a File to a JPEG data URL at ~maxKB kilobytes
    async function compressImage(file, maxKB = 50) {
        return new Promise((resolve) => {
            const reader = new FileReader();
            reader.onload = (e) => {
                const img = new Image();
                img.onload = () => {
                    const canvas = document.createElement('canvas');
                    const MAX_DIM = 900;
                    let w = img.width, h = img.height;
                    if (w > MAX_DIM || h > MAX_DIM) {
                        const r = Math.min(MAX_DIM / w, MAX_DIM / h);
                        w = Math.round(w * r); h = Math.round(h * r);
                    }
                    canvas.width = w; canvas.height = h;
                    canvas.getContext('2d').drawImage(img, 0, 0, w, h);

                    // Start at q=0.85, halve quality until under maxKB
                    let q = 0.85, dataUrl;
                    do {
                        dataUrl = canvas.toDataURL('image/jpeg', q);
                        q -= 0.1;
                    } while ((dataUrl.length * 0.75 / 1024) > maxKB && q > 0.1);

                    resolve(dataUrl);
                };
                img.src = e.target.result;
            };
            reader.readAsDataURL(file);
        });
    }

    // ── Image preview state ───────────────────────────────────────────────────
    let _pendingImages = []; // array of data URLs (compressed) or existing URLs

    function renderPreview() {
        const row = document.getElementById('img-preview-row');
        row.innerHTML = _pendingImages.map((src, i) => `
            <div class="img-preview-wrap">
                <img src="${src}" class="img-preview-thumb" alt="preview ${i+1}">
                <button type="button" class="img-preview-remove" onclick="removeImage(${i})" title="Remove">&times;</button>
            </div>`).join('');
    }

    function removeImage(idx) {
        _pendingImages.splice(idx, 1);
        renderPreview();
    }

    async function handleFileSelect(files) {
        const remaining = 4 - _pendingImages.length;
        const toProcess = Array.from(files).slice(0, remaining);
        if (!toProcess.length) { showToast('Maximum 4 images per listing.', 'info'); return; }

        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Compressing...';

        for (const file of toProcess) {
            const dataUrl = await compressImage(file, 50);
            _pendingImages.push(dataUrl);
        }
        renderPreview();
        btn.disabled = false;
        btn.textContent = document.getElementById('edit-id').value ? 'Save Changes' : 'Post Listing';
        // Reset file input so same file can be re-selected
        document.getElementById('f-images').value = '';
    }

    function handleDrop(e) {
        e.preventDefault();
        document.getElementById('drop-zone').classList.remove('drag-over');
        handleFileSelect(e.dataTransfer.files);
    }

    // ── Modal open/close ──────────────────────────────────────────────────────
    function openNewListingModal() {
        _pendingImages = [];
        document.getElementById('edit-id').value = '';
        document.getElementById('modal-title').textContent = 'New Listing';
        document.getElementById('listing-form').reset();
        renderPreview();
        document.getElementById('submit-btn').textContent = 'Post Listing';
        document.getElementById('modal-backdrop').style.display = 'flex';
    }

    function openEditModal(productId) {
        const p = _productsMap[productId];
        if (!p) { showToast('Product data not found. Refresh and try again.', 'error'); return; }
        _pendingImages = (p.images || []).filter(Boolean);
        document.getElementById('edit-id').value = p._id;
        document.getElementById('modal-title').textContent = 'Edit Listing';
        document.getElementById('f-title').value = p.title || '';
        document.getElementById('f-category').value = p.category || 'Electronics';
        document.getElementById('f-price').value = p.price ? (p.price / 100).toFixed(2) : '';
        document.getElementById('f-description').value = p.description || '';
        renderPreview();
        document.getElementById('submit-btn').textContent = 'Save Changes';
        document.getElementById('modal-backdrop').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('modal-backdrop').style.display = 'none';
        _pendingImages = [];
    }

    function handleBackdropClick(e) {
        if (e.target === document.getElementById('modal-backdrop')) closeModal();
    }

    // ── Create / Update listing ───────────────────────────────────────────────
    async function submitListing(e) {
        e.preventDefault();
        const editId = document.getElementById('edit-id').value;
        const btn = document.getElementById('submit-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Saving...';

        const product = {
            title:       document.getElementById('f-title').value.trim(),
            category:    document.getElementById('f-category').value,
            price:       Math.round(parseFloat(document.getElementById('f-price').value) * 100),
            images:      _pendingImages,
            description: document.getElementById('f-description').value.trim(),
        };
        if (!editId) product.status = 'active';

        const url    = editId ? `/api/catalog/products/${editId}` : '/api/catalog/products';
        const method = editId ? 'PUT' : 'POST';

        try {
            const res = await fetch(url, {
                method,
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify(product)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
            showToast(editId ? 'Listing updated!' : 'Listing posted!', 'success');
            closeModal();
            // Update map in-place so current filter/search state is preserved
            _productsMap[data._id] = data;
            filterListings();
            loadStats();
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
            btn.disabled = false;
            btn.textContent = editId ? 'Save Changes' : 'Post Listing';
        }
    }

    // ── Toggle active / paused ────────────────────────────────────────────────
    async function toggleStatus(productId, currentStatus) {
        const newStatus = currentStatus === 'active' ? 'paused' : 'active';
        try {
            const res = await fetch(`/api/catalog/products/${productId}`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body: JSON.stringify({ status: newStatus })
            });
            if (!res.ok) throw new Error((await res.json()).error || `HTTP ${res.status}`);
            // Keep map in sync
            if (_productsMap[productId]) _productsMap[productId].status = newStatus;
            // Update row in-place without full reload
            const label = document.getElementById(`status-label-${productId}`);
            const btn   = document.getElementById(`toggle-btn-${productId}`);
            if (label) { label.textContent = newStatus; label.style.color = newStatus === 'active' ? '#15803d' : '#a16207'; }
            if (btn)   {
                btn.className = `act-btn${newStatus === 'paused' ? ' activate' : ''}`;
                btn.setAttribute('onclick', `toggleStatus('${productId}', '${newStatus}')`);
                btn.innerHTML = `<i class="fa fa-${newStatus === 'active' ? 'pause' : 'play'}"></i> ${newStatus === 'active' ? 'Pause' : 'Activate'}`;
            }
            // Re-apply filter so status filter stays accurate (e.g. pausing while "Active" filter is on)
            filterListings();
            showToast(`Listing ${newStatus === 'active' ? 'activated' : 'paused'}.`, 'success');
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
        }
    }

    // ── Delete listing ────────────────────────────────────────────────────────
    async function deleteProduct(productId) {
        if (!confirm('Delete this listing? This cannot be undone.')) return;
        try {
            const res = await fetch(`/api/catalog/products/${productId}`, {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) throw new Error((await res.json()).error || `HTTP ${res.status}`);
            delete _productsMap[productId]; // remove from map so filter count is accurate
            const row = document.getElementById(`prod-row-${productId}`);
            if (row) row.remove();
            filterListings(); // re-run to update heading count
            showToast('Listing deleted.', 'info');
            loadStats();
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
        }
    }

    // ── Load buyer orders (My Purchases) ─────────────────────────────────────
    // Cached buyer orders for history filtering
    let _buyerOrders = [];
    let _historyRange = 'all';

    function renderBuyerOrderRow(o) {
        const statusCls  = ['pending','paid','processing','shipped','delivered','cancelled'].includes(o.status)
            ? `status-${o.status}` : 'status-pending';
        const shortId    = '…' + o._id.slice(-8);
        const date       = new Date(o.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
        const total      = `$${((o.totalAmount || o.totalCents || 0) / 100).toFixed(2)}`;
        const itemCount  = (o.items || []).reduce((s, i) => s + (i.qty || 1), 0);
        const canCancel  = o.status === 'pending';
        const canReview  = o.status === 'delivered';
        // Thumbnail strip — up to 3 item images (same as Orders Received)
        const thumbs = (o.items || []).slice(0, 3).map(i => i.image
            ? `<img src="${i.image}" style="width:32px;height:32px;border-radius:4px;object-fit:cover;border:1px solid var(--border-light);" onerror="this.style.display='none'">`
            : `<div style="width:32px;height:32px;border-radius:4px;background:var(--bg-secondary);border:1px solid var(--border-light);display:flex;align-items:center;justify-content:center;"><i class="fa fa-box" style="font-size:0.7rem;color:var(--text-muted);"></i></div>`
        ).join('');
        return `
        <div class="list-item" style="flex-direction:column; align-items:stretch; gap:0.5rem;" id="buyer-order-${o._id}">
            <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5rem;">
                <div style="display:flex; align-items:center; gap:0.75rem; cursor:pointer;" onclick="window.location='/orders/${o._id}'">
                    <div style="display:flex; gap:3px;">${thumbs}</div>
                    <div>
                        <div style="font-weight:600; font-size:0.875rem;">Order ${shortId}
                            <span style="font-size:0.75rem; color:#1d4ed8; margin-left:0.4rem;">${total}</span>
                        </div>
                        <div class="text-muted small">${date} · ${itemCount} item${itemCount !== 1 ? 's' : ''}</div>
                    </div>
                </div>
                <div style="display:flex; align-items:center; gap:0.5rem; flex-wrap:wrap;">
                    <span class="status-badge ${statusCls}">${o.status}</span>
                    ${canReview ? `<a href="/orders/${o._id}" class="act-btn" style="font-size:0.72rem; text-decoration:none;"><i class="fa fa-star"></i> Review</a>` : ''}
                    ${canCancel ? `<button class="act-btn danger" onclick="buyerCancelOrder('${o._id}')" title="Cancel order"><i class="fa fa-times"></i></button>` : ''}
                    <a href="/orders/${o._id}" style="font-size:0.78rem; color:var(--accent-red); white-space:nowrap;">Details →</a>
                </div>
            </div>
        </div>`;
    }

    function renderHistoryList(range) {
        const histList = document.getElementById('history-orders-list');
        if (!histList) return;
        const historyStatuses = ['delivered','completed','cancelled'];
        let history = _buyerOrders.filter(o => historyStatuses.includes(o.status));
        const now = Date.now();
        if (range === '7d')  history = history.filter(o => now - new Date(o.createdAt).getTime() <= 7 * 86400000);
        if (range === '1m')  history = history.filter(o => now - new Date(o.createdAt).getTime() <= 30 * 86400000);
        if (range === '3m')  history = history.filter(o => now - new Date(o.createdAt).getTime() <= 90 * 86400000);
        if (range === 'custom') {
            const start = document.getElementById('history-range-start')?.value;
            const end   = document.getElementById('history-range-end')?.value;
            if (start) history = history.filter(o => new Date(o.createdAt) >= new Date(start));
            if (end)   history = history.filter(o => new Date(o.createdAt) <= new Date(end + 'T23:59:59'));
        }
        histList.innerHTML = history.length
            ? history.map(renderBuyerOrderRow).join('')
            : '<p class="text-muted p-4">No orders in this period.</p>';
    }

    function filterOrderHistory(btn) {
        btn.closest('.filter-chip-row').querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        const range = btn.dataset.range;
        _historyRange = range;
        const picker = document.getElementById('history-date-range');
        if (picker) picker.style.display = range === 'range' ? 'flex' : 'none';
        if (range !== 'range') renderHistoryList(range);
    }

    function applyHistoryDateRange() {
        renderHistoryList('custom');
    }

    async function loadBuyerOrders() {
        const activeList  = document.getElementById('active-orders-list');
        const histList    = document.getElementById('history-orders-list');
        const sugStrip    = document.getElementById('suggestions-strip');
        if (!activeList) return;
        try {
            const res = await fetch('/api/orders/my-orders', { headers: { 'Authorization': `Bearer ${token}` } });
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const orders = await res.json();
            _buyerOrders = orders;

            // Populate buyer stat strip + watchlist
            updateBuyerStats(orders);
            renderWatchlist();

            // Split orders
            const historyStatuses = ['delivered','completed','cancelled'];
            const activeOrders  = orders.filter(o => !historyStatuses.includes(o.status));
            const historyOrders = orders.filter(o => historyStatuses.includes(o.status));

            // Active purchases
            if (!activeOrders.length) {
                activeList.innerHTML = '<p class="text-muted p-4">No active orders. <a href="/" style="color:var(--accent-red);">Start shopping →</a></p>';
            } else {
                activeList.innerHTML = activeOrders.map(renderBuyerOrderRow).join('');
            }

            // Order history (render with current filter)
            renderHistoryList(_historyRange);

            // Suggestions strip — unique products from past orders
            if (sugStrip) {
                const seen = new Set();
                const suggestions = [];
                for (const o of orders) {
                    for (const item of (o.items || [])) {
                        if (item.productId && !seen.has(item.productId.toString())) {
                            seen.add(item.productId.toString());
                            suggestions.push(item);
                        }
                    }
                }
                if (!suggestions.length) {
                    sugStrip.innerHTML = '<p class="suggestions-empty">Shop something to see suggestions here.</p>';
                } else {
                    sugStrip.innerHTML = suggestions.slice(0, 20).map(item => `
                        <a href="/product/${item.productId}" class="suggestion-card" style="text-decoration:none; color:inherit;">
                            ${item.image
                                ? `<img src="${item.image}" alt="${item.title || ''}" onerror="this.style.display='none'">`
                                : `<div style="width:100%;aspect-ratio:1/1;background:var(--bg-secondary);display:flex;align-items:center;justify-content:center;"><i class="fa fa-box" style="color:var(--text-muted);"></i></div>`}
                            <span class="suggestion-label">${(item.title || 'Item').slice(0, 22)}</span>
                        </a>`).join('');
                }
            }
        } catch (err) {
            if (activeList) activeList.innerHTML = `<p class="text-red p-4">Error loading orders: ${err.message}</p>`;
        }
    }

    // ── Register store (first-time sellers) ──────────────────────────────────
    async function activateStorefront() {
        const name = (document.getElementById('new-store-name')?.value || '').trim();
        if (!name) { showToast('Enter a store name to continue.', 'error'); return; }
        const btn = document.getElementById('start-selling-btn');
        if (btn) { btn.disabled = true; btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Setting up...'; }
        try {
            // Register the store document if it doesn't exist
            const regRes = await fetch('/api/seller/register', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                body:    JSON.stringify({ name })
            });
            if (!regRes.ok) {
                const d = await regRes.json();
                throw new Error(d.error || `HTTP ${regRes.status}`);
            }

            // Activate the store (sets active: true in Seller Service)
            if (userData.storeId) {
                const actRes = await fetch(`/api/seller/${userData.storeId}/activate`, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` }
                });
                if (!actRes.ok) {
                    const d = await actRes.json();
                    throw new Error('Activation failed: ' + (d.error || `HTTP ${actRes.status}`));
                }
            }

            // Refresh token — this is the critical step. If it fails the seller panel
            // won't appear on reload, so we must surface the failure explicitly.
            const rtRes = await fetch('/oauth/refresh', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ refresh_token: localStorage.getItem('refresh_token') })
            });

            if (!rtRes.ok) {
                throw new Error('Store activated but session refresh failed. Please log out and back in to start selling.');
            }

            const tokens   = await rtRes.json();
            const newToken = tokens.access_token;
            if (!newToken) {
                throw new Error('Store activated but received an empty token. Please log out and back in.');
            }

            // Verify the new token actually contains storeActive: true before committing it
            let decoded;
            try { decoded = JSON.parse(atob(newToken.split('.')[1])); } catch { decoded = null; }

            if (!decoded?.storeActive) {
                // Token refresh succeeded but storeActive is not set — likely a timing issue
                // between the activate call and the scope computation in Auth Service.
                // Store the new token anyway (it will be accurate on next refresh) and
                // tell the user so they're not confused by a buyer-only dashboard.
                localStorage.setItem('access_token',  newToken);
                localStorage.setItem('refresh_token', tokens.refresh_token);
                showToast('Storefront activated! If the seller panel is missing, log out and back in once.', 'info');
                setTimeout(() => window.location.reload(), 2000);
                return;
            }

            localStorage.setItem('access_token',  newToken);
            localStorage.setItem('refresh_token', tokens.refresh_token);
            showToast('Storefront activated! Welcome to selling on Markee.', 'success');
            setTimeout(() => window.location.reload(), 1200);

        } catch (err) {
            showToast('Error: ' + err.message, 'error');
            if (btn) { btn.disabled = false; btn.innerHTML = '<i class="fa fa-store" style="margin-right:0.4rem;"></i> Activate Storefront'; }
        }
    }

    // ── Dark Mode ─────────────────────────────────────────────────────────────
    function toggleDarkMode() {
        const isDark = document.body.getAttribute('data-theme') === 'dark';
        if (isDark) {
            document.body.removeAttribute('data-theme');
            localStorage.setItem('markee_theme', 'light');
            const tk = document.getElementById('dark-toggle');
            if (tk) tk.classList.remove('on');
        } else {
            document.body.setAttribute('data-theme', 'dark');
            localStorage.setItem('markee_theme', 'dark');
            const tk = document.getElementById('dark-toggle');
            if (tk) tk.classList.add('on');
        }
    }

    if (localStorage.getItem('markee_theme') === 'dark') {
        document.body.setAttribute('data-theme', 'dark');
        const _tk = document.getElementById('dark-toggle');
        if (_tk) _tk.classList.add('on');
    }

    // ── Notification bell ─────────────────────────────────────────────────────
    let _notifPanelOpen = false;

    function toggleNotifPanel() {
        const panel = document.getElementById('notif-panel');
        if (!panel) return;
        _notifPanelOpen = !_notifPanelOpen;
        panel.style.display = _notifPanelOpen ? 'block' : 'none';
        if (_notifPanelOpen) {
            loadNotifPanel();
            // Close when clicking outside
            setTimeout(() => document.addEventListener('click', closeNotifOnOutsideClick), 0);
        } else {
            document.removeEventListener('click', closeNotifOnOutsideClick);
        }
    }

    function closeNotifOnOutsideClick(e) {
        const wrap = document.querySelector('.nav-notif-wrap');
        if (wrap && !wrap.contains(e.target)) {
            document.getElementById('notif-panel').style.display = 'none';
            _notifPanelOpen = false;
            document.removeEventListener('click', closeNotifOnOutsideClick);
        }
    }

    async function loadNotifPanel() {
        const list = document.getElementById('notif-list');
        try {
            const res = await fetch('/api/notifications/my', { headers: { Authorization: `Bearer ${token}` } });
            if (!res.ok) throw new Error();
            const notifs = await res.json();
            if (!notifs.length) {
                list.innerHTML = '<div class="notif-empty">No notifications yet.</div>';
                return;
            }
            list.innerHTML = notifs.slice(0, 5).map(n => {
                const ago = formatTimeAgo(new Date(n.sentAt));
                const iconColor = n.priority === 'critical' ? '#b91c1c' : n.priority === 'high' ? '#ea580c' : '#6b7280';
                return `
                <div class="notif-item${n.read ? '' : ' unread'}" onclick="handleNotifClick('${n._id}', '${n.link || ''}')">
                    <div class="notif-icon"><i class="fa ${n.icon || 'fa-bell'}" style="color:${iconColor};"></i></div>
                    <div class="notif-body">
                        <div class="notif-subject">${n.subject || 'Notification'}</div>
                        <div class="notif-preview">${(n.body || '').slice(0, 80)}</div>
                        <div class="notif-time">${ago}</div>
                    </div>
                </div>`;
            }).join('');
        } catch {
            if (list) list.innerHTML = '<div class="notif-empty">Unable to load notifications.</div>';
        }
    }

    async function handleNotifClick(notifId, link) {
        // Mark as read
        fetch(`/api/notifications/${notifId}/read`, {
            method: 'PATCH',
            headers: { Authorization: `Bearer ${token}` }
        }).catch(() => {});
        if (link) window.location = link;
        toggleNotifPanel();
    }

    async function markAllRead() {
        await fetch('/api/notifications/read-all', {
            method: 'PATCH',
            headers: { Authorization: `Bearer ${token}` }
        }).catch(() => {});
        // Clear badge
        const badge = document.getElementById('notif-count');
        if (badge) badge.style.display = 'none';
        loadNotifPanel();
    }

    async function pollNotifCount() {
        try {
            const res = await fetch('/api/notifications/unread-count', { headers: { Authorization: `Bearer ${token}` } });
            if (!res.ok) return;
            const { count } = await res.json();
            const badge = document.getElementById('notif-count');
            if (badge) {
                badge.textContent = count;
                badge.style.display = count > 0 ? 'inline' : 'none';
            }
        } catch {}
    }

    function formatTimeAgo(date) {
        const diffMs = Date.now() - date.getTime();
        const mins = Math.floor(diffMs / 60000);
        if (mins < 1)  return 'just now';
        if (mins < 60) return `${mins}m ago`;
        const hrs = Math.floor(mins / 60);
        if (hrs < 24)  return `${hrs}h ago`;
        return `${Math.floor(hrs / 24)}d ago`;
    }

    // ── Messages unread badge ─────────────────────────────────────────────────
    async function loadUnreadMessageCount() {
        try {
            const res = await fetch('/api/messages/unread-count', {
                headers: { Authorization: `Bearer ${token}` }
            });
            if (!res.ok) return;
            const data = await res.json();
            const total = data.total || 0;
            const badge = document.getElementById('messages-badge');
            if (badge) {
                badge.textContent = total;
                badge.style.display = total > 0 ? 'inline' : 'none';
            }
            const topBadge = document.getElementById('dash-msg-badge');
            if (topBadge) {
                topBadge.textContent = total > 9 ? '9+' : total;
                topBadge.style.display = total > 0 ? 'block' : 'none';
            }
        } catch {}
    }

    // ── Boot ──────────────────────────────────────────────────────────────────
    window.addEventListener('load', () => {
        // Show the overview panel first — sidebar nav already shows it as active
        switchTab('overview');

        // Buyer orders always load (populates buyer stat strip and watchlist count)
        loadBuyerOrders();
        purchasesLoaded = true;

        if (isSeller || isAdmin) {
            // Seller: pre-load everything so tab switches are instant
            loadStats();
            loadSellerProducts();
            loadStoreCard();
            // Pre-load orders so badge count appears immediately
            loadSellerOrders();
            ordersLoaded = true;
        }

        // If Sell button navigated here, activate the appropriate sell flow
        if (new URLSearchParams(location.search).get('sell') === '1') {
            navSell();
        }

        if (window.MarkeeCart) MarkeeCart.updateAllCartBadges();

        // Messages badge — poll once now, then every 2 minutes
        loadUnreadMessageCount();
        setInterval(loadUnreadMessageCount, 120000);

        // Notification bell badge — poll once now, then every 60 seconds
        pollNotifCount();
        setInterval(pollNotifCount, 60000);
    });

// ── Operations Panel JS ───────────────────────────────────────────────────

let currentStoreOps = null;

async function loadOpsPanel() {
    try {
        const res = await fetch('/api/public-seller/' + userData.storeId);
        if (!res.ok) throw new Error('Failed to load ops');
        const data = await res.json();
        currentStoreOps = data;

        // Schedule
        renderOpsSchedule(data.schedule);

        // Discounts — schema: discount.storeWide.{enabled, percent, endsAt} + discount.byCategory[].{category, percent}
        if (data.discount) {
            if (data.discount.storeWide) {
                document.getElementById('ops-storewide-enabled').checked = data.discount.storeWide.enabled || false;
                document.getElementById('ops-storewide-pct').value = data.discount.storeWide.percent || '';
                if (data.discount.storeWide.endsAt) {
                    document.getElementById('ops-storewide-ends').value = new Date(data.discount.storeWide.endsAt).toISOString().slice(0,16);
                }
            }
            renderOpsCatDiscounts(data.discount.byCategory || []);
        }

        // Sale Banner — schema: salesBanner.{active, headline, subtext, ctaLabel, discountPercent, startsAt, endsAt, imageUrl}
        if (data.salesBanner) {
            document.getElementById('ops-sale-active').checked = data.salesBanner.active || false;
            document.getElementById('ops-sale-headline').value = data.salesBanner.headline || '';
            document.getElementById('ops-sale-subtext').value = data.salesBanner.subtext || '';
            document.getElementById('ops-sale-cta-label').value = data.salesBanner.ctaLabel || '';
            document.getElementById('ops-sale-pct').value = data.salesBanner.discountPercent || '';
            document.getElementById('ops-sale-image').value = data.salesBanner.imageUrl || '';
            if (data.salesBanner.startsAt) document.getElementById('ops-sale-starts').value = new Date(data.salesBanner.startsAt).toISOString().slice(0,16);
            if (data.salesBanner.endsAt) document.getElementById('ops-sale-ends').value = new Date(data.salesBanner.endsAt).toISOString().slice(0,16);
        }
        opsSaleBannerToggle();

        // Main Banner — schema: banner.{imageUrl, altText}
        if (data.banner) {
            document.getElementById('ops-banner-url').value = data.banner.imageUrl || '';
            document.getElementById('ops-banner-alt').value = data.banner.altText || '';
        }

        bindOpsPreview();
        opsDiscountToggle();

        // Reviews needing reply
        loadOpsNeedsReply();

    } catch (err) {
        console.error(err);
        showToast('Error loading operations details', 'error');
    }
}

async function loadOpsNeedsReply() {
    if (!userData?.storeId) return;
    try {
        const res = await fetch(`/api/reviews/seller/${userData.storeId}/needing-reply`, {
            headers: { Authorization: `Bearer ${token}` }
        });
        if (!res.ok) return;
        const reviews = await res.json();
        const card = document.getElementById('ops-needs-reply-card');
        const list = document.getElementById('ops-needs-reply-list');
        const countEl = document.getElementById('ops-needs-reply-count');
        card.style.display = 'block';
        if (!reviews.length) {
            list.innerHTML = '<p class="text-muted small" style="margin:0;">All reviews have been replied to. Great job!</p>';
            countEl.textContent = '';
            return;
        }
        countEl.textContent = `${reviews.length} unanswered`;
        const shown = reviews.slice(0, 5);
        list.innerHTML = shown.map(r => {
            const starsHtml = ['','','','',''].map((_,i) =>
                `<i class="fa fa-star" style="color:${i < r.rating ? '#f59e0b' : '#d1d5db'}; font-size:0.72rem;"></i>`
            ).join('');
            const date = new Date(r.createdAt).toLocaleDateString('en-US', { month:'short', day:'numeric' });
            const body = (r.body || '').slice(0, 100) + (r.body?.length > 100 ? '…' : '');
            return `
            <div style="padding:0.75rem 0; border-bottom:1px solid var(--border-light); display:flex; justify-content:space-between; align-items:flex-start; gap:0.75rem; flex-wrap:wrap;">
                <div style="flex:1; min-width:0;">
                    <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.2rem;">
                        <span style="font-size:0.72rem; font-weight:600; color:var(--text-muted);">${date}</span>
                        <span>${starsHtml}</span>
                    </div>
                    <div style="font-size:0.82rem; color:var(--text-main); line-height:1.5;">${escHtml(body)}</div>
                </div>
                <a href="/product/${r.productId}" style="font-size:0.75rem; font-weight:700; color:var(--accent-red); text-decoration:none; white-space:nowrap;">Reply →</a>
            </div>`;
        }).join('');
        if (reviews.length > 5) {
            list.innerHTML += `<p class="text-muted small" style="margin-top:0.5rem;">${reviews.length - 5} more not shown. Visit each product page to reply.</p>`;
        }
    } catch {}
}

function escHtml(str) {
    const d = document.createElement('div');
    d.appendChild(document.createTextNode(str || ''));
    return d.innerHTML;
}

function renderOpsSchedule(schedule = {}) {
    // Schema keys: mon, tue, wed, thu, fri, sat, sun
    // Schema per-day fields: open (bool), openTime (string), closeTime (string)
    const dayKeys   = ['mon','tue','wed','thu','fri','sat','sun'];
    const dayLabels = ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'];
    const grid = document.getElementById('ops-schedule-grid');
    grid.innerHTML = '';
    dayKeys.forEach((key, i) => {
        const rules = schedule[key] || { open: key !== 'sat' && key !== 'sun', openTime: '09:00', closeTime: key === 'fri' ? '17:00' : '18:00' };
        grid.innerHTML += `
            <div style="font-size:0.85rem; font-weight:600;">${dayLabels[i]}</div>
            <label class="ops-toggle-label"><input type="checkbox" id="sch-open-${key}" ${rules.open?'checked':''}> Open</label>
            <input type="time" class="ops-input" id="sch-start-${key}" value="${rules.openTime||'09:00'}">
            <input type="time" class="ops-input" id="sch-end-${key}" value="${rules.closeTime||'18:00'}">
        `;
    });
}

function renderOpsCatDiscounts(cats) {
    const list = document.getElementById('ops-cat-discounts');
    list.innerHTML = cats.map((c, i) => `
        <div style="display:flex; gap:0.5rem; margin-bottom:0.5rem;" class="ops-cat-rule">
            <input type="text" class="ops-input" placeholder="Category" value="${c.category || ''}" data-cat-id="${i}">
            <input type="number" class="ops-input" placeholder="%" value="${c.percent || ''}" style="width:70px;" data-pct-id="${i}">
            <button class="btn btn-outline" style="width:auto; border-color:#fecaca; color:#b91c1c; padding:0 0.5rem;" onclick="this.parentElement.remove()">
                <i class="fa fa-times"></i>
            </button>
        </div>
    `).join('');
}

function addCatDiscount() {
    renderOpsCatDiscounts([...Array.from(document.querySelectorAll('.ops-cat-rule')).map(el => ({
        category: el.querySelector('[data-cat-id]').value,
        percent:  el.querySelector('[data-pct-id]').value
    })), {category:'', percent:''}]);
}

function opsSaleBannerToggle() {
    const active = document.getElementById('ops-sale-active').checked;
    document.getElementById('ops-sale-fields').style.display = active ? 'block' : 'none';
}

function opsDiscountToggle() {
    const enableCb = document.getElementById('ops-storewide-enabled');
    if (!enableCb) return;
    const isE = enableCb.checked;
    document.getElementById('ops-storewide-pct').disabled = !isE;
    document.getElementById('ops-storewide-ends').disabled = !isE;
}

function bindOpsPreview() {
    const update = () => {
        const headline = document.getElementById('ops-sale-headline').value || 'Headline';
        const sub = document.getElementById('ops-sale-subtext').value || 'Subtext description';
        const pct = document.getElementById('ops-sale-pct').value;
        const bg = document.getElementById('ops-sale-image').value;
        
        document.getElementById('ops-preview-headline').textContent = headline;
        document.getElementById('ops-preview-subtext').textContent = sub;
        document.getElementById('ops-preview-pct').textContent = pct ? `Up to ${pct}% OFF` : '';
        
        const previewEl = document.getElementById('ops-sale-preview');
        previewEl.style.display = 'block';
        if (bg && bg.startsWith('http')) {
            previewEl.style.backgroundImage = `url('${bg}')`;
            previewEl.style.backgroundSize = 'cover';
            previewEl.style.backgroundPosition = 'center';
            previewEl.style.textShadow = '0 2px 4px rgba(0,0,0,0.8)';
        } else {
            previewEl.style.backgroundImage = 'none';
            previewEl.style.background = 'var(--accent-red)';
            previewEl.style.textShadow = 'none';
        }

        // Main banner update
        const mbg = document.getElementById('ops-banner-url').value;
        const mpv = document.getElementById('ops-banner-preview');
        if (mbg && mbg.startsWith('http')) {
            document.getElementById('ops-banner-img').src = mbg;
            mpv.style.display = 'block';
        } else {
            mpv.style.display = 'none';
        }
    };
    
    ['ops-sale-headline','ops-sale-subtext','ops-sale-pct','ops-sale-image', 'ops-banner-url'].forEach(id => {
        document.getElementById(id).addEventListener('input', update);
    });
    update();
}

async function saveOpsSettings() {
    const btn = document.getElementById('ops-save-btn');
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Saving...';
    btn.disabled = true;

    try {
        // Schema day keys: mon, tue, wed, thu, fri, sat, sun
        // Schema per-day: open (bool), openTime, closeTime
        const dayKeys = ['mon','tue','wed','thu','fri','sat','sun'];
        const schedule = {};
        dayKeys.forEach(d => {
            schedule[d] = {
                open:      document.getElementById(`sch-open-${d}`).checked,
                openTime:  document.getElementById(`sch-start-${d}`).value,
                closeTime: document.getElementById(`sch-end-${d}`).value
            };
        });

        const storeWideE   = document.getElementById('ops-storewide-enabled').checked;
        const storeWideP   = document.getElementById('ops-storewide-pct').value;
        const storeWideEnd = document.getElementById('ops-storewide-ends').value;

        // Schema: discount.byCategory[].{category, percent}
        const catRules = Array.from(document.querySelectorAll('.ops-cat-rule')).map(el => ({
            category: el.querySelector('[data-cat-id]').value,
            percent:  parseInt(el.querySelector('[data-pct-id]').value, 10)
        })).filter(r => r.category && r.percent);

        const saleActive = document.getElementById('ops-sale-active').checked;
        const sHead   = document.getElementById('ops-sale-headline').value;
        const sSub    = document.getElementById('ops-sale-subtext').value;
        const sCta    = document.getElementById('ops-sale-cta-label').value;
        const sPct    = document.getElementById('ops-sale-pct').value;
        const sStarts = document.getElementById('ops-sale-starts').value;
        const sEnds   = document.getElementById('ops-sale-ends').value;
        const sImg    = document.getElementById('ops-sale-image').value;

        const mainBan    = document.getElementById('ops-banner-url').value;
        const mainBanAlt = document.getElementById('ops-banner-alt').value;

        const payload = {
            schedule,
            // Schema: discount.storeWide.{enabled, percent, endsAt} + discount.byCategory
            discount: {
                storeWide: storeWideE
                    ? { enabled: true, percent: parseInt(storeWideP, 10) || 0, endsAt: storeWideEnd ? new Date(storeWideEnd).toISOString() : null }
                    : { enabled: false },
                byCategory: catRules
            },
            // Schema: salesBanner.{active, headline, subtext, ctaLabel, discountPercent, startsAt, endsAt, imageUrl}
            salesBanner: {
                active:          saleActive,
                headline:        sHead,
                subtext:         sSub,
                ctaLabel:        sCta,
                discountPercent: sPct ? parseInt(sPct, 10) : 0,
                startsAt:        sStarts ? new Date(sStarts).toISOString() : null,
                endsAt:          sEnds   ? new Date(sEnds).toISOString()   : null,
                imageUrl:        sImg
            },
            // Schema: banner.{imageUrl, altText}
            banner: {
                imageUrl: mainBan,
                altText:  mainBanAlt
            }
        };

        const res = await fetch('/api/seller/' + userData.storeId, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
            body: JSON.stringify(payload)
        });

        if (!res.ok) throw new Error('Failed to update operations');
        showToast('Operations saved successfully', 'success');
        
    } catch (err) {
        console.error(err);
        showToast(err.message, 'error');
    } finally {
        btn.innerHTML = '<i class="fa fa-save" style="margin-right:0.4rem;"></i> Save Operations';
        btn.disabled = false;
    }
}

function resetOpsForm() {
    loadOpsPanel();
}
</script>
