    // ── Store card ────────────────────────────────────────────────────────────
    async function loadStoreCard() {
        if (!userData.storeId) return;
        if (!isSeller && !isAdmin) return;
        
        try {
            const res = await fetch(`/api/public-seller/${userData.storeId}`);
            if (!res.ok) return;
            const store = await res.json();
            
            document.getElementById('store-name-display').textContent = store.name || '—';
            
            // Open/Closed logic
            const badge = document.getElementById('store-open-badge');
            if (store.isOpen) {
                badge.textContent = '● OPEN';
                badge.style.background = '#f0fdf4';
                badge.style.color = '#15803d';
                badge.style.borderColor = '#bbf7d0';
            } else {
                badge.textContent = '● CLOSED';
                badge.style.background = '#fef2f2';
                badge.style.color = '#b91c1c';
                badge.style.borderColor = '#fecaca';
            }

            // Hours display — nextOpen is a flat string like "Mon 09:00", not an object
            document.getElementById('store-hours-display').textContent = store.closesAt
                ? `Closes at ${store.closesAt}`
                : (store.nextOpen ? `Opens ${store.nextOpen}` : 'Schedule unavailable');

            // Last Active
            document.getElementById('store-last-active-display').textContent = store.lastActive
                ? new Date(store.lastActive).toLocaleDateString()
                : 'Recently';

            // Sale badge — backend returns null when inactive, object when live
            const saleBadge = document.getElementById('store-sale-badge');
            saleBadge.style.display = store.salesBanner ? 'inline-block' : 'none';

            // Discount badge — schema: discount.storeWide.{enabled, percent}
            const discBadge = document.getElementById('store-discount-badge');
            if (store.discount?.storeWide?.enabled && store.discount.storeWide.percent > 0) {
                discBadge.textContent = `-${store.discount.storeWide.percent}% ALL`;
                discBadge.style.display = 'inline-block';
            } else {
                discBadge.style.display = 'none';
            }

            document.getElementById('store-card').style.display = 'block';
        } catch (err) {
            console.error('Failed to load store card', err);
        }
    }

    // ── Storefront toggle (deactivate / reactivate) ───────────────────────────
    async function toggleStorefront(activate) {
        if (!userData.storeId) return;
        const action = activate ? 'activate' : 'deactivate';
        try {
            const r = await fetch(`/api/seller/${userData.storeId}/${action}`, {
                method: 'POST',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!r.ok) throw new Error((await r.json()).error || `HTTP ${r.status}`);

            // Refresh token so storeActive flag updates in JWT
            const rtRes = await fetch('/oauth/refresh', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json' },
                body:    JSON.stringify({ refresh_token: localStorage.getItem('refresh_token') })
            });
            if (!rtRes.ok) {
                showToast(
                    `Store ${action}d but session refresh failed. Log out and back in to apply changes.`,
                    'error'
                );
                return;
            }
            const tokens = await rtRes.json();
            if (tokens.access_token) {
                localStorage.setItem('access_token',  tokens.access_token);
                localStorage.setItem('refresh_token', tokens.refresh_token);
            }
            showToast(activate ? 'Storefront activated!' : 'Storefront deactivated.', 'success');
            setTimeout(() => window.location.reload(), 1000);
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
        }
    }

    // ── Watchlist ─────────────────────────────────────────────────────────────
    const WL_KEY = `markee_wl_${userData?.email || 'guest'}`;

    function getWatchlist() {
        try { return JSON.parse(localStorage.getItem(WL_KEY) || '[]'); }
        catch { return []; }
    }

    function saveWatchlist(wl) { localStorage.setItem(WL_KEY, JSON.stringify(wl)); }

    let _enrichingWL = false;
    async function enrichWatchlistPrices() {
        if (_enrichingWL) return;
        const wl = getWatchlist();
        if (!wl.length) return;
        _enrichingWL = true;

        try {
            const results = await Promise.allSettled(
                wl.map(item => Promise.all([
                    fetch(`/api/catalog/products/${item.productId}`).then(r => r.json()).catch(() => null),
                    fetch(`/api/inventory/stock/${item.productId}`).then(r => r.ok ? r.json() : null).catch(() => null)
                ]))
            );
            let changed = false;
            results.forEach((r, i) => {
                if (r.status !== 'fulfilled') return;
                const [catalogData, stockData] = r.value;

                if (catalogData?._id) {
                    const currentPrice = catalogData.price;
                    if (currentPrice !== wl[i].price && wl[i].currentPrice !== currentPrice) {
                        wl[i].priceChanged = true;
                        wl[i].currentPrice = currentPrice;
                        wl[i].priceDelta   = currentPrice - wl[i].price;
                        changed = true;
                    }
                    const nowUnavailable = catalogData.status !== 'active';
                    if (nowUnavailable !== !!wl[i].outOfStock) {
                        wl[i].outOfStock = nowUnavailable;
                        changed = true;
                    }
                }

                if (stockData !== null && stockData.available !== undefined) {
                    if (wl[i].stockAvailable !== stockData.available) {
                        wl[i].stockAvailable     = stockData.available;
                        wl[i].lowStockThreshold  = stockData.lowStockThreshold ?? 5;
                        changed = true;
                    }
                }
            });
            if (changed) {
                saveWatchlist(wl);
                renderWatchlist();
            }
        } catch (e) {
            console.warn('Watchlist enrichment error:', e);
        } finally {
            _enrichingWL = false;
        }
    }

    function renderWatchlist() {
        const wl   = getWatchlist();
        const list = document.getElementById('watchlist-list');
        const badge = document.getElementById('wl-badge');
        const statEl = document.getElementById('stat-watchlist');
        if (statEl) statEl.textContent = wl.length;
        if (badge) { badge.textContent = wl.length; badge.style.display = wl.length ? 'inline' : 'none'; }

        if (!wl.length) {
            list.innerHTML = '<p class="text-muted p-4">Nothing saved yet. Click the ♡ on any product to watch it.</p>';
            return;
        }

        list.innerHTML = wl.map(item => {
            const priceStr = `$${((item.price || 0) / 100).toFixed(2)}`;
            const img      = (item.image || '');
            const deltaStr = item.priceDelta
                ? (item.priceDelta < 0
                    ? `<span style="color:#15803d; font-weight:700; margin-left:0.4rem;">▼ $${Math.abs(item.priceDelta/100).toFixed(2)} drop!</span>`
                    : `<span style="color:#b91c1c; font-weight:700; margin-left:0.4rem;">▲ $${(item.priceDelta/100).toFixed(2)} increase</span>`)
                : (item.priceChanged ? `<span style="font-size:0.7rem; color:#b91c1c; font-weight:700; margin-left:0.4rem;">Price changed!</span>` : '');
            
            const stockBadge = item.outOfStock
                ? `<span style="font-size:0.7rem; color:#6b7280; font-weight:700; margin-left:0.4rem;">Unavailable</span>`
                : item.stockAvailable === 0
                    ? `<span style="font-size:0.7rem; color:#b91c1c; font-weight:700; margin-left:0.4rem;">Out of stock</span>`
                    : (item.stockAvailable > 0 && item.stockAvailable <= (item.lowStockThreshold ?? 5))
                        ? `<span style="font-size:0.7rem; color:#d97706; font-weight:700; margin-left:0.4rem;">Only ${item.stockAvailable} left</span>`
                        : '';
            return `
            <div class="list-item flex-between animate-fade" style="cursor:pointer;" onclick="window.location='/product/${item.productId}'">
                <div class="flex-center gap-2" style="min-width:0;">
                    <img src="${img}" style="width:44px;height:44px;border-radius:6px;object-fit:cover;background:var(--bg-secondary);flex-shrink:0;"
                         onerror="this.onerror=null;this.src=''">
                    <div>
                        <div style="font-weight:600; font-size:0.875rem;">${item.title}${stockBadge}</div>
                        <div class="text-muted small">${priceStr}${deltaStr} · Saved ${new Date(item.savedAt).toLocaleDateString()}</div>
                    </div>
                </div>
                <button class="act-btn danger" onclick="event.stopPropagation(); removeFromWatchlist('${item.productId}')" title="Remove">
                    <i class="fa fa-heart-broken"></i>
                </button>
            </div>`;
        }).join('');

        if (!_enrichingWL) enrichWatchlistPrices();
    }

    function removeFromWatchlist(productId) {
        const wl = getWatchlist().filter(i => i.productId !== productId);
        saveWatchlist(wl);
        renderWatchlist();
        // Sync removal to user-service DB so price-drop notifications work
        fetch(`/api/users/me/watchlist/${productId}`, {
            method: 'DELETE',
            headers: { Authorization: `Bearer ${token}` }
        }).catch(() => {});
    }

    function clearWatchlist() {
        // Sync every removal to DB before wiping localStorage
        const wl = getWatchlist();
        wl.forEach(item => {
            fetch(`/api/users/me/watchlist/${item.productId}`, {
                method: 'DELETE',
                headers: { Authorization: `Bearer ${token}` }
            }).catch(() => {});
        });
        saveWatchlist([]);
        renderWatchlist();
        showToast('Watchlist cleared.', 'info');
    }

    // ── Load seller stats strip ───────────────────────────────────────────────
    async function loadStats() {
        try {
            const [statsRes, pulseRes] = await Promise.all([
                fetch('/api/orders/seller-stats',    { headers: { 'Authorization': `Bearer ${token}` } }),
                fetch('/api/analytics/store-pulse',  { headers: { 'Authorization': `Bearer ${token}` } })
            ]);

            if (statsRes.ok) {
                const stats = await statsRes.json();
                document.getElementById('stat-orders').textContent = stats.activeOrders ?? 0;
                const total = stats.totalOrders ?? 0;
                const sub = document.getElementById('stat-orders-sub');
                if (sub) sub.textContent = `${total} total order${total !== 1 ? 's' : ''}`;
            }

            if (pulseRes.ok) {
                const pulse = await pulseRes.json();
                const rev30 = pulse.revenueThisMonth || 0;
                document.getElementById('stat-revenue').textContent =
                    `$${(rev30 / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}`;
                const revSub = document.getElementById('stat-revenue-sub');
                if (revSub) revSub.textContent = `${pulse.ordersThisMonth ?? 0} orders this month`;
                const missed = document.getElementById('stat-missed');
                if (missed) missed.textContent = pulse.missedSalesCount ?? 0;
