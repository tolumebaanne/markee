<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Accounts | Markee Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <style>
        body { background: #0f172a; color: #f1f5f9; }
        .admin-shell { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }
        /* Sidebar */
        .admin-sidebar {
            background: #1e293b; border-right: 1px solid #334155;
            padding: 1.5rem 1rem;
            position: sticky; top: 0; height: 100vh; overflow-y: auto;
        }
        .sidebar-logo { display:flex; align-items:center; gap:0.6rem; margin-bottom:1.75rem; }
        .sidebar-logo .mark { width:32px;height:32px;background:linear-gradient(135deg,#ef4444,#b91c1c);border-radius:8px;display:flex;align-items:center;justify-content:center; }
        .sidebar-logo .mark i { color:white;font-size:0.85rem; }
        .sidebar-logo span { font-weight:700;font-size:0.95rem; }
        .sidebar-section { font-size:0.68rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.08em;padding:0.5rem 0.5rem 0.25rem; }
        .sidebar-link { display:flex;align-items:center;gap:0.6rem;padding:0.6rem 0.75rem;border-radius:8px;color:#94a3b8;font-size:0.82rem;font-weight:500;text-decoration:none;cursor:pointer;transition:all 0.15s;border:none;background:none;width:100%; }
        .sidebar-link:hover { background:#334155;color:#f1f5f9; }
        .sidebar-link.active { background:#450a0a;color:#fca5a5; }
        .sidebar-link i { width:16px;text-align:center; }
        /* Main */
        .admin-main { padding: 2rem 2.5rem; }
        .page-header { display:flex;align-items:center;justify-content:space-between;margin-bottom:1.75rem; }
        .page-header h1 { font-size:1.4rem;font-weight:700;margin:0; }
        /* Cards */
        .card { background:#1e293b;border:1px solid #334155;border-radius:12px;overflow:hidden;margin-bottom:1.25rem; }
        .card-header { padding:0.9rem 1.25rem;border-bottom:1px solid #334155;display:flex;align-items:center;justify-content:space-between; }
        .card-header h3 { margin:0;font-size:0.9rem;font-weight:700; }
        .card-body { padding:1.25rem; }
        /* Table */
        .tbl { width:100%;border-collapse:collapse;font-size:0.82rem; }
        .tbl th { padding:0.6rem 0.9rem;text-align:left;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#64748b;border-bottom:1px solid #334155; }
        .tbl td { padding:0.75rem 0.9rem;border-bottom:1px solid #1e293b;vertical-align:middle; }
        .tbl tr:last-child td { border-bottom:none; }
        .tbl tr:hover td { background:#334155; }
        /* Badges */
        .badge { display:inline-block;padding:0.15rem 0.55rem;border-radius:20px;font-size:0.7rem;font-weight:700;text-transform:uppercase; }
        .badge-active   { background:#052e16;color:#4ade80; }
        .badge-suspended{ background:#431407;color:#fb923c; }
        .badge-revoked  { background:#450a0a;color:#f87171; }
        .badge-super    { background:#1e1b4b;color:#a5b4fc; }
        /* Buttons */
        .btn { padding:0.45rem 0.9rem;border-radius:7px;font-size:0.78rem;font-weight:600;cursor:pointer;border:none;transition:all 0.15s; }
        .btn-sm { padding:0.3rem 0.65rem;font-size:0.73rem; }
        .btn-primary { background:#ef4444;color:white; }
        .btn-primary:hover { background:#dc2626; }
        .btn-outline { background:transparent;color:#94a3b8;border:1px solid #334155; }
        .btn-outline:hover { background:#334155;color:#f1f5f9; }
        .btn-danger { background:#7f1d1d;color:#fca5a5; }
        .btn-danger:hover { background:#991b1b; }
        /* Modal */
        .modal-overlay { display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1000;align-items:center;justify-content:center; }
        .modal-overlay.open { display:flex; }
        .modal { background:#1e293b;border:1px solid #334155;border-radius:14px;padding:2rem;width:90%;max-width:560px;max-height:90vh;overflow-y:auto; }
        .modal h3 { margin:0 0 1.25rem;font-size:1rem;font-weight:700; }
        .form-group { margin-bottom:1rem; }
        .form-group label { display:block;font-size:0.75rem;font-weight:600;color:#94a3b8;margin-bottom:0.35rem;text-transform:uppercase;letter-spacing:0.05em; }
        .form-group input, .form-group select {
            width:100%;padding:0.6rem 0.8rem;background:#0f172a;border:1px solid #334155;
            border-radius:7px;color:#f1f5f9;font-size:0.85rem;box-sizing:border-box;
        }
        .form-group input:focus, .form-group select:focus { outline:none;border-color:#ef4444; }
        /* Permission grid */
        .perm-grid { display:grid;gap:0.75rem; }
        .perm-domain { background:#0f172a;border:1px solid #334155;border-radius:8px;padding:0.75rem 1rem; }
        .perm-domain-title { font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:#64748b;margin-bottom:0.5rem; }
        .perm-toggles { display:flex;flex-wrap:wrap;gap:0.4rem; }
        .perm-toggle { display:flex;align-items:center;gap:0.3rem; }
        .perm-toggle input[type=checkbox] { width:14px;height:14px;accent-color:#ef4444; }
        .perm-toggle label { font-size:0.75rem;color:#94a3b8;cursor:pointer; }
        /* Superuser badge */
        .su-badge { background:linear-gradient(135deg,#7c3aed,#4c1d95);color:white;padding:0.15rem 0.5rem;border-radius:5px;font-size:0.68rem;font-weight:700; }
    </style>
</head>
<body>
<div class="admin-shell">
    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <div class="mark"><i class="fa fa-shield-alt"></i></div>
            <span>Markee Admin</span>
        </div>
        <div class="sidebar-section">Navigation</div>
        <a class="sidebar-link" href="/admin"><i class="fa fa-th-large"></i> Overview</a>
        <a class="sidebar-link active" href="/admin/accounts"><i class="fa fa-users-cog"></i> Admin Accounts</a>
        <a class="sidebar-link" href="/admin/templates"><i class="fa fa-layer-group"></i> Templates</a>
        <a class="sidebar-link" href="/admin/intelligence"><i class="fa fa-brain"></i> Intelligence</a>
        <a class="sidebar-link" href="/admin/system"><i class="fa fa-cog"></i> System</a>
        <div style="margin-top:auto;padding-top:2rem;">
            <button class="sidebar-link" onclick="adminLogout()" style="color:#ef4444;">
                <i class="fa fa-sign-out-alt"></i> Logout
            </button>
        </div>
    </aside>

    <!-- Main -->
    <main class="admin-main">
        <div class="page-header">
            <div>
                <h1><i class="fa fa-users-cog" style="color:#ef4444;margin-right:0.5rem;"></i> Admin Accounts</h1>
                <p style="color:#64748b;margin:0.25rem 0 0;font-size:0.82rem;">Manage spawned admin accounts and their permission buckets</p>
            </div>
            <button class="btn btn-primary" onclick="openCreateModal()">
                <i class="fa fa-plus" style="margin-right:0.4rem;"></i> Create Admin
            </button>
        </div>

        <div class="card">
            <div class="card-header">
                <h3>All Accounts</h3>
                <div style="display:flex;gap:0.5rem;">
                    <select id="filter-status" onchange="loadAccounts()" style="background:#0f172a;border:1px solid #334155;color:#f1f5f9;padding:0.3rem 0.5rem;border-radius:6px;font-size:0.78rem;">
                        <option value="">All statuses</option>
                        <option value="active">Active</option>
                        <option value="suspended">Suspended</option>
                        <option value="revoked">Revoked</option>
                    </select>
                    <button class="btn btn-outline btn-sm" onclick="loadAccounts()"><i class="fa fa-sync"></i></button>
                </div>
            </div>
            <div style="overflow-x:auto;">
                <table class="tbl">
                    <thead>
                        <tr>
                            <th>Email</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Template</th>
                            <th>MFA</th>
                            <th>Last Active</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody id="accounts-tbody">
                        <tr><td colspan="7" style="text-align:center;color:#475569;padding:2rem;">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<!-- Create Account Modal -->
<div class="modal-overlay" id="create-modal">
    <div class="modal">
        <h3><i class="fa fa-user-plus" style="color:#ef4444;margin-right:0.5rem;"></i> Create Admin Account</h3>
        <div class="form-group">
            <label>Email Address</label>
            <input type="email" id="new-email" placeholder="admin@example.com" />
        </div>
        <div class="form-group">
            <label>Permission Template</label>
            <select id="new-template">
                <option value="">— Start with empty bucket —</option>
            </select>
        </div>
        <div class="form-group">
            <label>Scope Restriction (optional)</label>
            <input type="text" id="new-scope-store" placeholder="Store ID (leave blank for global access)" />
        </div>
        <div class="form-group">
            <label style="display:flex;align-items:center;gap:0.5rem;cursor:pointer;">
                <input type="checkbox" id="new-mfa" style="width:auto;" />
                Require MFA for this account
            </label>
        </div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1.25rem;">
            <button class="btn btn-outline" onclick="closeCreateModal()">Cancel</button>
            <button class="btn btn-primary" onclick="createAccount()">
                <i class="fa fa-user-plus" style="margin-right:0.3rem;"></i> Create Account
            </button>
        </div>
    </div>
</div>

<!-- Edit Permissions Modal -->
<div class="modal-overlay" id="perms-modal">
    <div class="modal">
        <h3 id="perms-modal-title"><i class="fa fa-key" style="color:#ef4444;margin-right:0.5rem;"></i> Edit Permissions</h3>
        <input type="hidden" id="perms-account-id" />
        <div id="perm-grid" class="perm-grid"></div>
        <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1.5rem;">
            <button class="btn btn-outline" onclick="closePermsModal()">Cancel</button>
            <button class="btn btn-primary" onclick="savePermissions()">
                <i class="fa fa-save" style="margin-right:0.3rem;"></i> Save Permissions
            </button>
        </div>
    </div>
</div>

<script>
const ADMIN_API = '/api/admin';
// ── Guard — check token exists ────────────────────────────────────────────────
let _adminToken = localStorage.getItem('admin_access_token');
(function guard() {
    if (!_adminToken) { window.location.replace('/admin-login'); return; }
    try { JSON.parse(atob(_adminToken.split('.')[1])); }
    catch { window.location.replace('/admin-login'); }
    // Expired tokens are handled by auto-refresh in api() — don't hard-redirect here
})();

// ── Silent token refresh ───────────────────────────────────────────────────────
let _refreshing = null;
async function _tryRefreshToken() {
    if (_refreshing) return _refreshing;
    _refreshing = (async () => {
        const rt = localStorage.getItem('admin_refresh_token');
        if (!rt) return false;
        try {
            const r = await fetch('/api/admin/auth/refresh', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ refresh_token: rt })
            });
            if (!r.ok) return false;
            const d = await r.json();
            _adminToken = d.access_token;
            localStorage.setItem('admin_access_token', d.access_token);
            localStorage.setItem('admin_refresh_token', d.refresh_token);
            return true;
        } catch { return false; }
        finally { _refreshing = null; }
    })();
    return _refreshing;
}

// ── API helpers ───────────────────────────────────────────────────────────────
async function api(method, path, body) {
    // Proactive refresh: if token expires within 60 seconds, refresh first
    try {
        const p = JSON.parse(atob(_adminToken.split('.')[1]));
        if (p.exp && (p.exp - Date.now() / 1000) < 60) await _tryRefreshToken();
    } catch {}

    const doFetch = (tok) => fetch(ADMIN_API + path, {
        method,
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + tok },
        body: body ? JSON.stringify(body) : undefined
    });

    let res = await doFetch(_adminToken);

    // Reactive refresh on 401
    if (res.status === 401) {
        const refreshed = await _tryRefreshToken();
        if (!refreshed) { window.location.replace('/admin-login'); return; }
        res = await doFetch(_adminToken);
        if (res.status === 401) { window.location.replace('/admin-login'); return; }
    }

    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.message || 'Request failed');
    return data;
}

function adminLogout() {
    api('POST', '/auth/logout').catch(() => {});
    localStorage.removeItem('admin_access_token');
    localStorage.removeItem('admin_refresh_token');
    window.location.replace('/admin-login');
}

// ── Permission domains ────────────────────────────────────────────────────────
const PERM_DOMAINS = {
    auth:          ['read','write','ban','impersonate'],
    catalog:       ['read','write','approve','reject','feature','categoryMgmt','bulk'],
    orders:        ['read','forceStatus','cancel','bulk'],
    payments:      ['read','refund','release','partialRefund','freeze','splitRefund','resolveDisputes','payoutHold'],
    sellers:       ['read','write','verify','suspend','ban','regApproval','tier'],
    reviews:       ['read','moderate','delete','bulk'],
    messages:      ['read','moderate','inject','ban'],
    notifications: ['read','send','broadcast','editTemplates','prefOverride','config'],
    analytics:     ['read','readAll','export'],
    search:        ['read','feature','reindex','hide','autocomplete'],
    inventory:     ['read','adjust','freeze'],
    shipping:      ['read','forceStatus'],
    intelligence:  ['sellerScores','buyerScores','buyerOverride','fraudSignals','anomalies','leakage','balance','funnel'],
    config:        ['read','write'],
    audit:         ['readOwn','readAll','export']
};

// ── Load accounts ─────────────────────────────────────────────────────────────
async function loadAccounts() {
    const status  = document.getElementById('filter-status').value;
    const tbody   = document.getElementById('accounts-tbody');
    tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#475569;padding:2rem;"><i class="fa fa-spinner fa-spin"></i> Loading...</td></tr>';

    try {
        const qs = status ? `?status=${status}` : '';
        const { accounts } = await api('GET', `/accounts${qs}`);
        if (!accounts?.length) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#475569;padding:2rem;">No accounts found</td></tr>';
            return;
        }
        tbody.innerHTML = accounts.map(a => `
            <tr>
                <td style="font-weight:600;">${a.email}${a.isSuperuser ? ' <span class="su-badge">SUPERUSER</span>' : ''}</td>
                <td>${a.isSuperuser ? '<span class="badge badge-super">Superuser</span>' : '<span class="badge" style="background:#1e3a5f;color:#93c5fd;">Admin</span>'}</td>
                <td><span class="badge badge-${a.status}">${a.status}</span></td>
                <td style="color:#64748b;font-size:0.75rem;">${a.permissionTemplateId ? 'Template applied' : 'Custom'}</td>
                <td style="text-align:center;">${a.mfaEnabled ? '<i class="fa fa-shield-alt" style="color:#4ade80;" title="MFA enabled"></i>' : '<i class="fa fa-minus" style="color:#475569;" title="No MFA"></i>'}</td>
                <td style="color:#64748b;font-size:0.75rem;">${a.lastActive ? new Date(a.lastActive).toLocaleDateString() : 'Never'}</td>
                <td>
                    <div style="display:flex;gap:0.35rem;">
                        ${!a.isSuperuser ? `<button class="btn btn-outline btn-sm" title="Edit permissions" onclick="openPermsModal('${a._id}','${a.email}')"><i class="fa fa-key"></i></button>` : ''}
                        ${!a.isSuperuser && a.status === 'active' ? `<button class="btn btn-sm" style="background:#431407;color:#fb923c;" title="Suspend" onclick="suspendAccount('${a._id}')"><i class="fa fa-ban"></i></button>` : ''}
                        ${!a.isSuperuser && a.status === 'suspended' ? `<button class="btn btn-outline btn-sm" title="Reactivate" onclick="reactivateAccount('${a._id}')"><i class="fa fa-check"></i></button>` : ''}
                    </div>
                </td>
            </tr>
        `).join('');
    } catch (err) {
        tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;color:#f87171;padding:2rem;">${err.message}</td></tr>`;
    }
}

// ── Create account ────────────────────────────────────────────────────────────
let templates = [];
async function openCreateModal() {
    // Load templates for the select
    if (!templates.length) {
        try { templates = await api('GET', '/templates'); } catch {}
    }
    const sel = document.getElementById('new-template');
    sel.innerHTML = '<option value="">— Start with empty bucket —</option>' +
        templates.map(t => `<option value="${t._id}">${t.name}</option>`).join('');
    document.getElementById('create-modal').classList.add('open');
}
function closeCreateModal() {
    document.getElementById('create-modal').classList.remove('open');
    document.getElementById('new-email').value = '';
    document.getElementById('new-template').value = '';
    document.getElementById('new-scope-store').value = '';
    document.getElementById('new-mfa').checked = false;
}
async function createAccount() {
    const email      = document.getElementById('new-email').value.trim();
    const templateId = document.getElementById('new-template').value;
    const storeId    = document.getElementById('new-scope-store').value.trim();
    const mfaEnabled = document.getElementById('new-mfa').checked;
    if (!email) { showToast('Email is required', 'error'); return; }
    try {
        await api('POST', '/accounts', {
            email, templateId: templateId || undefined,
            scopeRestrictions: storeId ? { storeId } : {},
            mfaEnabled
        });
        showToast('Admin account created', 'success');
        closeCreateModal();
        loadAccounts();
    } catch (err) {
        showToast(err.message, 'error');
    }
}

// ── Suspend / Reactivate ──────────────────────────────────────────────────────
async function suspendAccount(id) {
    const reason = prompt('Reason for suspension (optional):') || '';
    try {
        await api('POST', `/accounts/${id}/suspend`, { reason });
        showToast('Account suspended', 'success');
        loadAccounts();
    } catch (err) { showToast(err.message, 'error'); }
}
async function reactivateAccount(id) {
    try {
        await api('POST', `/accounts/${id}/reactivate`);
        showToast('Account reactivated', 'success');
        loadAccounts();
    } catch (err) { showToast(err.message, 'error'); }
}

// ── Edit Permissions Modal ────────────────────────────────────────────────────
let currentPermsAccount = null;
async function openPermsModal(id, email) {
    try {
        const account = await api('GET', `/accounts/${id}`);
        currentPermsAccount = account;
        document.getElementById('perms-account-id').value = id;
        document.getElementById('perms-modal-title').innerHTML =
            `<i class="fa fa-key" style="color:#ef4444;margin-right:0.5rem;"></i> Permissions — ${email}`;

        const grid = document.getElementById('perm-grid');
        grid.innerHTML = Object.entries(PERM_DOMAINS).map(([domain, actions]) => `
            <div class="perm-domain">
                <div class="perm-domain-title">${domain}</div>
                <div class="perm-toggles">
                    ${actions.map(action => `
                        <label class="perm-toggle">
                            <input type="checkbox" id="perm-${domain}-${action}"
                                ${account.permissions?.[domain]?.[action] ? 'checked' : ''} />
                            <span>${action}</span>
                        </label>
                    `).join('')}
                </div>
            </div>
        `).join('');

        document.getElementById('perms-modal').classList.add('open');
    } catch (err) { showToast(err.message, 'error'); }
}
function closePermsModal() { document.getElementById('perms-modal').classList.remove('open'); }

async function savePermissions() {
    const id = document.getElementById('perms-account-id').value;
    const permissions = {};
    for (const [domain, actions] of Object.entries(PERM_DOMAINS)) {
        permissions[domain] = {};
        for (const action of actions) {
            permissions[domain][action] = document.getElementById(`perm-${domain}-${action}`)?.checked || false;
        }
    }
    try {
        await api('PUT', `/accounts/${id}/permissions`, { permissions });
        showToast('Permissions updated', 'success');
        closePermsModal();
        loadAccounts();
    } catch (err) { showToast(err.message, 'error'); }
}

// ── Init ──────────────────────────────────────────────────────────────────────
loadAccounts();
</script>
</body>
</html>
