<!-- ══════════════ SHARED JAVASCRIPT ══════════════ -->
<script>
// ── Auth guard ────────────────────────────────────────────────────────────────
function parseJwt(t) {
  try { return JSON.parse(atob(t.split('.')[1].replace(/-/g,'+').replace(/_/g,'/'))); } catch { return null; }
}
const token = localStorage.getItem('admin_access_token');
if (!token) window.location.replace('/admin-login');
const user = parseJwt(token);
if (!user || !user.isAdmin) window.location.replace('/admin-login');

document.getElementById('adminEmail').textContent = user.email || 'Admin';
document.getElementById('adminRole').textContent   = user.isSuperuser ? 'Superuser' : 'Admin';
if (user.isSuperuser) document.getElementById('superuserBadge').style.display = 'inline-flex';
window._isSuperuser = !!user.isSuperuser;
window._adminEmail  = user.email || '';

function doLogout() {
  ['admin_access_token','admin_refresh_token','admin_is_superuser'].forEach(k => localStorage.removeItem(k));
  window.location.replace('/admin-login');
}

// ── Core API helper — with silent JWT auto-refresh ────────────────────────────
let _adminToken = localStorage.getItem('admin_access_token');
let _refreshing  = null; // deduplicate concurrent refresh attempts

async function _tryRefreshToken() {
  if (_refreshing) return _refreshing;
  _refreshing = (async () => {
    const rt = localStorage.getItem('admin_refresh_token');
    if (!rt) return false;
    try {
      const r = await fetch('/api/admin/auth/refresh', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ refresh_token: rt })
      });
      if (!r.ok) return false;
      const d = await r.json();
      _adminToken = d.access_token;
      localStorage.setItem('admin_access_token', d.access_token);
      localStorage.setItem('admin_refresh_token', d.refresh_token);
      return true;
    } catch { return false; }
    finally { _refreshing = null; }
  })();
  return _refreshing;
}

async function adminApi(method, path, body) {
  // Pro-active refresh: if the stored JWT expires within 60 seconds, refresh it first
  const parsed = parseJwt(_adminToken);
  if (parsed && parsed.exp && (parsed.exp - Date.now() / 1000) < 60) {
    await _tryRefreshToken();
  }

  const doFetch = (tok) => fetch('/api/admin' + path, {
    method,
    headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + tok },
    body: body != null ? JSON.stringify(body) : undefined
  });

  let res = await doFetch(_adminToken);

  // On 401, try a reactive refresh once then retry
  if (res.status === 401) {
    const refreshed = await _tryRefreshToken();
    if (!refreshed) { window.location.replace('/admin-login'); return; }
    res = await doFetch(_adminToken);
    if (res.status === 401) { window.location.replace('/admin-login'); return; }
  }

  const data = await res.json().catch(() => ({}));
  if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
  return data;
}

// ── Toast ─────────────────────────────────────────────────────────────────────
const _TOAST_ICONS = { success:'fa-check-circle', error:'fa-circle-xmark', warn:'fa-triangle-exclamation', info:'fa-circle-info' };
function toast(msg, type='success', dur=3500) {
  const c = document.getElementById('toast-container');
  const el = document.createElement('div');
  el.className = `toast ${type}`;
  el.innerHTML = `<i class="fas ${_TOAST_ICONS[type]} toast-icon"></i><span class="toast-msg">${msg}</span><button class="toast-dismiss" onclick="this.parentElement.remove()"><i class="fas fa-times"></i></button>`;
  c.appendChild(el);
  setTimeout(() => { el.classList.add('removing'); setTimeout(() => el.remove(), 250); }, dur);
}

// ── Formatters ────────────────────────────────────────────────────────────────
function fmt$(cents) { return '$' + ((cents||0)/100).toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}); }
function fmtDate(iso) { if (!iso) return '—'; return new Date(iso).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}); }
function fmtTime(iso) { if (!iso) return '—'; return new Date(iso).toLocaleString('en-US',{month:'short',day:'numeric',hour:'2-digit',minute:'2-digit'}); }
function trunc(s, n=22) { if (!s) return '—'; s=s.toString(); return s.length>n ? s.slice(0,n)+'…' : s; }
function stars(n) { const f=Math.min(Math.round(n||0),5); return '★'.repeat(f)+'☆'.repeat(5-f); }
function debounce(fn, ms) { let t; return (...a) => { clearTimeout(t); t=setTimeout(()=>fn(...a),ms); }; }
function animateCounter(el, target, prefix='', suffix='') {
  if (!el||isNaN(target)) { if(el) el.textContent=prefix+Math.round(target||0).toLocaleString()+suffix; return; }
  const dur=600, step=dur/60; let cur=0, t;
  t=setInterval(()=>{ cur+=(target-0)/(dur/step); if(cur>=target){cur=target;clearInterval(t);} el.textContent=prefix+Math.round(cur).toLocaleString()+suffix; },step);
}

// ── Status badge ──────────────────────────────────────────────────────────────
const _STATUS_STYLES = {
  active:['#052e16','#4ade80'], pending:['#1c1917','#d97706'], paid:['#1e3a5f','#93c5fd'],
  cancelled:['#450a0a','#f87171'], disputed:['#431407','#fb923c'], delivered:['#052e16','#4ade80'],
  shipped:['#1e1b4b','#a5b4fc'], processing:['#1e3a5f','#60a5fa'], suspended:['#431407','#fb923c'],
  held:['#1e3a5f','#93c5fd'], released:['#052e16','#4ade80'], refunded:['#450a0a','#f87171'],
  flagged:['#431407','#fbbf24'], approved:['#052e16','#4ade80'], pending_review:['#1c1917','#d97706'],
  rejected:['#450a0a','#f87171'], standard:['#1e293b','#64748b'], rising:['#1e3a5f','#93c5fd'],
  top:['#1c1917','#fbbf24'], frozen:['#0f2044','#60a5fa'], archived:['#1e293b','#475569'],
  created:['#1e3a5f','#60a5fa'], in_transit:['#1e1b4b','#a5b4fc'], revoked:['#450a0a','#f87171'],
  banned:['#450a0a','#f87171'], active_hold:['#1c1917','#d97706']
};
function badge(s) {
  if (!s) return '<span style="color:var(--muted)">—</span>';
  const [bg,color] = _STATUS_STYLES[s] || ['#1e293b','#64748b'];
  return `<span style="background:${bg};color:${color};padding:0.15rem 0.6rem;border-radius:20px;font-size:0.65rem;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;display:inline-flex;align-items:center;gap:0.22rem"><span style="font-size:0.42rem">●</span>${s.replace(/_/g,' ')}</span>`;
}

// ── Error helpers ─────────────────────────────────────────────────────────────
function showErr(id, msg) { const el=document.getElementById(id); if(!el) return; const sp=el.querySelector('span')||el; sp.textContent=msg; el.style.display='flex'; }
function hideErr(id) { const el=document.getElementById(id); if(el) el.style.display='none'; }

// ── Modal helpers ─────────────────────────────────────────────────────────────
function openModal(id)  { document.getElementById(id).classList.add('open'); }
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

function showConfirm({ title, body='', withReason=false, withSelect=null, selectLabel='Select', withInput=false, inputLabel='', danger=false }) {
  document.getElementById('confirmTitle').textContent = title;
  document.getElementById('confirmBody').textContent  = body;
  document.getElementById('confirmReasonWrap').style.display = withReason ? 'block' : 'none';
  document.getElementById('confirmReason').value = '';
  const sw=document.getElementById('confirmSelectWrap'), se=document.getElementById('confirmSelect');
  if (withSelect) {
    sw.style.display='block';
    document.getElementById('confirmSelectLabel').textContent=selectLabel;
    se.innerHTML=withSelect.map(o=>`<option value="${o.value}">${o.label}</option>`).join('');
  } else sw.style.display='none';
  const iw=document.getElementById('confirmInputWrap');
  if (withInput) {
    iw.style.display='block';
    document.getElementById('confirmInputLabel').textContent=inputLabel;
    document.getElementById('confirmInput').value='';
  } else iw.style.display='none';
  const btn=document.getElementById('confirmBtn');
  btn.className='btn '+(danger?'btn-danger':'btn-primary');
  openModal('confirmModal');
  return new Promise(resolve => {
    const clean=()=>{ btn.onclick=null; document.querySelector('#confirmModal .btn-ghost').onclick=null; };
    btn.onclick=()=>{ closeModal('confirmModal'); clean(); resolve({ confirmed:true, reason:document.getElementById('confirmReason').value.trim(), selected:withSelect?se.value:null, input:document.getElementById('confirmInput').value.trim() }); };
    document.querySelector('#confirmModal .btn-ghost').onclick=()=>{ closeModal('confirmModal'); clean(); resolve({confirmed:false}); };
  });
}

// ── Tab switching ─────────────────────────────────────────────────────────────
const loadedTabs = new Set();
const tabLoaders = {
  godview:        loadGodView,
  adminaccounts:  loadAdminAccounts,
  system:         loadSystem,
  users:          loadUsers,
  sellers:        loadSellers,
  catalog:        loadCatalog,
  'listing-review': loadListingReview,
  orders:         () => loadOrders(),
  payments:       loadPayments,
  coupons:        () => loadCoupons(1),
  inventory:      loadInventory,
  shipping:       loadShipping,
  reviews:        loadReviews,
  messages:       loadMessages,
  notifications:  loadNotifications,
  analytics:      loadAnalytics,
  search:         loadSearch,
  intelligence:   loadIntelligence,
  config:         loadConfig,
  audit:          () => loadAudit()
};

function switchTab(name, el) {
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.sidebar-link').forEach(l => l.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  if (el) el.classList.add('active');
  if (!loadedTabs.has(name)) { loadedTabs.add(name); tabLoaders[name]?.(); }
}
function switchSubTab(group, name, el) {
  document.querySelectorAll(`[id^="${group}-"].sub-panel`).forEach(p => p.style.display='none');
  const panel = document.getElementById(`${group}-${name}`);
  if (panel) panel.style.display = 'block';
  el.closest('.sub-tabs').querySelectorAll('.sub-tab').forEach(t => t.classList.remove('active'));
  el.classList.add('active');
}

// ── Init ──────────────────────────────────────────────────────────────────────
loadedTabs.add('godview');
loadGodView();
</script>
