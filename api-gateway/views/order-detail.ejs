    // ── Submit shipment (inline form) ─────────────────────────────────────────
    async function submitShipmentForm(e) {
        e.preventDefault();
        const btn = document.getElementById('ship-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Processing...';

        const fd = new FormData(e.target);
        try {
            const res = await fetch('/api/shipping', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify({
                    orderId:           ORDER_ID,
                    carrier:           fd.get('carrier'),
                    trackingNumber:    fd.get('trackingNumber'),
                    estimatedDelivery: fd.get('estimatedDelivery'),
                    sellerId:          user.storeId
                })
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);

            showToast('Shipment created — order marked as shipped!', 'success', 3500, e);
            document.getElementById('shipment-form-card').style.display = 'none';
            // Reload to reflect new status
            setTimeout(() => window.location.reload(), 800);
        } catch (err) {
            showToast('Error: ' + err.message, 'error');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-paper-plane" style="margin-right:0.5rem;"></i> Mark as Shipped';
