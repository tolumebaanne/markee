    // ── Seller: Escalation response panel ────────────────────────────────────
    function renderEscalationPanel() {
        if (!_shipment || !_shipment.escalationTier || _shipment.escalationTier < 1) return;
        // Determine seller role inline (mirrors renderActions logic)
        if (!(_order && user.storeId && _order.items.some(i => i.sellerId?.toString() === user.storeId))) return;
        // Don't double-render
        if (document.getElementById('escalation-response-panel')) return;

        const deadline = _shipment.sellerResponseDeadline
            ? new Date(_shipment.sellerResponseDeadline).toLocaleDateString()
            : 'as soon as possible';
        const tierColors = { 1: '#f59e0b', 2: '#ef4444', 3: '#7f1d1d' };
        const color = tierColors[_shipment.escalationTier] || '#f59e0b';
        const panel = document.createElement('div');
        panel.id = 'escalation-response-panel';
        panel.innerHTML = `
            <div style="margin:1rem 0; padding:1rem; border:2px solid ${color}44; border-radius:8px; background:${color}11;">
                <h5 style="color:${color}; margin:0 0 0.5rem;"><i class="fa fa-exclamation-triangle" style="margin-right:0.4rem;"></i> Escalation Notice — Tier ${_shipment.escalationTier}</h5>
                <p style="font-size:0.85rem; margin:0 0 0.75rem; color:var(--text-main);">This order has been flagged as delayed. Respond by <strong>${deadline}</strong> to avoid further escalation.</p>
                <div class="form-group mb-2">
                    <label style="font-size:0.8rem; font-weight:600;">Your Response (required)</label>
                    <textarea id="escalation-note-input" rows="3" placeholder="Explain the delay or describe your resolution..." style="font-size:0.85rem;"></textarea>
                </div>
                <div class="form-group mb-2">
                    <label style="font-size:0.8rem; font-weight:600;">New Estimated Delivery (optional)</label>
                    <input type="date" id="escalation-new-delivery" min="${new Date().toISOString().split('T')[0]}" style="font-size:0.85rem;">
                </div>
                <div id="escalation-response-error"></div>
                <button class="btn" style="background:${color}; color:white; padding:0.5rem 1rem; font-size:0.85rem; width:auto;" onclick="submitEscalationResponse(event)">
                    <i class="fa fa-reply" style="margin-right:0.4rem;"></i> Submit Response
                </button>
            </div>
        `;
        const actionsCard = document.getElementById('actions-card') || document.querySelector('.order-detail-main');
        if (actionsCard) actionsCard.insertBefore(panel, actionsCard.firstChild);
    }

    async function submitEscalationResponse(evt) {
        clearInlineError('escalation-response-error');
        const note = document.getElementById('escalation-note-input')?.value.trim();
        const newDelivery = document.getElementById('escalation-new-delivery')?.value;
        if (!note) { showInlineError('escalation-response-error', 'A response note is required.'); return; }
        if (!_shipment?._id) { showInlineError('escalation-response-error', 'Shipment not found.'); return; }
        try {
            const body = { note };
            if (newDelivery) body.newEstimatedDelivery = newDelivery;
            const res = await fetch(`/api/shipping/${_shipment._id}/seller-response`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body: JSON.stringify(body)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.message || data.error || 'Failed to submit');
            showToast('Response submitted — escalation resolved.', 'success', 3500, evt);
            document.getElementById('escalation-response-panel')?.remove();
        } catch (err) { showInlineError('escalation-response-error', 'Error: ' + err.message); }
    }

