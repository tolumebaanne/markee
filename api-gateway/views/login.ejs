<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connecting... | Markee</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .spinner {
            width: 40px; height: 40px; margin: 0 auto 1.5rem auto;
            border: 3px solid var(--border-light);
            border-top-color: var(--accent-red);
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <div class="auth-wrapper animate-fade">
        <div class="auth-panel" style="box-shadow: none;">
            <div class="spinner"></div>
            <h3>Connecting Securely</h3>
            <p class="text-muted">Initiating authorization handshake...</p>
            <script>
                // Use replace() so navigating 'Back' from the Auth Server doesn't trigger an infinite redirect loop
                // Pass the ?next= param through the OAuth state so the callback can redirect back to the right page.
                setTimeout(() => {
                    const params  = new URLSearchParams(window.location.search);
                    const nextUrl = params.get('next') || '';
                    // Validate: only allow relative paths (start with / but not //)
                    const safeNext = /^\/[^/]/.test(nextUrl) ? nextUrl : '';
                    const state = encodeURIComponent(JSON.stringify({ nonce: 'markee', next: safeNext }));
                    window.location.replace("/oauth/authorize?response_type=code&client_id=markee-gateway&redirect_uri=" + encodeURIComponent(window.location.origin + "/callback") + "&state=" + state);
                }, 800);
            </script>
        </div>
    </div>
</body>
</html>
