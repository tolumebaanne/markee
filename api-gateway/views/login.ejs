<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Authorize | Markee</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .loader {
            border: 4px solid var(--glass-border);
            border-top: 4px solid var(--accent-secondary);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 2rem auto;
        }
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>
    <nav class="navbar">
        <a href="/" class="brand">Markee.</a>
    </nav>
    <div class="auth-wrapper animate-fade">
        <div class="glass-card auth-panel">
            <div class="loader"></div>
            <h3>Connecting Securely...</h3>
            <p>Handshaking with the Markee Authorization Protocol.</p>
            <script>
                setTimeout(() => {
                    window.location.href = "http://localhost:5001/oauth/authorize?response_type=code&client_id=markee-gateway&redirect_uri=http://localhost:4000/callback&state=somestate";
                }, 1000);
            </script>
        </div>
    </div>
</body>
</html>
