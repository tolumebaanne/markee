<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>System Controls | Markee Admin</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <style>
        body { background:#0f172a;color:#f1f5f9; }
        .admin-shell { display:grid;grid-template-columns:220px 1fr;min-height:100vh; }
        .admin-sidebar { background:#1e293b;border-right:1px solid #334155;padding:1.5rem 1rem;position:sticky;top:0;height:100vh;overflow-y:auto; }
        .sidebar-logo { display:flex;align-items:center;gap:0.6rem;margin-bottom:1.75rem; }
        .sidebar-logo .mark { width:32px;height:32px;background:linear-gradient(135deg,#ef4444,#b91c1c);border-radius:8px;display:flex;align-items:center;justify-content:center; }
        .sidebar-logo .mark i { color:white;font-size:0.85rem; }
        .sidebar-logo span { font-weight:700;font-size:0.95rem; }
        .sidebar-section { font-size:0.68rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.08em;padding:0.5rem 0.5rem 0.25rem; }
        .sidebar-link { display:flex;align-items:center;gap:0.6rem;padding:0.6rem 0.75rem;border-radius:8px;color:#94a3b8;font-size:0.82rem;font-weight:500;text-decoration:none;cursor:pointer;transition:all 0.15s;border:none;background:none;width:100%; }
        .sidebar-link:hover { background:#334155;color:#f1f5f9; }
        .sidebar-link.active { background:#450a0a;color:#fca5a5; }
        .sidebar-link i { width:16px;text-align:center; }
        .admin-main { padding:2rem 2.5rem; }
        .page-header { margin-bottom:1.75rem; }
        .page-header h1 { font-size:1.4rem;font-weight:700;margin:0 0 0.25rem; }
        .page-header p { color:#64748b;margin:0;font-size:0.82rem; }
        .controls-grid { display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:1.25rem; }
        .control-card { background:#1e293b;border:1px solid #334155;border-radius:12px;padding:1.5rem; }
        .control-card.danger-zone { border-color:#7f1d1d; }
        .control-title { font-size:0.85rem;font-weight:700;margin-bottom:0.35rem;display:flex;align-items:center;gap:0.5rem; }
        .control-desc { font-size:0.78rem;color:#64748b;margin-bottom:1rem;line-height:1.5; }
        .toggle-row { display:flex;align-items:center;justify-content:space-between;padding:0.65rem 0;border-bottom:1px solid #334155; }
        .toggle-row:last-child { border-bottom:none; }
        .toggle-label { font-size:0.82rem;font-weight:500; }
        .toggle-desc  { font-size:0.72rem;color:#64748b;margin-top:0.15rem; }
        /* Toggle switch */
        .toggle-switch { position:relative;width:44px;height:24px;flex-shrink:0; }
        .toggle-switch input { opacity:0;width:0;height:0; }
        .toggle-slider { position:absolute;inset:0;background:#334155;border-radius:24px;cursor:pointer;transition:0.3s; }
        .toggle-slider:before { content:'';position:absolute;width:18px;height:18px;left:3px;bottom:3px;background:white;border-radius:50%;transition:0.3s; }
        input:checked + .toggle-slider { background:#ef4444; }
        input:checked + .toggle-slider:before { transform:translateX(20px); }
        .btn { padding:0.5rem 1rem;border-radius:8px;font-size:0.82rem;font-weight:600;cursor:pointer;border:none;transition:all 0.15s; }
        .btn-danger { background:#7f1d1d;color:#fca5a5;border:1px solid #991b1b; }
        .btn-danger:hover { background:#991b1b; }
        .btn-outline { background:transparent;color:#94a3b8;border:1px solid #334155; }
        .btn-outline:hover { background:#334155;color:#f1f5f9; }
        .btn-full { width:100%;margin-top:0.75rem; }
        .nuke-input { width:100%;padding:0.6rem 0.8rem;background:#0f172a;border:1px solid #334155;border-radius:7px;color:#f1f5f9;font-size:0.85rem;box-sizing:border-box;margin-bottom:0.5rem; }
        .status-pill { display:inline-flex;align-items:center;gap:0.4rem;padding:0.25rem 0.65rem;border-radius:20px;font-size:0.75rem;font-weight:700; }
        .status-pill.on  { background:#052e16;color:#4ade80; }
        .status-pill.off { background:#1e293b;color:#64748b;border:1px solid #334155; }
        .section-divider { font-size:0.78rem;font-weight:700;color:#475569;text-transform:uppercase;letter-spacing:0.08em;margin:1.75rem 0 0.75rem; }
    </style>
</head>
<body>
<div class="admin-shell">
    <aside class="admin-sidebar">
        <div class="sidebar-logo">
            <div class="mark"><i class="fa fa-shield-alt"></i></div>
            <span>Markee Admin</span>
        </div>
        <div class="sidebar-section">Navigation</div>
        <a class="sidebar-link" href="/admin"><i class="fa fa-th-large"></i> Overview</a>
        <a class="sidebar-link" href="/admin/accounts"><i class="fa fa-users-cog"></i> Admin Accounts</a>
        <a class="sidebar-link" href="/admin/templates"><i class="fa fa-layer-group"></i> Templates</a>
        <a class="sidebar-link" href="/admin/intelligence"><i class="fa fa-brain"></i> Intelligence</a>
        <a class="sidebar-link active" href="/admin/system"><i class="fa fa-cog"></i> System</a>
        <div style="margin-top:auto;padding-top:2rem;">
            <button class="sidebar-link" onclick="adminLogout()" style="color:#ef4444;">
                <i class="fa fa-sign-out-alt"></i> Logout
            </button>
        </div>
    </aside>

    <main class="admin-main">
        <div class="page-header">
            <h1><i class="fa fa-cog" style="color:#ef4444;margin-right:0.5rem;"></i> System Controls</h1>
            <p>Platform state, feature flags, and Superuser-only operations</p>
        </div>

        <!-- Platform State -->
        <div class="section-divider">Platform State</div>
        <div class="controls-grid" style="grid-template-columns:repeat(auto-fit,minmax(280px,1fr));">
            <div class="control-card">
                <div class="control-title"><i class="fa fa-tools" style="color:#f59e0b;"></i> Maintenance Mode</div>
                <div class="control-desc">Write operations return 503. Reads continue. Users see a maintenance banner.</div>
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span id="maintenance-status" class="status-pill off"><i class="fa fa-circle" style="font-size:0.5rem;"></i> Off</span>
                    <label class="toggle-switch">
                        <input type="checkbox" id="toggle-maintenance" onchange="toggleMaintenance()" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
            <div class="control-card danger-zone">
                <div class="control-title"><i class="fa fa-lock" style="color:#ef4444;"></i> Lockdown Mode</div>
                <div class="control-desc">All non-admin traffic is blocked. Platform is inaccessible to users. Use only in emergencies.</div>
                <div style="display:flex;align-items:center;justify-content:space-between;">
                    <span id="lockdown-status" class="status-pill off"><i class="fa fa-circle" style="font-size:0.5rem;"></i> Off</span>
                    <label class="toggle-switch">
                        <input type="checkbox" id="toggle-lockdown" onchange="toggleLockdown()" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            </div>
        </div>

        <!-- Feature Flags -->
        <div class="section-divider">Feature Flags</div>
        <div class="control-card" style="max-width:720px;">
            <div class="control-title"><i class="fa fa-flag" style="color:#8b5cf6;"></i> Runtime Feature Flags</div>
            <div class="control-desc">Changes take effect immediately — no deployment required.</div>
            <div id="flags-container">
                <div style="color:#475569;padding:1rem 0;"><i class="fa fa-spinner fa-spin"></i> Loading flags...</div>
            </div>
            <button class="btn btn-outline btn-full" onclick="saveFlags()">
                <i class="fa fa-save" style="margin-right:0.4rem;"></i> Save Flags
            </button>
        </div>

        <!-- Superuser-only controls -->
        <div class="section-divider" id="su-section" style="display:none;">Superuser Controls</div>
        <div class="controls-grid" id="su-controls" style="display:none;">
            <div class="control-card danger-zone">
                <div class="control-title"><i class="fa fa-fire-alt" style="color:#ef4444;"></i> Nuke User Tokens</div>
                <div class="control-desc">Immediately invalidate all active tokens for a user. Use for security incidents.</div>
                <input class="nuke-input" type="text" id="nuke-userid" placeholder="User ID to nuke tokens for" />
                <input class="nuke-input" type="text" id="nuke-reason" placeholder="Reason (audit log)" />
                <button class="btn btn-danger btn-full" onclick="nukeTokens()">
                    <i class="fa fa-fire-alt" style="margin-right:0.4rem;"></i> Nuke Tokens
                </button>
            </div>
            <div class="control-card danger-zone">
                <div class="control-title"><i class="fa fa-user-secret" style="color:#8b5cf6;"></i> Impersonate User</div>
                <div class="control-desc">Issue a 5-minute, non-refreshable impersonation token. All actions are audited.</div>
                <input class="nuke-input" type="text" id="imp-userid" placeholder="User ID to impersonate" />
                <input class="nuke-input" type="text" id="imp-reason" placeholder="Reason (required for audit)" />
                <button class="btn btn-outline btn-full" onclick="impersonateUser()">
                    <i class="fa fa-user-secret" style="margin-right:0.4rem;"></i> Begin Impersonation
                </button>
            </div>
        </div>
    </main>
</div>

<script>
const ADMIN_API = '/api/admin';
const token = () => localStorage.getItem('admin_access_token');
const isSU  = () => localStorage.getItem('admin_is_superuser') === 'true';

(function guard() {
    const t = token();
    if (!t) { window.location.replace('/admin-login'); return; }
    try {
        const payload = JSON.parse(atob(t.split('.')[1]));
        if (payload.exp && payload.exp * 1000 < Date.now()) {
            localStorage.removeItem('admin_access_token');
            localStorage.removeItem('admin_refresh_token');
            window.location.replace('/admin-login');
        }
    } catch { window.location.replace('/admin-login'); }
})();

async function api(method, path, body) {
    const res = await fetch(ADMIN_API + path, {
        method,
        headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token() },
        body: body ? JSON.stringify(body) : undefined
    });
    if (res.status === 401) {
        localStorage.removeItem('admin_access_token');
        localStorage.removeItem('admin_refresh_token');
        window.location.replace('/admin-login');
        return;
    }
    const data = await res.json().catch(() => ({}));
    if (!res.ok) throw new Error(data.message || 'Request failed');
    return data;
}

function adminLogout() {
    api('POST', '/auth/logout').catch(() => {});
    localStorage.removeItem('admin_access_token');
    localStorage.removeItem('admin_refresh_token');
    window.location.replace('/admin-login');
}

const FLAG_LABELS = {
    buyerReviewsEnabled:    'Buyer Reviews',
    sellerRegistrationOpen: 'Seller Registration Open',
    guestCheckoutEnabled:   'Guest Checkout',
    codEnabled:             'Cash on Delivery (COD)',
    searchAutocompleteLive: 'Live Search Autocomplete',
    analyticsPublic:        'Public Platform Analytics',
    messagingEnabled:       'Messaging System',
    notificationsEnabled:   'Notification System',
    sellerTierBadges:       'Seller Tier Badges'
};

async function loadStatus() {
    try {
        const status = await api('GET', '/system/status');

        // Platform state toggles
        const mt = document.getElementById('toggle-maintenance');
        const ld = document.getElementById('toggle-lockdown');
        mt.checked = status.maintenanceMode;
        ld.checked = status.lockdownMode;
        updateStatusPill('maintenance-status', status.maintenanceMode);
        updateStatusPill('lockdown-status', status.lockdownMode);

        // Feature flags
        const flagsEl = document.getElementById('flags-container');
        if (status.flags) {
            flagsEl.innerHTML = Object.entries(FLAG_LABELS).map(([key, label]) => `
                <div class="toggle-row">
                    <div>
                        <div class="toggle-label">${label}</div>
                        <div class="toggle-desc">${key}</div>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" id="flag-${key}" ${status.flags[key] ? 'checked' : ''} />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            `).join('');
        }

        // Superuser-only controls
        if (isSU()) {
            document.getElementById('su-section').style.display = '';
            document.getElementById('su-controls').style.display = '';
        }
    } catch (err) {
        showToast('Failed to load system status: ' + err.message, 'error');
    }
}

function updateStatusPill(id, isOn) {
    const el = document.getElementById(id);
    el.className = `status-pill ${isOn ? 'on' : 'off'}`;
    el.innerHTML = `<i class="fa fa-circle" style="font-size:0.5rem;"></i> ${isOn ? 'Active' : 'Off'}`;
}

async function toggleMaintenance() {
    const enabled = document.getElementById('toggle-maintenance').checked;
    if (enabled && !confirm('Enable maintenance mode? Write operations will return 503.')) {
        document.getElementById('toggle-maintenance').checked = false; return;
    }
    try {
        await api('POST', '/system/maintenance', { enabled, reason: '' });
        updateStatusPill('maintenance-status', enabled);
        showToast(`Maintenance mode ${enabled ? 'enabled' : 'disabled'}`, enabled ? 'warning' : 'success');
    } catch (err) {
        document.getElementById('toggle-maintenance').checked = !enabled;
        showToast(err.message, 'error');
    }
}

async function toggleLockdown() {
    const enabled = document.getElementById('toggle-lockdown').checked;
    if (enabled && !confirm('⚠️ ACTIVATE LOCKDOWN? All user traffic will be blocked immediately.')) {
        document.getElementById('toggle-lockdown').checked = false; return;
    }
    try {
        await api('POST', '/system/lockdown', { enabled, reason: '' });
        updateStatusPill('lockdown-status', enabled);
        showToast(`Lockdown ${enabled ? 'ACTIVATED' : 'deactivated'}`, enabled ? 'error' : 'success');
    } catch (err) {
        document.getElementById('toggle-lockdown').checked = !enabled;
        showToast(err.message, 'error');
    }
}

async function saveFlags() {
    const flags = {};
    Object.keys(FLAG_LABELS).forEach(key => {
        const el = document.getElementById(`flag-${key}`);
        if (el) flags[key] = el.checked;
    });
    try {
        await api('POST', '/system/flags', flags);
        showToast('Feature flags saved', 'success');
    } catch (err) { showToast(err.message, 'error'); }
}

async function nukeTokens() {
    const userId = document.getElementById('nuke-userid').value.trim();
    const reason = document.getElementById('nuke-reason').value.trim();
    if (!userId) { showToast('User ID required', 'error'); return; }
    if (!confirm(`Nuke ALL tokens for user ${userId}?`)) return;
    try {
        await api('POST', `/system/nuke-tokens/${userId}`, { reason });
        showToast('Tokens nuked successfully', 'success');
        document.getElementById('nuke-userid').value = '';
        document.getElementById('nuke-reason').value = '';
    } catch (err) { showToast(err.message, 'error'); }
}

async function impersonateUser() {
    const userId = document.getElementById('imp-userid').value.trim();
    const reason = document.getElementById('imp-reason').value.trim();
    if (!userId || !reason) { showToast('User ID and reason are required', 'error'); return; }
    try {
        const data = await api('POST', `/system/impersonate/${userId}`, { reason });
        prompt('Impersonation token (expires in 5 min — copy it):', data.access_token);
        showToast('Impersonation token issued — stored in audit log', 'warning');
    } catch (err) { showToast(err.message, 'error'); }
}

loadStatus();
</script>
</body>
</html>
