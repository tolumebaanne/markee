                       </div>` : '';
                return `
                <div style="padding:0.85rem 1.25rem; border-bottom:1px solid var(--border-light);">
                    <div style="display:flex; justify-content:space-between; align-items:flex-start; flex-wrap:wrap; gap:0.3rem; margin-bottom:0.3rem;">
                        <div style="display:flex; align-items:center; gap:0.4rem;">
                            <span>${renderReviewStars(r.rating)}</span>
                            ${statusBadge}
                        </div>
                        <span style="font-size:0.72rem; color:var(--text-muted);">${date}</span>
                    </div>
                    <div style="font-size:0.875rem; color:var(--text-main); line-height:1.55;">${r.body || '<em style="color:var(--text-muted);">No review text</em>'}</div>
                    ${imgHtml}
                    ${replyHtml}
                    <a href="/product/${r.productId}" style="font-size:0.72rem; color:var(--accent-red); text-decoration:none; margin-top:0.4rem; display:inline-block;">View Product →</a>
                </div>`;
            }).join('');
        } catch {}
    }

    // ── Phase 5: Activity Stats (Segment 1) ───────────────────────────────────
    async function loadActivityStats() {
        try {
            const res = await fetch('/api/orders/my-stats', {
                headers: { Authorization: `Bearer ${token}` }
            });
            if (!res.ok) return;
            const s = await res.json();
            window._activityStats = s;

            const card = document.getElementById('activity-stats-card');
            const grid = document.getElementById('activity-stats-grid');

            const fmt = cents => '$' + (cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

            grid.innerHTML = [
                { value: s.totalOrders,    label: 'Total Orders' },
                { value: s.completedOrders, label: 'Completed' },
                { value: fmt(s.totalSpentCents), label: 'Total Spent' },
                { value: s.uniqueSellers,  label: 'Sellers Bought From' },
                { value: s.totalItems,     label: 'Items Purchased' },
                { value: s.cancelledOrders, label: 'Cancelled' }
            ].map(item => `
                <div class="activity-stat-item">
                    <div class="stat-value">${item.value}</div>
                    <div class="stat-label">${item.label}</div>
                </div>`).join('');

            if (_userProfile?.createdAt) {
                const since = new Date(_userProfile.createdAt).toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
                document.getElementById('member-since-row').textContent = `Member since ${since}`;
            }

            card.style.display = 'block';

            // Segment 2 depends on _activityStats — trigger it now
            loadPurchaseInsights();
            // Segment 5 may now be ready
            _tryLoadAchievements();
        } catch(e) { console.error('loadActivityStats:', e); }
    }

    // ── Phase 5: Purchase Insights (Segment 2) ────────────────────────────────
    async function loadPurchaseInsights() {
        const s = window._activityStats;
        if (!s) return;

        const card    = document.getElementById('purchase-insights-card');
        const summary = document.getElementById('purchase-insights-summary');
        const chart   = document.getElementById('spend-chart');

        const fmt = cents => '$' + (cents / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });

        if (s.completedOrders === 0) {
            summary.textContent = 'No completed orders yet. Your spending breakdown will appear here after your first purchase.';
            card.style.display = 'block';
            return;
        }

        const avgOrder = s.completedOrders > 0 ? (s.totalSpentCents / s.completedOrders) : 0;
        summary.innerHTML = `Avg. order value: <strong>${fmt(avgOrder)}</strong> &nbsp;·&nbsp; ${s.completedOrders} completed order${s.completedOrders !== 1 ? 's' : ''}`;

        // Spend bar chart — last 6 months
        const months = Object.keys(s.spendByMonth).sort();
        if (months.length === 0) {
            chart.innerHTML = '<p style="font-size:0.78rem; color:var(--text-muted);">No spend data in the last 6 months.</p>';
        } else {
            const maxVal = Math.max(...Object.values(s.spendByMonth));
            chart.innerHTML = months.map(m => {
                const val  = s.spendByMonth[m];
                const pct  = maxVal > 0 ? Math.round((val / maxVal) * 100) : 0;
                const label = new Date(m + '-01').toLocaleDateString('en-US', { month: 'short', year: '2-digit' });
                return `
                    <div class="bar-row">
                        <span class="bar-month">${label}</span>
                        <div class="bar-track"><div class="bar-fill" style="width:${pct}%;"></div></div>
                        <span class="bar-amount">${fmt(val)}</span>
                    </div>`;
            }).join('');
        }

        card.style.display = 'block';
    }

    // ── Phase 5: Unified Reputation (Segment 3) ───────────────────────────────
    function loadReputation(profile, reviews) {
        const card = document.getElementById('reputation-card');
        const body = document.getElementById('reputation-body');

        const buyerScore   = profile.buyerScore        ?? 50;
        const tradingScore = profile.buyerTradingScore  ?? null;
        const written      = profile.reviewsWritten     ?? reviews.length;
        const tradeCount   = profile.buyerReviewCount   ?? 0;

        // Reviewer tier
        let rTier, rColor;
        if (buyerScore >= 80) { rTier = 'Trusted';     rColor = '#15803d'; }
        else if (buyerScore >= 60) { rTier = 'Established'; rColor = '#1d4ed8'; }
        else                  { rTier = 'New';          rColor = '#6b7280'; }

        const metricsHtml = `
            <div class="reputation-unified">
                <div class="rep-metric">
                    <div class="rep-value" style="color:${rColor};">${buyerScore}</div>
                    <div class="rep-label">Reviewer Score <span style="font-size:0.65rem;">/100</span></div>
                </div>
                <div class="rep-metric">
                    <div class="rep-value">${written}</div>
                    <div class="rep-label">Review${written !== 1 ? 's' : ''} Written</div>
                </div>
                ${tradingScore !== null ? `
                <div class="rep-metric">
                    <div class="rep-value" style="color:#15803d;">${tradingScore.toFixed(1)}</div>
                    <div class="rep-label">Buyer Rating <span style="font-size:0.65rem;">/5</span></div>
                </div>
                <div class="rep-metric">
                    <div class="rep-value">${tradeCount}</div>
                    <div class="rep-label">Seller Review${tradeCount !== 1 ? 's' : ''}</div>
                </div>` : ''}
            </div>`;

        // Progress bar
        const barHtml = `
            <div style="margin-bottom:0.75rem;">
                <div style="display:flex; justify-content:space-between; font-size:0.72rem; color:var(--text-muted); margin-bottom:0.25rem;">
                    <span>${rTier} Reviewer</span><span>${buyerScore} / 100</span>
                </div>
                <div style="height:6px; background:var(--bg-secondary); border-radius:3px; overflow:hidden;">
                    <div style="height:100%; width:${buyerScore}%; background:${rColor}; border-radius:3px; transition:width 0.6s;"></div>
                </div>
            </div>`;

        body.innerHTML = metricsHtml + barHtml;
        card.style.display = 'block';
    }

    // ── Phase 5: Watchlist Snapshot (Segment 4) ───────────────────────────────
    async function loadWatchlistSnapshot() {
        try {
            const res = await fetch('/api/users/me/watchlist', {
                headers: { Authorization: `Bearer ${token}` }
            });
            if (!res.ok) return;
            const list = await res.json();
            if (!list || list.length === 0) return;

            const card = document.getElementById('watchlist-card');
            const grid = document.getElementById('watchlist-snap-grid');

            // Take up to 6 most recently added
            const recent = list.slice().sort((a, b) => new Date(b.addedAt) - new Date(a.addedAt)).slice(0, 6);

            // Fetch product details for each
            const items = await Promise.all(recent.map(async entry => {
                try {
                    const r = await fetch(`/api/catalog/products/${entry.productId}`);
                    if (!r.ok) return null;
                    return await r.json();
                } catch { return null; }
            }));

            const validItems = items.filter(Boolean);
            if (validItems.length === 0) return;

            grid.innerHTML = validItems.map(p => {
                const img   = (p.images && p.images[0]) ? p.images[0] : '/img/placeholder.png';
                const price = p.price != null ? '$' + (p.price / 100).toFixed(2) : '';
                const title = p.title || 'Product';
                return `
                    <div class="wl-thumb" onclick="window.location='/product/${p._id}'">
                        <img src="${img}" alt="${title}" onerror="this.src='/img/placeholder.png'">
                        <div class="wl-title" title="${title}">${title}</div>
                        ${price ? `<div class="wl-price">${price}</div>` : ''}
                    </div>`;
            }).join('');

            card.style.display = 'block';
        } catch(e) { console.error('loadWatchlistSnapshot:', e); }
    }

    // ── Phase 5: Achievements (Segment 5) ─────────────────────────────────────
    function loadAchievements(profile, reviews, stats) {
        const card = document.getElementById('achievements-card');
        const grid = document.getElementById('achievements-grid');

        const completed = stats.completedOrders  || 0;
        const spent     = stats.totalSpentCents   || 0;
        const sellers   = stats.uniqueSellers     || 0;
        const written   = profile.reviewsWritten  ?? reviews.length;
        const score     = profile.buyerScore      ?? 50;

        const ACHIEVEMENTS = [
            {
                id: 'first_order',
                icon: '🛍️',
                name: 'First Purchase',
                desc: 'Placed your first order',
                earned: completed >= 1
            },
            {
                id: 'five_orders',
                icon: '🧺',
                name: 'Frequent Buyer',
                desc: '5 completed orders',
                earned: completed >= 5
            },
            {
                id: 'twenty_orders',
                icon: '🏆',
                name: 'Power Buyer',
                desc: '20 completed orders',
                earned: completed >= 20
            },
            {
                id: 'first_review',
                icon: '✍️',
                name: 'First Review',
                desc: 'Wrote your first review',
                earned: written >= 1
            },
            {
                id: 'ten_reviews',
                icon: '📝',
                name: 'Prolific Reviewer',
                desc: '10 reviews written',
                earned: written >= 10
            },
            {
                id: 'trusted_reviewer',
                icon: '🥇',
                name: 'Trusted Reviewer',
                desc: 'Reviewer score ≥ 80',
                earned: score >= 80
            },
            {
                id: 'big_spender',
                icon: '💰',
                name: 'Big Spender',
                desc: 'Spent over $500 total',
                earned: spent >= 50000
            },
            {
                id: 'explorer',
                icon: '🗺️',
                name: 'Explorer',
                desc: 'Bought from 5+ sellers',
                earned: sellers >= 5
            },
            {
                id: 'loyal_customer',
                icon: '🤝',
                name: 'Loyal Customer',
                desc: 'Bought from same seller 3+ times',
                earned: (stats.topSellers || []).some(s => s.orderCount >= 3)
            }
        ];

        grid.innerHTML = ACHIEVEMENTS.map(a => `
            <div class="achievement-item ${a.earned ? 'earned' : ''}" title="${a.earned ? 'Earned!' : 'Not yet unlocked'}">
                <div class="ach-icon" style="${a.earned ? '' : 'filter:grayscale(1); opacity:0.4;'}">${a.icon}</div>
                <div class="ach-name">${a.name}</div>
                <div class="ach-desc">${a.desc}</div>
            </div>`).join('');

        card.style.display = 'block';
    }

    // ── Boot ──────────────────────────────────────────────────────────────────
    loadAvatar();
    loadBio();
    loadLocale();
    loadReviewerScore();
    loadMyReviews();
    loadActivityStats();
    loadWatchlistSnapshot();
    if (window.MarkeeCart) MarkeeCart.updateAllCartBadges();
</script>
</body>
</html>
