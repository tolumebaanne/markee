            if (!res.ok) return;
            const profile = await res.json();
            const countrySel = document.getElementById('locale-country');
            const provinceSel = document.getElementById('locale-province');
            if (profile.country && countrySel) {
                countrySel.value = profile.country;
                toggleProvinceRow();
