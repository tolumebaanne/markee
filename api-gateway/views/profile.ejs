    // ── Avatar upload ─────────────────────────────────────────────────────────
    let _panX = 0, _panY = 0, _zoom = 1;
    let _dragging = false, _lastX = 0, _lastY = 0;

    function triggerAvatarUpload() {
        document.getElementById('avatar-input').click();
    }

    function handleAvatarFile(file) {
        if (!file || !file.type.startsWith('image/')) return;
        const url = URL.createObjectURL(file);
        const edImg = document.getElementById('editor-img');
        edImg.src = url;
        edImg.onload = () => {
            const S = 220; // circle diameter
            const scale = Math.max(S / edImg.naturalWidth, S / edImg.naturalHeight);
            _zoom = scale;
            _panX = 0; _panY = 0;
            const slider = document.getElementById('zoom-slider');
            slider.min   = scale * 0.8;
            slider.max   = scale * 4;
            slider.value = scale;
            applyTransform();
            document.getElementById('avatar-editor-overlay').classList.add('open');
        };
    }

    function applyTransform() {
        _zoom = parseFloat(document.getElementById('zoom-slider').value);
        const edImg = document.getElementById('editor-img');
        edImg.style.transform = `translate(-50%, -50%) translate(${_panX}px, ${_panY}px) scale(${_zoom})`;
    }

    function startDrag(e) {
        _dragging = true;
        _lastX = e.clientX; _lastY = e.clientY;
        e.preventDefault();
    }

    function startDragTouch(e) {
        _dragging = true;
        _lastX = e.touches[0].clientX; _lastY = e.touches[0].clientY;
    }

    document.addEventListener('mousemove', e => {
        if (!_dragging) return;
        _panX += e.clientX - _lastX; _panY += e.clientY - _lastY;
        _lastX = e.clientX; _lastY = e.clientY;
        applyTransform();
    });

    document.addEventListener('mouseup', () => { _dragging = false; });

    document.addEventListener('touchmove', e => {
        if (!_dragging) return;
        _panX += e.touches[0].clientX - _lastX;
        _panY += e.touches[0].clientY - _lastY;
        _lastX = e.touches[0].clientX; _lastY = e.touches[0].clientY;
        applyTransform();
    }, { passive: true });

    document.addEventListener('touchend', () => { _dragging = false; });

    // Click outside the box to close
    document.getElementById('avatar-editor-overlay').addEventListener('click', e => {
        if (e.target === document.getElementById('avatar-editor-overlay')) closeEditorModal();
    });

    // Scroll-to-zoom inside the editor circle
    document.getElementById('avatar-editor-overlay').addEventListener('wheel', e => {
        if (!document.getElementById('avatar-editor-overlay').classList.contains('open')) return;
        e.preventDefault();
        const slider = document.getElementById('zoom-slider');
        const delta  = -e.deltaY * 0.001;
        slider.value = Math.min(slider.max, Math.max(slider.min, parseFloat(slider.value) + delta));
        applyTransform();
    }, { passive: false });

    function closeEditorModal() {
        document.getElementById('avatar-editor-overlay').classList.remove('open');
        document.getElementById('avatar-input').value = '';
    }

    async function applyAvatar(evt) {
        const S      = 220;
        const canvas = document.createElement('canvas');
        canvas.width = canvas.height = S;
        const ctx    = canvas.getContext('2d');
        const edImg  = document.getElementById('editor-img');

        // Clip circle
        ctx.save();
        ctx.beginPath();
        ctx.arc(S / 2, S / 2, S / 2, 0, Math.PI * 2);
        ctx.clip();

        // Draw at current pan + zoom
        const iw = edImg.naturalWidth  * _zoom;
        const ih = edImg.naturalHeight * _zoom;
        ctx.drawImage(edImg, S / 2 - iw / 2 + _panX, S / 2 - ih / 2 + _panY, iw, ih);
        ctx.restore();

        // Binary-search JPEG quality to stay under ~50 KB
        let lo = 0.1, hi = 1, dataUrl = canvas.toDataURL('image/jpeg', 0.85);
        for (let i = 0; i < 12; i++) {
            const mid  = (lo + hi) / 2;
            const candidate = canvas.toDataURL('image/jpeg', mid);
            if (candidate.length * 0.75 > 51200) hi = mid;
            else { lo = mid; dataUrl = candidate; }
        }

        try { localStorage.setItem(`markee_avatar_${user.email}`, dataUrl); }
        catch (e) { /* storage full — still display it */ }

        const img = document.getElementById('avatar-img');
        img.src = dataUrl;
        img.style.display = 'block';
        document.getElementById('avatar-initial-wrap').style.display = 'none';

        closeEditorModal();
        showToast('Profile picture updated!', 'success', 3500, evt);
    }

    function loadAvatar() {
        const saved = localStorage.getItem(`markee_avatar_${user.email}`);
        if (saved) {
            const img = document.getElementById('avatar-img');
            img.src = saved;
            img.style.display = 'block';
            document.getElementById('avatar-initial-wrap').style.display = 'none';
        }
    }

