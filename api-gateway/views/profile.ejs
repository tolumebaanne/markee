    // ── Store settings ────────────────────────────────────────────────────────
    let _originalStore = null;
    let _storeId = user.storeId;

    async function loadNotifications() {
        try {
            const res = await fetch('/api/notifications/my?limit=5', {
                headers: { 'Authorization': `Bearer ${token}` }
            });
            if (!res.ok) throw new Error();
            const data = await res.json();
            const notifications = Array.isArray(data) ? data : (data.notifications || []);
            const list = document.getElementById('notifications-list');

            if (!notifications || notifications.length === 0) {
                list.innerHTML = '<p class="text-muted" style="padding:1.25rem; font-size:0.875rem;">No recent alerts.</p>';
                return;
            }

            list.innerHTML = notifications.map(n => {
                const dateStr = new Date(n.sentAt || new Date()).toLocaleDateString('en-US', { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' });
                const iconClass = n.icon || (n.type === 'PRICE_DROP_ALERT' ? 'fa-arrow-down' : 'fa-bell');
                const linkTarget = n.link || '';
                const unreadStyle = n.read ? '' : 'background:var(--bg-secondary); border-left:3px solid var(--accent-red);';
                const fontWeight  = n.read ? '400' : '600';

                return `
                <div data-notif-id="${n._id}" style="display:flex; gap:0.75rem; align-items:flex-start; border-bottom:1px solid var(--border-light); padding:1rem 1.25rem; ${unreadStyle}transition:background 0.2s;${linkTarget ? 'cursor:pointer;' : ''}"${linkTarget ? ` onclick="window.location='${linkTarget}'"` : ''}>
                    <i class="fa ${iconClass}" style="color:var(--accent-red); margin-top:3px; font-size:0.85rem; flex-shrink:0;"></i>
                    <div style="flex:1; min-width:0;">
                        <div style="font-weight:${fontWeight}; font-size:0.875rem; margin-bottom:0.2rem; color:var(--text-main);">${n.subject || 'Alert'}</div>
                        ${n.body ? `<div style="font-size:0.82rem; color:var(--text-muted); line-height:1.5;">${(n.body || '').replace(/\n/g, '<br>')}</div>` : ''}
                        <div style="font-size:0.72rem; color:var(--text-muted); margin-top:0.35rem;">${dateStr}</div>
                    </div>
                    <button type="button" onclick="event.stopPropagation(); dismissProfileNotification('${n._id}', this)" title="Dismiss" style="background:none;border:none;color:var(--text-muted);cursor:pointer;font-size:1rem;padding:0;flex-shrink:0;opacity:0.5;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.5'">&times;</button>
                </div>`;
            }).join('');
            list.innerHTML += '<a href="/notifications" style="display:block; padding:0.75rem 1.25rem; font-size:0.8rem; color:var(--accent-red); font-weight:600; text-decoration:none; text-align:center; border-top:1px solid var(--border-light);">View all notifications</a>';
        } catch (e) {
            document.getElementById('notifications-list').innerHTML = '<p class="text-muted" style="padding:1.25rem; font-size:0.875rem;">Could not load alerts.</p>';
        }
    }

    function dismissProfileNotification(id, btn) {
        if (!token || !id) return;
        fetch('/api/notifications/' + id, { method: 'DELETE', headers: { Authorization: 'Bearer ' + token } })
            .then(r => r.ok ? r.json() : null)
            .then(data => {
                if (!data?.ok) return;
                const row = document.querySelector('[data-notif-id="' + id + '"]');
                if (row) row.remove();
                const list = document.getElementById('notifications-list');
                if (list && !list.querySelector('[data-notif-id]')) {
                    list.innerHTML = '<p class="text-muted" style="padding:1.25rem; font-size:0.875rem;">No recent alerts.</p>';
                }
            }).catch(() => {});
    }

    async function loadStoreSettings() {
        if (!_storeId) {
            document.getElementById('store-skeleton').style.display = 'none';
            document.getElementById('store-error').style.display = 'block';
            return;
        }
        try {
            let res = await fetch(`/api/public-seller/${_storeId}`);

            // First-time seller: store document doesn't exist yet — auto-register it
            if (res.status === 404) {
                const defaultName = emailName.charAt(0).toUpperCase() + emailName.slice(1) + "'s Store";
                const regRes = await fetch('/api/seller/register', {
                    method:  'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body:    JSON.stringify({ name: defaultName, description: '', phone: '' })
                });
                if (!regRes.ok) throw new Error('Could not create store');
                res = await fetch(`/api/public-seller/${_storeId}`);
            }

            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const store = await res.json();
            _originalStore = store;

            document.getElementById('store-name').value  = store.name || '';
            document.getElementById('store-desc').value  = store.description || '';
            document.getElementById('store-phone').value = store.phone || '';

            // Response time
            const rtSel = document.getElementById('store-response-time');
            if (store.responseTime) rtSel.value = store.responseTime;

            // Business hours
            document.getElementById('store-open-time').value  = store.businessHours?.openTime  || '09:00';
            document.getElementById('store-close-time').value = store.businessHours?.closeTime || '18:00';

            // Store status
            const isOpen = store.isOpen !== false;
            document.getElementById('store-open').checked   = isOpen;
            document.getElementById('store-closed').checked = !isOpen;

            // Store-wide discount
            document.getElementById('discount-enabled').checked = !!(store.discount?.storeWide?.enabled);
            document.getElementById('discount-percent').value   = store.discount?.storeWide?.percent || '';

            // Policies
            document.getElementById('store-return-policy').value   = store.returnPolicy   || '';
            document.getElementById('store-shipping-policy').value = store.shippingPolicy || '';

            document.getElementById('store-skeleton').style.display = 'none';
            document.getElementById('store-form').style.display     = 'block';
            document.getElementById('store-actions').style.display  = 'flex';
        } catch (err) {
            document.getElementById('store-skeleton').style.display = 'none';
            document.getElementById('store-error').style.display    = 'block';
            document.getElementById('store-error').innerHTML =
                `<i class="fa fa-exclamation-circle" style="margin-right:0.5rem;"></i>Could not load store: ${err.message}`;
        }
    }

    function resetStoreForm() {
        if (!_originalStore) return;
        const s = _originalStore;
        document.getElementById('store-name').value  = s.name || '';
        document.getElementById('store-desc').value  = s.description || '';
        document.getElementById('store-phone').value = s.phone || '';

        const rtSel = document.getElementById('store-response-time');
        if (s.responseTime) rtSel.value = s.responseTime;

        document.getElementById('store-open-time').value  = s.businessHours?.openTime  || '09:00';
        document.getElementById('store-close-time').value = s.businessHours?.closeTime || '18:00';

        const isOpen = s.isOpen !== false;
        document.getElementById('store-open').checked   = isOpen;
        document.getElementById('store-closed').checked = !isOpen;

        document.getElementById('discount-enabled').checked = !!(s.discount?.storeWide?.enabled);
        document.getElementById('discount-percent').value   = s.discount?.storeWide?.percent || '';

        document.getElementById('store-return-policy').value   = s.returnPolicy   || '';
        document.getElementById('store-shipping-policy').value = s.shippingPolicy || '';
        showToast('Reset to saved values.', 'info');
    }

    async function saveStore(evt) {
        clearInlineError('store-save-error-container');
        const btn = document.getElementById('store-save-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.4rem;"></i> Saving...';

        const payload = {
            name:           document.getElementById('store-name').value.trim(),
            description:    document.getElementById('store-desc').value.trim(),
            phone:          document.getElementById('store-phone').value.trim(),
            responseTime:   document.getElementById('store-response-time').value,
            isOpen:         document.getElementById('store-open').checked,
            businessHours: {
                openTime:  document.getElementById('store-open-time').value,
                closeTime: document.getElementById('store-close-time').value,
                days:      ['Mon','Tue','Wed','Thu','Fri']
            },
            discount: {
                storeWide: {
                    enabled: document.getElementById('discount-enabled').checked,
                    percent: parseFloat(document.getElementById('discount-percent').value) || 0
                }
            },
            returnPolicy:   document.getElementById('store-return-policy').value.trim(),
            shippingPolicy: document.getElementById('store-shipping-policy').value.trim()
        };

        try {
            const res = await fetch(`/api/seller/${_storeId}`, {
                method: 'PUT',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(payload)
            });
            const data = await res.json();
            if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);

            _originalStore = data;
            showToast('Store settings saved!', 'success', 3500, evt);
        } catch (err) {
            showInlineError('store-save-error-container', 'Error: ' + err.message);
        } finally {
            btn.disabled = false;
            btn.innerHTML = '<i class="fa fa-save" style="margin-right:0.4rem;"></i> Save Changes';
        }
    }

    // ── Change password ───────────────────────────────────────────────────────
    async function changePassword() {
        clearInlineError('password-error-container');
        const oldPw  = document.getElementById('old-password')?.value || '';
        const newPw  = document.getElementById('new-password')?.value || '';
        const confPw = document.getElementById('confirm-password')?.value || '';

        if (!oldPw || !newPw) { showInlineError('password-error-container', 'All password fields are required'); return; }
        if (newPw !== confPw)  { showInlineError('password-error-container', 'New passwords do not match'); return; }
        if (newPw.length < 8)  { showInlineError('password-error-container', 'Password must be at least 8 characters'); return; }

        try {
            const r = await fetch('/api/auth/password', {
                method: 'PATCH',
                headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
                body: JSON.stringify({ oldPassword: oldPw, newPassword: newPw })
            });
            const data = await r.json();
            if (r.ok) {
                if (typeof showToast === 'function') showToast('Password updated. Please sign in again.');
                setTimeout(() => {
                    localStorage.removeItem('access_token');
                    localStorage.removeItem('refresh_token');
                    window.location.replace('/login');
                }, 1800);
            } else {
                showInlineError('password-error-container', data.message || 'Password change failed');
            }
        } catch { showInlineError('password-error-container', 'Request failed'); }
    }

    // ── Delete account (2FA: must type email) ────────────────────────────────
    async function deleteAccount() {
        clearInlineError('delete-account-error-container');
        const typed = (document.getElementById('delete-confirm-email').value || '').trim().toLowerCase();
        const actual = (user.email || '').toLowerCase();
        if (!typed) { showInlineError('delete-account-error-container', 'Type your email address to confirm deletion.'); return; }
        if (typed !== actual) { showInlineError('delete-account-error-container', 'Email does not match. Please try again.'); return; }

        const btn = document.getElementById('delete-account-btn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.4rem;"></i> Deleting...';

        try {
            const res = await fetch('/api/auth/account-jwt', {
                method: 'DELETE',
                headers: { 'Authorization': `Bearer ${token}` }
            });
            const data = await res.json();
            if (data.success || res.ok) {
                showToast('Account deleted.', 'success');
                setTimeout(() => {
                    localStorage.removeItem('access_token');
                    localStorage.removeItem('refresh_token');
