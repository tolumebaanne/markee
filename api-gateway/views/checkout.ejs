<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout | Markee</title>
    <meta name="description" content="Complete your purchase securely on Markee.">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="https://js.stripe.com/v3/"></script>
    <script src="/js/toast.js"></script>
    <script src="/js/address-selector.js"></script>
    <script src="/js/card-selector.js"></script>
    <script src="/js/cart.js"></script>
    <style>
        .checkout-grid { display: grid; grid-template-columns: 1fr 380px; gap: 2rem; align-items: start; }
        @media (max-width: 860px) { .checkout-grid { grid-template-columns: 1fr; } }

        .step-badge {
            display: inline-flex; align-items: center; justify-content: center;
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--accent-red); color: white;
            font-size: 0.8rem; font-weight: 700; margin-right: 0.6rem; flex-shrink: 0;
        }
        .section-heading { display: flex; align-items: center; font-size: 1rem; font-weight: 700; margin-bottom: 1.25rem; }

        .order-item-row { display: flex; gap: 0.75rem; align-items: center; padding: 0.85rem 0; border-bottom: 1px solid var(--border-light); }
        .order-item-row:last-child { border-bottom: none; }
        .order-item-img { width: 52px; height: 52px; border-radius: 8px; object-fit: cover; border: 1px solid var(--border-light); flex-shrink: 0; }

        .confirm-screen { display: none; text-align: center; padding: 3rem 0; }
        .confirm-icon { font-size: 3.5rem; color: var(--color-green); margin-bottom: 1rem; }

        input.error-field, select.error-field { border-color: var(--accent-red) !important; }

        /* Saved address chips */
        .addr-chips { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1rem; }
        .addr-chip {
            border: 1.5px solid var(--border-light); border-radius: 8px;
            padding: 0.5rem 0.75rem; font-size: 0.8rem; cursor: pointer;
            background: var(--bg-secondary); transition: border-color 0.15s, background 0.15s;
            line-height: 1.4;
        }
        .addr-chip.selected { border-color: var(--accent-red); background: #fff5f5; }

        /* Delivery options */
        .delivery-option {
            display: flex; align-items: center; gap: 0.75rem;
            border: 1.5px solid var(--border-light); border-radius: 8px;
            padding: 0.85rem 1rem; cursor: pointer; transition: border-color 0.15s, background 0.15s;
            margin-bottom: 0.6rem;
        }
        .delivery-option.selected { border-color: var(--accent-red); background: #fff5f5; }
        .delivery-option .d-label { font-weight: 600; font-size: 0.9rem; }
        .delivery-option .d-detail { font-size: 0.8rem; color: var(--text-muted); }
        .delivery-option .d-price { margin-left: auto; font-weight: 700; white-space: nowrap; }

        /* Fulfillment options */
        .radio-option {
            display: flex; align-items: center; gap: 0.75rem;
            border: 1.5px solid var(--border-light); border-radius: 8px;
            padding: 0.85rem 1rem; cursor: pointer; transition: border-color 0.15s, background 0.15s;
            margin-bottom: 0.5rem; font-weight: 500; font-size: 0.85rem;
        }
        .radio-option:last-child { margin-bottom: 0; }
        .radio-option.selected { border-color: var(--accent-red); background: #fff5f5; }
        .radio-option i { flex-shrink: 0; color: var(--text-muted); }
        .radio-option input, .delivery-option input, .payment-option input, .same-billing-row input {
            width: auto; flex-shrink: 0; padding: 0; border: none; background: transparent; border-radius: 0; box-shadow: none;
        }

        /* Payment method options */
        .payment-option {
            display: flex; align-items: center; gap: 0.5rem; cursor: pointer;
            flex: 1; border: 1.5px solid var(--border-light); border-radius: 8px;
            padding: 0.75rem; font-weight: 600; font-size: 0.9rem;
            transition: border-color 0.15s, background 0.15s;
        }
        .payment-option.selected { border-color: var(--accent-red); background: #fff5f5; }

        /* Same-as billing toggle */
        .same-billing-row {
            display: flex; align-items: center; gap: 0.6rem;
            padding: 0.75rem; background: var(--bg-secondary); border-radius: 8px;
            margin-bottom: 1rem; cursor: pointer;
        }
    </style>
</head>
<body class="bg-light">

<nav class="navbar">
    <div class="brand-combo">
        <a href="/"><span class="brand">Markee</span></a>
    </div>
    <%- include('_nav') %>
</nav>

<div class="container py-4 animate-fade">

    <!-- Auth guard notice -->
    <div id="auth-guard" style="display:none; text-align:center; padding:4rem 0;">
        <i class="fa fa-lock" style="font-size:3rem; color:var(--border-light); margin-bottom:1rem; display:block;"></i>
        <h3>Sign in to Checkout</h3>
        <p class="text-muted mb-4">You need to be signed in to place an order.</p>
        <a href="/login" class="nav-pill nav-pill-red" style="text-decoration:none;">Sign In</a>
        <a href="/register" class="nav-pill nav-pill-outline" style="text-decoration:none; margin-left:0.5rem;">Register</a>
    </div>

    <!-- Order Confirmed screen -->
    <div class="confirm-screen" id="confirm-screen">
        <div class="confirm-icon"><i class="fa fa-check-circle"></i></div>
        <h2 style="margin-bottom:0.5rem;">Order Confirmed!</h2>
        <p class="text-muted mb-2">Order <strong id="confirm-order-id" style="color:var(--text-main);"></strong></p>
        <p class="text-muted mb-4">You'll receive updates as your order is processed.</p>
        <a href="/dashboard" class="nav-pill nav-pill-red" style="text-decoration:none; margin-right:0.5rem;">Go to Dashboard</a>
        <a href="/" class="nav-pill nav-pill-outline" style="text-decoration:none;">Keep Shopping</a>
    </div>

    <!-- Main checkout form -->
    <div id="checkout-main">
        <h2 class="mb-4">Secure Checkout</h2>
        <div class="checkout-grid">

            <!-- LEFT: Billing → Shipping → Delivery → Payment -->
            <div>

                <!-- Step 1: Billing Address -->
                <div class="card p-4 mb-3">
                    <div class="section-heading">
                        <span class="step-badge">1</span> Billing Address
                    </div>

                    <!-- Selected billing address card -->
                    <div id="billing-addr-display" style="display:none; padding:0.75rem; border:1.5px solid var(--accent-red); border-radius:8px; background:#fff5f5; margin-bottom:0.75rem;">
                        <div style="font-weight:600; font-size:0.85rem; margin-bottom:0.15rem;" id="billing-addr-label"></div>
                        <div style="font-size:0.82rem; color:var(--text-muted); line-height:1.5;" id="billing-addr-text"></div>
                        <button type="button" onclick="showBillingSelector()" style="font-size:0.75rem; color:var(--accent-red); background:none; border:none; padding:0.2rem 0 0; cursor:pointer; display:inline-flex; align-items:center; gap:0.3rem;">
                            <i class="fa fa-pen"></i> Change address
                        </button>
                    </div>

                    <!-- Empty state -->
                    <div id="billing-addr-empty">
                        <p class="text-muted small" style="margin-bottom:0.75rem;">
                            Select a saved address. Addresses are managed in <a href="/account/addresses" style="color:var(--accent-red);">Account Settings</a>.
                        </p>
                        <button type="button" class="btn btn-outline" style="width:auto; padding:0.5rem 1.25rem; font-size:0.875rem;" onclick="showBillingSelector()">
                            <i class="fa fa-map-marker-alt" style="margin-right:0.5rem;"></i> Select Billing Address
                        </button>
                    </div>
                </div>

                <!-- Step 2: Shipping Address -->
                <div class="card p-4 mb-3">
                    <div class="section-heading">
                        <span class="step-badge">2</span> Shipping Address
                    </div>

                    <div class="form-group">
                        <label>Fulfillment Method</label>
                        <div id="fulfillment-type-section" style="margin-top:0.5rem;">
                            <!-- populated by renderFulfillmentOptions() -->
                        </div>
                    </div>

                    <!-- Shipping address section (hidden for non-shipping fulfillment) -->
                    <div id="shipping-address-section">

                    <!-- Same as billing toggle -->
                    <label class="same-billing-row" for="same-as-billing">
                        <input type="checkbox" id="same-as-billing" checked onchange="toggleShippingFields()">
                        <span style="font-weight:600; font-size:0.9rem;">Deliver to billing address</span>
                    </label>

                    <!-- Different delivery address (shown when "same as billing" is unchecked) -->
                    <div id="shipping-fields" style="display:none;">
                        <!-- Selected delivery address card -->
                        <div id="shipping-addr-display" style="display:none; padding:0.75rem; border:1.5px solid var(--accent-red); border-radius:8px; background:#fff5f5; margin-bottom:0.75rem;">
                            <div style="font-weight:600; font-size:0.85rem; margin-bottom:0.15rem;" id="shipping-addr-label"></div>
                            <div style="font-size:0.82rem; color:var(--text-muted); line-height:1.5;" id="shipping-addr-text"></div>
                            <button type="button" onclick="showShippingSelector()" style="font-size:0.75rem; color:var(--accent-red); background:none; border:none; padding:0.2rem 0 0; cursor:pointer; display:inline-flex; align-items:center; gap:0.3rem;">
                                <i class="fa fa-pen"></i> Change address
                            </button>
                        </div>
                        <div id="shipping-addr-empty">
                            <button type="button" class="btn btn-outline" style="width:auto; padding:0.5rem 1.25rem; font-size:0.875rem;" onclick="showShippingSelector()">
                                <i class="fa fa-map-marker-alt" style="margin-right:0.5rem;"></i> Select Delivery Address
                            </button>
                        </div>
                    </div>

                    <p id="shipping-same-note" class="text-muted small" style="margin:0.25rem 0 0;">
                        <i class="fa fa-check-circle" style="color:var(--color-green); margin-right:0.3rem;"></i>
                        Delivering to billing address.
                    </p>

                    </div><!-- end #shipping-address-section -->

                    <!-- Pickup location card (shown when pickup selected) -->
                    <div id="pickup-location-card" style="display:none; margin-top:0.75rem;">
                        <div style="border:1.5px solid var(--border-light); border-radius:8px; padding:0.85rem 1rem; background:var(--bg-secondary);">
                            <p style="font-weight:600; font-size:0.9rem; margin:0 0 0.35rem;"><i class="fa fa-map-marker-alt" style="color:var(--accent-red); margin-right:0.4rem;"></i> Pickup Location</p>
                            <p id="pickup-address-text" style="font-size:0.85rem; margin:0 0 0.2rem;"></p>
                            <p id="pickup-hours-text" style="font-size:0.8rem; color:var(--text-muted); margin:0 0 0.2rem;"></p>
                            <p id="pickup-instructions-text" style="font-size:0.8rem; color:var(--text-muted); margin:0;"></p>
                        </div>
                    </div>
                    <!-- Carrier picker (shown when Courier Delivery selected) -->
                    <div id="carrier-picker-section" style="display:none; margin-top:0.75rem;">
                        <label style="font-size:0.85rem; font-weight:600; display:block; margin-bottom:0.35rem;">Select Carrier</label>
                        <select id="carrier-select" class="form-control" style="width:100%;">
                            <option value="canada_post">Canada Post</option>
                            <option value="ups">UPS</option>
                            <option value="fedex">FedEx</option>
                            <option value="purolator">Purolator</option>
                            <option value="dhl">DHL</option>
                        </select>
                    </div>
                    <!-- Self-fulfil form (shown when self_fulfilled selected) -->
                    <div id="self-fulfill-form" style="display:none; margin-top:0.75rem;">
                        <div style="border:1.5px solid var(--border-light); border-radius:8px; padding:0.85rem 1rem; background:var(--bg-secondary); margin-bottom:0.75rem;">
                            <p style="font-size:0.85rem; color:var(--text-muted); margin:0;"><i class="fa fa-info-circle" style="margin-right:0.4rem;"></i> The seller will coordinate fulfillment directly with you — this covers digital delivery, in-person services, and seller-arranged shipping.</p>
                        </div>
                        <!-- Address the seller will see -->
                        <div style="margin-bottom:0.75rem;">
                            <label style="font-size:0.85rem; font-weight:600; margin-bottom:0.4rem; display:block;">Your address <span style="font-weight:400; color:var(--text-muted); font-size:0.8rem;">— shared with the seller for coordination</span></label>
                            <div id="sf-addr-display" style="display:none; padding:0.75rem; border:1.5px solid var(--accent-red); border-radius:8px; background:#fff5f5;">
                                <div style="font-weight:600; font-size:0.85rem; margin-bottom:0.15rem;" id="sf-addr-label"></div>
                                <div style="font-size:0.82rem; color:var(--text-muted); line-height:1.5;" id="sf-addr-text"></div>
                                <button type="button" onclick="showSelfFulfillSelector()" style="font-size:0.75rem; color:var(--accent-red); background:none; border:none; padding:0.2rem 0 0; cursor:pointer; display:inline-flex; align-items:center; gap:0.3rem;">
                                    <i class="fa fa-pen"></i> Change address
                                </button>
                            </div>
                            <div id="sf-addr-empty">
                                <button type="button" class="btn btn-outline" style="width:auto; padding:0.5rem 1.25rem; font-size:0.875rem;" onclick="showSelfFulfillSelector()">
                                    <i class="fa fa-map-marker-alt" style="margin-right:0.5rem;"></i> Select Address
                                </button>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>Instructions for seller <span style="font-weight:400; color:var(--text-muted);">(optional)</span></label>
                            <textarea id="sf-instructions" rows="3" placeholder="Any details the seller needs to fulfil your order..." maxlength="500" style="resize:vertical;"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Step 3: Delivery Speed -->
                <div class="card p-4 mb-3" id="delivery-step-card">
                    <div class="section-heading">
                        <span class="step-badge">3</span> Delivery Speed
                    </div>

                    <label class="delivery-option selected" id="delivery-standard-label">
                        <input type="radio" name="delivery" value="standard" checked
                               onchange="selectDelivery('standard')">
                        <div>
                            <div class="d-label">Standard Delivery</div>
                            <div class="d-detail">5–10 business days</div>
                        </div>
                        <div class="d-price" id="standard-delivery-price"></div>
                    </label>

                    <label class="delivery-option" id="delivery-fast-label">
                        <input type="radio" name="delivery" value="fast"
                               onchange="selectDelivery('fast')">
                        <div>
                            <div class="d-label"><i class="fa fa-bolt" style="color:var(--color-amber); margin-right:0.3rem;"></i> Fast Delivery</div>
                            <div class="d-detail">1–3 business days — priority handling</div>
                        </div>
                        <div class="d-price" id="fast-delivery-price" style="color:var(--accent-red);">+$9.99</div>
                    </label>
                </div>

                <!-- Step 4: Payment -->
                <div class="card p-4 mb-3">
                    <div class="section-heading">
                        <span class="step-badge">4</span> Payment Method
                    </div>

                    <!-- Saved payment methods — card selector trigger -->
                    <div id="saved-payments-section" style="display:none; margin-bottom:1rem;">
                        <!-- No saved cards message (shown when user has no cards) -->
                        <div id="no-saved-cards-msg" style="display:none; padding:0.6rem 0.5rem 0.75rem; font-size:0.88rem; color:var(--text-muted);">
                            <i class="fa fa-credit-card" style="margin-right:0.4rem; color:var(--accent-red);"></i>
                            No saved cards yet.
                            <a href="/account/wallet" style="color:var(--accent-red); font-weight:600; text-decoration:underline;">Add a card to your wallet</a>
                            to pay by card.
                        </div>
                        <!-- Selected card display -->
                        <div id="selected-card-display" style="display:none; border:1.5px solid var(--accent-red); border-radius:8px; padding:0.875rem 1rem; background:#fff5f5; margin-bottom:0.75rem;">
                            <div class="pm-card-brand" id="selected-card-brand"></div>
                            <div class="pm-card-expiry" id="selected-card-expiry"></div>
                        </div>
                        <!-- Selector trigger (only shown when saved cards exist) -->
                        <div id="card-selector-actions" style="display:none; gap:0.5rem; flex-wrap:wrap; align-items:center;">
                            <button type="button" class="btn btn-outline" style="font-size:0.85rem; width:auto;"
                                    onclick="openCardSelector()">
                                <i class="fa fa-credit-card" style="margin-right:0.4rem;"></i>
                                <span id="card-selector-btn-text">Choose saved card</span>
                            </button>
                            <a href="/account/wallet" class="btn btn-ghost btn-sm" style="width:auto; text-decoration:none;">
                                Add / manage cards
                            </a>
                        </div>
                    </div>

                    <div id="payment-type-row" style="display:flex; gap:0.75rem; margin-bottom:1rem;">
                        <label class="payment-option selected">
                            <input type="radio" name="payment" value="card" checked onchange="togglePaymentMethod()"> Credit / Debit Card
                        </label>
                        <label class="payment-option">
                            <input type="radio" name="payment" value="cod" onchange="togglePaymentMethod()"> Cash on Delivery
                        </label>
                    </div>

                    <div id="card-fields">
                        <div id="stripe-payment-element" style="min-height:40px;"></div>
                        <div id="stripe-loading" class="text-muted small" style="text-align:center; padding:1.25rem 0;">
                            <i class="fa fa-spinner fa-spin" style="margin-right:0.4rem;"></i> Loading secure payment form...
                        </div>
                    </div>

                    <div id="cod-note" style="display:none;" class="alert alert-info">
                        <i class="fa fa-info-circle mr-2"></i>
                        Pay in cash when your order is delivered.
                    </div>
                </div>

                <div id="checkout-error-container"></div>
                <button id="place-order-btn" onclick="placeOrder(event)"
                    class="btn w-100" style="background:var(--accent-red); padding:1rem; font-size:1rem; margin-top:0.5rem;">
                    <i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order
                </button>
                <p class="text-muted small text-center" style="margin-top:0.75rem;">
                    By placing this order you agree to Markee's <a href="#">Terms of Service</a>.
                </p>
            </div>

            <!-- RIGHT: Order Summary -->
            <div>
                <div class="card p-4" style="position:sticky; top:5rem;">
                    <h4 class="mb-3">Order Summary</h4>
                    <div id="order-items-list"></div>

                    <hr style="margin:1rem 0; border:none; border-top:1px solid var(--border-light);">

                    <div class="flex-between mb-2">
                        <span class="text-muted">Subtotal (<span id="item-count">0</span> items)</span>
                        <span id="summary-subtotal" style="font-weight:600;">$0.00</span>
                    </div>
                    <div class="flex-between mb-2" id="summary-delivery-row">
                        <span class="text-muted">Delivery</span>
                        <span id="summary-delivery" style="color:var(--color-green); font-weight:600;">Free</span>
                    </div>
                    <div class="flex-between mb-2" id="summary-discount-row" style="display:none;">
                        <span style="color:var(--color-green); font-weight:600;">Promo discount</span>
                        <span id="summary-discount" style="color:var(--color-green); font-weight:600;">-$0.00</span>
                    </div>
                    <div class="flex-between mb-3">
                        <span class="text-muted" id="summary-tax-label">Tax (13% HST)</span>
                        <span id="summary-tax" style="font-weight:600;">$0.00</span>
                    </div>
                    <hr style="margin:0 0 1rem; border:none; border-top:1px solid var(--border-light);">
                    <div class="flex-between">
                        <span style="font-weight:700; font-size:1.1rem;">Total</span>
                        <span id="summary-total" style="font-weight:800; font-size:1.3rem; color:var(--accent-red);">$0.00</span>
                    </div>
                    <p style="text-align:right; font-size:0.75rem; color:var(--text-muted); margin:0.35rem 0 0;">
                        You will be charged in <strong><%- (locals.defaultCurrency || 'cad').toUpperCase() %></strong>
                    </p>

                    <div style="margin-top:1rem;">
                        <div style="display:flex; gap:0.5rem; align-items:center;">
                            <input id="coupon-code" placeholder="Promo code" style="flex:1; width:auto;" />
                            <button onclick="applyCoupon()" class="btn btn-sm" style="background:var(--accent-red); color:#fff; white-space:nowrap;">Apply</button>
                            <button onclick="removeCoupon()" id="remove-coupon-btn" class="btn btn-sm" style="display:none; background:#f1f5f9; color:#475569;" title="Remove coupon">&#x2715;</button>
                        </div>
                        <span id="coupon-status" class="small" style="display:block; margin-top:0.35rem;"></span>
                    </div>

                    <div style="border:1px solid var(--toast-success-border); border-radius:8px; padding:0.75rem; background:var(--toast-success-bg); margin-top:1.25rem;">
                        <p class="small" style="color:var(--toast-success-fg); margin:0;">
                            <i class="fa fa-shield-alt mr-2"></i>
                            <strong>Markee Buyer Protection</strong> — If your item doesn't arrive, we'll refund you.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
// ── Constants ─────────────────────────────────────────────────────────
// Server-authoritative delivery fee constants — injected at render time so client and
// server always agree. Must match STANDARD_DELIVERY_FEE_CENTS / FAST_DELIVERY_FEE_CENTS
// env vars in order-service/app.js (both default to 599 / 1499).
const SERVER_STANDARD_DELIVERY_CENTS = <%- standardDeliveryFeeCents %>;
const SERVER_FAST_DELIVERY_CENTS     = <%- fastDeliveryFeeCents %>;
// PLATFORM_TAX_RATE override — null when not set (client uses province table).
// When set, mirrors order-service getTaxRate() flat-rate override so client and server agree.
const SERVER_PLATFORM_TAX_RATE = <%- platformTaxRate === null ? 'null' : platformTaxRate %>;

// ── Inline error helpers ──────────────────────────────────────────────
function showInlineError(elId, msg) {
    const el = document.getElementById(elId);
    if (el) { el.textContent = msg; el.style.color = '#dc2626'; el.style.fontSize = '0.82rem'; el.style.marginTop = '0.25rem'; }
}
function clearInlineError(elId) {
    const el = document.getElementById(elId);
    if (el) el.textContent = '';
}

// ── Auth helpers ──────────────────────────────────────────────────────
function getToken() {
    const t = localStorage.getItem('access_token');
    if (!t) return null;
    try {
        const payload = JSON.parse(atob(t.split('.')[1]));
        if (payload.exp * 1000 < Date.now()) { localStorage.removeItem('access_token'); return null; }
        return t;
    } catch { return null; }
}
function getUser() {
    const t = getToken();
    if (!t) return null;
    try { return JSON.parse(atob(t.split('.')[1])); } catch { return null; }
}

// ── State ─────────────────────────────────────────────────────────────
let checkoutItems = [];
let selectedDelivery = 'standard';
let sellerStoreData = [];  // store data for all sellers in cart
let availableFulfillmentOptions = ['shipping'];  // computed from intersection
let selectedBillingAddr      = null;   // address object chosen via modal
let selectedShippingAddr     = null;   // null = use billing
let selectedSelfFulfillAddr  = null;   // shown to seller for self_fulfilled orders
let appliedCouponCode    = null;
let appliedDiscountCents = 0;

const _stripeKey          = '<%- locals.stripePublishableKey || "" %>';
let _stripe               = null;
let _stripeElements       = null;
let _stripeIntentId       = null;
let _stripeMounting       = false;
let _lastMountedAmountCents = 0;
let _selectedSavedPmId    = null;

// ── Address selector helpers ──────────────────────────────────────────
function escHtml(s) {
    return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function renderSelectedAddrCard(type, addr) {
    const display = document.getElementById(`${type}-addr-display`);
    const empty   = document.getElementById(`${type}-addr-empty`);
    const labelEl = document.getElementById(`${type}-addr-label`);
    const textEl  = document.getElementById(`${type}-addr-text`);
    if (!display || !empty) return;
    if (!addr) {
        display.style.display = 'none';
        empty.style.display   = '';
        return;
    }
    if (labelEl) labelEl.textContent = addr.label || 'Address';
    if (textEl) {
        const line2 = [addr.city, addr.province, addr.postalCode].filter(Boolean).join(', ');
        const recipient = addr.recipientName ? `<strong>${escHtml(addr.recipientName)}</strong><br>` : '';
        textEl.innerHTML = `${recipient}${escHtml(addr.street || '')}<br>${escHtml(line2)}<br>${escHtml(addr.country || '')}`;
    }
    display.style.display = '';
    empty.style.display   = 'none';
}

function showBillingSelector() {
    if (typeof window.showAddressSelector !== 'function') {
        showToast('Address selector not available.', 'error'); return;
    }
    window.showAddressSelector({ type: 'delivery', title: 'Select Billing Address' }, (addr) => {
        selectedBillingAddr = addr;
        renderSelectedAddrCard('billing', addr);
        if (document.getElementById('same-as-billing')?.checked) {
            selectedShippingAddr = null; // means use billing
        }
    });
}

function showShippingSelector() {
    if (typeof window.showAddressSelector !== 'function') {
        showToast('Address selector not available.', 'error'); return;
    }
    window.showAddressSelector({ type: 'delivery', title: 'Select Delivery Address' }, (addr) => {
        selectedShippingAddr = addr;
        renderSelectedAddrCard('shipping', addr);
    });
}

function showSelfFulfillSelector() {
    if (typeof window.showAddressSelector !== 'function') {
        showToast('Address selector not available.', 'error'); return;
    }
    window.showAddressSelector({ type: 'delivery', title: 'Select Address for Seller' }, (addr) => {
        selectedSelfFulfillAddr = addr;
        renderSelfFulfillAddrCard(addr);
        document.getElementById('sf-addr-empty').style.outline = '';
    });
}

function renderSelfFulfillAddrCard(addr) {
    const display = document.getElementById('sf-addr-display');
    const empty   = document.getElementById('sf-addr-empty');
    const label   = document.getElementById('sf-addr-label');
    const text    = document.getElementById('sf-addr-text');
    if (!display || !label || !text) return;
    label.textContent = addr.label || 'Address';
    const line2 = [addr.city, addr.province, addr.postalCode].filter(Boolean).join(', ');
    const sfRecipient = addr.recipientName ? `<strong>${escHtml(addr.recipientName)}</strong><br>` : '';
    text.innerHTML = sfRecipient + [addr.street, line2, addr.country].filter(Boolean).map(escHtml).join('<br>');
    display.style.display = 'block';
    if (empty) empty.style.display = 'none';
}

// ── Fulfillment options ───────────────────────────────────────────────
async function loadFulfillmentOptions() {
    const sellerIds = [...new Set(checkoutItems.map(i => i.sellerId).filter(Boolean))];
    if (!sellerIds.length) return;
    const results = await Promise.allSettled(
        sellerIds.map(id => fetch(`/api/public-seller/by-seller/${id}`).then(r => r.ok ? r.json() : null))
    );
    sellerStoreData = results.map(r => r.status === 'fulfilled' ? r.value : null).filter(Boolean);

    const allOptions = sellerStoreData.map(s => (s.fulfillmentOptions && s.fulfillmentOptions.length) ? s.fulfillmentOptions : ['shipping']);
    availableFulfillmentOptions = allOptions.length
        ? allOptions.reduce((a, b) => a.filter(x => b.includes(x)))
        : ['shipping'];

    // Product-level override: if the product defines its own FO list, use it directly.
    // Per D1 — product overrides store defaults, it is not filtered through them.
    if (checkoutItems.length === 1 && checkoutItems[0].fulfillmentOptions?.length) {
        availableFulfillmentOptions = checkoutItems[0].fulfillmentOptions;
    }

    if (!availableFulfillmentOptions.length) availableFulfillmentOptions = ['shipping'];

    renderFulfillmentOptions();
}

function renderFulfillmentOptions() {
    const section = document.getElementById('fulfillment-type-section');
    if (!section) return;
    const labels = {
        shipping:       'Courier Delivery',
        pickup:         'Local Pickup',
        self_fulfilled: 'Seller Fulfillment',
    };
    const options = availableFulfillmentOptions.map((opt, idx) =>
        `<option value="${opt}" ${idx === 0 ? 'selected' : ''}>${labels[opt] || opt}</option>`
    ).join('');
    section.innerHTML = `<select id="fulfillment-type-select" class="form-control" onchange="onFulfillmentChange()" style="width:100%;">${options}</select>`;

    // Populate carrier select from seller's enabled carriers
    const carrierSelect = document.getElementById('carrier-select');
    if (carrierSelect) {
        const carrierLabels = {
            canada_post: 'Canada Post',
            ups:         'UPS',
            fedex:       'FedEx',
            purolator:   'Purolator',
            dhl:         'DHL',
            other:       'Other Carrier',
        };
        // Product-level carrier override takes precedence over store default
        const productCarriers = checkoutItems.length === 1 && checkoutItems[0].enabledCarriers?.length
            ? checkoutItems[0].enabledCarriers : null;
        const enabledCarriers = productCarriers
            || (sellerStoreData[0]?.enabledCarriers?.length ? sellerStoreData[0].enabledCarriers : null)
            || ['canada_post','ups','fedex','purolator','dhl'];
        carrierSelect.innerHTML = enabledCarriers
            .map(c => `<option value="${c}">${carrierLabels[c] || c}</option>`)
            .join('');
    }

    onFulfillmentChange();
}

function onFulfillmentChange() {
    const ft = document.getElementById('fulfillment-type-select')?.value || 'shipping';

    const addrSection   = document.getElementById('shipping-address-section');
    const pickupCard    = document.getElementById('pickup-location-card');
    const carrierPicker = document.getElementById('carrier-picker-section');
    const selfNote      = document.getElementById('self-fulfill-form');
    const deliveryCard  = document.getElementById('delivery-step-card');

    updateDeliveryLabels(); // re-render standard fee label (Free for pickup/self_fulfilled, $X for shipping)

    if (ft === 'shipping') {
        if (addrSection)   addrSection.style.display   = 'block';
        if (pickupCard)    pickupCard.style.display    = 'none';
        if (carrierPicker) carrierPicker.style.display = 'block';
        if (selfNote)      selfNote.style.display      = 'none';
        if (deliveryCard)  deliveryCard.style.display  = 'block';
    } else if (ft === 'pickup') {
        if (addrSection)   addrSection.style.display   = 'none';
        if (pickupCard)    pickupCard.style.display    = 'block';
        if (carrierPicker) carrierPicker.style.display = 'none';
        if (selfNote)      selfNote.style.display      = 'none';
        if (deliveryCard)  deliveryCard.style.display  = 'none';
        renderPickupLocation();
        selectedDelivery = 'standard';
        updateTotals();
    } else if (ft === 'self_fulfilled') {
        if (addrSection)   addrSection.style.display   = 'none';
        if (pickupCard)    pickupCard.style.display    = 'none';
        if (carrierPicker) carrierPicker.style.display = 'none';
        if (selfNote)      selfNote.style.display      = 'block';
        if (deliveryCard)  deliveryCard.style.display  = 'none';
        selectedDelivery = 'standard';
        updateTotals();
        // Auto-populate from billing if already selected
        if (selectedBillingAddr && !selectedSelfFulfillAddr) {
            selectedSelfFulfillAddr = selectedBillingAddr;
            renderSelfFulfillAddrCard(selectedBillingAddr);
        }
    }
}

function renderPickupLocation() {
    const store = sellerStoreData[0]; // single seller in most cases
    const locations = (store?.pickupLocations || []).filter(l => l.active !== false);
    const addrEl    = document.getElementById('pickup-address-text');
    const hoursEl   = document.getElementById('pickup-hours-text');
    const instrEl   = document.getElementById('pickup-instructions-text');
    if (!locations.length) {
        if (addrEl) addrEl.textContent = 'Pickup address will be provided by the seller.';
        if (hoursEl) hoursEl.textContent = '';
        if (instrEl) instrEl.textContent = '';
        return;
    }
    const preferredId = (checkoutItems[0] || {}).pickupLocationId;
    const loc = (preferredId && locations.find(l => l._id?.toString() === preferredId?.toString())) || locations[0];
    const streetVal = loc.street || loc.address || '';
    const addr = [streetVal, loc.city, loc.province, loc.postalCode, loc.country].filter(Boolean).join(', ');
    if (addrEl) addrEl.textContent = addr;
    if (hoursEl) hoursEl.textContent = loc.hours ? `Hours: ${loc.hours}` : '';
    if (instrEl) instrEl.textContent = loc.instructions || '';
}

// ── Shipping address toggle ───────────────────────────────────────────
function toggleShippingFields() {
    const sameAsBilling = document.getElementById('same-as-billing').checked;
    document.getElementById('shipping-fields').style.display  = sameAsBilling ? 'none' : 'block';
    document.getElementById('shipping-same-note').style.display = sameAsBilling ? 'block' : 'none';
    if (sameAsBilling) selectedShippingAddr = null;
    updateTotals();
}

function getShippingAddress() {
    const sameAsBilling = document.getElementById('same-as-billing').checked;
    const addr = sameAsBilling ? selectedBillingAddr : (selectedShippingAddr || selectedBillingAddr);
    if (!addr) return null;
    return {
        street:        addr.street        || '',
        city:          addr.city          || '',
        province:      addr.province      || '',
        postalCode:    addr.postalCode    || '',
        country:       addr.country       || 'Canada',
        recipientName: addr.recipientName || '',
    };
}

// ── Delivery speed ────────────────────────────────────────────────────
function selectDelivery(speed) {
    selectedDelivery = speed;
    document.getElementById('delivery-standard-label').classList.toggle('selected', speed === 'standard');
    document.getElementById('delivery-fast-label').classList.toggle('selected', speed === 'fast');
    updateTotals();
}

function deliveryCents() {
    // Pickup and self_fulfilled orders carry $0 delivery — matches server computeDeliveryFee()
    const ft = document.getElementById('fulfillment-type-select')?.value || 'shipping';
    if (ft === 'pickup' || ft === 'self_fulfilled') return 0;

    // Both fast and standard use the server's flat platform fee.
    // The server computeDeliveryFee() always uses FAST/STANDARD_DELIVERY_FEE_CENTS
    // regardless of per-seller fastDeliveryFee — client must match exactly.
    return selectedDelivery === 'fast' ? SERVER_FAST_DELIVERY_CENTS : SERVER_STANDARD_DELIVERY_CENTS;
}

function updateDeliveryLabels() {
    const stdEl  = document.getElementById('standard-delivery-price');
    const fastEl = document.getElementById('fast-delivery-price');
    if (stdEl) {
        const ft = document.getElementById('fulfillment-type-select')?.value || 'shipping';
        if (ft === 'pickup' || ft === 'self_fulfilled') {
            stdEl.textContent  = 'Free';
            stdEl.style.color  = '#16a34a';
        } else {
            stdEl.textContent  = `+$${(SERVER_STANDARD_DELIVERY_CENTS / 100).toFixed(2)}`;
            stdEl.style.color  = 'var(--accent-red)';
        }
    }
    if (fastEl) fastEl.textContent = `+$${(SERVER_FAST_DELIVERY_CENTS / 100).toFixed(2)}`;
}
// Keep backward-compatible alias used in loadCheckoutItems and selectDelivery callers
function updateFastDeliveryLabel() { updateDeliveryLabels(); }

// ── Payment toggle ────────────────────────────────────────────────────
function togglePaymentMethod() {
    const val = document.querySelector('input[name="payment"]:checked').value;
    document.querySelectorAll('.payment-option').forEach(l => {
        l.classList.toggle('selected', l.querySelector('input')?.value === val);
    });
    const isCod = val === 'cod';
    // Card entry never happens on checkout — saved-payments-section handles the card path
    document.getElementById('card-fields').style.display            = 'none';
    document.getElementById('cod-note').style.display               = isCod ? 'block' : 'none';
    document.getElementById('saved-payments-section').style.display = isCod ? 'none' : 'block';
}

function useNewCard() {
    // Card entry does not happen on checkout — send user to wallet to add/manage cards
    window.location.href = '/account/wallet';
}

// Called when user clicks "Choose saved card" button
function openCardSelector() {
    if (typeof window.showCardSelector !== 'function') {
        window.location.href = '/account/wallet';
        return;
    }
    window.showCardSelector(function (card) {
        _selectedSavedPmId = card.id;
        const brand = card.brand.charAt(0).toUpperCase() + card.brand.slice(1);
        const exp   = String(card.expMonth).padStart(2,'0') + '/' + card.expYear;
        document.getElementById('selected-card-brand').innerHTML =
            `<i class="fa fa-credit-card" style="margin-right:0.4rem"></i>${brand} •••• ${card.last4}`;
        document.getElementById('selected-card-expiry').textContent = 'Expires ' + exp;
        document.getElementById('selected-card-display').style.display = 'block';
        document.getElementById('card-selector-btn-text').textContent  = 'Change card';
        document.getElementById('card-selector-actions').style.display = 'flex';
        document.getElementById('no-saved-cards-msg').style.display    = 'none';
        document.getElementById('payment-type-row').style.display = 'none';
        document.getElementById('card-fields').style.display      = 'none';
    });
}

// ── Expiry check (matches wallet.ejs and card-selector.js) ──────────────
function isExpired(c) {
    const today        = new Date();
    const currentYear  = today.getFullYear();
    const currentMonth = today.getMonth() + 1;
    const cardYear     = parseInt(c.expYear,  10);
    const cardMonth    = parseInt(c.expMonth, 10);
    if (cardYear < currentYear) return true;
    if (cardYear === currentYear && cardMonth < currentMonth) return true;
    return false;
}

// S21 — Check for saved cards on page load; card entry never happens on checkout
async function loadSavedCards() {
    const token = getToken();
    if (!token) return;
    try {
        const res  = await fetch('/api/payments/saved-cards', { headers: { Authorization: `Bearer ${token}` } });
        if (!res.ok) return;
        const data  = await res.json();
        const cards = data.cards || [];

        const section = document.getElementById('saved-payments-section');
        section.style.display = 'block';
        document.getElementById('payment-type-row').style.display = 'none';
        document.getElementById('card-fields').style.display      = 'none';

        if (!cards.length) {
            // No saved cards — show wallet link, no card auto-selected
            _selectedSavedPmId = null;
            document.getElementById('no-saved-cards-msg').style.display    = 'block';
            document.getElementById('selected-card-display').style.display = 'none';
            document.getElementById('card-selector-actions').style.display = 'none';
            return;
        }

        const validCards = cards.filter(c => !isExpired(c));

        if (!validCards.length) {
            // All cards expired — prompt user to update wallet
            _selectedSavedPmId = null;
            document.getElementById('no-saved-cards-msg').innerHTML =
                `<i class="fa fa-exclamation-triangle" style="margin-right:0.4rem;color:var(--accent-red);"></i>` +
                `All saved cards are expired. <a href="/account/wallet" style="color:var(--accent-red);font-weight:600;text-decoration:underline;">Update your wallet</a>`;
            document.getElementById('no-saved-cards-msg').style.display    = 'block';
            document.getElementById('selected-card-display').style.display = 'none';
            document.getElementById('card-selector-actions').style.display = 'none';
            return;
        }

        document.getElementById('no-saved-cards-msg').style.display    = 'none';
        document.getElementById('card-selector-actions').style.display = 'flex';

        const first = validCards[0];
        _selectedSavedPmId = first.id;
        const brand = first.brand.charAt(0).toUpperCase() + first.brand.slice(1);
        const exp   = String(first.expMonth).padStart(2,'0') + '/' + first.expYear;
        document.getElementById('selected-card-brand').innerHTML =
            `<i class="fa fa-credit-card" style="margin-right:0.4rem"></i>${brand} •••• ${first.last4}`;
        document.getElementById('selected-card-expiry').textContent = 'Expires ' + exp;
        document.getElementById('selected-card-display').style.display = 'block';
        document.getElementById('card-selector-btn-text').textContent  = 'Change card';
    } catch (err) {
        // Non-fatal — do not show Stripe Elements as fallback
        console.warn('[checkout] loadSavedCards failed:', err.message);
    }
}

// ── Cart / product loading ────────────────────────────────────────────
function loadCheckoutItems() {
    const params = new URLSearchParams(window.location.search);
    const productId = params.get('productId');

    if (productId) {
        fetch(`/api/catalog/products/${productId}`)
            .then(r => r.json())
            .then(p => {
                checkoutItems = [{
                    _id: p._id, productId: p._id, sellerId: p.sellerId,
                    title: p.title, price: p.price, qty: 1,
                    image: (p.images||[])[0],
                    fastDeliveryFee: p.fastDeliveryFee || 0,
                    pickupLocationId: p.pickupLocationId || null,
                    enabledCarriers: p.enabledCarriers || [],
                    fulfillmentOptions: p.fulfillmentOptions || [],
                }];
                renderSummary();
                updateFastDeliveryLabel();
                loadFulfillmentOptions();
            })
            .catch(() => showToast('Failed to load product details.', 'error'));
    } else {
        checkoutItems = MarkeeCart.getCart().map(i => ({
            _id: i._id, productId: i._id, sellerId: i.sellerId,
            title: i.title, price: i.price, qty: i.qty, image: i.image,
            fastDeliveryFee: i.fastDeliveryFee || 0,
            pickupLocationId: i.pickupLocationId || null,
            enabledCarriers: i.enabledCarriers || [],
            fulfillmentOptions: i.fulfillmentOptions || [],
        }));
        if (checkoutItems.length === 0) {
            document.getElementById('checkout-main').innerHTML =
                `<div style="text-align:center;padding:4rem 0;">
                    <p class="text-muted mb-4">Your cart is empty.</p>
                    <a href="/" class="nav-pill nav-pill-red" style="text-decoration:none;">Browse Marketplace</a>
                </div>`;
            return;
        }
        renderSummary();
        updateFastDeliveryLabel();
        loadFulfillmentOptions();
    }
}

function updateTotals() {
    const subtotalCents  = checkoutItems.reduce((s, i) => s + i.price * i.qty, 0);
    const deliveryCost   = deliveryCents();
    const discountedSub  = Math.max(0, subtotalCents - appliedDiscountCents);
    const taxCents       = Math.round(discountedSub * getLocaleTaxRate().rate);
    const totalCents     = discountedSub + taxCents + deliveryCost;
    const totalCount     = checkoutItems.reduce((s, i) => s + i.qty, 0);

    document.getElementById('item-count').textContent       = totalCount;
    document.getElementById('summary-subtotal').textContent = `$${(subtotalCents / 100).toFixed(2)}`;
    document.getElementById('summary-tax').textContent      = `$${(taxCents / 100).toFixed(2)}`;
    document.getElementById('summary-total').textContent    = `$${(totalCents / 100).toFixed(2)}`;

    // Discount row — show only when a coupon is applied
    const discountRow = document.getElementById('summary-discount-row');
    if (discountRow) {
        if (appliedDiscountCents > 0) {
            discountRow.style.display = '';
            document.getElementById('summary-discount').textContent = `-$${(appliedDiscountCents / 100).toFixed(2)}`;
        } else {
            discountRow.style.display = 'none';
        }
    }

    const delivEl = document.getElementById('summary-delivery');
    if (deliveryCost > 0) {
        delivEl.textContent = `+$${(deliveryCost / 100).toFixed(2)}`;
        delivEl.style.color = 'var(--accent-red)';
    } else {
        delivEl.textContent = 'Free';
        delivEl.style.color = '#16a34a';
    }

    // Phase 3: remount Stripe element if amount changed, card is selected, and the card
    // fields container is visible (it is hidden when a saved card is active).
    const payMethod = document.querySelector('input[name="payment"]:checked')?.value;
    const cardFieldsVisible = document.getElementById('card-fields')?.style.display !== 'none';
    if (payMethod === 'card' && cardFieldsVisible && totalCents !== _lastMountedAmountCents && totalCents >= 50) {
        mountStripeElement();
    }
}

// Phase 6 — Coupon application
async function applyCoupon() {
    const input  = document.getElementById('coupon-code');
    const status = document.getElementById('coupon-status');
    const code   = (input?.value || '').trim().toUpperCase();
    if (!code) { if (status) status.textContent = 'Please enter a promo code.'; return; }

    const token = getToken();
    if (!token) { if (status) status.textContent = 'Please log in to apply a coupon.'; return; }

    if (status) { status.textContent = 'Checking…'; status.style.color = 'var(--text-muted)'; }

    const subtotalCents = checkoutItems.reduce((s, i) => s + i.price * i.qty, 0);
    const sellerIds     = [...new Set(checkoutItems.map(i => i.sellerId).filter(Boolean))];

    try {
        const user = JSON.parse(atob(token.split('.')[1]));
        const res  = await fetch('/api/catalog/coupons/validate', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
            body: JSON.stringify({
                code,
                userId:    user.sub,
                cartTotal: subtotalCents,
                sellerId:  sellerIds.length === 1 ? sellerIds[0] : null,
            }),
        });
        const data = await res.json();
        const removeBtn = document.getElementById('remove-coupon-btn');
        if (!res.ok || !data.valid) {
            appliedCouponCode    = null;
            appliedDiscountCents = 0;
            if (status)    { status.textContent = data.message || 'Invalid coupon.'; status.style.color = 'var(--accent-red)'; }
            if (removeBtn) removeBtn.style.display = 'none';
        } else {
            appliedCouponCode    = code;
            appliedDiscountCents = data.discountCents;
            if (status)    { status.textContent = data.message; status.style.color = '#16a34a'; }
            if (removeBtn) removeBtn.style.display = '';
            if (input)     input.disabled = true;
        }
    } catch {
        if (status) { status.textContent = 'Could not check coupon — try again.'; status.style.color = 'var(--accent-red)'; }
    }
    updateTotals();
}

function removeCoupon() {
    appliedCouponCode    = null;
    appliedDiscountCents = 0;
    const input     = document.getElementById('coupon-code');
    const status    = document.getElementById('coupon-status');
    const removeBtn = document.getElementById('remove-coupon-btn');
    if (input)     { input.value = ''; input.disabled = false; }
    if (status)    { status.textContent = 'Coupon removed.'; status.style.color = 'var(--text-muted)'; }
    if (removeBtn) removeBtn.style.display = 'none';
    updateTotals();
}

function renderSummary() {
    const list = document.getElementById('order-items-list');
    list.innerHTML = checkoutItems.map(item => `
        <div class="order-item-row">
            <img src="${item.image || ''}" class="order-item-img"
                 style="background:var(--bg-secondary);"
                 onerror="this.onerror=null; this.src=''">
            <div style="flex:1; min-width:0;">
                <p style="font-weight:600; font-size:0.85rem; line-height:1.3; margin:0; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">
                    ${item.title}
                </p>
                <p class="text-muted small">Qty: ${item.qty}</p>
            </div>
            <span style="font-weight:700; font-size:0.9rem; white-space:nowrap;">
                $${((item.price * item.qty) / 100).toFixed(2)}
            </span>
        </div>
    `).join('');

    updateTotals();
}

// ── Stripe Payment Element ────────────────────────────────────────────
function computeFinalAmountCents() {
    const subtotalCents = checkoutItems.reduce((s, i) => s + i.price * i.qty, 0);
    const deliveryCost  = deliveryCents();
    const discountedSub = Math.max(0, subtotalCents - appliedDiscountCents);
    const taxCents      = Math.round(discountedSub * getLocaleTaxRate().rate);
    return discountedSub + taxCents + deliveryCost;
}

async function mountStripeElement() {
    if (!_stripeKey) return; // Stripe not configured on this deployment
    if (_stripeMounting) return;

    const totalCents = computeFinalAmountCents();
    if (totalCents < 50) return;

    // Skip remount if amount unchanged and element already mounted
    if (totalCents === _lastMountedAmountCents && _stripeElements) return;

    _stripeMounting = true;
    const loadingEl = document.getElementById('stripe-loading');
    const elementEl = document.getElementById('stripe-payment-element');
    if (loadingEl) loadingEl.style.display = 'block';
    if (elementEl) elementEl.innerHTML = '';
    _stripeElements = null;

    try {
        const token = getToken();
        if (!token) {
            // Session expired while the user was on the checkout page — send to login
            if (loadingEl) loadingEl.style.display = 'none';
            window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search));
            return;
        }
        const res = await fetch('/api/payments/create-intent', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
            body:    JSON.stringify({ amountCents: totalCents, currency: _platformCurrency }),
        });
        if (!res.ok) {
            const err = await res.json().catch(() => ({}));
            throw new Error(err.message || err.error || 'Payment setup failed');
        }
        const { clientSecret, intentId } = await res.json();
        _stripeIntentId         = intentId;
        _lastMountedAmountCents = totalCents;

        if (!_stripe) _stripe = Stripe(_stripeKey);
        _stripeElements = _stripe.elements({ clientSecret });
        const payEl = _stripeElements.create('payment');
        payEl.mount('#stripe-payment-element');
        if (loadingEl) loadingEl.style.display = 'none';
    } catch (err) {
        console.error('[Stripe] mount failed:', err);
        if (loadingEl) {
            loadingEl.innerHTML = '<i class="fa fa-exclamation-circle" style="color:var(--accent-red);margin-right:0.4rem;"></i> Secure payment form unavailable — please refresh and try again.';
        }
    } finally {
        _stripeMounting = false;
    }
}

// ── Card formatters ───────────────────────────────────────────────────
function formatCard(el) {
    let v = el.value.replace(/\D/g, '').slice(0, 16);
    el.value = v.replace(/(.{4})/g, '$1 ').trim();
}
function formatExpiry(el) {
    let v = el.value.replace(/\D/g, '').slice(0, 4);
    if (v.length >= 3) v = v.slice(0, 2) + ' / ' + v.slice(2);
    el.value = v;
}

// ── Validation ────────────────────────────────────────────────────────
function validate() {
    let ok = true;
    const errors = [];

    if (!selectedBillingAddr) {
        errors.push('Please select a billing address.');
        const emptyEl = document.getElementById('billing-addr-empty');
        if (emptyEl) emptyEl.style.outline = '2px solid var(--accent-red)';
        ok = false;
    } else {
        const emptyEl = document.getElementById('billing-addr-empty');
        if (emptyEl) emptyEl.style.outline = '';
    }

    const ft = document.getElementById('fulfillment-type-select')?.value || 'shipping';
    const sameAsBilling = document.getElementById('same-as-billing').checked;

    if (ft === 'shipping' && !sameAsBilling && !selectedShippingAddr) {
        errors.push('Please select a delivery address.');
        const emptyEl = document.getElementById('shipping-addr-empty');
        if (emptyEl) emptyEl.style.outline = '2px solid var(--accent-red)';
        ok = false;
    } else {
        const emptyEl = document.getElementById('shipping-addr-empty');
        if (emptyEl) emptyEl.style.outline = '';
    }

    if (ft === 'self_fulfilled' && !selectedSelfFulfillAddr) {
        errors.push('Please select an address to share with the seller.');
        const emptyEl = document.getElementById('sf-addr-empty');
        if (emptyEl) emptyEl.style.outline = '2px solid var(--accent-red)';
        ok = false;
    } else if (ft === 'self_fulfilled') {
        const emptyEl = document.getElementById('sf-addr-empty');
        if (emptyEl) emptyEl.style.outline = '';
    }

    if (!ok && errors.length) showInlineError('checkout-error-container', errors[0]);
    return ok;
}

// ── Stock pre-check ───────────────────────────────────────────────────
async function checkStock() {
    const outOfStock = [];
    await Promise.allSettled(checkoutItems.map(async item => {
        try {
            const r = await fetch(`/api/catalog/products/${item.productId || item._id}`);
            if (!r.ok) return;
            const p = await r.json();
            if (p.status !== 'active') {
                outOfStock.push(`"${item.title}" is no longer available.`);
            }
        } catch {}
    }));
    return outOfStock;
}

// ── Place order ───────────────────────────────────────────────────────
async function placeOrder(evt) {
    clearInlineError('checkout-error-container');
    if (!validate()) { showInlineError('checkout-error-container', 'Please fill in all required fields.'); return; }

    const token = getToken();
    if (!token) { showInlineError('checkout-error-container', 'You must be signed in to place an order.'); return; }
    const user  = getUser();

    const btn = document.getElementById('place-order-btn');
    btn.disabled = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Checking stock...';

    const stockIssues = await checkStock();
    if (stockIssues.length) {
        showInlineError('checkout-error-container', stockIssues[0]);
        btn.disabled = false;
        btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
        return;
    }

    btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Processing...';

    const payMethod      = document.querySelector('input[name="payment"]:checked').value;
    const subtotalCents  = checkoutItems.reduce((s, i) => s + i.price * i.qty, 0);
    const deliveryCost   = deliveryCents();
    const discountedSub  = Math.max(0, subtotalCents - appliedDiscountCents);
    const taxCents       = Math.round(discountedSub * getLocaleTaxRate().rate);

    // ── Stripe card authorization ─────────────────────────────────────
    let stripePaymentIntentId = null;
    if (payMethod === 'card' || _selectedSavedPmId) {
        const currentTotal = discountedSub + taxCents + deliveryCost;

        // Guard: card payment requires a saved card — no card entry on checkout
        if (payMethod === 'card' && !_selectedSavedPmId) {
            showInlineError('checkout-error-container',
                'Please add a card to your wallet before placing a card order. ' +
                '<a href="/account/wallet" style="color:var(--accent-red);font-weight:600;">Go to Wallet →</a>');
            btn.disabled  = false;
            btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
            return;
        }

        if (_selectedSavedPmId) {
            // S21 — Saved card path: create intent then confirm with the saved PM id
            btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Setting up payment...';
            const intentRes = await fetch('/api/payments/create-intent', {
                method:  'POST',
                headers: { 'Content-Type': 'application/json', Authorization: `Bearer ${token}` },
                body:    JSON.stringify({ amountCents: currentTotal }),
            });
            const intentData = await intentRes.json();
            if (!intentRes.ok) {
                showInlineError('checkout-error-container', intentData.error || 'Could not set up payment.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
                return;
            }
            // Initialize _stripe here — mountStripeElement() is never called on the saved-card path
            if (!_stripe && _stripeKey) _stripe = Stripe(_stripeKey);
            if (!_stripe) {
                showInlineError('checkout-error-container', 'Stripe not configured — please refresh.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
                return;
            }
            btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Authorizing payment...';
            const result = await _stripe.confirmPayment({
                clientSecret:  intentData.clientSecret,
                confirmParams: { payment_method: _selectedSavedPmId },
                redirect:      'if_required',
            });
            if (result.error) {
                showInlineError('checkout-error-container', result.error.message || 'Payment authorization failed.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
                return;
            }
            stripePaymentIntentId = result.paymentIntent.id;
        } else {
            // New card path — use Stripe Elements
            if (currentTotal !== _lastMountedAmountCents || !_stripeElements) {
                btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Setting up payment...';
                await mountStripeElement();
            }
            if (!_stripe || !_stripeElements) {
                showInlineError('checkout-error-container', 'Payment form not ready — please refresh and try again.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
                return;
            }
            btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Authorizing payment...';
            const result = await _stripe.confirmPayment({
                elements:  _stripeElements,
                redirect:  'if_required',
            });
            if (result.error) {
                showInlineError('checkout-error-container', result.error.message || 'Payment authorization failed.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
                return;
            }
            stripePaymentIntentId = result.paymentIntent.id;
        }
        btn.innerHTML = '<i class="fa fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Placing order...';
    }

    const billingAddress = {
        street:        selectedBillingAddr?.street        || '',
        city:          selectedBillingAddr?.city          || '',
        province:      selectedBillingAddr?.province      || '',
        postalCode:    selectedBillingAddr?.postalCode    || '',
        country:       selectedBillingAddr?.country       || 'Canada',
        recipientName: selectedBillingAddr?.recipientName || '',
    };
    const fulfillmentType = document.getElementById('fulfillment-type-select')?.value || 'shipping';

    // For pickup orders, store the resolved pickup location as shippingAddress
    // so order-detail can always display where to get the order.
    let shippingAddress;
    if (fulfillmentType === 'pickup') {
        const store = sellerStoreData[0];
        const locations = (store?.pickupLocations || []).filter(l => l.active !== false);
        const preferredId = (checkoutItems[0] || {}).pickupLocationId;
        const loc = (preferredId && locations.find(l => l._id?.toString() === preferredId?.toString())) || locations[0];
        shippingAddress = loc ? {
            street:     loc.street     || loc.address || '',
            city:       loc.city       || '',
            postalCode: loc.postalCode || '',
            country:    loc.country    || 'Canada',
        } : getShippingAddress();
    } else {
        shippingAddress = getShippingAddress();
    }

    const payload = {
        buyerId: user.sub,
        items: checkoutItems.map(i => ({
            productId: i.productId || i._id,
            sellerId:  i.sellerId,
            title:     i.title,
            image:     i.image || '',
            qty:       i.qty,
            price:     i.price,
        })),
        billingAddress,
        shippingAddress,
        deliverySpeed:  selectedDelivery,
        deliveryFee:    deliveryCost,
        totalAmount:    discountedSub + taxCents + deliveryCost,
        couponCode:            appliedCouponCode  || null,
        discountCents:         appliedDiscountCents,
        paymentMethod:         payMethod === 'cod' ? 'cod' : 'stripe',
        stripePaymentIntentId: stripePaymentIntentId,
        buyerCountry:  _userLocale.country  || 'CA',
        buyerProvince: _userLocale.province || 'ON',
        fulfillmentType,
        selectedCarrier: fulfillmentType === 'shipping'
            ? (document.getElementById('carrier-select')?.value || null)
            : null,
        selfFulfillmentInstructions: fulfillmentType === 'self_fulfilled'
            ? (document.getElementById('sf-instructions')?.value || '').trim()
            : '',
        selfFulfillmentAddress: fulfillmentType === 'self_fulfilled' && selectedSelfFulfillAddr
            ? {
                street:     selectedSelfFulfillAddr.street     || '',
                city:       selectedSelfFulfillAddr.city       || '',
                province:   selectedSelfFulfillAddr.province   || '',
                postalCode: selectedSelfFulfillAddr.postalCode || '',
                country:    selectedSelfFulfillAddr.country    || 'Canada',
            }
            : null,
    };

    try {
        const res = await fetch('/api/orders', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'Authorization': `Bearer ${token}`,
            },
            body: JSON.stringify(payload),
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.message || data.error || 'Order failed');

        const params = new URLSearchParams(window.location.search);
        if (!params.get('productId')) MarkeeCart.clearCart();

        // Reset Stripe state so a subsequent order creates a fresh Payment Intent
        _stripeElements       = null;
        _lastMountedAmountCents = 0;

        document.getElementById('checkout-main').style.display = 'none';
        const confirm = document.getElementById('confirm-screen');
        confirm.style.display = 'block';
        document.getElementById('confirm-order-id').textContent = `#${data._id.slice(-8).toUpperCase()}`;
        showToast('Order placed successfully!', 'success', 3500, evt);

    } catch (err) {
        showInlineError('checkout-error-container', `Failed to place order: ${err.message}`);
        btn.disabled = false;
        btn.innerHTML = '<i class="fa fa-lock" style="margin-right:0.5rem;"></i> Place Order';
    }
}

// ── Platform currency (injected from server-side EJS local) ──────────
const _platformCurrency = '<%- (locals.defaultCurrency || "cad").toLowerCase() %>';

// ── User locale (for tax) ──────────────────────────────────────────────
let _userLocale = { country: 'CA', province: 'ON' };

// Client-side CA province tax rates — mirrors order-service CA_DEFAULT_RATES
const _CA_PROVINCE_TAX = {
    'AB': { rate: 0.05,    label: '5% GST'        },
    'BC': { rate: 0.12,    label: '12% GST+PST'   },
    'MB': { rate: 0.12,    label: '12% GST+PST'   },
    'NB': { rate: 0.15,    label: '15% HST'        },
    'NL': { rate: 0.15,    label: '15% HST'        },
    'NS': { rate: 0.15,    label: '15% HST'        },
    'NT': { rate: 0.05,    label: '5% GST'         },
    'NU': { rate: 0.05,    label: '5% GST'         },
    'ON': { rate: 0.13,    label: '13% HST'        },
    'PE': { rate: 0.15,    label: '15% HST'        },
    'QC': { rate: 0.14975, label: '14.975% GST+QST'},
    'SK': { rate: 0.11,    label: '11% GST+PST'   },
    'YT': { rate: 0.05,    label: '5% GST'         },
};
function getLocaleTaxRate() {
    // Platform override takes precedence — mirrors order-service getTaxRate() env check
    if (SERVER_PLATFORM_TAX_RATE !== null) {
        const pct = (SERVER_PLATFORM_TAX_RATE * 100).toFixed(2).replace(/\.00$/, '');
        return { rate: SERVER_PLATFORM_TAX_RATE, label: `${pct}% Tax` };
    }
    if (_userLocale.country !== 'CA') return { rate: 0.05, label: '5% GST' };
    return _CA_PROVINCE_TAX[_userLocale.province] || { rate: 0.13, label: '13% HST' };
}
function updateTaxLabel() {
    const { label } = getLocaleTaxRate();
    const el = document.getElementById('summary-tax-label');
    if (el) el.textContent = `Tax (${label})`;
}

async function loadUserLocale() {
    try {
        const token = getToken();
        if (!token) return;
        const res = await fetch('/api/users/me', { headers: { Authorization: `Bearer ${token}` } });
        if (!res.ok) return;
        const profile = await res.json();
        if (profile.country)  _userLocale.country  = profile.country;
        if (profile.province) _userLocale.province = profile.province;
        updateTaxLabel();
        updateTotals(); // recalc with correct province rate
    } catch {}
}

// ── Init ──────────────────────────────────────────────────────────────
window.addEventListener('DOMContentLoaded', () => {
    MarkeeCart.updateAllCartBadges();

    const user = getUser();
    if (!user) {
        window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search));
        return;
    }

    loadCheckoutItems();
    loadUserLocale();
    loadSavedCards();

});
</script>

