<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wallet | Markee</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <script src="/js/confirm.js"></script>
    <script src="https://js.stripe.com/v3/"></script>
    <style>
        /* ── Wallet page layout ───────────────────────────────────────────── */
        .wallet-page-header    { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.75rem; }
        .wallet-back-link      { color: var(--muted); text-decoration: none; font-size: 0.85rem; }
        .wallet-divider        { color: var(--border); }
        .wallet-section        { margin-bottom: 2.5rem; }
        .wallet-section h3     { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }
        .wallet-section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
        .wallet-section-icon   { color: var(--accent); margin-right: 0.4rem; }
        .wallet-hint           { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.75rem; }

        /* ── Add-card panel ───────────────────────────────────────────────── */
        .add-card-panel       { display: none; border: 1.5px solid var(--border); border-radius: 10px; padding: 1.1rem; margin-bottom: 1rem; background: var(--surface2); }
        .stripe-payment-element { min-height: 40px; }
        .stripe-loading-msg   { text-align: center; padding: 1.25rem 0; color: var(--muted); font-size: 0.9rem; }
        .add-card-error-msg   { display: none; color: var(--danger); font-size: 0.83rem; margin: 0.6rem 0; }
        .add-card-actions     { display: flex; gap: 0.5rem; align-items: center; margin-top: 0.75rem; }

        /* ── Saved cards list ─────────────────────────────────────────────── */
        .card-list            { display: flex; flex-direction: column; gap: 0.75rem; }
        .cards-loading-msg    { color: var(--muted); font-size: 0.9rem; }
        .empty-state          { text-align: center; padding: 2.5rem 1rem; color: var(--muted); }
        .empty-state i        { font-size: 2.2rem; display: block; margin-bottom: 0.6rem; }

        /* ── Card item (wallet list, not selector modal) ──────────────────── */
        .payment-selector-card          { display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; cursor: default; }
        .payment-selector-card:hover    { border-color: var(--border); background: var(--surface2); }
        .payment-selector-card .pm-card-info { flex: 1; }

        /* ── Payout section ───────────────────────────────────────────────── */
        .payout-status      { font-size: 0.88rem; margin-bottom: 0.6rem; }
        .payout-info        { font-size: 0.82rem; color: var(--text-muted); }

        /* ── Payout balance display ───────────────────────────────────────── */
        .payout-balance-grid        { display: grid; grid-template-columns: 1fr 1fr; gap: .75rem; margin-bottom: 1.25rem; }
        .payout-balance-card        { border: 1px solid var(--border-light); border-radius: 8px; padding: .75rem 1rem; background: var(--bg-secondary); }
        .payout-balance-label       { font-size: .78rem; color: var(--text-muted); margin-bottom: .25rem; }
        .payout-balance-value       { font-size: 1.3rem; font-weight: 700; }
        .payout-balance-value--green{ color: var(--color-green); }
        .payout-balance-hint        { font-size: .74rem; color: var(--text-muted); margin-top: .2rem; }
        .payout-balance-error       { color: var(--color-error); }
        .payout-mode-fields         { display: none; }
        .payout-method-section      { border-top: 1px solid var(--border-light); margin-top: 1.25rem; padding-top: 1.1rem; }
        .payout-method-section h4   { margin: 0 0 .6rem; font-size: .92rem; font-weight: 700; }
        .wallet-page-header h2      { margin: 0; }
        .wallet-section-header h3   { margin: 0; }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="brand-combo">
        <a href="/"><span class="brand">Markee</span></a>
    </div>
    <%- include('_nav') %>
</nav>

<div class="container py-4 animate-fade">
    <div class="wallet-page-header">
        <a href="/account" class="wallet-back-link"><i class="fa fa-arrow-left"></i> Account</a>
        <span class="wallet-divider">/</span>
        <h2>Wallet</h2>
    </div>

    <!-- ── Saved Cards ─────────────────────────────────────────────────────────── -->
    <div class="wallet-section">
        <div class="wallet-section-header">
            <h3><i class="fa fa-credit-card wallet-section-icon"></i> Saved Cards</h3>
            <button id="add-card-btn" onclick="showAddCardForm()" class="btn btn-sm btn-red">
                <i class="fa fa-plus"></i>Add Card
            </button>
        </div>
        <p class="wallet-hint">
            Add a card here or cards are saved automatically when you complete a card payment. Remove a card to stop it appearing at checkout.
        </p>

        <!-- Add card form (hidden by default) -->
        <div id="add-card-form" class="add-card-panel">
            <p class="wallet-hint">Enter your card details. You may be prompted to verify with your bank.</p>
            <div id="stripe-payment-element" class="stripe-payment-element"></div>
            <div id="stripe-loading" class="stripe-loading-msg">
                <i class="fa fa-spinner fa-spin"></i> Loading secure payment form...
            </div>
            <div id="add-card-error" class="add-card-error-msg"></div>
            <div class="add-card-actions">
                <button id="save-card-btn" onclick="saveCard()" class="btn btn-sm btn-red">
                    <i class="fa fa-lock"></i>Save Card
                </button>
                <button onclick="cancelAddCard()" class="btn btn-ghost btn-sm">Cancel</button>
            </div>
        </div>

        <div id="cards-loading" class="cards-loading-msg"><i class="fa fa-spinner fa-spin"></i> Loading...</div>
        <div id="cards-error"   style="display:none" class="error-banner"></div>
        <div id="cards-list"    class="card-list"    style="display:none"></div>
        <div id="cards-empty"   class="empty-state"  style="display:none">
            <i class="fa fa-credit-card"></i>
            No saved cards yet. Add a card above or complete a card payment to save one automatically.
        </div>
    </div>

    <!-- ── Payout Account (sellers only) ─────────────────────────────────────── -->
    <div class="wallet-section" id="payout-section" style="display:none">
        <h3><i class="fa fa-building-columns wallet-section-icon"></i> Payout Account</h3>

        <!-- Balance -->
        <div id="payout-balance-loading" class="wallet-hint"><i class="fa fa-spinner fa-spin"></i> Loading balance…</div>
        <div id="payout-balance-grid" class="payout-balance-grid" style="display:none">
            <div class="payout-balance-card">
                <div class="payout-balance-label">In Escrow</div>
                <div class="payout-balance-value" id="payout-in-escrow">—</div>
                <div class="payout-balance-hint">Held pending order completion</div>
            </div>
            <div class="payout-balance-card">
                <div class="payout-balance-label">Available for Payout</div>
                <div class="payout-balance-value payout-balance-value--green" id="payout-available">—</div>
                <div class="payout-balance-hint">Released earnings minus past payouts</div>
            </div>
        </div>
        <div id="payout-balance-error" class="wallet-hint payout-balance-error" style="display:none"></div>

        <!-- Payout method form -->
        <div class="payout-method-section">
            <h4>Payout Method</h4>
            <p class="wallet-hint">How you want to receive earnings. Saved details are used when admin processes your payout.</p>

            <div id="payout-method-loading" class="wallet-hint"><i class="fa fa-spinner fa-spin"></i> Loading…</div>
            <div id="payout-method-form" style="display:none">
                <div class="form-group">
                    <label>Payout Mode</label>
                    <select id="wallet-payout-mode" class="form-control" onchange="walletSwitchPayoutMode(this.value)">
                        <option value="bank_transfer">Bank Transfer</option>
                        <option value="cheque">Cheque</option>
                        <option value="paypal">PayPal</option>
                        <option value="interac">Interac e-Transfer</option>
                        <option value="stripe">Stripe Connect</option>
                        <option value="other">Other / Custom</option>
                    </select>
                </div>

                <!-- Bank Transfer -->
                <div id="wallet-fields-bank_transfer" class="payout-mode-fields" style="display:block">
                    <div class="form-group"><label>Account Holder Name</label><input type="text" id="wallet-bank-holder" class="form-control" placeholder="Full legal name on account" maxlength="100"></div>
                    <div class="form-group"><label>Institution / Bank Name</label><input type="text" id="wallet-bank-institution" class="form-control" placeholder="e.g. TD Canada Trust" maxlength="100"></div>
                    <div class="form-group"><label>Transit Number</label><input type="text" id="wallet-bank-transit" class="form-control" placeholder="5-digit transit number" maxlength="20"></div>
                    <div class="form-group"><label>Account Number</label><input type="text" id="wallet-bank-account" class="form-control" placeholder="7–12 digit account number" maxlength="20"></div>
                </div>

                <!-- Cheque -->
                <div id="wallet-fields-cheque" class="payout-mode-fields">
                    <div class="form-group"><label>Make Cheque Payable To</label><input type="text" id="wallet-cheque-payable" class="form-control" placeholder="Full name or business name" maxlength="100"></div>
                    <div class="form-group"><label>Street Address</label><input type="text" id="wallet-cheque-street" class="form-control" placeholder="123 Main St" maxlength="200"></div>
                    <div class="form-group"><label>City</label><input type="text" id="wallet-cheque-city" class="form-control" placeholder="City" maxlength="100"></div>
                    <div class="form-group"><label>Province / State</label><input type="text" id="wallet-cheque-province" class="form-control" placeholder="e.g. ON" maxlength="100"></div>
                    <div class="form-group"><label>Postal / ZIP</label><input type="text" id="wallet-cheque-postal" class="form-control" placeholder="e.g. M5V 3A8" maxlength="20"></div>
                    <div class="form-group"><label>Country</label><input type="text" id="wallet-cheque-country" class="form-control" placeholder="Canada" maxlength="100"></div>
                </div>

                <!-- PayPal -->
                <div id="wallet-fields-paypal" class="payout-mode-fields">
                    <div class="form-group"><label>PayPal Email</label><input type="email" id="wallet-paypal-email" class="form-control" placeholder="your@paypal.com" maxlength="200"></div>
                </div>

                <!-- Interac -->
                <div id="wallet-fields-interac" class="payout-mode-fields">
                    <div class="form-group"><label>Interac Email or Phone</label><input type="text" id="wallet-interac-contact" class="form-control" placeholder="email@example.com or 416-555-0100" maxlength="200"></div>
                </div>

                <!-- Stripe Connect -->
                <div id="wallet-fields-stripe" class="payout-mode-fields">
                    <div class="form-group"><label>Stripe Account ID or Email</label><input type="text" id="wallet-stripe-account" class="form-control" placeholder="acct_1234… or seller@email.com" maxlength="200"></div>
                </div>

                <!-- Other -->
                <div id="wallet-fields-other" class="payout-mode-fields">
                    <div class="form-group"><label>Payment Reference / Instructions</label><textarea id="wallet-other-reference" class="form-control" rows="3" placeholder="Describe how you'd like to be paid…" maxlength="500"></textarea></div>
                </div>

                <div id="wallet-payout-save-error" style="display:none" class="alert-error mb-2"></div>
                <button id="wallet-payout-save-btn" class="btn btn-red" onclick="walletSavePayoutMethod()">
                    <i class="fa fa-save"></i> Save Payout Method
                </button>
            </div>
        </div>
    </div>
</div>

<script>
(function() { const _t = localStorage.getItem('access_token'); if (!_t) window.location.replace('/login?next=' + encodeURIComponent(location.pathname + location.search)); })();
const _stripeKey = '<%= stripePublishableKey %>';

// ── Expiry check ──────────────────────────────────────────────────────────────
function isExpired(c) {
    const today        = new Date();
    const currentYear  = today.getFullYear();
    const currentMonth = today.getMonth() + 1; // 1–12
    const cardYear     = parseInt(c.expYear,  10);
    const cardMonth    = parseInt(c.expMonth, 10);
    if (cardYear < currentYear) return true;
    if (cardYear === currentYear && cardMonth < currentMonth) return true;
    return false;
}

// ── Brand icons ───────────────────────────────────────────────────────────────
function brandIcon(brand) {
    const icons = {
        visa:       'fa-cc-visa',
        mastercard: 'fa-cc-mastercard',
        amex:       'fa-cc-amex',
        discover:   'fa-cc-discover',
        diners:     'fa-cc-diners-club',
        jcb:        'fa-cc-jcb',
    };
    const key = (brand || '').toLowerCase();
    return icons[key]
        ? `<i class="fab ${icons[key]} brand-icon"></i>`
        : `<i class="fa fa-credit-card brand-icon-generic"></i>`;
}

// ── Add Card flow ─────────────────────────────────────────────────────────────
let _stripe         = null;
let _stripeElements = null;

async function showAddCardForm() {
    document.getElementById('add-card-form').style.display  = 'block';
    document.getElementById('add-card-btn').style.display   = 'none';
    document.getElementById('add-card-error').style.display = 'none';

    if (_stripeElements) return; // already mounted

    const loadingEl = document.getElementById('stripe-loading');
    const elementEl = document.getElementById('stripe-payment-element');
    if (loadingEl) loadingEl.style.display = 'block';
    if (elementEl) elementEl.innerHTML     = '';

    try {
        const token  = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
        const siRes  = await fetch('/api/payments/setup-intent', {
            method:  'POST',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
        });
        const siData = await siRes.json();
        if (!siRes.ok) throw new Error(siData.error || 'Could not set up card saving.');

        if (!_stripe && _stripeKey) _stripe = Stripe(_stripeKey);
        _stripeElements = _stripe.elements({ clientSecret: siData.clientSecret });
        const payEl = _stripeElements.create('payment');
        payEl.mount('#stripe-payment-element');
        if (loadingEl) loadingEl.style.display = 'none';
    } catch (err) {
        if (loadingEl) loadingEl.style.display = 'none';
        const errEl = document.getElementById('add-card-error');
        errEl.textContent   = err.message;
        errEl.style.display = 'block';
    }
}

function cancelAddCard() {
    document.getElementById('add-card-form').style.display  = 'none';
    document.getElementById('add-card-btn').style.display   = '';
    document.getElementById('add-card-error').style.display = 'none';
    const elementEl = document.getElementById('stripe-payment-element');
    if (elementEl) elementEl.innerHTML = '';
    _stripeElements = null;
}

async function saveCard() {
    const saveBtn = document.getElementById('save-card-btn');
    const errEl   = document.getElementById('add-card-error');
    errEl.style.display = 'none';

    if (!_stripe || !_stripeElements) {
        errEl.textContent   = 'Payment form not ready. Please refresh and try again.';
        errEl.style.display = 'block';
        return;
    }

    saveBtn.disabled  = true;
    saveBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>Saving…';

    try {
        const result = await _stripe.confirmSetup({
            elements:      _stripeElements,
            confirmParams: { return_url: window.location.href },
            redirect:      'if_required',
        });

        if (result.error) {
            errEl.textContent   = result.error.message || 'Card setup failed.';
            errEl.style.display = 'block';
            saveBtn.disabled    = false;
            saveBtn.innerHTML   = '<i class="fa fa-lock"></i>Save Card';
            return;
        }

        // Card saved successfully — clean up form and reload list
        document.getElementById('stripe-payment-element').innerHTML = '';
        _stripeElements = null;
        document.getElementById('add-card-form').style.display = 'none';
        document.getElementById('add-card-btn').style.display  = '';
        saveBtn.disabled  = false;
        saveBtn.innerHTML = '<i class="fa fa-lock"></i>Save Card';
        showToast('Card saved successfully!', 'success');
        const _p  = new URLSearchParams(window.location.search);
        const _rt = _p.get('returnTo');
        if (_rt) {
            const _decoded = decodeURIComponent(_rt);
            if (_decoded.startsWith('/')) { window.location.href = _decoded; return; }
        }
        loadSavedCards();
    } catch (err) {
        errEl.textContent   = err.message;
        errEl.style.display = 'block';
        saveBtn.disabled    = false;
        saveBtn.innerHTML   = '<i class="fa fa-lock"></i>Save Card';
    }
}

async function loadSavedCards() {
    // Reset all display states before every fetch
    document.getElementById('cards-loading').style.display = 'block';
    document.getElementById('cards-error').style.display   = 'none';
    document.getElementById('cards-list').style.display    = 'none';
    document.getElementById('cards-list').innerHTML        = '';
    document.getElementById('cards-empty').style.display   = 'none';

    const token = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
    if (!token) {
        document.getElementById('cards-loading').style.display = 'none';
        document.getElementById('cards-empty').style.display   = 'block';
        return;
    }
    try {
        const res  = await fetch('/api/payments/saved-cards', { headers: { Authorization: `Bearer ${token}` } });
        const data = await res.json();
        document.getElementById('cards-loading').style.display = 'none';
        if (!res.ok) throw new Error(data.error || 'Failed to load cards');
        const cards = data.cards || [];
        if (!cards.length) {
            document.getElementById('cards-empty').style.display = 'block';
            return;
        }
        const list = document.getElementById('cards-list');
        list.style.display = 'flex';
        list.innerHTML = cards.map(c => {
            const brand   = c.brand.charAt(0).toUpperCase() + c.brand.slice(1);
            const exp     = `${String(c.expMonth).padStart(2,'0')}/${c.expYear}`;
            const expired = isExpired(c);
            return `
            <div class="payment-selector-card${expired ? ' payment-selector-card--expired' : ''}" id="card-${c.id}">
                <div class="pm-card-info">
                    <div class="pm-card-brand">${brandIcon(c.brand)}${brand} &bull;&bull;&bull;&bull; ${c.last4}</div>
                    <div class="pm-card-expiry${expired ? ' pm-card-expiry--expired' : ''}">
                        Expires ${exp}
                        ${expired ? '<span class="card-badge-expired">Expired</span>' : ''}
                    </div>
                </div>
                <button class="btn btn-sm btn-red btn-remove-card" data-id="${c.id}">
                    <i class="fa fa-trash"></i>Remove
                </button>
            </div>`;
        }).join('');
    } catch (err) {
        document.getElementById('cards-loading').style.display = 'none';
        const errEl = document.getElementById('cards-error');
        errEl.style.display = 'block';
        errEl.textContent   = err.message;
    }
}

function removeCard(pmId) {
    showConfirm(
        'Remove this saved card from your account?',
        async function () {
            try {
                const token = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
                const res   = await fetch(`/api/payments/saved-cards/${pmId}/delete`, {
                    method:  'POST',
                    headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
                });
                if (!res.ok) { const d = await res.json(); throw new Error(typeof d.error === 'string' ? d.error : 'Remove failed'); }
                document.getElementById(`card-${pmId}`)?.remove();
                showToast('Card removed.', 'success');
                if (!document.getElementById('cards-list').children.length) {
                    document.getElementById('cards-list').style.display  = 'none';
                    document.getElementById('cards-empty').style.display = 'block';
                }
            } catch (err) { showToast('Error: ' + err.message, 'error'); }
        },
        null,
        { confirmText: 'Remove', cancelText: 'Cancel', type: 'danger' }
    );
}

// ── Payout section (sellers only) ─────────────────────────────────────────────
function fmtDollars(cents) {
    return '$' + ((cents || 0) / 100).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function walletSwitchPayoutMode(mode) {
    document.querySelectorAll('.payout-mode-fields').forEach(el => el.style.display = 'none');
    const target = document.getElementById('wallet-fields-' + mode);
    if (target) target.style.display = 'block';
}

function walletPopulatePayoutForm(pm) {
    if (!pm) return;
    const sel = document.getElementById('wallet-payout-mode');
    if (pm.mode) { sel.value = pm.mode; walletSwitchPayoutMode(pm.mode); }
    const set = (id, val) => { const el = document.getElementById(id); if (el && val) el.value = val; };
    set('wallet-bank-holder',      pm.accountHolderName);
    set('wallet-bank-institution', pm.institutionName);
    set('wallet-bank-transit',     pm.transitNumber);
    set('wallet-bank-account',     pm.accountNumber);
    set('wallet-cheque-payable',   pm.payableTo);
    set('wallet-cheque-street',    pm.mailingStreet);
    set('wallet-cheque-city',      pm.mailingCity);
    set('wallet-cheque-province',  pm.mailingProvince);
    set('wallet-cheque-postal',    pm.mailingPostal);
    set('wallet-cheque-country',   pm.mailingCountry);
    set('wallet-paypal-email',     pm.paypalEmail);
    set('wallet-interac-contact',  pm.interacContact);
    set('wallet-stripe-account',   pm.stripeAccountId);
    set('wallet-other-reference',  pm.reference);
}

async function walletSavePayoutMethod() {
    const token  = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
    const errEl  = document.getElementById('wallet-payout-save-error');
    const btn    = document.getElementById('wallet-payout-save-btn');
    errEl.style.display = 'none';
    btn.disabled  = true;
    btn.innerHTML = '<i class="fa fa-spinner fa-spin"></i> Saving…';
    const mode = document.getElementById('wallet-payout-mode').value;
    const body = {
        mode,
        accountHolderName: document.getElementById('wallet-bank-holder').value.trim(),
        institutionName:   document.getElementById('wallet-bank-institution').value.trim(),
        transitNumber:     document.getElementById('wallet-bank-transit').value.trim(),
        accountNumber:     document.getElementById('wallet-bank-account').value.trim(),
        payableTo:         document.getElementById('wallet-cheque-payable').value.trim(),
        mailingStreet:     document.getElementById('wallet-cheque-street').value.trim(),
        mailingCity:       document.getElementById('wallet-cheque-city').value.trim(),
        mailingProvince:   document.getElementById('wallet-cheque-province').value.trim(),
        mailingPostal:     document.getElementById('wallet-cheque-postal').value.trim(),
        mailingCountry:    document.getElementById('wallet-cheque-country').value.trim(),
        paypalEmail:       document.getElementById('wallet-paypal-email').value.trim(),
        interacContact:    document.getElementById('wallet-interac-contact').value.trim(),
        stripeAccountId:   document.getElementById('wallet-stripe-account').value.trim(),
        reference:         document.getElementById('wallet-other-reference').value.trim()
    };
    try {
        const res  = await fetch('/api/users/me/payout-method', {
            method:  'PUT',
            headers: { 'Content-Type': 'application/json', Authorization: 'Bearer ' + token },
            body:    JSON.stringify(body)
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
        showToast('Payout method saved', 'success');
    } catch (err) {
        errEl.textContent   = err.message;
        errEl.style.display = 'block';
    } finally {
        btn.disabled  = false;
        btn.innerHTML = '<i class="fa fa-save"></i> Save Payout Method';
    }
}

async function loadPayoutSection() {
    const token = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
    if (!token) return;
    let payload;
    try { payload = JSON.parse(atob(token.split('.')[1])); } catch { return; }
    if (!payload.storeActive) return;

    document.getElementById('payout-section').style.display = 'block';

    // Load balance
    fetch('/api/payments/seller-balance', { headers: { Authorization: `Bearer ${token}` } })
        .then(r => r.json())
        .then(data => {
            document.getElementById('payout-balance-loading').style.display = 'none';
            document.getElementById('payout-in-escrow').textContent  = fmtDollars(data.inEscrow  || 0);
            document.getElementById('payout-available').textContent  = fmtDollars(data.available || 0);
            document.getElementById('payout-balance-grid').style.display = 'grid';
        })
        .catch(() => {
            document.getElementById('payout-balance-loading').style.display = 'none';
            const errEl = document.getElementById('payout-balance-error');
            errEl.textContent   = 'Could not load balance.';
            errEl.style.display = 'block';
        });

    // Load saved payout method
    fetch('/api/users/me/payout-method', { headers: { Authorization: `Bearer ${token}` } })
        .then(r => r.json())
        .then(data => {
            document.getElementById('payout-method-loading').style.display = 'none';
            document.getElementById('payout-method-form').style.display    = 'block';
            if (data.payoutMethod) walletPopulatePayoutForm(data.payoutMethod);
        })
        .catch(() => {
            document.getElementById('payout-method-loading').style.display = 'none';
            document.getElementById('payout-method-form').style.display    = 'block';
        });
}

loadSavedCards();
loadPayoutSection();

document.getElementById('cards-list').addEventListener('click', function (e) {
    const btn = e.target.closest('.btn-remove-card');
    if (btn) removeCard(btn.dataset.id);
});
</script>
</body>
</html>
