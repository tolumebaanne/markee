<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wallet | Markee</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <script src="/js/toast.js"></script>
    <script src="/js/confirm.js"></script>
    <script src="https://js.stripe.com/v3/"></script>
    <style>
        /* ── Wallet page layout ───────────────────────────────────────────── */
        .wallet-page-header    { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1.75rem; }
        .wallet-back-link      { color: var(--muted); text-decoration: none; font-size: 0.85rem; }
        .wallet-divider        { color: var(--border); }
        .wallet-section        { margin-bottom: 2.5rem; }
        .wallet-section h3     { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; }
        .wallet-section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
        .wallet-section-icon   { color: var(--accent); margin-right: 0.4rem; }
        .wallet-hint           { font-size: 0.85rem; color: var(--muted); margin-bottom: 0.75rem; }

        /* ── Add-card panel ───────────────────────────────────────────────── */
        .add-card-panel       { display: none; border: 1.5px solid var(--border); border-radius: 10px; padding: 1.1rem; margin-bottom: 1rem; background: var(--surface2); }
        .stripe-payment-element { min-height: 40px; }
        .stripe-loading-msg   { text-align: center; padding: 1.25rem 0; color: var(--muted); font-size: 0.9rem; }
        .add-card-error-msg   { display: none; color: var(--danger); font-size: 0.83rem; margin: 0.6rem 0; }
        .add-card-actions     { display: flex; gap: 0.5rem; align-items: center; margin-top: 0.75rem; }

        /* ── Saved cards list ─────────────────────────────────────────────── */
        .card-list            { display: flex; flex-direction: column; gap: 0.75rem; }
        .cards-loading-msg    { color: var(--muted); font-size: 0.9rem; }
        .empty-state          { text-align: center; padding: 2.5rem 1rem; color: var(--muted); }
        .empty-state i        { font-size: 2.2rem; display: block; margin-bottom: 0.6rem; }

        /* ── Card item (wallet list, not selector modal) ──────────────────── */
        .payment-selector-card          { display: flex; justify-content: space-between; align-items: center; gap: 0.75rem; cursor: default; }
        .payment-selector-card:hover    { border-color: var(--border); background: var(--surface2); }
        .payment-selector-card .pm-card-info { flex: 1; }

        /* ── Payout section ───────────────────────────────────────────────── */
        .payout-status      { font-size: 0.88rem; margin-bottom: 0.6rem; }
        .payout-info        { font-size: 0.82rem; color: var(--muted); }
    </style>
</head>
<body>

<nav class="navbar">
    <div class="brand-combo">
        <a href="/"><span class="brand">Markee</span></a>
    </div>
    <%- include('_nav') %>
</nav>

<div class="container py-4 animate-fade">
    <div class="wallet-page-header">
        <a href="/account" class="wallet-back-link"><i class="fa fa-arrow-left"></i> Account</a>
        <span class="wallet-divider">/</span>
        <h2 style="margin:0">Wallet</h2>
    </div>

    <!-- ── Saved Cards ─────────────────────────────────────────────────────────── -->
    <div class="wallet-section">
        <div class="wallet-section-header">
            <h3 style="margin:0"><i class="fa fa-credit-card wallet-section-icon"></i> Saved Cards</h3>
            <button id="add-card-btn" onclick="showAddCardForm()" class="btn btn-sm btn-red">
                <i class="fa fa-plus"></i>Add Card
            </button>
        </div>
        <p class="wallet-hint">
            Add a card here or cards are saved automatically when you complete a card payment. Remove a card to stop it appearing at checkout.
        </p>

        <!-- Add card form (hidden by default) -->
        <div id="add-card-form" class="add-card-panel">
            <p class="wallet-hint">Enter your card details. You may be prompted to verify with your bank.</p>
            <div id="stripe-payment-element" class="stripe-payment-element"></div>
            <div id="stripe-loading" class="stripe-loading-msg">
                <i class="fa fa-spinner fa-spin"></i> Loading secure payment form...
            </div>
            <div id="add-card-error" class="add-card-error-msg"></div>
            <div class="add-card-actions">
                <button id="save-card-btn" onclick="saveCard()" class="btn btn-sm btn-red">
                    <i class="fa fa-lock"></i>Save Card
                </button>
                <button onclick="cancelAddCard()" class="btn btn-ghost btn-sm">Cancel</button>
            </div>
        </div>

        <div id="cards-loading" class="cards-loading-msg"><i class="fa fa-spinner fa-spin"></i> Loading...</div>
        <div id="cards-error"   style="display:none" class="error-banner"></div>
        <div id="cards-list"    class="card-list"    style="display:none"></div>
        <div id="cards-empty"   class="empty-state"  style="display:none">
            <i class="fa fa-credit-card"></i>
            No saved cards yet. Add a card above or complete a card payment to save one automatically.
        </div>
    </div>

    <!-- ── Payout Account (sellers only) ─────────────────────────────────────── -->
    <div class="wallet-section" id="payout-section" style="display:none">
        <h3><i class="fa fa-building-columns wallet-section-icon"></i> Payout Account</h3>
        <div id="payout-body"></div>
    </div>
</div>

<script>
const _stripeKey = '<%= stripePublishableKey %>';

// ── Expiry check ──────────────────────────────────────────────────────────────
function isExpired(c) {
    const today        = new Date();
    const currentYear  = today.getFullYear();
    const currentMonth = today.getMonth() + 1; // 1–12
    const cardYear     = parseInt(c.expYear,  10);
    const cardMonth    = parseInt(c.expMonth, 10);
    if (cardYear < currentYear) return true;
    if (cardYear === currentYear && cardMonth < currentMonth) return true;
    return false;
}

// ── Brand icons ───────────────────────────────────────────────────────────────
function brandIcon(brand) {
    const icons = {
        visa:       'fa-cc-visa',
        mastercard: 'fa-cc-mastercard',
        amex:       'fa-cc-amex',
        discover:   'fa-cc-discover',
        diners:     'fa-cc-diners-club',
        jcb:        'fa-cc-jcb',
    };
    const key = (brand || '').toLowerCase();
    return icons[key]
        ? `<i class="fab ${icons[key]} brand-icon"></i>`
        : `<i class="fa fa-credit-card brand-icon-generic"></i>`;
}

// ── Add Card flow ─────────────────────────────────────────────────────────────
let _stripe         = null;
let _stripeElements = null;

async function showAddCardForm() {
    document.getElementById('add-card-form').style.display  = 'block';
    document.getElementById('add-card-btn').style.display   = 'none';
    document.getElementById('add-card-error').style.display = 'none';

    if (_stripeElements) return; // already mounted

    const loadingEl = document.getElementById('stripe-loading');
    const elementEl = document.getElementById('stripe-payment-element');
    if (loadingEl) loadingEl.style.display = 'block';
    if (elementEl) elementEl.innerHTML     = '';

    try {
        const token  = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
        const siRes  = await fetch('/api/payments/setup-intent', {
            method:  'POST',
            headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
        });
        const siData = await siRes.json();
        if (!siRes.ok) throw new Error(siData.error || 'Could not set up card saving.');

        if (!_stripe && _stripeKey) _stripe = Stripe(_stripeKey);
        _stripeElements = _stripe.elements({ clientSecret: siData.clientSecret });
        const payEl = _stripeElements.create('payment');
        payEl.mount('#stripe-payment-element');
        if (loadingEl) loadingEl.style.display = 'none';
    } catch (err) {
        if (loadingEl) loadingEl.style.display = 'none';
        const errEl = document.getElementById('add-card-error');
        errEl.textContent   = err.message;
        errEl.style.display = 'block';
    }
}

function cancelAddCard() {
    document.getElementById('add-card-form').style.display  = 'none';
    document.getElementById('add-card-btn').style.display   = '';
    document.getElementById('add-card-error').style.display = 'none';
    const elementEl = document.getElementById('stripe-payment-element');
    if (elementEl) elementEl.innerHTML = '';
    _stripeElements = null;
}

async function saveCard() {
    const saveBtn = document.getElementById('save-card-btn');
    const errEl   = document.getElementById('add-card-error');
    errEl.style.display = 'none';

    if (!_stripe || !_stripeElements) {
        errEl.textContent   = 'Payment form not ready. Please refresh and try again.';
        errEl.style.display = 'block';
        return;
    }

    saveBtn.disabled  = true;
    saveBtn.innerHTML = '<i class="fa fa-spinner fa-spin"></i>Saving…';

    try {
        const result = await _stripe.confirmSetup({
            elements:      _stripeElements,
            confirmParams: { return_url: window.location.href },
            redirect:      'if_required',
        });

        if (result.error) {
            errEl.textContent   = result.error.message || 'Card setup failed.';
            errEl.style.display = 'block';
            saveBtn.disabled    = false;
            saveBtn.innerHTML   = '<i class="fa fa-lock"></i>Save Card';
            return;
        }

        // Card saved successfully — clean up form and reload list
        document.getElementById('stripe-payment-element').innerHTML = '';
        _stripeElements = null;
        document.getElementById('add-card-form').style.display = 'none';
        document.getElementById('add-card-btn').style.display  = '';
        saveBtn.disabled  = false;
        saveBtn.innerHTML = '<i class="fa fa-lock"></i>Save Card';
        toast('Card saved successfully!', 'success');
        const _p  = new URLSearchParams(window.location.search);
        const _rt = _p.get('returnTo');
        if (_rt) {
            const _decoded = decodeURIComponent(_rt);
            if (_decoded.startsWith('/')) { window.location.href = _decoded; return; }
        }
        loadSavedCards();
    } catch (err) {
        errEl.textContent   = err.message;
        errEl.style.display = 'block';
        saveBtn.disabled    = false;
        saveBtn.innerHTML   = '<i class="fa fa-lock"></i>Save Card';
    }
}

async function loadSavedCards() {
    // Reset all display states before every fetch
    document.getElementById('cards-loading').style.display = 'block';
    document.getElementById('cards-error').style.display   = 'none';
    document.getElementById('cards-list').style.display    = 'none';
    document.getElementById('cards-list').innerHTML        = '';
    document.getElementById('cards-empty').style.display   = 'none';

    const token = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
    if (!token) {
        document.getElementById('cards-loading').style.display = 'none';
        document.getElementById('cards-empty').style.display   = 'block';
        return;
    }
    try {
        const res  = await fetch('/api/payments/saved-cards', { headers: { Authorization: `Bearer ${token}` } });
        const data = await res.json();
        document.getElementById('cards-loading').style.display = 'none';
        if (!res.ok) throw new Error(data.error || 'Failed to load cards');
        const cards = data.cards || [];
        if (!cards.length) {
            document.getElementById('cards-empty').style.display = 'block';
            return;
        }
        const list = document.getElementById('cards-list');
        list.style.display = 'flex';
        list.innerHTML = cards.map(c => {
            const brand   = c.brand.charAt(0).toUpperCase() + c.brand.slice(1);
            const exp     = `${String(c.expMonth).padStart(2,'0')}/${c.expYear}`;
            const expired = isExpired(c);
            return `
            <div class="payment-selector-card${expired ? ' payment-selector-card--expired' : ''}" id="card-${c.id}">
                <div class="pm-card-info">
                    <div class="pm-card-brand">${brandIcon(c.brand)}${brand} &bull;&bull;&bull;&bull; ${c.last4}</div>
                    <div class="pm-card-expiry${expired ? ' pm-card-expiry--expired' : ''}">
                        Expires ${exp}
                        ${expired ? '<span class="card-badge-expired">Expired</span>' : ''}
                    </div>
                </div>
                <button class="btn btn-sm btn-red btn-remove-card" data-id="${c.id}">
                    <i class="fa fa-trash"></i>Remove
                </button>
            </div>`;
        }).join('');
    } catch (err) {
        document.getElementById('cards-loading').style.display = 'none';
        const errEl = document.getElementById('cards-error');
        errEl.style.display = 'block';
        errEl.textContent   = err.message;
    }
}

function removeCard(pmId) {
    showConfirm(
        'Remove this saved card from your account?',
        async function () {
            try {
                const token = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
                const res   = await fetch(`/api/payments/saved-cards/${pmId}/delete`, {
                    method:  'POST',
                    headers: { Authorization: `Bearer ${token}`, 'Content-Type': 'application/json' },
                });
                if (!res.ok) { const d = await res.json(); throw new Error(typeof d.error === 'string' ? d.error : 'Remove failed'); }
                document.getElementById(`card-${pmId}`)?.remove();
                toast('Card removed.', 'success');
                if (!document.getElementById('cards-list').children.length) {
                    document.getElementById('cards-list').style.display  = 'none';
                    document.getElementById('cards-empty').style.display = 'block';
                }
            } catch (err) { toast('Error: ' + err.message, 'error'); }
        },
        null,
        { confirmText: 'Remove', cancelText: 'Cancel', type: 'danger' }
    );
}

async function loadPayoutSection() {
    const token = localStorage.getItem('access_token') || localStorage.getItem('authToken') || localStorage.getItem('token') || '';
    if (!token) return;
    try {
        const payload  = JSON.parse(atob(token.split('.')[1]));
        const isSeller = payload.capabilities?.includes('seller:manage') || payload.role === 'seller';
        if (!isSeller) return;
        document.getElementById('payout-section').style.display = 'block';
        const res  = await fetch('/api/sellers/my-store', { headers: { Authorization: `Bearer ${token}` } });
        const data = await res.json();
        const store = data.store || data;
        const cs    = store.stripeConnectStatus || 'not_connected';
        const labels= { not_connected:'Not Connected', pending:'Under Review', active:'Active — Payouts Enabled' };
        const colors= { not_connected:'var(--warn)', pending:'#60a5fa', active:'var(--success)' };
        document.getElementById('payout-body').innerHTML = `
            <div class="payout-status">
                Status: <strong style="color:${colors[cs]}">${labels[cs] || cs}</strong>
            </div>
            <p class="payout-info wallet-hint">
                Payout account status is managed by Markee staff. Contact support to connect your bank account.
            </p>`;
    } catch (err) { /* non-critical — hide payout section */ }
}

loadSavedCards();
loadPayoutSection();

document.getElementById('cards-list').addEventListener('click', function (e) {
    const btn = e.target.closest('.btn-remove-card');
    if (btn) removeCard(btn.dataset.id);
});
</script>
</body>
</html>
