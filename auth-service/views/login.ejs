<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login | Markee Auth</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-panel animate-fade">
        <center><a href="/"><img src="/assets/logo.svg" alt="Markee Logo" style="width: 60px; margin-bottom: 1rem;"></a></center>
        <h2>Welcome Back</h2>
        <p class="text-muted mb-4">Sign in to your Markee account to continue</p>
        
        <% if (locals.success) { %>
            <div class="alert alert-success"><%- success %></div>
        <% } %>
        <% if (locals.error) { %>
            <div class="alert alert-error"><%- error %></div>
        <% } %>

        <form method="POST" action="/oauth/login">
            <div class="form-group">
                <label>Email Address</label>
                <input type="email" name="email" placeholder="you@example.com" required>
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="password" name="password" placeholder="••••••••" required>
                <span class="password-toggle" onclick="togglePassword()">Show</span>
                <a href="/forgot-password" class="forgot-pass">Forgot your password?</a>
            </div>
            
            <button type="submit" class="btn btn-red mb-3">Sign In</button>
            <p class="text-muted" style="font-size: 0.9rem;">
                Don't have an account? <a href="/register" class="font-bold">Create one now</a>
            </p>
        </form>
    </div>
</div>

<script>
function togglePassword() {
    const input = document.getElementById('password');
    const toggle = document.querySelector('.password-toggle');
    if (input.type === 'password') {
        input.type = 'text';
        toggle.textContent = 'Hide';
    } else {
        input.type = 'password';
        toggle.textContent = 'Show';
    }
}
</script>
</body>
</html>
