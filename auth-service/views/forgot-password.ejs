<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password | Markee</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-panel animate-fade">
        <center>
            <a href="/"><img src="/assets/logo.svg" alt="Markee Logo" style="width:60px;margin-bottom:1rem;" onerror="this.onerror=null;this.style.display='none';"></a>
        </center>

        <% if (locals.sent) { %>
            <div class="alert alert-success">
                <strong>Check your inbox.</strong><br>
                If that email is registered, a reset link has been sent. It expires in 1 hour.
            </div>
            <p class="text-muted" style="font-size:0.88rem;margin-top:1rem;text-align:center">
                Didn't get it? Check your spam folder, or
                <a href="/forgot-password" class="font-bold">try again</a>.
            </p>
            <div style="text-align:center;margin-top:1.25rem">
                <a href="/login" class="btn btn-ghost" style="width:auto;display:inline-block">← Back to Sign In</a>
            </div>
        <% } else { %>
            <h2>Forgot your password?</h2>
            <p class="text-muted mb-4">Enter your email and we'll send you a reset link.</p>

            <% if (locals.error) { %>
                <div class="alert alert-error"><%- error %></div>
            <% } %>

            <form method="POST" action="/forgot-password">
                <div class="form-group">
                    <label>Email Address</label>
                    <input type="email" name="email" placeholder="you@example.com" required autocomplete="email">
                </div>
                <button type="submit" class="btn btn-red mb-3" id="forgot-submit">Send Reset Link</button>
                <p class="text-muted" style="font-size:0.9rem;text-align:center">
                    <a href="/login" class="font-bold">← Back to Sign In</a>
                </p>
            </form>
        <% } %>
    </div>
</div>

<script>
// Disable submit button on click to prevent double-submit
document.getElementById('forgot-submit')?.closest('form')?.addEventListener('submit', function () {
    const btn = document.getElementById('forgot-submit');
    if (btn) { btn.disabled = true; btn.textContent = 'Sending…'; }
});
</script>
</body>
</html>
