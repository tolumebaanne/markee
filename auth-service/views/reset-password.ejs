<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Password | Markee</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="auth-wrapper">
    <div class="auth-panel animate-fade">
        <center>
            <a href="/"><img src="/assets/logo.svg" alt="Markee Logo" style="width:60px;margin-bottom:1rem;" onerror="this.onerror=null;this.style.display='none';"></a>
        </center>

        <% if (!locals.valid) { %>
            <!-- Invalid / expired token state -->
            <h2>Link expired</h2>
            <% if (locals.error) { %>
                <div class="alert alert-error"><%- error %></div>
            <% } %>
            <p class="text-muted mb-4">
                This reset link is invalid or has expired. Reset links are valid for 1 hour.
            </p>
            <a href="/forgot-password" class="btn btn-red mb-3">Request a New Link</a>
            <p class="text-muted" style="font-size:0.9rem;text-align:center">
                <a href="/login" class="font-bold">← Back to Sign In</a>
            </p>
        <% } else { %>
            <!-- Valid token — show the reset form -->
            <h2>Set a new password</h2>
            <p class="text-muted mb-4">Choose a strong password with at least 8 characters.</p>

            <% if (locals.error) { %>
                <div class="alert alert-error"><%- error %></div>
            <% } %>

            <form method="POST" action="/reset-password" id="reset-form">
                <input type="hidden" name="token" value="<%= locals.token || '' %>">

                <div class="form-group">
                    <label>New Password</label>
                    <input type="password" id="newPassword" name="newPassword"
                           placeholder="Min 8 characters" minlength="8" required
                           autocomplete="new-password">
                    <span class="password-toggle" onclick="toggleField('newPassword', this)">Show</span>
                </div>

                <div class="form-group">
                    <label>Confirm Password</label>
                    <input type="password" id="confirmPassword" name="confirmPassword"
                           placeholder="Repeat your new password" minlength="8" required
                           autocomplete="new-password">
                    <span class="password-toggle" onclick="toggleField('confirmPassword', this)">Show</span>
                </div>

                <!-- Client-side match hint -->
                <p id="pw-match-hint" class="text-muted" style="font-size:0.8rem;min-height:1.2em;margin-bottom:0.75rem"></p>

                <button type="submit" class="btn btn-red mb-3" id="reset-submit">Set New Password</button>
                <p class="text-muted" style="font-size:0.9rem;text-align:center">
                    <a href="/login" class="font-bold">← Back to Sign In</a>
                </p>
            </form>
        <% } %>
    </div>
</div>

<script>
function toggleField(id, btn) {
    const input = document.getElementById(id);
    if (!input) return;
    if (input.type === 'password') { input.type = 'text'; btn.textContent = 'Hide'; }
    else                           { input.type = 'password'; btn.textContent = 'Show'; }
}

// Live match indicator
const npw = document.getElementById('newPassword');
const cpw = document.getElementById('confirmPassword');
const hint = document.getElementById('pw-match-hint');
const form = document.getElementById('reset-form');
const submitBtn = document.getElementById('reset-submit');

function checkMatch() {
    if (!cpw || !hint) return;
    if (!cpw.value) { hint.textContent = ''; return; }
    if (npw.value === cpw.value) {
        hint.textContent = '✓ Passwords match';
        hint.style.color = 'var(--success, #22c55e)';
    } else {
        hint.textContent = '✗ Passwords do not match';
        hint.style.color = 'var(--accent-red, #ff2d55)';
    }
}
npw?.addEventListener('input', checkMatch);
cpw?.addEventListener('input', checkMatch);

form?.addEventListener('submit', function (e) {
    if (npw && cpw && npw.value !== cpw.value) {
        e.preventDefault();
        hint.textContent = '✗ Passwords do not match';
        hint.style.color = 'var(--accent-red, #ff2d55)';
        return;
    }
    if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = 'Saving…'; }
});
</script>
</body>
</html>
